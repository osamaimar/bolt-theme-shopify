  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart Type",
        "default": "drawer",
        "options": [
          {
            "value": "drawer",
            "label": "Drawer"
          },
          {
            "value": "page",
            "label": "Page"
          }
        ]
      },
      {
        "type": "checkbox",
        "id": "enable_free_shipping_threshold",
        "label": "Enable free shipping threshold",
        "default": true
      },
      {
        "type": "number",
        "id": "free_shipping_threshold",
        "label": "Free shipping threshold",
        "default": 100,
        "info": "Amount is in the store's currency."
      }
    ]
  },
  {
    "name": "Product Pricing",
    "settings": [
      {
        "type": "header",
        "content": "Unit Pricing"
      },
      {
        "type": "paragraph",
        "content": "Unit pricing (e.g. $1.20 / 100ml) is required by law in some regions (EU, UK, Australia). Only displays when a product has unit pricing configured in the Shopify Admin product editor."
      },
      {
        "type": "checkbox",
        "id": "show_unit_price",
        "label": "Show unit price",
        "default": true,
        "info": "Applies to: product cards, product pages, cart page, and cart drawer."
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "header",
        "content": "Predictive Search"
      },
      {
        "type": "checkbox",
        "id": "enable_predictive_search",
        "label": "Enable predictive search",
        "default": true,
        "info": "Show live product suggestions as customers type."
      },
      {
        "type": "range",
        "id": "predictive_search_results_count",
        "min": 3,
        "max": 10,
        "step": 1,
        "label": "Max suggestions",
        "default": 5
      },
      {
        "type": "checkbox",
        "id": "predictive_search_show_image",
        "label": "Show product image in suggestions",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "predictive_search_show_price",
        "label": "Show product price in suggestions",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "predictive_search_show_vendor",
        "label": "Show product vendor in suggestions",
        "default": true
      }
