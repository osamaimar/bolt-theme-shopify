<!doctype html>
{%- liquid
  assign text_direction = request.locale.direction | default: 'ltr'
  if request.locale.iso_code == 'ar' or request.locale.iso_code == 'he' or request.locale.iso_code == 'fa' or request.locale.iso_code == 'ur'
    assign text_direction = 'rtl'
  endif
-%}
<html class="no-js" lang="{{ request.locale.iso_code }}" dir="{{ text_direction }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_primary }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>{{ shop.name }}</title>

    <meta name="description" content="{{ page_description | escape }}">

    {% render 'meta-tags' %}

    {{ content_for_header }}

    {%- liquid
      assign body_font_bold = settings.body_font | font_modify: 'weight', 'bold'
      assign body_font_italic = settings.body_font | font_modify: 'style', 'italic'
      assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
    %}



    <style>
      {{ settings.heading_font | font_face: font_display: 'swap' }}
      {{ settings.body_font | font_face: font_display: 'swap' }}
      {{ body_font_bold | font_face: font_display: 'swap' }}
      {{ body_font_italic | font_face: font_display: 'swap' }}
      {{ body_font_bold_italic | font_face: font_display: 'swap' }}

      :root {
        --font-body-family: {{ settings.body_font.family }}, {{ settings.body_font.fallback_families }};
        --font-body-style: {{ settings.body_font.style }};
        --font-body-weight: {{ settings.body_font.weight }};

        --font-heading-family: {{ settings.heading_font.family }}, {{ settings.heading_font.fallback_families }};
        --font-heading-style: {{ settings.heading_font.style }};
        --font-heading-weight: {{ settings.heading_font.weight }};

        --font-body-scale: {{ settings.font_scale | divided_by: 100.0 }};
        --font-heading-scale: {{ settings.font_scale | divided_by: 100.0 }};

        --color-primary-rgb: {{ settings.color_primary.red }}, {{ settings.color_primary.green }}, {{ settings.color_primary.blue }};
        --color-accent-rgb: {{ settings.color_accent.red }}, {{ settings.color_accent.green }}, {{ settings.color_accent.blue }};
        --color-secondary-rgb: {{ settings.color_secondary.red }}, {{ settings.color_secondary.green }}, {{ settings.color_secondary.blue }};
        --bg-primary-rgb: {{ settings.bg_primary.red }}, {{ settings.bg_primary.green }}, {{ settings.bg_primary.blue }};
        --bg-secondary-rgb: {{ settings.bg_secondary.red }}, {{ settings.bg_secondary.green }}, {{ settings.bg_secondary.blue }};
        --bg-card-rgb: {{ settings.bg_card.red }}, {{ settings.bg_card.green }}, {{ settings.bg_card.blue }};
        --text-primary-rgb: {{ settings.text_primary.red }}, {{ settings.text_primary.green }}, {{ settings.text_primary.blue }};
        --text-secondary-rgb: {{ settings.text_secondary.red }}, {{ settings.text_secondary.green }}, {{ settings.text_secondary.blue }};
        --text-muted-rgb: {{ settings.text_muted.red }}, {{ settings.text_muted.green }}, {{ settings.text_muted.blue }};
        --border-color-rgb: {{ settings.border_color.red }}, {{ settings.border_color.green }}, {{ settings.border_color.blue }};
        --color-success-rgb: {{ settings.success_color.red }}, {{ settings.success_color.green }}, {{ settings.success_color.blue }};
        --color-warning-rgb: {{ settings.warning_color.red }}, {{ settings.warning_color.green }}, {{ settings.warning_color.blue }};
        --color-error-rgb: {{ settings.error_color.red }}, {{ settings.error_color.green }}, {{ settings.error_color.blue }};

        --page-width: {{ settings.page_width }}px;
        --spacing-scale: {{ settings.spacing_scale | divided_by: 100.0 }};
        --border-radius: {{ settings.border_radius }}px;
      }
    </style>

    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'section-password.css' | asset_url | stylesheet_tag }}

    {%- if text_direction == 'rtl' -%}
      {{ 'rtl.css' | asset_url | stylesheet_tag }}
    {%- endif -%}

    <script>document.documentElement.className = document.documentElement.className.replace('no-js', 'js');</script>
    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
  </head>

  <body class="password-layout gradient">
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ "accessibility.skip_to_content" | t }}
    </a>


    <main id="MainContent" class="password-main focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {%- if text_direction == 'rtl' -%}
    <script>
    /* RTL Alignment Flipper — flips left↔right in section <style> blocks */
    (function() {
      if (document.documentElement.getAttribute('dir') !== 'rtl') return;
      
      document.querySelectorAll('style').forEach(function(styleEl) {
        var css = styleEl.textContent;
        if (!css) return;
        
        /* Only process styles that contain text alignment properties */
        if (!/text-align/.test(css)) return;
        
        /* Use placeholders to avoid double-swapping */
        css = css
          .replace(/text-align:\s*left/g,           'text-align: __RTL_RIGHT__')
          .replace(/text-align:\s*right/g,          'text-align: left')
          .replace(/text-align: __RTL_RIGHT__/g,    'text-align: right');
        
        styleEl.textContent = css;
      });
    })();
    </script>
    {%- endif -%}
  </body>
</html>
