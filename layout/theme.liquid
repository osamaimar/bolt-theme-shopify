<!doctype html>
{%- liquid
  assign text_direction = request.locale.direction | default: 'ltr'
  if request.locale.iso_code == 'ar' or request.locale.iso_code == 'he' or request.locale.iso_code == 'fa' or request.locale.iso_code == 'ur'
    assign text_direction = 'rtl'
  endif
-%}
<html class="no-js" lang="{{ request.locale.iso_code }}" dir="{{ text_direction }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_primary }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
    {%- comment -%}theme-check-disable RemoteAsset{%- endcomment -%}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    {%- comment -%}theme-check-enable RemoteAsset{%- endcomment -%}
    {{ content_for_header }}

    {%- liquid
      assign body_font_bold = settings.body_font | font_modify: 'weight', 'bold'
      assign body_font_italic = settings.body_font | font_modify: 'style', 'italic'
      assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
    %}



    <style>
      {{ settings.heading_font | font_face: font_display: 'swap' }}
      {{ settings.body_font | font_face: font_display: 'swap' }}
      {{ body_font_bold | font_face: font_display: 'swap' }}
      {{ body_font_italic | font_face: font_display: 'swap' }}
      {{ body_font_bold_italic | font_face: font_display: 'swap' }}

      :root {
        /* Base RGB Colors */
        --color-primary-rgb: {{ settings.color_primary.red }}, {{ settings.color_primary.green }}, {{ settings.color_primary.blue }};
        --color-accent-rgb: {{ settings.color_accent.red }}, {{ settings.color_accent.green }}, {{ settings.color_accent.blue }};
        --color-secondary-rgb: {{ settings.color_secondary.red }}, {{ settings.color_secondary.green }}, {{ settings.color_secondary.blue }};
        --color-accent-secondary-rgb: {{ settings.color_secondary.red }}, {{ settings.color_secondary.green }}, {{ settings.color_secondary.blue }};
        --bg-primary-rgb: {{ settings.bg_primary.red }}, {{ settings.bg_primary.green }}, {{ settings.bg_primary.blue }};
        --bg-secondary-rgb: {{ settings.bg_secondary.red }}, {{ settings.bg_secondary.green }}, {{ settings.bg_secondary.blue }};
        --bg-card-rgb: {{ settings.bg_card.red }}, {{ settings.bg_card.green }}, {{ settings.bg_card.blue }};
        --text-primary-rgb: {{ settings.text_primary.red }}, {{ settings.text_primary.green }}, {{ settings.text_primary.blue }};
        --text-secondary-rgb: {{ settings.text_secondary.red }}, {{ settings.text_secondary.green }}, {{ settings.text_secondary.blue }};
        --text-muted-rgb: {{ settings.text_muted.red }}, {{ settings.text_muted.green }}, {{ settings.text_muted.blue }};
        --border-color-rgb: {{ settings.border_color.red }}, {{ settings.border_color.green }}, {{ settings.border_color.blue }};
        --color-success-rgb: {{ settings.success_color.red }}, {{ settings.success_color.green }}, {{ settings.success_color.blue }};
        --color-warning-rgb: {{ settings.warning_color.red }}, {{ settings.warning_color.green }}, {{ settings.warning_color.blue }};
        --color-error-rgb: {{ settings.error_color.red }}, {{ settings.error_color.green }}, {{ settings.error_color.blue }};
        --color-white-rgb: 255, 255, 255;
        --color-black-rgb: 0, 0, 0;

        /* Derived Colors */
        --color-primary: rgb(var(--color-primary-rgb));
        --bg-primary: rgb(var(--bg-primary-rgb));
        --bg-secondary: rgb(var(--bg-secondary-rgb));
        --bg-card: rgba(var(--bg-card-rgb), 0.6);
        --text-primary: rgb(var(--text-primary-rgb));
        --text-secondary: rgba(var(--text-primary-rgb), 0.8);
        {%- assign bg_brightness = settings.bg_primary | color_brightness -%}
        {%- if bg_brightness > 128 -%}
          --text-inverse: rgb(var(--color-black-rgb));
        {%- else -%}
          --text-inverse: rgb(var(--color-white-rgb));
        {%- endif -%}
        --color-white: rgb(var(--color-white-rgb));
        --color-accent: rgb(var(--color-accent-rgb));
        --color-secondary: rgb(var(--color-secondary-rgb));
        --color-accent-secondary: rgb(var(--color-secondary-rgb)); /* Mapping secondary to accent-secondary for compatibility */
        
        --border-primary: rgba(var(--color-accent-rgb), 0.2);
        --border-light: rgba(var(--color-accent-rgb), 0.1);
        --bg-glass: rgba(var(--text-primary-rgb), 0.05);
        --bg-glass-header: rgba(var(--text-primary-rgb), 0.08);
        --border-glass-header: rgba(var(--color-accent-rgb), 0.25);

        /* Dynamic Opacities */
        --bg-primary-90: rgba(var(--bg-primary-rgb), 0.9);
        --bg-primary-95: rgba(var(--bg-primary-rgb), 0.95);
        --color-accent-5: rgba(var(--color-accent-rgb), 0.05);
        --color-accent-10: rgba(var(--color-accent-rgb), 0.1);
        --color-accent-20: rgba(var(--color-accent-rgb), 0.2);
        --color-accent-30: rgba(var(--color-accent-rgb), 0.3);
        --color-accent-secondary-10: rgba(var(--color-secondary-rgb), 0.1);
        --color-accent-secondary-20: rgba(var(--color-secondary-rgb), 0.2);
        --color-white-5: rgba(var(--color-white-rgb), 0.05);
        --color-black-30: rgba(var(--color-black-rgb), 0.3);
        --color-black-50: rgba(var(--color-black-rgb), 0.5);

        /* Typography */
        --font-body-family: {{ settings.body_font.family }}, {{ settings.body_font.fallback_families }};
        --font-body-style: {{ settings.body_font.style }};
        --font-body-weight: {{ settings.body_font.weight }};
        --font-heading-family: {{ settings.heading_font.family }}, {{ settings.heading_font.fallback_families }};
        --font-heading-style: {{ settings.heading_font.style }};
        --font-heading-weight: {{ settings.heading_font.weight }};
        --font-body-scale: {{ settings.font_scale | divided_by: 100.0 }};
        --font-heading-scale: {{ settings.font_scale | divided_by: 100.0 }};

        --font-size-xs: 0.75rem;
        --font-size-sm: 0.875rem;
        --font-size-base: 1rem;
        --font-size-lg: 1.125rem;
        --font-size-xl: 1.25rem;
        --font-size-2xl: 1.5rem;
        --font-size-3xl: 1.875rem;
        --font-size-4xl: 2.25rem;

        --font-weight-normal: 400;
        --font-weight-medium: 500;
        --font-weight-semibold: 600;
        --font-weight-bold: 700;

        /* Spacing & Layout */
        --page-width: {{ settings.page_width }}px;
        --spacing-scale: {{ settings.spacing_scale | divided_by: 100.0 }};
        --border-radius: {{ settings.border_radius }}px;

        --radius-xs: 2px;
        --radius-sm: 4px;
        --radius-md: 8px;
        --radius-lg: 12px;
        --radius-xl: 16px;
        --radius-2xl: 24px;
        --radius-full: 9999px;

        --spacing-xs: 4px;
        --spacing-sm: 8px;
        --spacing-md: 16px;
        --spacing-lg: 24px;
        --spacing-xl: 32px;
        --spacing-2xl: 48px;
        --spacing-3xl: 64px;
        --spacing-4xl: 80px;
        --spacing-5xl: 120px;

        /* Z-Index */
        --z-index-dropdown: 100;
        --z-index-sticky: 200;
        --z-index-drawer: 300;
        --z-index-modal: 400;
      }
    </style>

    {{ 'base.css' | asset_url | stylesheet_tag }}

    {%- if text_direction == 'rtl' -%}
      {{ 'rtl.css' | asset_url | stylesheet_tag }}
    {%- endif -%}

    <script>document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    if (Shopify.designMode) {
      document.documentElement.classList.add('shopify-design-mode');
    }
    </script>
    <style>
      /* Forced Scrollbar Styling - Inline to bypass caching */
      ::-webkit-scrollbar {
        width: 12px !important;
        height: 12px !important;
      }
      ::-webkit-scrollbar-track {
        background: rgb({{ settings.bg_secondary.red }}, {{ settings.bg_secondary.green }}, {{ settings.bg_secondary.blue }}) !important;
      }
      ::-webkit-scrollbar-thumb {
        background: rgb({{ settings.color_accent.red }}, {{ settings.color_accent.green }}, {{ settings.color_accent.blue }}) !important;
        border-radius: 10px !important;
        border: 3px solid rgb({{ settings.bg_secondary.red }}, {{ settings.bg_secondary.green }}, {{ settings.bg_secondary.blue }}) !important;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: rgb({{ settings.color_secondary.red }}, {{ settings.color_secondary.green }}, {{ settings.color_secondary.blue }}) !important;
      }
      /* Firefox */
      * {
        scrollbar-width: auto !important;
        scrollbar-color: rgb({{ settings.color_accent.red }}, {{ settings.color_accent.green }}, {{ settings.color_accent.blue }}) rgb({{ settings.bg_secondary.red }}, {{ settings.bg_secondary.green }}, {{ settings.bg_secondary.blue }}) !important;
      }
    </style>
  </head>

  <body class="gradient template-{{ template.name | handle }} template-{{ template | handle }}{% if settings.bg_primary | color_brightness > 128 %} theme-light{% else %} theme-dark{% endif %}">
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ "accessibility.skip_to_content" | t }}
    </a>

    {% sections 'header-group' %}

    <main id="main-content" class="content-for-layout focus-none {% if template == 'index' %}is-index{% endif %}" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% section 'back-to-top' %}



    {%- section 'cart-drawer' -%}
    {% section 'quick-view' %}
    {% section 'language-switcher' %}
    {% render 'search-popup' %}

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>

    <script>
      window.shopUrl = '{{ request.origin }}';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}',
        predictive_search_url: '{{ routes.predictive_search_url }}'
      };

      window.cartStrings = {
        error: `{{ 'sections.cart.cart_error' | t }}`,
        quantityError: `{{ 'sections.cart.cart_quantity_error_html' | t: quantity: '[quantity]' }}`
      };

      window.variantStrings = {
        addToCart: `{{ 'products.product.add_to_cart' | t }}`,
        soldOut: `{{ 'products.product.sold_out' | t }}`,
        unavailable: `{{ 'products.product.unavailable' | t }}`,
        unavailable_with_option: `{{ 'products.product.value_unavailable' | t: option_value: '[value]' }}`
      };

      window.accessibilityStrings = {
        imageAvailable: `{{ 'products.product.media.image_available' | t: index: '[index]' }}`,
        shareSuccess: `{{ 'general.share.copy_to_clipboard_confirmation' | t }}`,
        pauseSlideshow: `{{ 'sections.slideshow.pause_slideshow' | t }}`,
        playSlideshow: `{{ 'sections.slideshow.play_slideshow' | t }}`
      };
    </script>
    {%- if text_direction == 'rtl' -%}
    <script>
    /* RTL Alignment Flipper — flips left↔right in section <style> blocks */
    (function() {
      if (document.documentElement.getAttribute('dir') !== 'rtl') return;
      
      document.querySelectorAll('style').forEach(function(styleEl) {
        var css = styleEl.textContent;
        if (!css) return;
        
        /* Only process styles that contain text alignment properties */
        if (!/text-align/.test(css)) return;
        
        /* Use placeholders to avoid double-swapping */
        css = css
          .replace(/text-align:\s*left/g,           'text-align: __RTL_RIGHT__')
          .replace(/text-align:\s*right/g,          'text-align: left')
          .replace(/text-align: __RTL_RIGHT__/g,    'text-align: right');
        
        styleEl.textContent = css;
      });
    })();
    </script>
    {%- endif -%}
  </body>
</html>
