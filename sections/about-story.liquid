{{ 'section-about-story.css' | asset_url | stylesheet_tag }}

{%- assign has_image_block = false -%}
{%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'image'
        assign b_align_alignment = 'center'
      when 'paragraph'
        assign b_align_alignment = 'left'
  endcase
-%}
  {%- if block.type == 'image' -%}
    {%- assign has_image_block = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

<style>
  {%- if has_image_block == false -%}
    #shopify-section-{{ section.id }} .story-grid {
      grid-template-columns: 1fr !important;
    }
  {%- endif -%}

  /* Section Spacing / Visibility overrides */
  #shopify-section-{{ section.id }} .story-section {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .story-section {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Container Width overrides */
  #shopify-section-{{ section.id }} .container-fluid {
    max-width: 100% !important;
    padding-left: 2rem !important;
    padding-right: 2rem !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container-narrow {
    max-width: 800px !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container {
    max-width: {{ section.settings.max_width | default: 1340 }}px !important;
    margin: 0 auto !important;
  }

  /* Blocks Position align overrides */
  #shopify-section-{{ section.id }} .story-text {
    display: flex;
    flex-direction: column;
    {%- if section.settings.blocks_position == 'center' -%}
      align-items: center !important;
    {%- elsif section.settings.blocks_position == 'right' -%}
      align-items: flex-end !important;
    {%- else -%}
      align-items: flex-start !important;
    {%- endif -%}
  }

  /* Block Spacing overrides */
  #shopify-section-{{ section.id }} .section-title {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 32px) !important;
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .section-title {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 32px)) !important;
    }
  }

  /* Responsive Font Sizing */
  #shopify-section-{{ section.id }} .section-title.size-small { font-size: 2rem !important; }
  #shopify-section-{{ section.id }} .section-title.size-medium { font-size: 2.5rem !important; }
  #shopify-section-{{ section.id }} .section-title.size-large { font-size: 3rem !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .section-title.size-small { font-size: 1.6rem !important; }
    #shopify-section-{{ section.id }} .section-title.size-medium { font-size: 2rem !important; }
    #shopify-section-{{ section.id }} .section-title.size-large { font-size: 2.25rem !important; }
  }

  /* paragraph block overrides */
  {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'image'
        assign b_align_alignment = 'center'
      when 'paragraph'
        assign b_align_alignment = 'left'
  endcase
-%}
    {%- if block.type == 'paragraph' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }} {
        text-align: {{ b_align_alignment | default: 'left' }} !important;
        margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
        margin-bottom: {{ block.settings.margin_bottom | default: 20 }}px !important;
        
        /* Typography */
        font-size: {% if block.settings.font_size == 'small' %}0.95rem{% elsif block.settings.font_size == 'large' %}1.25rem{% else %}1.1rem{% endif %} !important;
        font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %} !important;
        font-style: {{ block.settings.font_style | default: 'normal' }} !important;
        text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
        letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
        line-height: {{ block.settings.line_height | default: 170 }}% !important;

        /* Colors & Background */
        {%- if block.settings.bg_gradient != blank -%}
          background: {{ block.settings.bg_gradient }} !important;
          padding: 10px 15px !important;
          border-radius: 6px !important;
        {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
          background-color: {{ block.settings.bg_color }} !important;
          padding: 10px 15px !important;
          border-radius: 6px !important;
        {%- endif -%}
        {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
          color: {{ block.settings.text_color }} !important;
        {%- endif -%}
      }
      @media screen and (max-width: 768px) {
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom_mobile | default: 16 }}px !important;
        }
      }
    {%- endif -%}
  {%- endfor -%}

  /* image block overrides */
  {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'image'
        assign b_align_alignment = 'center'
      when 'paragraph'
        assign b_align_alignment = 'left'
  endcase
-%}
    {%- if block.type == 'image' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }} {
        margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
        margin-bottom: {{ block.settings.margin_bottom | default: 0 }}px !important;
        width: 100% !important;
        max-width: {{ block.settings.max_width | default: 100 }}% !important;
        
        /* Alignment */
        {%- if b_align_alignment == 'left' -%}
          margin-left: 0 !important;
          margin-right: auto !important;
        {%- elsif b_align_alignment == 'right' -%}
          margin-left: auto !important;
          margin-right: 0 !important;
        {%- else -%}
          margin-left: auto !important;
          margin-right: auto !important;
        {%- endif -%}

        /* Hover Effect Lift */
        {%- if block.settings.hover_effect == 'lift' -%}
          transition: transform 0.3s ease !important;
        {%- else -%}
          transition: none !important;
        {%- endif -%}
      }

      {%- if block.settings.hover_effect == 'lift' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover {
          transform: translateY(-5px) !important;
        }
      {%- endif -%}

      #shopify-section-{{ section.id }} .block-{{ block.id }} .about-story-img {
        /* Aspect Ratio */
        {%- if block.settings.image_aspect_ratio == 'square' -%}
          aspect-ratio: 1 / 1 !important;
        {%- elsif block.settings.image_aspect_ratio == 'portrait' -%}
          aspect-ratio: 3 / 4 !important;
        {%- elsif block.settings.image_aspect_ratio == 'landscape' -%}
          aspect-ratio: 4 / 3 !important;
        {%- else -%}
          aspect-ratio: auto !important;
        {%- endif -%}
        object-fit: cover !important;

        /* Border radius, width, color */
        border-radius: {{ block.settings.image_border_radius | default: 24 }}px !important;
        border-width: {{ block.settings.border_width | default: 4 }}px !important;
        {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
          border-color: {{ block.settings.border_color }} !important;
        {%- endif -%}

        /* Box Shadow */
        {%- if block.settings.show_shadow == false -%}
          box-shadow: none !important;
        {%- endif -%}

        /* Hover Effect Zoom */
        {%- if block.settings.hover_effect == 'zoom' -%}
          transition: transform 0.5s ease, border-color 0.3s ease !important;
        {%- else -%}
          transition: transform 0.3s ease, border-color 0.3s ease !important;
        {%- endif -%}
      }

      {%- if block.settings.hover_effect == 'zoom' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          overflow: hidden !important;
          border-radius: {{ block.settings.image_border_radius | default: 24 }}px !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .about-story-img:hover {
          transform: scale(1.05) !important;
        }
      {%- endif -%}

      @media screen and (max-width: 768px) {
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom_mobile | default: 0 }}px !important;
        }
      }
    {%- endif -%}
  {%- endfor -%}
</style>

{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile,
  padding_left: 20,
  padding_right: 20,
  padding_left_mobile: 15,
  padding_right_mobile: 15
%}

{%- if section.settings.show_section -%}
<section 
  class="story-section color-{{ section.settings.color_scheme }}{% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
  id="AboutStory-{{ section.id }}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    <div class="story-grid{% if section.settings.layout == 'image_left' %} story-grid--reversed{% endif %}{% unless has_image_block %} story-grid--no-image{% endunless %}">
      <div class="story-content">
        <div class="story-text">
          {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'image'
        assign b_align_alignment = 'center'
      when 'paragraph'
        assign b_align_alignment = 'left'
  endcase
-%}
            {%- case block.type -%}
              {%- when 'header' -%}
                {%- if block.settings.heading != blank -%}
                  {%- assign heading_tag = block.settings.heading_tag | default: 'h2' -%}
                  {%- assign h_color = block.settings.highlight_color -%}
                  {%- assign h_gradient = block.settings.highlight_gradient -%}
                  {%- assign head_text_align = b_align_alignment -%}
                  {%- if head_text_align == blank -%}
                    {%- if section.settings.blocks_position == 'center' -%}
                      {%- assign head_text_align = 'center' -%}
                    {%- elsif section.settings.blocks_position == 'right' -%}
                      {%- assign head_text_align = 'right' -%}
                    {%- else -%}
                      {%- assign head_text_align = 'left' -%}
                    {%- endif -%}
                  {%- endif -%}
                  
                  <{{ heading_tag }} 
                    class="section-title size-{{ block.settings.font_size | default: 'medium' }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                    {{ block.shopify_attributes }}
                    style="
                      --m-t: {{ block.settings.margin_top | default: 0 }}px;
                      --m-b: {{ block.settings.margin_bottom | default: 32 }}px;
                      --m-t-m: {{ block.settings.margin_top_mobile | default: 0 }}px;
                      --m-b-m: {{ block.settings.margin_bottom_mobile | default: 24 }}px;
                      font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                      font-style: {{ block.settings.font_style | default: 'normal' }};
                      text-transform: {{ block.settings.text_transform | default: 'none' }};
                      letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                      line-height: {{ block.settings.line_height | default: 120 }}%;
                      text-align: {{ head_text_align }};
                      width: 100% !important;
                      max-width: {{ block.settings.max_width | default: 800 }}px !important;
                      {%- if section.settings.blocks_position == 'center' -%}
                        margin-left: auto !important;
                        margin-right: auto !important;
                      {%- elsif section.settings.blocks_position == 'right' -%}
                        margin-left: auto !important;
                        margin-right: 0 !important;
                      {%- else -%}
                        margin-left: 0 !important;
                        margin-right: auto !important;
                      {%- endif -%}
                      {% if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.text_color }} !important;{% endif %}
                      {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' %}background: {{ block.settings.bg_color }} !important;{% endif %}
                    "
                  >
                    {%- if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' -%}
                      {%- assign highlight_span = '<span class="highlight-text" style="background: ' | append: h_gradient | append: '; -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">' -%}
                    {%- elsif h_color != blank and h_color != 'rgba(0,0,0,0)' -%}
                      {%- assign highlight_span = '<span class="highlight-text" style="color: ' | append: h_color | append: ';">' -%}
                    {%- else -%}
                      {%- assign highlight_span = '<span class="highlight-text">' -%}
                    {%- endif -%}
                    {{ block.settings.heading | replace: '[', highlight_span | replace: ']', '</span>' }}
                  </{{ heading_tag }}>
                {%- endif -%}

              {%- when 'paragraph' -%}
                {%- if block.settings.text != blank -%}
                  <p class="block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
                {%- endif -%}
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
      {%- if has_image_block -%}
        <div class="story-image-wrapper">
          {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'image'
        assign b_align_alignment = 'center'
      when 'paragraph'
        assign b_align_alignment = 'left'
  endcase
-%}
            {%- if block.type == 'image' -%}
              <div class="story-image-block block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
                {%- if block.settings.story_image != blank -%}
                  {{ block.settings.story_image | image_url: width: 1200 | image_tag:
                    loading: 'lazy',
                    class: 'about-story-img',
                    alt: block.settings.story_image.alt | default: 'Our story',
                    widths: '400, 600, 800, 1200'
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg about-story-img' }}
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "About Story",
  "tag": "section",
  "class": "section-about-story",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop layout",
      "default": "image_right",
      "options": [
        { "value": "image_left", "label": "Image left, text right" },
        { "value": "image_right", "label": "Image right, text left" }
      ]
    },
    {
      "type": "select",
      "id": "blocks_position",
      "label": "Blocks Position",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "standard",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "standard", "label": "Standard" },
        { "value": "narrow", "label": "Narrow" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1",
      "options": [
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "inverse", "label": "Inverse" },
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" }
      ]
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "header",
      "name": "Header",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "General Settings"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Our Story",
          "info": "Use [text] to highlight text with accent color"
        },
        {
          "type": "select",
          "id": "heading_tag",
          "label": "Heading Tag",
          "info": "Specify heading code types for SEO and search engines.",
          "default": "h2",
          "options": [
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" },
            { "value": "h4", "label": "H4" },
            { "value": "h5", "label": "H5" },
            { "value": "h6", "label": "H6" },
            { "value": "div", "label": "div" },
            { "value": "span", "label": "span" },
            { "value": "p", "label": "p" }
          ]
        },
        {
          "type": "header",
          "content": "Visibility"
        },
        {
          "type": "checkbox",
          "id": "show_on_desktop",
          "label": "Show on Desktop",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_on_mobile",
          "label": "Show on Mobile",
          "default": true
        },
        {
          "type": "header",
          "content": "Layout"
        },
        
        {
          "type": "range",
          "id": "max_width",
          "min": 400,
          "max": 1200,
          "step": 10,
          "unit": "px",
          "label": "Maximum width",
          "default": 800
        },
        {
          "type": "range",
          "id": "margin_top",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Top Margin (Desktop)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Bottom Margin (Desktop)",
          "default": 32
        },
        {
          "type": "range",
          "id": "margin_top_mobile",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Top Margin (Mobile)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom_mobile",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Bottom Margin (Mobile)",
          "default": 24
        },
        {
          "type": "header",
          "content": "Typography"
        },
        {
          "type": "select",
          "id": "font_size",
          "label": "Font Size",
          "default": "medium",
          "options": [
            { "value": "small", "label": "Small" },
            { "value": "medium", "label": "Medium" },
            { "value": "large", "label": "Large" }
          ]
        },
        {
          "type": "select",
          "id": "font_weight",
          "label": "Font Weight",
          "default": "bold",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "bold", "label": "Bold" }
          ]
        },
        {
          "type": "select",
          "id": "font_style",
          "label": "Font Style",
          "default": "normal",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "italic", "label": "Italic" }
          ]
        },
        {
          "type": "select",
          "id": "text_transform",
          "label": "Text Transform",
          "default": "none",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "uppercase", "label": "Uppercase" },
            { "value": "lowercase", "label": "Lowercase" },
            { "value": "capitalize", "label": "Capitalize" }
          ]
        },
        {
          "type": "range",
          "id": "letter_spacing",
          "min": -5,
          "max": 10,
          "step": 0.5,
          "unit": "px",
          "label": "Letter Spacing",
          "default": 0
        },
        {
          "type": "range",
          "id": "line_height",
          "min": 80,
          "max": 200,
          "step": 5,
          "unit": "%",
          "label": "Line Height",
          "default": 120
        },
        {
          "type": "header",
          "content": "Colors"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color"
        },
