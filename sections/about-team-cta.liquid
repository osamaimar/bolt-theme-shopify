{{ 'section-about-team-cta.css' | asset_url | stylesheet_tag }}

<style>
  /* Section Spacing / Visibility overrides */
  #shopify-section-{{ section.id }} .about-cta-section {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .about-cta-section {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Container Width overrides */
  #shopify-section-{{ section.id }} .container-fluid {
    max-width: 100% !important;
    padding-left: 2rem !important;
    padding-right: 2rem !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container-narrow {
    max-width: 800px !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container {
    max-width: {{ section.settings.max_width | default: 1340 }}px !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
    margin: 0 auto !important;
  }

  /* Blocks Position align overrides */
  #shopify-section-{{ section.id }} .about-cta-content {
    display: flex;
    flex-direction: column;
    width: 100%;
    {%- if section.settings.blocks_position == 'left' -%}
      align-items: flex-start !important;
      text-align: left !important;
    {%- elsif section.settings.blocks_position == 'right' -%}
      align-items: flex-end !important;
      text-align: right !important;
    {%- else -%}
      align-items: center !important;
      text-align: center !important;
    {%- endif -%}
  }

  /* Block Spacing overrides */
  #shopify-section-{{ section.id }} .section-title {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 20px) !important;
  }
  #shopify-section-{{ section.id }} .about-cta-content p {
    margin-top: var(--sm-t, 0px) !important;
    margin-bottom: var(--sm-b, 28px) !important;
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .section-title {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 20px)) !important;
    }
    #shopify-section-{{ section.id }} .about-cta-content p {
      margin-top: var(--sm-t-m, var(--sm-t, 0px)) !important;
      margin-bottom: var(--sm-b-m, var(--sm-b, 28px)) !important;
    }
  }

  /* Responsive Font Sizing */
  #shopify-section-{{ section.id }} .section-title.size-small { font-size: clamp(1.1rem, 3vw, 1.25rem) !important; }
  #shopify-section-{{ section.id }} .section-title.size-medium { font-size: clamp(1.25rem, 3.5vw, 1.5rem) !important; }
  #shopify-section-{{ section.id }} .section-title.size-large { font-size: clamp(1.5rem, 4vw, 1.875rem) !important; }

  #shopify-section-{{ section.id }} .about-cta-content p.size-small { font-size: 13px !important; }
  #shopify-section-{{ section.id }} .about-cta-content p.size-medium { font-size: 15px !important; }
  #shopify-section-{{ section.id }} .about-cta-content p.size-large { font-size: 18px !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .about-cta-content p.size-small { font-size: 11px !important; }
    #shopify-section-{{ section.id }} .about-cta-content p.size-medium { font-size: 13px !important; }
    #shopify-section-{{ section.id }} .about-cta-content p.size-large { font-size: 15px !important; }
  }

  /* Icon block dynamic styling */
  {%- for block in section.blocks -%}
    {%- if block.type == 'icon' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }} {
        width: {{ block.settings.icon_size | default: 64 }}px !important;
        height: {{ block.settings.icon_size | default: 64 }}px !important;
        margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
        margin-bottom: {{ block.settings.margin_bottom | default: 24 }}px !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        {%- if block.settings.bg_gradient != blank -%}
          background: {{ block.settings.bg_gradient }} !important;
          border-radius: 50% !important;
        {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
          background-color: {{ block.settings.bg_color }} !important;
          border-radius: 50% !important;
        {%- else -%}
          background: var(--icon-bg, var(--color-accent-secondary-10, rgba(85, 228, 237, 0.1))) !important;
          border-radius: 50% !important;
        {%- endif -%}
        {%- if block.settings.icon_color != blank and block.settings.icon_color != 'rgba(0,0,0,0)' -%}
          color: {{ block.settings.icon_color }} !important;
        {%- else -%}
          color: var(--icon-color, var(--color-accent-secondary, #55e4ed)) !important;
        {%- endif -%}
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} svg {
        width: calc({{ block.settings.icon_size | default: 64 }}px * 0.4375) !important;
        height: calc({{ block.settings.icon_size | default: 64 }}px * 0.4375) !important;
      }
      @media screen and (max-width: 768px) {
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom_mobile | default: 16 }}px !important;
        }
      }
    {%- endif -%}
  {%- endfor -%}
</style>

{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

{%- if section.settings.show_section -%}
<section 
  class="about-cta-section color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
  id="shopify-section-{{ section.id }}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    <div class="about-cta-card" style="border-radius: {{ section.settings.card_border_radius }}px;">
      {%- if section.settings.show_background_pattern -%}
        <div class="bg-pattern pattern-top-left"></div>
        <div class="bg-pattern pattern-bottom-right"></div>
      {%- endif -%}

      <div class="about-cta-content">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'icon' -%}
              {%- if block.settings.icon != blank or block.settings.custom_icon_svg != blank -%}
                <div class="about-cta-icon block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
                  {%- if block.settings.icon != blank -%}
                    {%- case block.settings.icon -%}
                      {%- when 'laptop' -%}
                        {% render 'icon-laptop' %}
                      {%- when 'phone' -%}
                        {% render 'icon-phone' %}
                      {%- when 'headphones' -%}
                        {% render 'icon-headphones' %}
                      {%- when 'tools' -%}
                        {% render 'icon-tools' %}
                      {%- when 'gamepad' -%}
                        {% render 'icon-gamepad' %}
                      {%- when 'watch' -%}
                        {% render 'icon-watch' %}
                      {%- when 'shipping' -%}
                        {% render 'icon-shipping' %}
                      {%- when 'support' -%}
                        {% render 'icon-support' %}
                      {%- when 'secure' -%}
                        {% render 'icon-secure' %}
                      {%- when 'returns' -%}
                        {% render 'icon-returns' %}
                      {%- when 'check' -%}
                        {% render 'icon-check' %}
                      {%- when 'heart' -%}
                        {% render 'icon-heart' %}
                      {%- when 'star' -%}
                        {% render 'icon-star' %}
                      {%- when 'user' -%}
                        {% render 'icon-user' %}
                      {%- when 'user-plus' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                          <circle cx="9" cy="7" r="4" />
                          <line x1="19" y1="8" x2="19" y2="14" />
                          <line x1="22" y1="11" x2="16" y2="11" />
                        </svg>
                      {%- when 'award' -%}
                        <svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='8' r='7' /><polyline points='8.21 13.89 7 23 12 20 17 23 15.79 13.88' /></svg>
                      {%- when 'target' -%}
                        <svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='10' /><circle cx='12' cy='12' r='6' /><circle cx='12' cy='12' r='2' /></svg>
                      {%- when 'zap' -%}
                        <svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polygon points='13 2 3 14 12 14 11 22 21 10 12 10 13 2' /></svg>
                      {%- when 'gift' -%}
                        <svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='20 12 20 22 4 22 4 12' /><rect x='2' y='7' width='20' height='5' /><line x1='12' y1='22' x2='12' y2='7' /><path d='M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z' /><path d='M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z' /></svg>
                    {%- endcase -%}
                  {%- elsif block.settings.custom_icon_svg != blank -%}
                    {{ block.settings.custom_icon_svg }}
                  {%- endif -%}
                </div>
              {%- endif -%}

            {%- when 'header' -%}
              {%- if block.settings.heading != blank -%}
                {%- assign heading_tag = block.settings.heading_tag | default: 'h2' -%}
                {%- assign h_color = block.settings.highlight_color -%}
                {%- assign h_gradient = block.settings.highlight_gradient -%}
                {%- assign head_text_align = '' -%}
                {%- if head_text_align == blank -%}
                  {%- if section.settings.blocks_position == 'left' -%}
                    {%- assign head_text_align = 'left' -%}
                  {%- elsif section.settings.blocks_position == 'right' -%}
                    {%- assign head_text_align = 'right' -%}
                  {%- else -%}
                    {%- assign head_text_align = 'center' -%}
                  {%- endif -%}
                {%- endif -%}
                
                <{{ heading_tag }} 
                  class="section-title size-{{ block.settings.font_size | default: 'large' }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                  {{ block.shopify_attributes }}
                  style="
                    --m-t: {{ block.settings.margin_top | default: 0 }}px;
                    --m-b: {{ block.settings.margin_bottom | default: 20 }}px;
                    --m-t-m: {{ block.settings.margin_top_mobile | default: 0 }}px;
                    --m-b-m: {{ block.settings.margin_bottom_mobile | default: 16 }}px;
                    font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                    font-style: {{ block.settings.font_style | default: 'normal' }};
                    text-transform: {{ block.settings.text_transform | default: 'none' }};
                    letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                    line-height: {{ block.settings.line_height | default: 120 }}%;
                    text-align: {{ head_text_align }};
                    width: 100% !important;
                    max-width: {{ block.settings.max_width | default: 800 }}px !important;
                    {%- if section.settings.blocks_position == 'left' -%}
                      margin-left: 0 !important;
                      margin-right: auto !important;
                    {%- elsif section.settings.blocks_position == 'right' -%}
                      margin-left: auto !important;
                      margin-right: 0 !important;
                    {%- else -%}
                      margin-left: auto !important;
                      margin-right: auto !important;
                    {%- endif -%}
                    {% if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.text_color }} !important;{% endif %}
                    {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' %}background: {{ block.settings.bg_color }} !important;{% endif %}
                  "
                >
                  {%- if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' -%}
                    {%- assign highlight_span = '<span class="highlight-text" style="background: ' | append: h_gradient | append: ' !important; -webkit-background-clip: text !important; background-clip: text !important; -webkit-text-fill-color: transparent !important;color: transparent !important;">' -%}
                  {%- elsif h_color != blank and h_color != 'rgba(0,0,0,0)' -%}
                    {%- assign highlight_span = '<span class="highlight-text" style="color: ' | append: h_color | append: ' !important;">' -%}
                  {%- else -%}
                    {%- assign highlight_span = '<span class="highlight-text">' -%}
                  {%- endif -%}
                  {{ block.settings.heading | replace: '[', highlight_span | replace: ']', '</span>' }}
                </{{ heading_tag }}>
              {%- endif -%}

            {%- when 'subtitle' -%}
              {%- if block.settings.description != blank -%}
                {%- assign subheading_tag = block.settings.subheading_tag | default: 'p' -%}
                {%- assign sub_text_align = '' -%}
                {%- if sub_text_align == blank -%}
                  {%- if section.settings.blocks_position == 'left' -%}
                    {%- assign sub_text_align = 'left' -%}
                  {%- elsif section.settings.blocks_position == 'right' -%}
                    {%- assign sub_text_align = 'right' -%}
                  {%- else -%}
                    {%- assign sub_text_align = 'center' -%}
                  {%- endif -%}
                {%- endif -%}

                <{{ subheading_tag }} 
                  class="size-{{ block.settings.font_size | default: 'medium' }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                  {{ block.shopify_attributes }}
                  style="
                    --sm-t: {{ block.settings.margin_top | default: 0 }}px;
                    --sm-b: {{ block.settings.margin_bottom | default: 28 }}px;
                    --sm-t-m: {{ block.settings.margin_top_mobile | default: 0 }}px;
                    --sm-b-m: {{ block.settings.margin_bottom_mobile | default: 20 }}px;
                    font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                    font-style: {{ block.settings.font_style | default: 'normal' }};
                    text-transform: {{ block.settings.text_transform | default: 'none' }};
                    letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                    line-height: {{ block.settings.line_height | default: 160 }}%;
                    text-align: {{ sub_text_align }};
                    width: 100% !important;
                    max-width: {{ block.settings.max_width | default: 800 }}px !important;
                    {%- if section.settings.blocks_position == 'left' -%}
                      margin-left: 0 !important;
                      margin-right: auto !important;
                    {%- elsif section.settings.blocks_position == 'right' -%}
                      margin-left: auto !important;
                      margin-right: 0 !important;
                    {%- else -%}
                      margin-left: auto !important;
                      margin-right: auto !important;
                    {%- endif -%}
                    {% if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.text_color }} !important;{% endif %}
                    {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' %}background: {{ block.settings.bg_color }} !important;{% endif %}
                  "
                >
                  {{ block.settings.description }}
                </{{ subheading_tag }}>
              {%- endif -%}


          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "About Team CTA",
  "tag": "section",
  "class": "section-about-team-cta",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "blocks_position",
      "label": "Blocks Position",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "standard",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "standard", "label": "Standard" },
        { "value": "narrow", "label": "Narrow" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Maximum width",
      "default": 1340
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Card border radius",
      "default": 30
    },
    {
      "type": "checkbox",
      "id": "show_background_pattern",
      "label": "Show background pattern",
      "default": true
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1",
      "options": [
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "inverse", "label": "Inverse" },
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" }
      ]
    },

    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 20
    },

  ],
  "blocks": [
    {
      "type": "icon",
      "name": "Icon",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "General Settings"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon Preset",
          "default": "user",
          "options": [
            { "value": "", "label": "Custom SVG (HTML setting below)" },
            { "value": "laptop", "label": "Laptop" },
            { "value": "phone", "label": "Phone" },
            { "value": "headphones", "label": "Headphones" },
            { "value": "tools", "label": "Tools" },
            { "value": "gamepad", "label": "Gamepad" },
            { "value": "watch", "label": "Watch" },
            { "value": "shipping", "label": "Shipping" },
            { "value": "support", "label": "Support" },
            { "value": "secure", "label": "Secure" },
            { "value": "returns", "label": "Returns" },
            { "value": "check", "label": "Check" },
            { "value": "heart", "label": "Heart" },
            { "value": "star", "label": "Star" },
            { "value": "award", "label": "Award" },
            { "value": "target", "label": "Target" },
            { "value": "zap", "label": "Zap" },
            { "value": "gift", "label": "Gift" },
            { "value": "user", "label": "User" },
            { "value": "user-plus", "label": "User Plus" }
          ]
        },
        {
          "type": "html",
          "id": "custom_icon_svg",
          "label": "Custom Icon SVG",
          "info": "Paste custom SVG HTML code here. Only works when 'Icon Preset' is set to Custom SVG."
        },

        {
          "type": "header",
          "content": "Visibility"
        },
        {
          "type": "checkbox",
          "id": "show_on_desktop",
          "label": "Show on Desktop",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_on_mobile",
          "label": "Show on Mobile",
          "default": true
        },
        {
          "type": "header",
          "content": "Layout"
        },
        {
          "type": "range",
          "id": "icon_size",
          "min": 24,
          "max": 120,
          "step": 4,
          "unit": "px",
          "label": "Icon Size",
          "default": 64
        },
        {
          "type": "range",
          "id": "margin_top",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Top Margin (Desktop)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Bottom Margin (Desktop)",
          "default": 24
        },
        {
          "type": "range",
          "id": "margin_top_mobile",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Top Margin (Mobile)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom_mobile",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Bottom Margin (Mobile)",
          "default": 16
        },
        {
          "type": "header",
          "content": "Colors"
        },
        {
          "type": "color",
          "id": "icon_color",
          "label": "Icon Color"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color"
        },
        {
          "type": "color_background",
          "id": "bg_gradient",
          "label": "Background Gradient"
        }
      ]
    },
    {
      "type": "header",
      "name": "Header",
