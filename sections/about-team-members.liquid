                        </svg>
                      </a>
                    {%- endif -%}
                    {%- if block.settings.email != blank -%}
                      <a href="mailto:{{ block.settings.email }}" class="team-social-link" title="Email">
                        {% render 'icon-mail' %}
                      </a>
                    {%- endif -%}
                    {%- if block.settings.phone != blank -%}
                      <a href="tel:{{ block.settings.phone }}" class="team-social-link" title="Phone">
                        {% render 'icon-phone' %}
                      </a>
                    {%- endif -%}
                    {%- if block.settings.website_url != blank -%}
                      <a href="{{ block.settings.website_url }}" class="team-social-link" title="Website" target="_blank" rel="noopener">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="12" r="10" />
                          <line x1="2" y1="12" x2="22" y2="12" />
                          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                        </svg>
                      </a>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

