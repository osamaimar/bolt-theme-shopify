{{ 'section-about-team-members.css' | asset_url | stylesheet_tag }}

<style>
  /* Section Spacing / Visibility overrides */
  #shopify-section-{{ section.id }} .team-section {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .team-section {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Container Width overrides */
  #shopify-section-{{ section.id }} .container-fluid {
    max-width: 100% !important;
    padding-left: 2rem !important;
    padding-right: 2rem !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container-narrow {
    max-width: 800px !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container {
    max-width: {{ section.settings.max_width | default: 1340 }}px !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
    margin: 0 auto !important;
  }

  /* Blocks Position align overrides */
  #shopify-section-{{ section.id }} .team-header-wrap {
    display: flex;
    flex-direction: column;
    width: 100%;
    {%- if section.settings.blocks_position == 'left' -%}
      align-items: flex-start !important;
      text-align: left !important;
    {%- elsif section.settings.blocks_position == 'right' -%}
      align-items: flex-end !important;
      text-align: right !important;
    {%- else -%}
      align-items: center !important;
      text-align: center !important;
    {%- endif -%}
  }

  /* Block Spacing overrides */
  #shopify-section-{{ section.id }} .section-title {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 20px) !important;
  }
  #shopify-section-{{ section.id }} .section-subtitle {
    margin-top: var(--sm-t, 0px) !important;
    margin-bottom: var(--sm-b, 28px) !important;
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .section-title {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 20px)) !important;
    }
    #shopify-section-{{ section.id }} .section-subtitle {
      margin-top: var(--sm-t-m, var(--sm-t, 0px)) !important;
      margin-bottom: var(--sm-b-m, var(--sm-b, 28px)) !important;
    }
  }

  /* Responsive Font Sizing */
  #shopify-section-{{ section.id }} .section-title.size-small { font-size: 24px !important; }
  #shopify-section-{{ section.id }} .section-title.size-medium { font-size: 36px !important; }
  #shopify-section-{{ section.id }} .section-title.size-large { font-size: 48px !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .section-title.size-small { font-size: 20px !important; }
    #shopify-section-{{ section.id }} .section-title.size-medium { font-size: 28px !important; }
    #shopify-section-{{ section.id }} .section-title.size-large { font-size: 36px !important; }
  }

  #shopify-section-{{ section.id }} .section-subtitle.size-small { font-size: 13px !important; }
  #shopify-section-{{ section.id }} .section-subtitle.size-medium { font-size: 15px !important; }
  #shopify-section-{{ section.id }} .section-subtitle.size-large { font-size: 18px !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .section-subtitle.size-small { font-size: 11px !important; }
    #shopify-section-{{ section.id }} .section-subtitle.size-medium { font-size: 13px !important; }
    #shopify-section-{{ section.id }} .section-subtitle.size-large { font-size: 15px !important; }
  }

  /* team_member block settings overrides */
  {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subtitle'
        assign b_align_alignment = ''
      when 'team_member'
        assign b_align_alignment = 'center'
  endcase
-%}
    {%- if block.type == 'team_member' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }} {
        margin-top: {{ block.settings.margin_top | default: 20 }}px !important;
        margin-bottom: {{ block.settings.margin_bottom | default: 20 }}px !important;
        {%- if block.settings.bg_gradient != blank -%}
          background: {{ block.settings.bg_gradient }} !important;
        {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
          background-color: {{ block.settings.bg_color }} !important;
        {%- endif -%}
        {%- if block.settings.card_border_color != blank and block.settings.card_border_color != 'rgba(0,0,0,0)' -%}
          border-color: {{ block.settings.card_border_color }} !important;
        {%- endif -%}
      }

      /* Alignment Override */
      {%- if b_align_alignment != blank -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .team-card-body {
          text-align: {{ b_align_alignment }} !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .team-socials {
          {%- if b_align_alignment == 'left' -%}
            justify-content: flex-start !important;
          {%- elsif b_align_alignment == 'right' -%}
            justify-content: flex-end !important;
            padding-right: 0 !important;
            justify-self: flex-end !important;
          {%- else -%}
            justify-content: center !important;
          {%- endif -%}
        }
      {%- endif -%}

      /* Photo Section background override */
      {%- if block.settings.photo_section_bg_gradient != blank -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .team-card-image {
          background: {{ block.settings.photo_section_bg_gradient }} !important;
        }
      {%- elsif block.settings.photo_section_bg_color != blank and block.settings.photo_section_bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .team-card-image {
          background: {{ block.settings.photo_section_bg_color }} !important;
          background-image: none !important;
        }
      {%- endif -%}

      /* Name typography and color */
      #shopify-section-{{ section.id }} .block-{{ block.id }} h3 {
        font-size: {% if block.settings.name_font_size == 'small' %}1.1rem{% elsif block.settings.name_font_size == 'large' %}1.5rem{% else %}1.3rem{% endif %} !important;
        font-weight: {% if block.settings.name_font_weight == 'bold' %}700{% else %}400{% endif %} !important;
        {%- if block.settings.name_gradient != blank -%}
          background: {{ block.settings.name_gradient }} !important;
          -webkit-background-clip: text !important;
          background-clip: text !important;
          -webkit-text-fill-color: transparent !important;
        color: transparent !important;
        {%- elsif block.settings.name_color != blank and block.settings.name_color != 'rgba(0,0,0,0)' -%}
          color: {{ block.settings.name_color }} !important;
        {%- endif -%}
      }

      /* Role typography and color */
      #shopify-section-{{ section.id }} .block-{{ block.id }} .team-role {
        font-size: {% if block.settings.role_font_size == 'small' %}0.8rem{% elsif block.settings.role_font_size == 'large' %}1.05rem{% else %}0.875rem{% endif %} !important;
        font-weight: {% if block.settings.role_font_weight == 'bold' %}700{% else %}500{% endif %} !important;
        {%- if block.settings.role_color != blank and block.settings.role_color != 'rgba(0,0,0,0)' -%}
          color: {{ block.settings.role_color }} !important;
        {%- endif -%}
      }

      /* Description typography and color */
      #shopify-section-{{ section.id }} .block-{{ block.id }} p {
        font-size: {% if block.settings.desc_font_size == 'small' %}0.8rem{% elsif block.settings.desc_font_size == 'large' %}1.05rem{% else %}0.9rem{% endif %} !important;
        font-weight: {% if block.settings.desc_font_weight == 'bold' %}700{% else %}400{% endif %} !important;
        {%- if block.settings.desc_color != blank and block.settings.desc_color != 'rgba(0,0,0,0)' -%}
          color: {{ block.settings.desc_color }} !important;
        {%- endif -%}
      }

      /* Photo/Avatar background & border color override */
      {%- if block.settings.avatar_border_color != blank and block.settings.avatar_border_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .team-avatar {
          border-color: {{ block.settings.avatar_border_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.avatar_bg_gradient != blank -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .team-avatar {
          background: {{ block.settings.avatar_bg_gradient }} !important;
        }
      {%- elsif block.settings.avatar_bg_color != blank and block.settings.avatar_bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .team-avatar {
          background: {{ block.settings.avatar_bg_color }} !important;
          background-image: none !important;
        }
      {%- endif -%}
      {%- if block.settings.avatar_icon_color != blank and block.settings.avatar_icon_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .team-avatar svg {
          color: {{ block.settings.avatar_icon_color }} !important;
        }
      {%- endif -%}

      /* Social Link colors */
      #shopify-section-{{ section.id }} .block-{{ block.id }} .team-social-link {
        {%- if block.settings.social_color != blank and block.settings.social_color != 'rgba(0,0,0,0)' -%}
          color: {{ block.settings.social_color }} !important;
        {%- endif -%}
        {%- if block.settings.social_bg_color != blank and block.settings.social_bg_color != 'rgba(0,0,0,0)' -%}
          background: {{ block.settings.social_bg_color }} !important;
        {%- endif -%}
        {%- if block.settings.social_border_color != blank and block.settings.social_border_color != 'rgba(0,0,0,0)' -%}
          border-color: {{ block.settings.social_border_color }} !important;
        {%- elsif block.settings.social_color != blank and block.settings.social_color != 'rgba(0,0,0,0)' -%}
          border-color: {{ block.settings.social_color }}33 !important;
        {%- endif -%}
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} .team-social-link:hover {
        {%- if block.settings.social_hover_color != blank and block.settings.social_hover_color != 'rgba(0,0,0,0)' -%}
          color: {{ block.settings.social_hover_color }} !important;
        {%- endif -%}
        {%- if block.settings.social_bg_hover_color != blank and block.settings.social_bg_hover_color != 'rgba(0,0,0,0)' -%}
          background: {{ block.settings.social_bg_hover_color }} !important;
        {%- endif -%}
        {%- if block.settings.social_border_hover_color != blank and block.settings.social_border_hover_color != 'rgba(0,0,0,0)' -%}
          border-color: {{ block.settings.social_border_hover_color }} !important;
        {%- elsif block.settings.social_hover_color != blank and block.settings.social_hover_color != 'rgba(0,0,0,0)' -%}
          border-color: {{ block.settings.social_hover_color }} !important;
        {%- endif -%}
      }

      @media screen and (max-width: 768px) {
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top_mobile | default: 15 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom_mobile | default: 15 }}px !important;
        }
      }
    {%- endif -%}
  {%- endfor -%}

  /* Grid Layout / Columns settings */
  #shopify-section-{{ section.id }} .team-grid {
    grid-template-columns: repeat({{ section.settings.columns_desktop | default: 3 }}, 1fr) !important;
  }
  @media screen and (max-width: 990px) {
    #shopify-section-{{ section.id }} .team-grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet | default: 2 }}, 1fr) !important;
    }
  }
  @media screen and (max-width: 480px) {
    #shopify-section-{{ section.id }} .team-grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile | default: 1 }}, 1fr) !important;
    }
  }
</style>

{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

{%- if section.settings.show_section -%}
<section 
  class="team-section color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
  id="shopify-section-{{ section.id }}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    <div class="team-header-wrap mb-16">
      {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subtitle'
        assign b_align_alignment = ''
      when 'team_member'
        assign b_align_alignment = 'center'
  endcase
-%}
        {%- case block.type -%}
          {%- when 'header' -%}
            {%- if block.settings.heading != blank -%}
              {%- assign heading_tag = block.settings.heading_tag | default: 'h2' -%}
              {%- assign h_color = block.settings.highlight_color -%}
              {%- assign h_gradient = block.settings.highlight_gradient -%}
              {%- assign head_text_align = b_align_alignment -%}
              {%- if head_text_align == blank -%}
                {%- if section.settings.blocks_position == 'left' -%}
                  {%- assign head_text_align = 'left' -%}
                {%- elsif section.settings.blocks_position == 'right' -%}
                  {%- assign head_text_align = 'right' -%}
                {%- else -%}
                  {%- assign head_text_align = 'center' -%}
                {%- endif -%}
              {%- endif -%}
              {%- assign head_pos_align = b_align_alignment | default: section.settings.blocks_position -%}
              
              <{{ heading_tag }} 
                class="section-title size-{{ block.settings.font_size | default: 'large' }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                {{ block.shopify_attributes }}
                style="
                  --m-t: {{ block.settings.margin_top | default: 0 }}px;
                  --m-b: {{ block.settings.margin_bottom | default: 20 }}px;
                  --m-t-m: {{ block.settings.margin_top_mobile | default: 0 }}px;
                  --m-b-m: {{ block.settings.margin_bottom_mobile | default: 16 }}px;
                  font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                  font-style: {{ block.settings.font_style | default: 'normal' }};
                  text-transform: {{ block.settings.text_transform | default: 'none' }};
                  letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                  line-height: {{ block.settings.line_height | default: 120 }}%;
                  text-align: {{ head_text_align }};
                  width: 100% !important;
                  max-width: {{ block.settings.max_width | default: 800 }}px !important;
                  {%- if head_pos_align == 'left' -%}
                    margin-left: 0 !important;
                    margin-right: auto !important;
                  {%- elsif head_pos_align == 'right' -%}
                    margin-left: auto !important;
                    margin-right: 0 !important;
                  {%- else -%}
                    margin-left: auto !important;
                    margin-right: auto !important;
                  {%- endif -%}
                  {% if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.text_color }} !important;{% endif %}
                  {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' %}background: {{ block.settings.bg_color }} !important;{% endif %}
                "
              >
                {%- if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' -%}
                  {%- assign highlight_span = '<span class="highlight-text" style="background: ' | append: h_gradient | append: '; -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">' -%}
                {%- elsif h_color != blank and h_color != 'rgba(0,0,0,0)' -%}
                  {%- assign highlight_span = '<span class="highlight-text" style="color: ' | append: h_color | append: ';">' -%}
                {%- else -%}
                  {%- assign highlight_span = '<span class="highlight-text">' -%}
                {%- endif -%}
                {{ block.settings.heading | replace: '[', highlight_span | replace: ']', '</span>' }}
              </{{ heading_tag }}>
            {%- endif -%}

          {%- when 'subtitle' -%}
            {%- if block.settings.subheading != blank -%}
              {%- assign subheading_tag = block.settings.subheading_tag | default: 'p' -%}
              {%- assign sub_text_align = b_align_alignment -%}
              {%- if sub_text_align == blank -%}
                {%- if section.settings.blocks_position == 'left' -%}
                  {%- assign sub_text_align = 'left' -%}
                {%- elsif section.settings.blocks_position == 'right' -%}
                  {%- assign sub_text_align = 'right' -%}
                {%- else -%}
                  {%- assign sub_text_align = 'center' -%}
                {%- endif -%}
              {%- endif -%}
              {%- assign sub_pos_align = b_align_alignment | default: section.settings.blocks_position -%}
 
              <{{ subheading_tag }} 
                class="section-subtitle size-{{ block.settings.font_size | default: 'medium' }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                {{ block.shopify_attributes }}
                style="
                  --sm-t: {{ block.settings.margin_top | default: 0 }}px;
                  --sm-b: {{ block.settings.margin_bottom | default: 28 }}px;
                  --sm-t-m: {{ block.settings.margin_top_mobile | default: 0 }}px;
                  --sm-b-m: {{ block.settings.margin_bottom_mobile | default: 20 }}px;
                  font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                  font-style: {{ block.settings.font_style | default: 'normal' }};
                  text-transform: {{ block.settings.text_transform | default: 'none' }};
                  letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                  line-height: {{ block.settings.line_height | default: 160 }}%;
                  text-align: {{ sub_text_align }};
                  width: 100% !important;
                  max-width: {{ block.settings.max_width | default: 800 }}px !important;
                  {%- if sub_pos_align == 'left' -%}
                    margin-left: 0 !important;
                    margin-right: auto !important;
                  {%- elsif sub_pos_align == 'right' -%}
                    margin-left: auto !important;
                    margin-right: 0 !important;
                  {%- else -%}
                    margin-left: auto !important;
                    margin-right: auto !important;
                  {%- endif -%}
                  {% if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.text_color }} !important;{% endif %}
                  {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' %}background: {{ block.settings.bg_color }} !important;{% endif %}
                "
              >
                {{ block.settings.subheading }}
              </{{ subheading_tag }}>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <div class="team-grid">
      {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subtitle'
        assign b_align_alignment = ''
      when 'team_member'
        assign b_align_alignment = 'center'
  endcase
-%}
        {%- case block.type -%}
          {%- when 'team_member' -%}
            <div class="team-card block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
              {%- if block.settings.show_image -%}
              <div class="team-card-image">
                <div class="team-avatar">
                  {%- if block.settings.member_image != blank -%}
                    {{ block.settings.member_image | image_url: width: 200 | image_tag: loading: 'lazy', alt: block.settings.member_name | default: 'Team member' }}
                  {%- elsif block.settings.use_placeholder == true -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                      <circle cx="12" cy="7" r="4" />
                    </svg>
                  {%- endif -%}
                </div>
              </div>
              {%- endif -%}
              <div class="team-card-body">
                {%- if block.settings.show_name and block.settings.member_name != blank -%}
                  <h3>{{ block.settings.member_name }}</h3>
                {%- endif -%}
                {%- if block.settings.show_role and block.settings.member_role != blank -%}
                  <div class="team-role">{{ block.settings.member_role }}</div>
                {%- endif -%}
                {%- if block.settings.show_description and block.settings.member_description != blank -%}
                  <p>{{ block.settings.member_description }}</p>
                {%- endif -%}
                
                {%- if block.settings.show_socials == true -%}
                  <div class="team-socials">
                    {%- if block.settings.linkedin_url != blank -%}
                      <a href="{{ block.settings.linkedin_url }}" class="team-social-link" title="LinkedIn" target="_blank" rel="noopener">
                        {% render 'icon-linkedin' %}
                      </a>
                    {%- endif -%}
                    {%- if block.settings.twitter_url != blank -%}
                      <a href="{{ block.settings.twitter_url }}" class="team-social-link" title="Twitter/X" target="_blank" rel="noopener">
                        {% render 'icon-twitter' %}
                      </a>
                    {%- endif -%}
                    {%- if block.settings.facebook_url != blank -%}
                      <a href="{{ block.settings.facebook_url }}" class="team-social-link" title="Facebook" target="_blank" rel="noopener">
                        {% render 'icon-facebook' %}
                      </a>
                    {%- endif -%}
                    {%- if block.settings.instagram_url != blank -%}
                      <a href="{{ block.settings.instagram_url }}" class="team-social-link" title="Instagram" target="_blank" rel="noopener">
                        {% render 'icon-instagram' %}
                      </a>
                    {%- endif -%}
                    {%- if block.settings.youtube_url != blank -%}
                      <a href="{{ block.settings.youtube_url }}" class="team-social-link" title="YouTube" target="_blank" rel="noopener">
                        {% render 'icon-youtube' %}
                      </a>
                    {%- endif -%}
                    {%- if block.settings.tiktok_url != blank -%}
                      <a href="{{ block.settings.tiktok_url }}" class="team-social-link" title="TikTok" target="_blank" rel="noopener">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5" />
                        </svg>
                      </a>
                    {%- endif -%}
                    {%- if block.settings.pinterest_url != blank -%}
                      <a href="{{ block.settings.pinterest_url }}" class="team-social-link" title="Pinterest" target="_blank" rel="noopener">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
