{{ 'section-about-team-timeline.css' | asset_url | stylesheet_tag }}

<style>
  /* Timeline Event block styles */
  {%- for block in section.blocks -%}
    {%- if block.type == 'timeline_event' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }} {
        padding-bottom: {{ block.settings.margin_bottom | default: 60 }}px !important;
        margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
      }
      @media screen and (max-width: 768px) {
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          padding-bottom: {{ block.settings.margin_bottom_mobile | default: 40 }}px !important;
          margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
        }
      }

      /* Alignment Override */
      {%- if '' != blank -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content {
          text-align: {{ '' }} !important;
        }
      {%- endif -%}

      /* Typography Font Size overrides */
      {%- if block.settings.font_size == 'small' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content h3 { font-size: 1rem !important; }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content p { font-size: 0.85rem !important; }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-year-badge { font-size: 0.8rem !important; }
      {%- elsif block.settings.font_size == 'large' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content h3 { font-size: 1.5rem !important; }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content p { font-size: 1.1rem !important; }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-year-badge { font-size: 1rem !important; }
      {%- else -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content h3 { font-size: 1.25rem !important; }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content p { font-size: 0.95rem !important; }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-year-badge { font-size: 0.9rem !important; }
      {%- endif -%}

      /* Typography Style Overrides on Paragraph */
      #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content p {
        font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %} !important;
        font-style: {{ block.settings.font_style | default: 'normal' }} !important;
        text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
        letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
        line-height: {{ block.settings.line_height | default: 160 }}% !important;
      }

      /* Text color */
      {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content p,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a {
          color: {{ block.settings.text_color }} !important;
        }
      {%- endif -%}

      /* Heading Color & Gradient overrides */
      {%- if block.settings.heading_gradient != blank -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content h3 {
          background: {{ block.settings.heading_gradient }} !important;
          -webkit-background-clip: text !important;
          background-clip: text !important;
          -webkit-text-fill-color: transparent !important;
        color: transparent !important;
        }
      {%- elsif block.settings.heading_color != blank and block.settings.heading_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content h3 {
          color: {{ block.settings.heading_color }} !important;
        }
      {%- elsif block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content h3 {
          color: {{ block.settings.text_color }} !important;
        }
      {%- endif -%}

      /* Block Background Color/Gradient */
      {%- if block.settings.bg_gradient != blank or block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
          {%- else -%}
            background: {{ block.settings.bg_color }} !important;
          {%- endif -%}
          border-radius: var(--radius-md, 8px) !important;
          padding: 20px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 60 }}px !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }}::before,
        #shopify-section-{{ section.id }} .block-{{ block.id }}::after {
          top: calc(var(--spacing-sm, 12px) + 20px) !important;
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            padding: 20px 20px 20px 50px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 40 }}px !important;
          }
        }
      {%- endif -%}

      /* Badge Background, Text, and Border Color Overrides */
      {%- if block.settings.badge_bg_gradient != blank -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-year-badge {
          background: {{ block.settings.badge_bg_gradient }} !important;
        }
      {%- elsif block.settings.badge_bg_color != blank and block.settings.badge_bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-year-badge {
          background: {{ block.settings.badge_bg_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.badge_text_color != blank and block.settings.badge_text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-year-badge {
          color: {{ block.settings.badge_text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.badge_border_color != blank and block.settings.badge_border_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-year-badge {
          border-color: {{ block.settings.badge_border_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.icon_color != blank and block.settings.icon_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-year-badge svg {
          color: {{ block.settings.icon_color }} !important;
          stroke: {{ block.settings.icon_color }} !important;
        }
      {%- endif -%}

      /* Timeline Marker Dot Color Override */
      {%- if block.settings.dot_color != blank and block.settings.dot_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}::before {
          background: {{ block.settings.dot_color }} !important;
          box-shadow: 0 0 0 3px {{ block.settings.dot_color }}4d !important;
        }
      {%- endif -%}

      /* Button / Link Custom Colors */
      {%- if block.settings.button_text_color != blank and block.settings.button_text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.cta-button,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.hero-button,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.timeline-cta {
          color: {{ block.settings.button_text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.button_bg_gradient != blank -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.cta-button,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.hero-button,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.timeline-cta {
          background: {{ block.settings.button_bg_gradient }} !important;
          border-color: transparent !important;
        }
      {%- elsif block.settings.button_bg_color != blank and block.settings.button_bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.cta-button,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.hero-button,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.timeline-cta {
          background: {{ block.settings.button_bg_color }} !important;
          background-image: none !important;
        }
      {%- endif -%}
      {%- if block.settings.button_border_color != blank and block.settings.button_border_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.cta-button,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.hero-button,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.timeline-cta {
          border: 1px solid {{ block.settings.button_border_color }} !important;
        }
      {%- endif -%}

      /* Button / Link Custom Hover Colors */
      {%- if block.settings.button_text_hover_color != blank and block.settings.button_text_hover_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.cta-button:hover,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.hero-button:hover,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.timeline-cta:hover {
          color: {{ block.settings.button_text_hover_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.button_bg_hover_gradient != blank -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.cta-button:hover,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.hero-button:hover,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.timeline-cta:hover {
          background: {{ block.settings.button_bg_hover_gradient }} !important;
          border-color: transparent !important;
        }
      {%- elsif block.settings.button_bg_hover_color != blank and block.settings.button_bg_hover_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.cta-button:hover,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.hero-button:hover,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.timeline-cta:hover {
          background: {{ block.settings.button_bg_hover_color }} !important;
          background-image: none !important;
        }
      {%- endif -%}
      {%- if block.settings.button_border_hover_color != blank and block.settings.button_border_hover_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.cta-button:hover,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.hero-button:hover,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .timeline-content a.timeline-cta:hover {
          border-color: {{ block.settings.button_border_hover_color }} !important;
        }
      {%- endif -%}

    {%- endif -%}
  {%- endfor -%}
  /* Ensure timeline line renders on top of block backgrounds */
  #shopify-section-{{ section.id }} .timeline::before {
    z-index: 1 !important;
    {%- if section.settings.line_gradient != blank -%}
      background: {{ section.settings.line_gradient }} !important;
    {%- elsif section.settings.line_color != blank and section.settings.line_color != 'rgba(0,0,0,0)' -%}
      background: linear-gradient(
        to bottom,
        transparent,
        {{ section.settings.line_color }} 15%,
        {{ section.settings.line_color }} 85%,
        transparent
      ) !important;
    {%- endif -%}
  }
</style>
{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile,
  padding_left: section.settings.padding_left,
  padding_right: section.settings.padding_right,
  padding_left_mobile: section.settings.padding_left_mobile,
  padding_right_mobile: section.settings.padding_right_mobile
%}

{%- if section.settings.show_section -%}
<section 
  class="timeline-section color-{{ section.settings.color_scheme }}{% if section.settings.enable_animation %} animate-on-scroll{% endif %}" 
  id="shopify-section-{{ section.id }}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    <div class="text-center mb-16">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'header' -%}
            {%- if block.settings.heading != blank -%}
              <h2 class="section-title" {{ block.shopify_attributes }}>{{ block.settings.heading | replace: '[', '<span class="highlight-text">' | replace: ']', '</span>' }}</h2>
            {%- endif -%}
          {%- when 'subtitle' -%}
            {%- if block.settings.subheading != blank -%}
              <p class="section-subtitle" {{ block.shopify_attributes }}>{{ block.settings.subheading }}</p>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <div class="timeline">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'timeline_event' -%}
            {%- assign highlight_span = '<span class="highlight-text">' -%}

            <div class="timeline-item block-{{ block.id }}{% if block.settings.layout == 'left' %} layout-left{% elsif block.settings.layout == 'right' %} layout-right{% endif %}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
              <div class="timeline-content">
                {%- if block.settings.show_title and block.settings.event_title != blank -%}
                  <h3>{{ block.settings.event_title | replace: '[', highlight_span | replace: ']', '</span>' }}</h3>
                {%- endif -%}
                {%- if block.settings.show_description and block.settings.event_description != blank -%}
                  <p>{{ block.settings.event_description | replace: '[', highlight_span | replace: ']', '</span>' }}</p>
                {%- endif -%}
                {%- if block.settings.show_link and block.settings.event_link != blank -%}
                  <a href="{{ block.settings.event_link }}" class="{% if block.settings.button_style == 'cta' %}cta-button{% elsif block.settings.button_style == 'secondary' %}hero-button secondary-button{% else %}timeline-cta link{% endif %}">
                    {{ block.settings.event_link_text | default: 'Read More' }}
                  </a>
                {%- endif -%}
              </div>
              {%- if block.settings.show_year -%}
              <div class="timeline-year-badge">
                {%- if block.settings.show_icon and block.settings.icon_select != 'none' -%}
                  {%- if block.settings.icon_select == 'custom' and block.settings.custom_icon_svg != blank -%}
                    <span class="timeline-custom-icon">{{ block.settings.custom_icon_svg }}</span>
                  {%- else -%}
                    {%- case block.settings.icon_select -%}
                      {%- when 'clock' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="12" r="10" />
                          <polyline points="12 6 12 12 16 14" />
                        </svg>
                      {%- when 'star' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                        </svg>
                      {%- when 'award' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="8" r="7" />
                          <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88" />
                        </svg>
                      {%- when 'briefcase' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <rect x="2" y="7" width="20" height="14" rx="2" ry="2" />
                          <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
                        </svg>
                      {%- when 'rocket' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M4.5 16.5c-1.5 1.25-2.5 3.5-2.5 3.5s2.25-1 3.5-2.5" />
                          <path d="M12 2C6.5 2 2 6.5 2 12c0 2.5 2 4.5 4.5 4.5S11 12 11 12s4.5 4.5 4.5 4.5 2-2 2-4.5C17.5 6.5 13 2 12 2z" />
                          <path d="M9 15l-3-3" />
                          <path d="M15 9l3 3" />
                        </svg>
                    {%- endcase -%}
                  {%- endif -%}
                {%- endif -%}
                {%- if block.settings.event_year != blank -%}
                  <span>{{ block.settings.event_year }}</span>
                {%- endif -%}
              </div>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "About Team Timeline",
  "tag": "section",
  "class": "section-about-team-timeline",
  "settings": [

    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1",
      "options": [
        {
          "value": "background-1",
          "label": "Background 1"
        },
        {
          "value": "background-2",
          "label": "Background 2"
        },
        {
          "value": "inverse",
          "label": "Inverse"
        },
        {
          "value": "accent-1",
          "label": "Accent 1"
        },
        {
          "value": "accent-2",
          "label": "Accent 2"
        }
      ]
    },
    {
      "type": "header",
      "content": "Vertical Line Divider"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Vertical Line Divider Color"
    },
    {
      "type": "color_background",
      "id": "line_gradient",
      "label": "Vertical Line Divider Gradient"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Left",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Right",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_left_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Left (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Right (Mobile)",
      "default": 20
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "standard",
      "options": [
        {
          "value": "full",
          "label": "Full width"
        },
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "narrow",
          "label": "Narrow"
        }
      ]
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable scroll animation",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "header",
      "name": "Header",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Our [Tech Hub]"
        }
      ]
    },
    {
      "type": "subtitle",
      "name": "Subtitle",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "subheading",
          "label": "Subheading",
          "default": "From a single workbench to a global digital storefront."
        }
      ]
    },
    {
      "type": "@app"
    },
    {
      "type": "timeline_event",
      "name": "Timeline Event",
      "settings": [
        {
          "type": "header",
          "content": "General Settings"
        },
        {
          "type": "text",
          "id": "event_year",
          "label": "Year",
          "default": "2019"
        },
        {
          "type": "text",
          "id": "event_title",
          "label": "Event title",
          "default": "The Spark"
        },
        {
          "type": "textarea",
          "id": "event_description",
          "label": "Event description",
          "default": "Founded by three tech enthusiasts with a simple goal: provide high-performance hardware that empowers creators and gamers everywhere."
        },
        {
          "type": "header",
          "content": "Icon & Marker"
        },
        {
          "type": "select",
          "id": "icon_select",
          "label": "Icon",
          "default": "clock",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "clock", "label": "Clock" },
            { "value": "star", "label": "Star" },
            { "value": "award", "label": "Award" },
            { "value": "briefcase", "label": "Briefcase" },
            { "value": "rocket", "label": "Rocket" },
            { "value": "custom", "label": "Custom SVG" }
          ]
        },
        {
          "type": "html",
          "id": "custom_icon_svg",
          "label": "Custom SVG Code",
          "info": "Used when Icon is set to 'Custom SVG'."
        },
        {
          "type": "header",
          "content": "Link / Call to Action"
        },
        {
