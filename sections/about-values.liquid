{{ 'section-about-values.css' | asset_url | stylesheet_tag }}

<style>
  /* Section Spacing / Visibility overrides */
  #shopify-section-{{ section.id }} .values-section {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .values-section {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Container Width overrides */
  #shopify-section-{{ section.id }} .container-fluid {
    max-width: 100% !important;
    padding-left: 2rem !important;
    padding-right: 2rem !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container-narrow {
    max-width: 800px !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container {
    max-width: {{ section.settings.max_width | default: 1340 }}px !important;
    margin: 0 auto !important;
  }

  /* Blocks Position align overrides */
  #shopify-section-{{ section.id }} .values-section .container,
  #shopify-section-{{ section.id }} .values-section .container-fluid,
  #shopify-section-{{ section.id }} .values-section .container-narrow {
    display: flex;
    flex-direction: column;
    {%- if section.settings.blocks_position == 'left' -%}
      align-items: flex-start !important;
      text-align: left !important;
    {%- elsif section.settings.blocks_position == 'right' -%}
      align-items: flex-end !important;
      text-align: right !important;
    {%- else -%}
      align-items: center !important;
      text-align: center !important;
    {%- endif -%}
  }

  /* Block Spacing overrides */
  #shopify-section-{{ section.id }} .section-title {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 20px) !important;
  }
  #shopify-section-{{ section.id }} .section-subtitle {
    margin-top: var(--sm-t, 0px) !important;
    margin-bottom: var(--sm-b, 28px) !important;
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .section-title {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 20px)) !important;
    }
    #shopify-section-{{ section.id }} .section-subtitle {
      margin-top: var(--sm-t-m, var(--sm-t, 0px)) !important;
      margin-bottom: var(--sm-b-m, var(--sm-b, 28px)) !important;
    }
  }

  /* Responsive Font Sizing */
  #shopify-section-{{ section.id }} .section-title.size-small { font-size: 2rem !important; }
  #shopify-section-{{ section.id }} .section-title.size-medium { font-size: 2.5rem !important; }
  #shopify-section-{{ section.id }} .section-title.size-large { font-size: 3rem !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .section-title.size-small { font-size: 1.6rem !important; }
    #shopify-section-{{ section.id }} .section-title.size-medium { font-size: 2rem !important; }
    #shopify-section-{{ section.id }} .section-title.size-large { font-size: 2.25rem !important; }
  }

  #shopify-section-{{ section.id }} .section-subtitle.size-small { font-size: 0.95rem !important; }
  #shopify-section-{{ section.id }} .section-subtitle.size-medium { font-size: 1.1rem !important; }
  #shopify-section-{{ section.id }} .section-subtitle.size-large { font-size: 1.25rem !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .section-subtitle.size-small { font-size: 0.85rem !important; }
    #shopify-section-{{ section.id }} .section-subtitle.size-medium { font-size: 0.95rem !important; }
    #shopify-section-{{ section.id }} .section-subtitle.size-large { font-size: 1.1rem !important; }
  }

  /* value block overrides */
  {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subtitle'
        assign b_align_alignment = ''
      when 'value'
        assign b_align_alignment = 'left'
  endcase
-%}
    {%- if block.type == 'value' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }} {
        text-align: {{ b_align_alignment | default: 'left' }} !important;
        {%- if b_align_alignment == 'right' -%}
          align-items: flex-end !important;
        {%- elsif b_align_alignment == 'center' -%}
          align-items: center !important;
        {%- else -%}
          align-items: flex-start !important;
        {%- endif -%}
        margin-top: {{ block.settings.margin_top | default: 20 }}px !important;
        margin-bottom: {{ block.settings.margin_bottom | default: 20 }}px !important;
        {%- if block.settings.bg_gradient != blank -%}
          background: {{ block.settings.bg_gradient }} !important;
        {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
          background-color: {{ block.settings.bg_color }} !important;
        {%- endif -%}
        {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
          border: 1px solid {{ block.settings.border_color }} !important;
        {%- endif -%}
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} .value-icon {
        {%- if block.settings.icon_bg_gradient != blank -%}
          background: {{ block.settings.icon_bg_gradient }} !important;
        {%- elsif block.settings.icon_bg_color != blank and block.settings.icon_bg_color != 'rgba(0,0,0,0)' -%}
          background-color: {{ block.settings.icon_bg_color }} !important;
        {%- endif -%}
        {%- if block.settings.icon_color != blank and block.settings.icon_color != 'rgba(0,0,0,0)' -%}
          color: {{ block.settings.icon_color }} !important;
        {%- endif -%}
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} .card-title {
        text-align: {{ b_align_alignment | default: 'left' }} !important;
        width: 100% !important;
        font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %} !important;
        font-style: {{ block.settings.font_style | default: 'normal' }} !important;
        text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
        letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
        line-height: {{ block.settings.line_height | default: 120 }}% !important;
        {%- if block.settings.title_color != blank and block.settings.title_color != 'rgba(0,0,0,0)' -%}
          color: {{ block.settings.title_color }} !important;
        {%- endif -%}
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} p {
        text-align: {{ b_align_alignment | default: 'left' }} !important;
        width: 100% !important;
        font-weight: {% if block.settings.desc_font_weight == 'bold' %}700{% else %}400{% endif %} !important;
        font-style: {{ block.settings.desc_font_style | default: 'normal' }} !important;
        line-height: {{ block.settings.desc_line_height | default: 160 }}% !important;
        letter-spacing: {{ block.settings.desc_letter_spacing | default: 0 }}px !important;
        {%- if block.settings.desc_color != blank and block.settings.desc_color != 'rgba(0,0,0,0)' -%}
          color: {{ block.settings.desc_color }} !important;
        {%- endif -%}
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} .card-title.size-small { font-size: 1.1rem !important; }
      #shopify-section-{{ section.id }} .block-{{ block.id }} .card-title.size-medium { font-size: 1.25rem !important; }
      #shopify-section-{{ section.id }} .block-{{ block.id }} .card-title.size-large { font-size: 1.5rem !important; }
      #shopify-section-{{ section.id }} .block-{{ block.id }} p.size-small { font-size: 0.85rem !important; }
      #shopify-section-{{ section.id }} .block-{{ block.id }} p.size-medium { font-size: 0.95rem !important; }
      #shopify-section-{{ section.id }} .block-{{ block.id }} p.size-large { font-size: 1.1rem !important; }
      @media screen and (max-width: 768px) {
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top_mobile | default: 16 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom_mobile | default: 16 }}px !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .card-title.size-small { font-size: 1rem !important; }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .card-title.size-medium { font-size: 1.15rem !important; }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .card-title.size-large { font-size: 1.3rem !important; }
        #shopify-section-{{ section.id }} .block-{{ block.id }} p.size-small { font-size: 0.8rem !important; }
        #shopify-section-{{ section.id }} .block-{{ block.id }} p.size-medium { font-size: 0.85rem !important; }
        #shopify-section-{{ section.id }} .block-{{ block.id }} p.size-large { font-size: 1rem !important; }
      }
    {%- endif -%}
  {%- endfor -%}
</style>

{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile,
  padding_left: 20,
  padding_right: 20,
  padding_left_mobile: 15,
  padding_right_mobile: 15
%}

{%- if section.settings.show_section -%}
<section 
  class="values-section color-{{ section.settings.color_scheme }}{% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
  id="AboutValues-{{ section.id }}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subtitle'
        assign b_align_alignment = ''
      when 'value'
        assign b_align_alignment = 'left'
  endcase
-%}
      {%- case block.type -%}
        {%- when 'header' -%}
          {%- if block.settings.heading != blank -%}
            {%- assign heading_tag = block.settings.heading_tag | default: 'h2' -%}
            {%- assign h_color = block.settings.highlight_color -%}
            {%- assign h_gradient = block.settings.highlight_gradient -%}
            {%- assign head_text_align = b_align_alignment -%}
            {%- if head_text_align == blank -%}
              {%- if section.settings.blocks_position == 'left' -%}
                {%- assign head_text_align = 'left' -%}
              {%- elsif section.settings.blocks_position == 'right' -%}
                {%- assign head_text_align = 'right' -%}
              {%- else -%}
                {%- assign head_text_align = 'center' -%}
              {%- endif -%}
            {%- endif -%}
            
            <{{ heading_tag }} 
              class="section-title size-{{ block.settings.font_size | default: 'medium' }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
              {{ block.shopify_attributes }}
              style="
                --m-t: {{ block.settings.margin_top | default: 0 }}px;
                --m-b: {{ block.settings.margin_bottom | default: 20 }}px;
                --m-t-m: {{ block.settings.margin_top_mobile | default: 0 }}px;
                --m-b-m: {{ block.settings.margin_bottom_mobile | default: 16 }}px;
                font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                font-style: {{ block.settings.font_style | default: 'normal' }};
                text-transform: {{ block.settings.text_transform | default: 'none' }};
                letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                line-height: {{ block.settings.line_height | default: 120 }}%;
                text-align: {{ head_text_align }};
                width: 100% !important;
                max-width: {{ block.settings.max_width | default: 800 }}px !important;
                {%- if section.settings.blocks_position == 'left' -%}
                  margin-left: 0 !important;
                  margin-right: auto !important;
                {%- elsif section.settings.blocks_position == 'right' -%}
                  margin-left: auto !important;
                  margin-right: 0 !important;
                {%- else -%}
                  margin-left: auto !important;
                  margin-right: auto !important;
                {%- endif -%}
                {% if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.text_color }} !important;{% endif %}
                {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' %}background: {{ block.settings.bg_color }} !important;{% endif %}
              "
            >
              {%- if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' -%}
                {%- assign highlight_span = '<span class="highlight-text" style="background: ' | append: h_gradient | append: '; -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">' -%}
              {%- elsif h_color != blank and h_color != 'rgba(0,0,0,0)' -%}
                {%- assign highlight_span = '<span class="highlight-text" style="color: ' | append: h_color | append: ';">' -%}
              {%- else -%}
                {%- assign highlight_span = '<span class="highlight-text">' -%}
              {%- endif -%}
              {{ block.settings.heading | replace: '[', highlight_span | replace: ']', '</span>' }}
            </{{ heading_tag }}>
          {%- endif -%}

        {%- when 'subtitle' -%}
          {%- if block.settings.subheading != blank -%}
            {%- assign subheading_tag = block.settings.subheading_tag | default: 'p' -%}
            {%- assign sub_text_align = b_align_alignment -%}
            {%- if sub_text_align == blank -%}
              {%- if section.settings.blocks_position == 'left' -%}
                {%- assign sub_text_align = 'left' -%}
              {%- elsif section.settings.blocks_position == 'right' -%}
                {%- assign sub_text_align = 'right' -%}
              {%- else -%}
                {%- assign sub_text_align = 'center' -%}
              {%- endif -%}
            {%- endif -%}

            <{{ subheading_tag }} 
              class="section-subtitle size-{{ block.settings.font_size | default: 'medium' }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
              {{ block.shopify_attributes }}
              style="
                --sm-t: {{ block.settings.margin_top | default: 0 }}px;
                --sm-b: {{ block.settings.margin_bottom | default: 28 }}px;
                --sm-t-m: {{ block.settings.margin_top_mobile | default: 0 }}px;
                --sm-b-m: {{ block.settings.margin_bottom_mobile | default: 20 }}px;
                font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                font-style: {{ block.settings.font_style | default: 'normal' }};
                text-transform: {{ block.settings.text_transform | default: 'none' }};
                letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                line-height: {{ block.settings.line_height | default: 160 }}%;
                text-align: {{ sub_text_align }};
                width: 100% !important;
                max-width: {{ block.settings.max_width | default: 800 }}px !important;
                {%- if section.settings.blocks_position == 'left' -%}
                  margin-left: 0 !important;
                  margin-right: auto !important;
                {%- elsif section.settings.blocks_position == 'right' -%}
                  margin-left: auto !important;
                  margin-right: 0 !important;
                {%- else -%}
                  margin-left: auto !important;
                  margin-right: auto !important;
                {%- endif -%}
                {% if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.text_color }} !important;{% endif %}
                {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' %}background: {{ block.settings.bg_color }} !important;{% endif %}
              "
            >
              {{ block.settings.subheading }}
            </{{ subheading_tag }}>
          {%- endif -%}
      {%- endcase -%}
    {%- endfor -%}

    <div class="values-grid" style="grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr); width: 100%;">
      {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subtitle'
        assign b_align_alignment = ''
      when 'value'
        assign b_align_alignment = 'left'
  endcase
-%}
        {%- case block.type -%}
          {%- when 'value' -%}
            <div class="value-card block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
              {%- if block.settings.custom_icon_svg != blank or block.settings.icon != blank -%}
                <div class="value-icon" style="--icon-size: {{ section.settings.icon_size }}px;">
                  {%- if block.settings.custom_icon_svg != blank -%}
                    {{ block.settings.custom_icon_svg }}
                  {%- else -%}
                    {%- case block.settings.icon -%}
                      {%- when 'laptop' -%}{% render 'icon-laptop' %}
                      {%- when 'phone' -%}{% render 'icon-phone' %}
                      {%- when 'headphones' -%}{% render 'icon-headphones' %}
                      {%- when 'tools' -%}{% render 'icon-tools' %}
                      {%- when 'gamepad' -%}{% render 'icon-gamepad' %}
                      {%- when 'watch' -%}{% render 'icon-watch' %}
                      {%- when 'shipping' -%}{% render 'icon-shipping' %}
                      {%- when 'support' -%}{% render 'icon-support' %}
                      {%- when 'secure' -%}{% render 'icon-secure' %}
                      {%- when 'returns' -%}{% render 'icon-returns' %}
                      {%- when 'check' -%}{% render 'icon-check' %}
                      {%- when 'heart' -%}{% render 'icon-heart' %}
                      {%- when 'star' -%}{% render 'icon-star' %}
                      {%- when 'award' -%}
                        <svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='8' r='7' /><polyline points='8.21 13.89 7 23 12 20 17 23 15.79 13.88' /></svg>
                      {%- when 'users' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                      {%- when 'globe' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                      {%- when 'target' -%}
                        <svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='10' /><circle cx='12' cy='12' r='6' /><circle cx='12' cy='12' r='2' /></svg>
                      {%- when 'zap' -%}
                        <svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polygon points='13 2 3 14 12 14 11 22 21 10 12 10 13 2' /></svg>
                    {%- endcase -%}
                  {%- endif -%}
                </div>
              {%- endif -%}
              
              {%- if block.settings.title != blank -%}
                <h3 class="card-title size-{{ block.settings.font_size | default: 'medium' }}">{{ block.settings.title }}</h3>
              {%- endif -%}
              
              {%- if block.settings.description != blank -%}
                <p class="size-{{ block.settings.desc_font_size | default: 'medium' }}">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "About Values",
  "tag": "section",
  "class": "section-about-values",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "blocks_position",
      "label": "Blocks Position",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "default": "2",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ]
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "standard",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "standard", "label": "Standard" },
        { "value": "narrow", "label": "Narrow" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 24,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Icon size",
      "default": 48
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1",
      "options": [
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "inverse", "label": "Inverse" },
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" }
      ]
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 100
    },
