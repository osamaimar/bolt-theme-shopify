        {%- endif -%}
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} h3 {
        font-size: {% if block.settings.font_size == 'small' %}1.3rem{% elsif block.settings.font_size == 'large' %}1.9rem{% else %}1.6rem{% endif %} !important;
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} h4 {
        font-size: {% if block.settings.font_size == 'small' %}1.1rem{% elsif block.settings.font_size == 'large' %}1.5rem{% else %}1.3rem{% endif %} !important;
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} h5 {
        font-size: {% if block.settings.font_size == 'small' %}0.95rem{% elsif block.settings.font_size == 'large' %}1.3rem{% else %}1.1rem{% endif %} !important;
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} h6 {
        font-size: {% if block.settings.font_size == 'small' %}0.85rem{% elsif block.settings.font_size == 'large' %}1.15rem{% else %}1rem{% endif %} !important;
      }

      /* Links Styling overrides */
      #shopify-section-{{ section.id }} .block-{{ block.id }} a {
        {%- if block.settings.link_color != blank and block.settings.link_color != 'rgba(0,0,0,0)' -%}
          color: {{ block.settings.link_color }} !important;
        {%- endif -%}
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} a:hover {
        {%- if block.settings.link_hover_color != blank and block.settings.link_hover_color != 'rgba(0,0,0,0)' -%}
          color: {{ block.settings.link_hover_color }} !important;
        {%- endif -%}
      }

      /* Unordered Bullet & Ordered Marker Color overrides */
      #shopify-section-{{ section.id }} .block-{{ block.id }} ul li::before {
        {%- if block.settings.list_marker_color != blank and block.settings.list_marker_color != 'rgba(0,0,0,0)' -%}
          background-color: {{ block.settings.list_marker_color }} !important;
        {%- endif -%}
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} ol li::before {
        {%- if block.settings.list_marker_color != blank and block.settings.list_marker_color != 'rgba(0,0,0,0)' -%}
          color: {{ block.settings.list_marker_color }} !important;
        {%- endif -%}
      }

      /* Blockquote Colors overrides */
      #shopify-section-{{ section.id }} .block-{{ block.id }} blockquote {
        {%- if block.settings.blockquote_bg_color != blank and block.settings.blockquote_bg_color != 'rgba(0,0,0,0)' -%}
          background-color: {{ block.settings.blockquote_bg_color }} !important;
          background: {{ block.settings.blockquote_bg_color }} !important;
        {%- endif -%}
        {%- if block.settings.blockquote_border_color != blank and block.settings.blockquote_border_color != 'rgba(0,0,0,0)' -%}
          border-inline-start-color: {{ block.settings.blockquote_border_color }} !important;
        {%- endif -%}
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} blockquote p,
      #shopify-section-{{ section.id }} .block-{{ block.id }} blockquote cite {
        {%- if block.settings.blockquote_text_color != blank and block.settings.blockquote_text_color != 'rgba(0,0,0,0)' -%}
          color: {{ block.settings.blockquote_text_color }} !important;
        {%- endif -%}
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} blockquote::before {
        {%- if block.settings.blockquote_border_color != blank and block.settings.blockquote_border_color != 'rgba(0,0,0,0)' -%}
          color: {{ block.settings.blockquote_border_color }} !important;
          opacity: 0.25 !important;
        {%- endif -%}
      }

      /* Code Blocks & inline code overrides */
      #shopify-section-{{ section.id }} .block-{{ block.id }} pre,
      #shopify-section-{{ section.id }} .block-{{ block.id }} code {
        {%- if block.settings.code_text_color != blank and block.settings.code_text_color != 'rgba(0,0,0,0)' -%}
          color: {{ block.settings.code_text_color }} !important;
        {%- endif -%}
        {%- if block.settings.code_bg_color != blank and block.settings.code_bg_color != 'rgba(0,0,0,0)' -%}
          background-color: {{ block.settings.code_bg_color }} !important;
          background: {{ block.settings.code_bg_color }} !important;
        {%- endif -%}
      }

      /* Tables overrides */
      #shopify-section-{{ section.id }} .block-{{ block.id }} table th {
        {%- if block.settings.table_header_text_color != blank and block.settings.table_header_text_color != 'rgba(0,0,0,0)' -%}
          color: {{ block.settings.table_header_text_color }} !important;
        {%- endif -%}
        {%- if block.settings.table_header_bg_color != blank and block.settings.table_header_bg_color != 'rgba(0,0,0,0)' -%}
          background-color: {{ block.settings.table_header_bg_color }} !important;
          background: {{ block.settings.table_header_bg_color }} !important;
        {%- endif -%}
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} table,
      #shopify-section-{{ section.id }} .block-{{ block.id }} table td,
      #shopify-section-{{ section.id }} .block-{{ block.id }} table th {
        {%- if block.settings.table_border_color != blank and block.settings.table_border_color != 'rgba(0,0,0,0)' -%}
          border-color: {{ block.settings.table_border_color }} !important;
        {%- endif -%}
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} table tr:nth-child(even) {
        {%- if block.settings.table_row_striping_color != blank and block.settings.table_row_striping_color != 'rgba(0,0,0,0)' -%}
          background-color: {{ block.settings.table_row_striping_color }} !important;
        {%- endif -%}
      }

      /* Dividers overrides */
      #shopify-section-{{ section.id }} .block-{{ block.id }} hr {
        {%- if block.settings.divider_color != blank and block.settings.divider_color != 'rgba(0,0,0,0)' -%}
          border-color: {{ block.settings.divider_color }} !important;
          background-color: {{ block.settings.divider_color }} !important;
        {%- endif -%}
      }
    {%- endif -%}
  {%- endfor -%}
</style>

{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

{%- if section.settings.show_section -%}

{%- if request.page_type == 'article' -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": {{ article.title | json }},
    "datePublished": {{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' | json }},
    "dateModified": {{ article.updated_at | default: article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' | json }},
    "description": {{ article.excerpt_or_content | strip_html | truncatewords: 30 | json }},
    {%- if article.image -%}
      "image": [
        {{ article.image | image_url: width: 1200 | prepend: "https:" | json }}
      ],
    {%- endif -%}
    "author": {
      "@type": "Person",
      "name": {{ article.author | json }}
    },
    "publisher": {
      "@type": "Organization",
      "name": {{ shop.name | json }},
      "logo": {
        "@type": "ImageObject",
        {%- if settings.logo_ltr != blank -%}
          "url": {{ settings.logo_ltr | image_url: width: 200 | prepend: "https:" | json }}
        {%- else -%}
          "url": {{ page_image | image_url: width: 200 | prepend: "https:" | json }}
        {%- endif -%}
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": {{ canonical_url | json }}
    }
  }
</script>
{%- endif -%}

{%- comment -%}Reading Progress Bar{%- endcomment -%}
{%- if section.settings.show_reading_progress -%}
<div class="blog-post-progress-bar section-padding-exclude" id="blog-post-progress-{{ section.id }}"></div>
{%- endif -%}

<section 
  class="article-main-section color-{{ section.settings.color_scheme }}{% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    
    <div class="blog-main-container">
      
      {%- comment -%}Blocks{%- endcomment -%}
      {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'breadcrumb'
        assign b_align_alignment = 'left'
      when 'post_header'
        assign b_align_alignment = 'left'
      when 'featured_image'
        assign b_align_alignment = 'center'
      when 'tags'
        assign b_align_alignment = 'left'
      when 'author_card'
        assign b_align_alignment = 'left'
      when 'post_navigation'
        assign b_align_alignment = 'space-between'
  endcase
-%}
        {%- case block.type -%}
          
          {%- when 'breadcrumb' -%}
            <nav class="blog-post-breadcrumb block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" aria-label="Breadcrumb" {{ block.shopify_attributes }}>
              {%- if block.settings.show_home_link -%}
                <a href="{{ routes.root_url }}">{{ 'general.home' | t }}</a>
                {%- if block.settings.show_separator -%}
                  <span class="blog-post-breadcrumb-separator">/</span>
                {%- endif -%}
              {%- endif -%}
              {%- assign blog_title_val = blog.title | default: 'Blog' -%}{%- assign temp_key = 'custom_labels.' | append: blog_title_val | handleize -%}{%- assign temp_trans = temp_key | t -%}{%- unless temp_trans contains 'translation' or temp_trans contains 'Translation' -%}{%- assign blog_title_val = temp_trans -%}{%- endunless -%}
              <a href="{{ blog.url }}">{{ blog_title_val }}</a>
              {%- if block.settings.show_separator -%}
                <span class="blog-post-breadcrumb-separator">/</span>
              {%- endif -%}
              <span class="blog-post-breadcrumb-current" aria-current="page">{{ article.title }}</span>
            </nav>
          
          {%- when 'post_header' -%}
            <header class="blog-post-header block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
              {%- if block.settings.show_category and article.tags.size > 0 -%}
              <span class="blog-post-category">{{ article.tags.first }}</span>
              {%- endif -%}

              <h1 class="blog-post-title title-size-large title-align-{{ b_align_alignment | default: 'left' }}">{{ article.title | replace: '[', '<span>' | replace: ']', '</span>' }}</h1>

              <div class="blog-post-meta">
                {%- if block.settings.show_author -%}
                <div class="blog-post-author-info">
                  {%- if block.settings.show_author_avatar -%}
                  <div class="blog-author-avatar">
                    {%- if block.settings.author_image != blank -%}
                      {{ block.settings.author_image | image_url: width: 88 | image_tag: loading: 'lazy', alt: article.author }}
                    {%- else -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                      </svg>
                    {%- endif -%}
                  </div>
                  {%- endif -%}
                  <div class="blog-post-author-details">
                    {%- if block.settings.show_author_name -%}
                    <span class="blog-author-name">{{ article.author }}</span>
                    {%- endif -%}
                    {%- if block.settings.show_author_role and block.settings.author_role != blank -%}
                    <span class="blog-post-author-role">{{ block.settings.author_role }}</span>
                    {%- endif -%}
                  </div>
                </div>
                {%- endif -%}

                {%- if block.settings.show_meta_dividers and block.settings.show_author and block.settings.show_date -%}
                <div class="blog-post-meta-divider"></div>
                {%- endif -%}

                {%- if block.settings.show_date -%}
                <span class="blog-meta-item">
                  {%- if block.settings.show_date_icon -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                  </svg>
                  {%- endif -%}
                  {%- case block.settings.date_format -%}
                    {%- when 'short' -%}<span>{{ article.published_at | date: '%b %d, %Y' }}</span>
                    {%- when 'medium' -%}<span>{{ article.published_at | date: '%B %d, %Y' }}</span>
                    {%- when 'long' -%}<span>{{ article.published_at | date: '%A, %B %d, %Y' }}</span>
                    {%- when 'iso' -%}<span>{{ article.published_at | date: '%Y-%m-%d' }}</span>
                  {%- endcase -%}
                </span>
                {%- endif -%}

                {%- if block.settings.show_read_time -%}
                <span class="blog-meta-item">
                  {%- if block.settings.show_read_time_icon -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                  </svg>
                  {%- endif -%}
                  {%- assign am_read_time = article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 -%}
                  <span>{{ 'blogs.article.read_time' | t: count: am_read_time }}</span>
                </span>
                {%- endif -%}
              </div>
            </header>
          
            {%- when 'featured_image' -%}
              {%- assign image_to_show = block.settings.story_image | default: article.image -%}
              {%- if image_to_show -%}
              <div class="blog-post-featured-image-wrapper block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
                <div class="blog-post-featured-image">
                  <div class="blog-post-featured-image-inner">
                    {{ image_to_show | image_url: width: 1200 | image_tag: loading: 'eager', alt: image_to_show.alt, class: 'blog-post-hero-image' }}
                  </div>
                </div>
              </div>
              {%- endif -%}
          
          {%- when 'article_body' -%}
            <article class="blog-post-body rte block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" id="blog-post-body-{{ block.id }}" {{ block.shopify_attributes }}>
              {{ article.content }}
            </article>
          
          {%- when 'tags' -%}
            {%- if article.tags.size > 0 -%}
            <div class="blog-post-tags block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
              {%- for tag in article.tags -%}
                <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="blog-post-tag"># {{ tag }}</a>
              {%- endfor -%}
            </div>
            {%- endif -%}
          
          {%- when 'share' -%}
            {%- if block.settings.show_share -%}
            <div class="blog-post-share block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
              <span class="blog-post-share-label">{{ 'blog.share_this_article' | t | default: 'Share this article:' }}</span>
              <div class="blog-post-share-links">
                {%- if block.settings.share_facebook -%}
                <a href="https://www.facebook.com/sharer/sharer.php?u={{ article.url | url_encode }}" class="blog-post-share-link" target="_blank" rel="noopener" title="Share on Facebook">
                  {% render 'icon-facebook' %}
                </a>
                {%- endif -%}
                {%- if block.settings.share_twitter -%}
                <a href="https://twitter.com/intent/tweet?url={{ article.url | url_encode }}&text={{ article.title | url_encode }}" class="blog-post-share-link" target="_blank" rel="noopener" title="Share on X">
                  {% render 'icon-twitter' %}
                </a>
                {%- endif -%}
                {%- if block.settings.share_linkedin -%}
                <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ article.url | url_encode }}" class="blog-post-share-link" target="_blank" rel="noopener" title="Share on LinkedIn">
                  {% render 'icon-linkedin' %}
                </a>
                {%- endif -%}
                 {%- if block.settings.share_pinterest -%}
                 <a href="https://pinterest.com/pin/create/button/?url={{ article.url | url_encode }}&media={{ article.image | image_url: width: 800 | url_encode }}&description={{ article.title | url_encode }}" class="blog-post-share-link" target="_blank" rel="noopener" title="Share on Pinterest">
                   {% render 'icon-pinterest' %}
                 </a>
                 {%- endif -%}
                 {%- if block.settings.share_whatsapp -%}
                 <a href="https://api.whatsapp.com/send?text={{ article.title | url_encode }}%20{{ article.url | url_encode }}" class="blog-post-share-link" target="_blank" rel="noopener" title="Share on WhatsApp">
                   {% render 'icon-whatsapp' %}
                 </a>
                 {%- endif -%}
                {%- if block.settings.share_reddit -%}
                <a href="https://reddit.com/submit?url={{ article.url | url_encode }}&title={{ article.title | url_encode }}" class="blog-post-share-link" target="_blank" rel="noopener" title="Share on Reddit">
                  {% render 'icon-reddit' %}
                </a>
                {%- endif -%}
                {%- if block.settings.share_telegram -%}
                <a href="https://telegram.me/share/url?url={{ article.url | url_encode }}&text={{ article.title | url_encode }}" class="blog-post-share-link" target="_blank" rel="noopener" title="Share on Telegram">
                  {% render 'icon-telegram' %}
                </a>
                {%- endif -%}
                {%- if block.settings.share_email -%}
                <a href="mailto:?subject={{ article.title | url_encode }}&body={{ article.url | url_encode }}" class="blog-post-share-link" title="Share via Email">
                  {% render 'icon-mail' %}
                </a>
                {%- endif -%}
                {%- if block.settings.share_copy -%}
                <button class="blog-post-share-link js-copy-link" data-url="{{ article.url }}" title="Copy Link">
                  {% render 'icon-link' %}
                </button>
                {%- endif -%}
              </div>
            </div>
            {%- endif -%}
          
          {%- when 'author_card' -%}
            {%- if block.settings.show_author_card -%}
            <div class="blog-post-author-card style-{{ block.settings.author_card_style }} block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
              {%- if block.settings.show_avatar -%}
              <div class="blog-author-avatar">
                {%- if block.settings.author_image != blank -%}
                  {{ block.settings.author_image | image_url: width: 144 | image_tag: loading: 'lazy', alt: article.author }}
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                  </svg>
                {%- endif -%}
              </div>
              {%- endif -%}
              <div class="blog-post-author-card-info">
                {%- if block.settings.show_label -%}
                <span class="blog-post-author-card-label">{{ 'blog.written_by' | t | default: 'Written by' }}</span>
                {%- endif -%}
                <h3 class="blog-post-author-card-name">{{ article.author }}</h3>
                {%- if block.settings.show_bio and block.settings.author_bio != blank -%}
                <p class="blog-post-author-card-bio">{{ block.settings.author_bio }}</p>
                {%- endif -%}
              </div>
            </div>
            {%- endif -%}
          
          {%- when 'post_navigation' -%}
            {%- if block.settings.show_post_navigation -%}
            <nav class="blog-post-navigation block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" aria-label="Post navigation" {{ block.shopify_attributes }}>
              {%- if blog.previous_article -%}
              <a href="{{ blog.previous_article.url }}" class="blog-post-nav-link">
                {%- if block.settings.show_nav_labels -%}
                <span class="blog-post-nav-label">
                  {%- if block.settings.show_nav_icons -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="15 18 9 12 15 6" />
                  </svg>
                  {%- endif -%}
                  {{ 'blog.previous_article' | t | default: 'Previous Article' }}
                </span>
                {%- endif -%}
                {%- if block.settings.show_nav_titles -%}
                <span class="blog-post-nav-title">{{ blog.previous_article.title }}</span>
                {%- endif -%}
              </a>
              {%- else -%}
              <div></div>
              {%- endif -%}
              
              {%- if blog.next_article -%}
              <a href="{{ blog.next_article.url }}" class="blog-post-nav-link blog-post-nav-link--next">
                {%- if block.settings.show_nav_labels -%}
                <span class="blog-post-nav-label">
                  {{ 'blog.next_article' | t | default: 'Next Article' }}
                  {%- if block.settings.show_nav_icons -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="9 18 15 12 9 6" />
                  </svg>
                  {%- endif -%}
                </span>
                {%- endif -%}
                {%- if block.settings.show_nav_titles -%}
                <span class="blog-post-nav-title">{{ blog.next_article.title }}</span>
                {%- endif -%}
              </a>
              {%- endif -%}
            </nav>
            {%- endif -%}

          {%- when 'article_comments' -%}
            {% render 'article-comments-block', block: block %}

          {%- when 'article_comment_form' -%}
            {% render 'article-comment-form-block', block: block %}
          
        {%- endcase -%}
      {%- endfor -%}

    </div>
  </div>
</section>

{%- if section.settings.show_reading_progress -%}
<script>
(function() {
  var progressBar = document.getElementById('blog-post-progress-{{ section.id }}');
  if (progressBar) {
    window.addEventListener('scroll', function() {
      var scrollTop = window.pageYOffset;
      var docHeight = document.documentElement.scrollHeight - window.innerHeight;
      var progress = Math.min((scrollTop / docHeight) * 100, 100);
      progressBar.style.width = progress + '%';
    });
  }
})();
</script>
{%- endif -%}

{%- if section.settings.show_share -%}
<script>
(function() {
  var copyButtons = document.querySelectorAll('#shopify-section-{{ section.id }} .js-copy-link');
  copyButtons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var url = this.getAttribute('data-url');
      if (navigator.clipboard) {
        navigator.clipboard.writeText(url).then(function() {
          alert('{{ "general.share_link_copied" | t | default: "Link copied to clipboard!" }}');
        });
      }
    });
  });
})();
</script>
{%- endif -%}

{%- endif -%}

{% schema %}
{
