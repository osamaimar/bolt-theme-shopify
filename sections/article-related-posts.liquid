{{ 'section-article-related.css' | asset_url | stylesheet_tag }}

<style>
  /* Section Spacing / Visibility overrides */
  #shopify-section-{{ section.id }} .article-related-section {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .article-related-section {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Container Width overrides */
  #shopify-section-{{ section.id }} .container-fluid {
    max-width: 100% !important;
    padding-left: var(--spacing-lg, 24px) !important;
    padding-right: var(--spacing-lg, 24px) !important;
  }
  #shopify-section-{{ section.id }} .container-narrow {
    max-width: 800px !important;
    padding-left: var(--spacing-lg, 24px) !important;
    padding-right: var(--spacing-lg, 24px) !important;
    margin-left: auto !important;
    margin-right: auto !important;
  }
  #shopify-section-{{ section.id }} .container {
    max-width: {{ section.settings.max_width | default: 1200 }}px !important;
    padding-left: var(--spacing-lg, 24px) !important;
    padding-right: var(--spacing-lg, 24px) !important;
    margin-left: auto !important;
    margin-right: auto !important;
  }

  /* Blocks Position overrides */
  #shopify-section-{{ section.id }} .container,
  #shopify-section-{{ section.id }} .container-fluid,
  #shopify-section-{{ section.id }} .container-narrow {
    display: flex;
    flex-direction: column;
    align-items: {% if section.settings.blocks_position == 'left' %}flex-start{% elsif section.settings.blocks_position == 'right' %}flex-end{% else %}center{% endif %} !important;
  }

  /* Title Highlight styling */
  #shopify-section-{{ section.id }} .blog-post-related-title span {
    background: var(--highlight-gradient, var(--color-accent)) !important;
    -webkit-background-clip: var(--highlight-clip, text) !important;
    background-clip: var(--highlight-clip, text) !important;
    -webkit-text-fill-color: var(--highlight-fill, transparent) !important;
    display: inline-block;
    color: var(--highlight-color, inherit) !important;
  }

  {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'heading'
        assign b_align_alignment = 'center'
      when 'subheading'
        assign b_align_alignment = 'center'
      when 'article_list'
        assign b_align_alignment = 'left'
  endcase
-%}
    /* Spacing overrides */
    #shopify-section-{{ section.id }} .block-{{ block.id }} {
      margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
      margin-bottom: {{ block.settings.margin_bottom | default: 0 }}px !important;
    }
    @media screen and (max-width: 768px) {
      #shopify-section-{{ section.id }} .block-{{ block.id }} {
        margin-top: {{ block.settings.margin_top_mobile | default: block.settings.margin_top | default: 0 }}px !important;
        margin-bottom: {{ block.settings.margin_bottom_mobile | default: block.settings.margin_bottom | default: 0 }}px !important;
      }
    }

    {%- if b_align_alignment != blank and block.type != 'article_list' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }} {
        text-align: {{ b_align_alignment }} !important;
      }
    {%- endif -%}

    /* Visibility overrides */
    @media screen and (min-width: 769px) {
      #shopify-section-{{ section.id }} .block-{{ block.id }}.hidden-desktop,
      #shopify-section-{{ section.id }} .block-{{ block.id }}.related-posts-grid.hidden-desktop {
        display: none !important;
      }
    }
    @media screen and (max-width: 768px) {
      #shopify-section-{{ section.id }} .block-{{ block.id }}.hidden-mobile,
      #shopify-section-{{ section.id }} .block-{{ block.id }}.related-posts-grid.hidden-mobile {
        display: none !important;
      }
    }

    /* Apply typography & colors dynamically to each block */
    #shopify-section-{{ section.id }} .block-{{ block.id }} {
      {%- if block.settings.font_size != blank -%}
        font-size: {% if block.settings.font_size == 'small' %}0.85rem{% elsif block.settings.font_size == 'large' %}1.25rem{% else %}1rem{% endif %} !important;
      {%- endif -%}
      {%- if block.settings.font_weight != blank -%}
        font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %} !important;
      {%- endif -%}
      {%- if block.settings.font_style != blank -%}
        font-style: {{ block.settings.font_style }} !important;
      {%- endif -%}
      {%- if block.settings.text_transform != blank -%}
        text-transform: {{ block.settings.text_transform }} !important;
      {%- endif -%}
      {%- if block.settings.letter_spacing != blank -%}
        letter-spacing: {{ block.settings.letter_spacing }}px !important;
      {%- endif -%}
      {%- if block.settings.line_height != blank -%}
        line-height: {{ block.settings.line_height }}% !important;
      {%- endif -%}
      {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
        color: {{ block.settings.text_color }} !important;
      {%- endif -%}
      {%- if block.settings.bg_gradient != blank and block.settings.bg_gradient != 'rgba(0,0,0,0)' -%}
        background: {{ block.settings.bg_gradient }} !important;
      {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
        background-color: {{ block.settings.bg_color }} !important;
      {%- endif -%}
    }

    {%- if block.type == 'heading' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-post-related-title {
        font-size: {% if block.settings.font_size == 'small' %}1.5rem{% elsif block.settings.font_size == 'large' %}2.2rem{% else %}1.8rem{% endif %} !important;
        width: 100% !important;
      }
      {%- if block.settings.highlight_gradient != blank and block.settings.highlight_gradient != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-post-related-title span {
          background: {{ block.settings.highlight_gradient }} !important;
          -webkit-background-clip: text !important;
          background-clip: text !important;
          -webkit-text-fill-color: transparent !important;
          color: transparent !important;
        }
      {%- elsif block.settings.highlight_color != blank and block.settings.highlight_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-post-related-title span {
          color: {{ block.settings.highlight_color }} !important;
          -webkit-text-fill-color: {{ block.settings.highlight_color }} !important;
          background: none !important;
        }
      {%- endif -%}
    {%- endif -%}

    {%- if block.type == 'subheading' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-post-related-subtitle {
        max-width: {{ block.settings.max_width | default: 500 }}px !important;
        width: 100% !important;
      }
    {%- endif -%}

    {%- if block.type == 'article_list' -%}
      /* Grid columns & gap settings */
      #shopify-section-{{ section.id }} .block-{{ block.id }}.related-posts-grid {
        display: flex !important;
        flex-wrap: wrap !important;
        gap: {{ block.settings.grid_gap | default: 30 }}px !important;
        justify-content: {% if b_align_alignment == 'center' %}center{% elsif b_align_alignment == 'right' %}flex-end{% else %}flex-start{% endif %} !important;
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }}.related-posts-grid .blog-card {
        flex: 0 0 auto !important;
      }
      @media (min-width: 1025px) {
        #shopify-section-{{ section.id }} .block-{{ block.id }}.related-posts-grid .blog-card {
          width: calc((100% - ({{ block.settings.columns_desktop | default: 3 }} - 1) * {{ block.settings.grid_gap | default: 30 }}px) / {{ block.settings.columns_desktop | default: 3 }}) !important;
        }
      }
      @media (max-width: 1024px) and (min-width: 769px) {
        #shopify-section-{{ section.id }} .block-{{ block.id }}.related-posts-grid .blog-card {
          width: calc((100% - ({{ block.settings.columns_tablet | default: 2 }} - 1) * {{ block.settings.grid_gap | default: 30 }}px) / {{ block.settings.columns_tablet | default: 2 }}) !important;
        }
      }
      @media (max-width: 768px) {
        #shopify-section-{{ section.id }} .block-{{ block.id }}.related-posts-grid .blog-card {
          width: calc((100% - ({{ block.settings.columns_mobile | default: 1 }} - 1) * {{ block.settings.grid_gap | default: 30 }}px) / {{ block.settings.columns_mobile | default: 1 }}) !important;
        }
      }

      /* Image aspect ratio */
      #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-image-wrapper {
        aspect-ratio: {{ block.settings.image_aspect_ratio | default: '16/10' }} !important;
      }

      /* Card hover effect lift/shadow lift disabled */
      {%- if block.settings.card_style == 'minimal' or block.settings.show_hover_effect == false -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card:hover,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .related-blog-card,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .related-blog-card:hover {
          transform: none !important;
          box-shadow: none !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card:hover .blog-card-image,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .related-blog-card:hover .blog-card-image {
          transform: none !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card:hover,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .related-blog-card:hover {
          border-color: {% if block.settings.card_style == 'minimal' %}transparent{% elsif block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' %}{{ block.settings.border_color }}{% else %}var(--border-light){% endif %} !important;
        }
      {%- endif -%}

      /* Spotlight effect visibility */
      {%- unless block.settings.enable_card_spotlight -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card::before,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .related-blog-card::before {
          display: none !important;
        }
      {%- endunless -%}

      /* Card border visibility */
      {%- unless block.settings.show_border -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card {
          border: none !important;
        }
      {%- endunless -%}

      /* Card style standard vs minimal */
      {%- if block.settings.card_style == 'minimal' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card {
          background: transparent !important;
          border: none !important;
          box-shadow: none !important;
          transform: none !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card::before {
          display: none !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-content {
          padding: 12px 0 0 0 !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-footer {
          border-top: none !important;
          padding-top: 12px !important;
        }
      {%- else -%}
        /* Default Card background & border custom colors */
        {%- if block.settings.card_bg_gradient != blank and block.settings.card_bg_gradient != 'rgba(0,0,0,0)' -%}
          #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card {
            background: {{ block.settings.card_bg_gradient }} !important;
          }
        {%- elsif block.settings.card_bg_color != blank and block.settings.card_bg_color != 'rgba(0,0,0,0)' -%}
          #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card {
            background-color: {{ block.settings.card_bg_color }} !important;
            background-image: none !important;
          }
        {%- endif -%}
        {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
          #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card {
            border-color: {{ block.settings.border_color }} !important;
          }
        {%- endif -%}
      {%- endif -%}

      /* Font size override for all card texts and icons */
      {%- if block.settings.font_size != blank -%}
        {%- assign fs = block.settings.font_size -%}
        {%- assign fs_val = '1rem' -%}
        {%- assign icon_val = '14px' -%}
        {%- if fs == 'small' -%}
          {%- assign fs_val = '0.85rem' -%}{%- assign title_fs = '1.05rem' -%}{%- assign icon_val = '12px' -%}
        {%- elsif fs == 'large' -%}
          {%- assign fs_val = '1.15rem' -%}{%- assign title_fs = '1.35rem' -%}{%- assign icon_val = '18px' -%}
        {%- else -%}
          {%- assign fs_val = '1rem' -%}{%- assign title_fs = '1.15rem' -%}{%- assign icon_val = '14px' -%}
        {%- endif -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-excerpt,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-meta-item,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-author-name,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-read-more {
          font-size: {{ fs_val }} !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-title {
          font-size: {{ title_fs }} !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} svg {
          width: {{ icon_val }} !important;
          height: {{ icon_val }} !important;
        }
      {%- endif -%}

      /* Title & Description custom colors */
      {%- if block.settings.title_color != blank and block.settings.title_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-title a {
          color: {{ block.settings.title_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.desc_color != blank and block.settings.desc_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-excerpt {
          color: {{ block.settings.desc_color }} !important;
        }
      {%- endif -%}

      /* Show/hide divider */
      {%- unless block.settings.show_divider -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-footer {
          border-top: none !important;
        }
      {%- endunless -%}

      /* Meta Text and Icon colors */
      {%- if block.settings.meta_text_color != blank and block.settings.meta_text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-meta-item {
          color: {{ block.settings.meta_text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.meta_icon_color != blank and block.settings.meta_icon_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-meta-item svg {
          color: {{ block.settings.meta_icon_color }} !important;
        }
      {%- endif -%}

      /* Category Badge colors */
      {%- if block.settings.badge_bg_gradient != blank and block.settings.badge_bg_gradient != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-category {
          background: {{ block.settings.badge_bg_gradient }} !important;
        }
      {%- elsif block.settings.badge_bg_color != blank and block.settings.badge_bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-category {
          background-color: {{ block.settings.badge_bg_color }} !important;
          background-image: none !important;
        }
      {%- endif -%}
      {%- if block.settings.badge_text_color != blank and block.settings.badge_text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-category {
          color: {{ block.settings.badge_text_color }} !important;
        }
      {%- endif -%}

      /* Author Colors */
      {%- if block.settings.author_name_color != blank and block.settings.author_name_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-author-name {
          color: {{ block.settings.author_name_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.author_avatar_bg_color != blank and block.settings.author_avatar_bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-author-avatar {
          background: {{ block.settings.author_avatar_bg_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.author_avatar_text_color != blank and block.settings.author_avatar_text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-author-avatar {
          color: {{ block.settings.author_avatar_text_color }} !important;
        }
      {%- endif -%}

      /* Button specific colors */
      {%- if block.settings.btn_bg_gradient != blank and block.settings.btn_bg_gradient != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-read-more {
          background: {{ block.settings.btn_bg_gradient }} !important;
          padding: 6px 14px !important;
          border-radius: 50px !important;
        }
      {%- elsif block.settings.btn_bg_color != blank and block.settings.btn_bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-read-more {
          background-color: {{ block.settings.btn_bg_color }} !important;
          background-image: none !important;
          padding: 6px 14px !important;
          border-radius: 50px !important;
        }
      {%- endif -%}
      {%- if block.settings.btn_text_color != blank and block.settings.btn_text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-read-more {
          color: {{ block.settings.btn_text_color }} !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-read-more svg {
          color: {{ block.settings.btn_text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.btn_border_color != blank and block.settings.btn_border_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-read-more {
          border: 1px solid {{ block.settings.btn_border_color }} !important;
          padding: 6px 14px !important;
          border-radius: 50px !important;
        }
      {%- endif -%}

      /* Button Hover overrides */
      {%- if block.settings.btn_hover_bg_gradient != blank and block.settings.btn_hover_bg_gradient != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-read-more:hover {
          background: {{ block.settings.btn_hover_bg_gradient }} !important;
        }
      {%- elsif block.settings.btn_hover_bg_color != blank and block.settings.btn_hover_bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-read-more:hover {
          background-color: {{ block.settings.btn_hover_bg_color }} !important;
          background-image: none !important;
        }
      {%- endif -%}
      {%- if block.settings.btn_hover_text_color != blank and block.settings.btn_hover_text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-read-more:hover {
          color: {{ block.settings.btn_hover_text_color }} !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-read-more:hover svg {
          color: {{ block.settings.btn_hover_text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.btn_hover_border_color != blank and block.settings.btn_hover_border_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-card-read-more:hover {
          border-color: {{ block.settings.btn_hover_border_color }} !important;
        }
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
</style>

{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

{%- if section.settings.show_section and blog.articles.size > 1 -%}

<section 
  class="article-related-section color-{{ section.settings.color_scheme }}{% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    
    {%- comment -%}Section Content via Blocks{%- endcomment -%}
    {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'heading'
        assign b_align_alignment = 'center'
      when 'subheading'
        assign b_align_alignment = 'center'
      when 'article_list'
        assign b_align_alignment = 'left'
  endcase
-%}
      {%- case block.type -%}
        
        {%- when 'heading' -%}
          {%- if block.settings.title != blank -%}
            {%- assign heading_tag = block.settings.heading_tag | default: 'h2' -%}
            <{{ heading_tag }} class="blog-post-related-title size-{{ block.settings.font_size | default: 'medium' }} block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
              {{ block.settings.title | replace: '[', '<span>' | replace: ']', '</span>' }}
            </{{ heading_tag }}>
          {%- endif -%}
          
        {%- when 'subheading' -%}
          {%- if block.settings.subheading != blank -%}
            <div class="blog-post-related-subtitle block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
              {{ block.settings.subheading }}
            </div>
          {%- endif -%}
          
        {%- when 'article_list' -%}
          <div class="blog-grid related-posts-grid columns-{{ block.settings.columns_desktop | default: 3 }} block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
            {%- assign current_article_id = article.id -%}
            {%- assign articles_shown = 0 -%}
            
            {%- comment -%}Render related articles (excluding current){%- endcomment -%}
            {%- for blog_article in blog.articles -%}
              {%- if blog_article.id != current_article_id and articles_shown < block.settings.posts_to_show -%}
                {%- assign articles_shown = articles_shown | plus: 1 -%}
                <article class="blog-card related-blog-card">
                  <div class="blog-card-image-wrapper">
                    {%- if blog_article.image -%}
                      {{ blog_article.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: blog_article.title, class: 'blog-card-image' }}
                    {%- else -%}
                      <div class="blog-card-image-placeholder">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                          <circle cx="8.5" cy="8.5" r="1.5"/>
                          <polyline points="21 15 16 10 5 21"/>
                        </svg>
                      </div>
                    {%- endif -%}
                    {%- if block.settings.show_category and blog_article.tags.size > 0 -%}
                    <span class="blog-card-category">{{ blog_article.tags.first }}</span>
                    {%- endif -%}
                  </div>
                  <div class="blog-card-content">
                    <div class="blog-card-meta">
                      {%- if block.settings.show_date -%}
                      <span class="blog-meta-item">
                        {%- if block.settings.show_date_icon -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                          <line x1="16" y1="2" x2="16" y2="6" />
                          <line x1="8" y1="2" x2="8" y2="6" />
                          <line x1="3" y1="10" x2="21" y2="10" />
                        </svg>
                        {%- endif -%}
                        {{ blog_article.published_at | date: '%b %d, %Y' }}
                      </span>
                      {%- endif -%}
                      {%- if block.settings.show_read_time -%}
                      <span class="blog-meta-item">
                        {%- if block.settings.show_read_time_icon -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <circle cx="12" cy="12" r="10" />
                          <polyline points="12 6 12 12 16 14" />
                        </svg>
                        {%- endif -%}
                        {{ blog_article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min
                      </span>
                      {%- endif -%}
                    </div>
                    
                    <h3 class="blog-card-title">
                      <a href="{{ blog_article.url }}">{{ blog_article.title }}</a>
                    </h3>
                    
                    {%- if block.settings.show_excerpt -%}
                    <p class="blog-card-excerpt">
                      {%- if blog_article.excerpt.size > 0 -%}
                        {{ blog_article.excerpt | strip_html | truncate: block.settings.excerpt_length }}
                      {%- else -%}
                        {{ blog_article.content | strip_html | truncate: block.settings.excerpt_length }}
                      {%- endif -%}
                    </p>
                    {%- endif -%}
                    
                    <div class="blog-card-footer">
                      {%- if block.settings.show_author -%}
                      <div class="blog-card-author">
                        {%- if block.settings.show_author_avatar -%}
                        <div class="blog-author-avatar">
                          {%- if blog_article.author contains ' ' -%}
                            {{ blog_article.author | split: ' ' | first | slice: 0 }}{{ blog_article.author | split: ' ' | last | slice: 0 }}
                          {%- else -%}
                            {{ blog_article.author | slice: 0, 2 | upcase }}
                          {%- endif -%}
                        </div>
                        {%- endif -%}
                        <span class="blog-author-name">{{ blog_article.author }}</span>
                      </div>
                      {%- endif -%}
                      {%- if block.settings.show_read_more -%}
                      <a href="{{ blog_article.url }}" class="blog-card-read-more">
                        {%- assign read_more_val = block.settings.read_more_label | default: 'Read More' -%}{%- assign temp_key = 'custom_labels.' | append: read_more_val | handleize -%}{%- assign temp_trans = temp_key | t -%}{%- unless temp_trans contains 'translation' or temp_trans contains 'Translation' -%}{%- assign read_more_val = temp_trans -%}{%- endunless -%}
                        {{ read_more_val }}
                        {%- if block.settings.show_button_arrow -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <polyline points="9 18 15 12 9 6" />
                        </svg>
                        {%- endif -%}
                      </a>
                      {%- endif -%}
                    </div>
                  </div>
                </article>
              {%- endif -%}
            {%- endfor -%}
          </div>
          
      {%- endcase -%}
    {%- endfor -%}

  </div>
</section>

{%- assign card_spotlight_enabled = false -%}
{%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'heading'
        assign b_align_alignment = 'center'
      when 'subheading'
        assign b_align_alignment = 'center'
      when 'article_list'
        assign b_align_alignment = 'left'
  endcase
-%}
  {%- if block.type == 'article_list' -%}
    {%- if block.settings.enable_card_spotlight -%}
      {%- assign card_spotlight_enabled = true -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- if card_spotlight_enabled -%}
<script>
function initCardSpotlight() {
  const allCards = document.querySelectorAll('#shopify-section-{{ section.id }} .blog-card');
  allCards.forEach(function(card) {
    if (card.dataset.spotlightInitialized) return;
    card.dataset.spotlightInitialized = 'true';
    card.addEventListener('mousemove', function(e) {
      const rect = card.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * 100;
      const y = ((e.clientY - rect.top) / rect.height) * 100;
      card.style.setProperty('--mouse-x', x + '%');
      card.style.setProperty('--mouse-y', y + '%');
    });
  });
}
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initCardSpotlight);
} else {
  initCardSpotlight();
}
document.addEventListener('shopify:section:load', (event) => {
  if (event.detail.sectionId === '{{ section.id }}') {
    initCardSpotlight();
  }
});
</script>
{%- endif -%}

{%- endif -%}

