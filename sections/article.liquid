{% comment %}
  This section is used in the article template to render the article page, which
  displays the full content of the blog post and can optionally include a
  comments section for customers.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/article
{% endcomment %}

{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile,
  padding_left: section.settings.padding_left,
  padding_right: section.settings.padding_right,
  padding_left_mobile: section.settings.padding_left_mobile,
  padding_right_mobile: section.settings.padding_right_mobile
%}
<article class="article">
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'article_image' -%}
        {% render 'article-image-block', block: block %}
      {%- when 'article_title' -%}
        {% render 'article-title-block', block: block %}
      {%- when 'article_metadata' -%}
        {% render 'article-metadata-block', block: block %}
      {%- when 'article_content' -%}
        {% render 'article-content-block', block: block %}
      {%- when 'article_comments' -%}
        {% render 'article-comments-block', block: block %}
      {%- when 'article_comment_form' -%}
        {% render 'article-comment-form-block', block: block %}
    {%- endcase -%}
  {%- endfor -%}
</article>

{% schema %}
{
  "name": "t:general.article",
  "settings": [
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Left",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Right",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_left_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Left (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Right (Mobile)",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "article_image",
      "name": "Article Image",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "image_width",
          "label": "Image width",
          "default": "contained",
          "options": [
            { "value": "full", "label": "Full width" },
            { "value": "contained", "label": "Contained" }
          ]
        }
      ]
    },
    {
      "type": "article_title",
      "name": "Article Title",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "heading_tag",
          "label": "Heading tag",
          "default": "h1",
          "options": [
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" }
          ]
        }
      ]
    },
    {
      "type": "article_metadata",
      "name": "Article Metadata",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_author",
          "label": "Show author",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_date",
          "label": "Show date",
          "default": true
        },
        {
          "type": "select",
          "id": "date_format",
          "label": "Date format",
          "default": "date",
          "options": [
            { "value": "date", "label": "Date only" },
            { "value": "date_at_time", "label": "Date and time" }
          ]
        },
        {
          "type": "checkbox",
          "id": "show_read_time",
          "label": "Show read time",
          "default": true
        }
      ]
    },
    {
      "type": "article_content",
      "name": "Article Content",
      "limit": 1,
      "settings": []
    },
    {
      "type": "article_comments",
      "name": "Article Comments",
      "limit": 1,
      "settings": [
        {
          "type": "range",
          "id": "comments_per_page",
          "min": 5,
          "max": 50,
          "step": 5,
          "label": "Comments per page",
          "default": 10
        },
        {
          "type": "select",
          "id": "heading_level",
          "label": "Heading level",
          "default": "2",
          "options": [
            { "value": "2", "label": "H2" },
            { "value": "3", "label": "H3" }
          ]
        }
      ]
    },
    {
      "type": "article_comment_form",
      "name": "Article Comment Form",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "heading_level",
          "label": "Heading level",
          "default": "2",
          "options": [
            { "value": "2", "label": "H2" },
            { "value": "3", "label": "H3" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Article",
      "blocks": [
        {
          "type": "article_image",
          "settings": {
            "image_width": "contained"
          }
        },
        {
          "type": "article_title",
          "settings": {
            "heading_tag": "h1"
          }
        },
        {
          "type": "article_metadata",
          "settings": {
            "show_author": true,
            "show_date": true,
            "date_format": "date",
            "show_read_time": true
          }
        },
        {
          "type": "article_content",
          "settings": {}
        },
        {
          "type": "article_comments",
          "settings": {
            "comments_per_page": 10,
            "heading_level": "2"
          }
        },
        {
          "type": "article_comment_form",
          "settings": {
            "heading_level": "2"
          }
        }
      ]
    }
  ]
}
{% endschema %}
