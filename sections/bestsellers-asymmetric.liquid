{{ 'section-home-ecommerce-minimal.css' | asset_url | stylesheet_tag }}

{%- if section.settings.show_section -%}
{% style %}
  #shopify-section-{{ section.id }} .hev-bs-block {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 0px) !important;
    color: var(--block-text-color, var(--default-text-color, inherit)) !important;
    background: var(--block-bg, transparent) !important;
  }
  #shopify-section-{{ section.id }} .hev-bs-block *:not(span):not(.hev-section-link) {
    color: inherit !important;
  }
  #shopify-section-{{ section.id }} .hev-bs-heading span {
    background: var(--highlight-gradient, var(--color-accent)) !important;
    -webkit-background-clip: var(--highlight-clip, text) !important;
    background-clip: var(--highlight-clip, text) !important;
    -webkit-text-fill-color: var(--highlight-fill, transparent) !important;
    display: inline-block;
    color: var(--highlight-color, inherit) !important;
  }
  
  /* View All Link System */
  .hev-section-link {
    background: var(--btn-bg, transparent) !important;
    color: var(--btn-text, var(--text-inverse)) !important;
    border: none !important;
    transition: all 0.3s ease !important;
  }
  .hev-section-link:hover {
    background: var(--btn-hover-bg, var(--color-white-5)) !important;
    color: var(--btn-hover-text, var(--color-accent-secondary)) !important;
  }

  /* Product Card System */
  .hev-bs-card {
    background: var(--card-bg, transparent) !important;
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 0px) !important;
  }
  .hev-bs-card-category {
    color: var(--cat-color, var(--color-accent-secondary)) !important;
  }
  .hev-bs-card-name a {
    color: var(--title-color, var(--text-primary)) !important;
    font-size: var(--title-size, 1.2rem) !important;
    font-weight: var(--title-weight, 700) !important;
    font-style: var(--title-style, normal) !important;
    text-transform: var(--title-transform, none) !important;
    letter-spacing: var(--title-spacing, 0px) !important;
    line-height: var(--title-lh, 1.2) !important;
  }
  .hev-bs-card-price {
    color: var(--price-color, var(--color-accent-secondary)) !important;
    font-size: var(--price-size, 1.4rem) !important;
    font-weight: var(--price-weight, 700) !important;
    font-style: var(--price-style, normal) !important;
    text-transform: var(--price-transform, none) !important;
    letter-spacing: var(--price-spacing, 0px) !important;
    line-height: var(--price-lh, 1.2) !important;
  }
  .hev-bs-card-stars svg {
    fill: var(--rating-color, var(--color-accent)) !important;
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .hev-bs-block {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 0px)) !important;
    }
    .hev-bs-card {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 0px)) !important;
    }
  }
{% endstyle %}

{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

<section class="hev-bestsellers color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}" id="shopify-section-{{ section.id }}">
    <div class="{% if section.settings.container_width == 'full' %}container-full{% else %}container{% endif %}" style="max-width: {{ section.settings.max_width }}px; margin: 0 auto;">
        <div class="hev-section-header" style="justify-content: {% if 'left' == 'center' %}center{% elsif 'left' == 'right' %}flex-end{% else %}space-between{% endif %}; text-align: {{ 'left' }};">
            <div class="hev-section-header-text">
                {%- for block in section.blocks -%}
                    {%- case block.type -%}
                        {%- when 'bs_heading' -%}
                            {%- if block.settings.heading != blank -%}
                                {%- assign h_color = block.settings.highlight_color -%}
                                {%- assign h_gradient = block.settings.highlight_gradient -%}
                                <h2 class="hev-bs-heading hev-bs-block hev-bs-heading--{{ block.settings.font_size }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                                    style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px; font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; --default-text-color: var(--text-primary); {% if block.settings.text_color != blank %}--block-text-color: {{ block.settings.text_color }};{% endif %} {% if block.settings.bg_gradient != blank %}--block-bg: {{ block.settings.bg_gradient }};{% elsif block.settings.bg_color != blank %}--block-bg: {{ block.settings.bg_color }};{% endif %}
                                    {% if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' %}--highlight-gradient: {{ h_gradient }}; --highlight-clip: text; --highlight-fill: transparent;
                                    {% elsif h_color != blank and h_color != 'rgba(0,0,0,0)' %}--highlight-color: {{ h_color }}; --highlight-gradient: none; --highlight-clip: initial; --highlight-fill: {{ h_color }};
                                    {% endif %}" 
                                    {{ block.shopify_attributes }}>
                                    {{ block.settings.heading | replace: '[', '<span>' | replace: ']', '</span>' }}
                                </h2>
                            {%- endif -%}

                        {%- when 'bs_subheading' -%}
                            {%- if block.settings.subheading != blank -%}
                                <p class="hev-bs-block {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                                   style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px; font-size: {{ block.settings.font_size }}rem; max-width: {{ block.settings.max_width }}px; margin-inline: {% if 'left' == 'center' %}auto{% elsif 'left' == 'right' %}0 0{% else %}0 auto{% endif %}; font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; --default-text-color: var(--text-secondary); {% if block.settings.text_color != blank %}--block-text-color: {{ block.settings.text_color }};{% endif %} {% if block.settings.bg_gradient != blank %}--block-bg: {{ block.settings.bg_gradient }};{% elsif block.settings.bg_color != blank %}--block-bg: {{ block.settings.bg_color }};{% endif %}" 
                                   {{ block.shopify_attributes }}>
                                    {{ block.settings.subheading }}
                                </p>
                            {%- endif -%}
                    {%- endcase -%}
                {%- endfor -%}
            </div>
            {%- for block in section.blocks -%}
                {%- if block.type == 'bs_view_all' -%}
                    {%- if block.settings.label != blank -%}
                        {%- liquid
                           assign btn_bg = block.settings.bg_color | default: 'transparent'
                           if block.settings.bg_gradient != blank
                              assign btn_bg = block.settings.bg_gradient
                           endif
                           assign btn_text = block.settings.text_color | default: 'var(--text-inverse)'
                        -%}
                        <div class="hev-bs-block {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                             style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px;" {{ block.shopify_attributes }}>
                            <a href="{{ block.settings.link | default: '#' }}" 
                               class="hev-section-link" 
                               id="hev-view-all-link-{{ block.id }}" 
                               aria-label="{{ block.settings.label | escape }}"
                               {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener"{% endif %}
                               style="font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }};
                               --btn-bg: {{ btn_bg }}; 
                               --btn-text: {{ btn_text }};
                               --btn-hover-bg: {{ block.settings.hover_bg_color | default: 'var(--color-white-5)' }};
                               --btn-hover-text: {{ block.settings.hover_text_color | default: 'var(--color-accent-secondary)' }};">
                                {{ block.settings.label }}
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true" focusable="false">
                                    <path d="M5 12h14" />
                                    <path d="M12 5l7 7-7 7" />
                                </svg>
                            </a>
                        </div>
                    {%- endif -%}
                {%- endif -%}
            {%- endfor -%}
        </div>

        <div class="hev-bestsellers-grid">
            {%- assign product_index = 0 -%}
            {%- for block in section.blocks -%}
                {%- if block.type == 'product_card' -%}
                    {%- assign product_index = product_index | plus: 1 -%}
                    <div class="hev-bs-card{% if product_index == 1 %} hev-bs-card-hero{% endif %} hev-bs-card--{{ block.settings.image_ratio }} hev-bs-card--align-{{ 'left' }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                         style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px;
                         --card-bg: {{ block.settings.card_bg | default: 'transparent' }};
                         --cat-color: {{ block.settings.category_color | default: 'var(--color-accent-secondary)' }};
                         --title-color: {{ block.settings.title_color | default: 'var(--text-primary)' }};
                         --title-size: {{ block.settings.title_size }}rem;
                         --title-weight: {% if block.settings.title_weight == 'bold' %}700{% else %}400{% endif %};
                         --title-style: {{ block.settings.title_style }};
                         --title-transform: {{ block.settings.title_transform }};
                         --title-spacing: {{ block.settings.title_spacing }}px;
                         --title-lh: {{ block.settings.title_line_height }};
                         --price-color: {{ block.settings.price_color | default: 'var(--color-accent-secondary)' }};
                         --price-size: {{ block.settings.price_size }}rem;
                         --price-weight: {% if block.settings.price_weight == 'bold' %}700{% else %}400{% endif %};
                         --price-style: {{ block.settings.price_style }};
                         --price-transform: {{ block.settings.price_transform }};
                         --price-spacing: {{ block.settings.price_spacing }}px;
                         --price-lh: {{ block.settings.price_line_height }};
                         --rating-color: {{ block.settings.rating_color | default: 'var(--color-accent-secondary)' }};"
                         {{ block.shopify_attributes }}>
                            <div class="hev-bs-card-img">
                                {%- if block.settings.image != blank -%}
                                    {{ block.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy', sizes: '(min-width: 769px) 60vw, 100vw', alt: block.settings.title | default: 'Product image' }}
                                {%- elsif block.settings.product != blank -%}
                                    {{ block.settings.product.featured_image | image_url: width: 1500 | image_tag: loading: 'lazy', sizes: '(min-width: 769px) 60vw, 100vw', alt: block.settings.product.title | escape }}
                                {%- else -%}
                                    {{ 'product-' | append: product_index | placeholder_svg_tag: 'placeholder-svg' }}
                                {%- endif -%}
                            </div>
                            <div class="hev-bs-card-info">
                                {%- if block.settings.show_category and block.settings.category != blank -%}
                                    <div class="hev-bs-card-category">{{ block.settings.category }}</div>
                                {%- endif -%}
                                <div class="hev-bs-card-name">
                                    {%- if block.settings.show_title -%}
                                        {%- if block.settings.title != blank -%}
                                            <a href="{{ block.settings.link | default: '#' }}" aria-label="View {{ block.settings.title | escape }}">{{ block.settings.title }}</a>
                                        {%- elsif block.settings.product != blank -%}
                                            <a href="{{ block.settings.product.url }}" aria-label="View {{ block.settings.product.title | escape }}">{{ block.settings.product.title }}</a>
                                        {%- else -%}
                                            <a href="#">{{ 'products.product.title_placeholder' | t }}</a>
                                        {%- endif -%}
                                    {%- endif -%}
                                </div>
                                <div class="hev-bs-card-bottom">
                                    {%- if block.settings.show_price -%}
                                        <span class="hev-bs-card-price">
                                            {%- if block.settings.price != blank -%}
                                                {{ block.settings.price }}
                                            {%- elsif block.settings.product != blank -%}
                                                {{ block.settings.product.price | money }}
                                            {%- else -%}
                                                $0.00
                                            {%- endif -%}
                                        </span>
                                    {%- endif -%}
                                    {%- if block.settings.show_rating -%}
                                        <div class="hev-bs-card-rating-group">
                                            <div class="hev-bs-card-stars" aria-label="{{ block.settings.rating | default: 5 }} star rating">
                                                {%- assign rating_val = block.settings.rating | default: 5 | floor -%}
                                                {%- for i in (1..5) -%}
                                                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" {% if i > rating_val %}style="opacity: 0.3;"{% endif %}>
                                                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                                                    </svg>
                                                {%- endfor -%}
                                            </div>
                                            {%- if block.settings.rating_count != blank -%}
                                                <span class="hev-bs-card-rating-count">({{ block.settings.rating_count }})</span>
                                            {%- endif -%}
                                        </div>
                                    {%- endif -%}
                                </div>
                            </div>
                        </div>
                {%- endif -%}
            {%- endfor -%}
        </div>
    </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Best Sellers - Asymmetric",
  "tag": "section",
  "class": "section-bestsellers",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "full",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "full", "label": "Full Width" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Max Width",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "paragraph",
      "content": "Typography settings are managed within individual blocks."
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 40
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "inverse", "label": "Inverse" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "bs_heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "General Settings"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Best [Sellers]",
          "info": "Use [ ] to highlight text with gradient"
        },
        {
          "type": "header",
          "content": "Visibility"
        },
        {
          "type": "checkbox",
          "id": "show_on_desktop",
          "label": "Show on Desktop",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_on_mobile",
          "label": "Show on Mobile",
          "default": true
        },
        {
          "type": "header",
          "content": "Layout"
        },
        {
          "type": "range",
          "id": "margin_top",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Top Margin (Desktop)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Bottom Margin (Desktop)",
          "default": 16
        },
        {
          "type": "range",
          "id": "margin_top_mobile",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Top Margin (Mobile)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom_mobile",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Bottom Margin (Mobile)",
          "default": 16
        },
        {
          "type": "header",
          "content": "Typography"
        },
        {
          "type": "select",
          "id": "font_size",
          "label": "Font size",
          "default": "medium",
          "options": [
            { "value": "small", "label": "Small" },
            { "value": "medium", "label": "Medium" },
            { "value": "large", "label": "Large" }
          ]
        },
        {
          "type": "select",
          "id": "font_weight",
          "label": "Font Weight",
          "default": "bold",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "bold", "label": "Bold" }
          ]
        },
        {
          "type": "select",
          "id": "font_style",
          "label": "Font Style",
          "default": "normal",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "italic", "label": "Italic" }
          ]
        },
        {
          "type": "select",
          "id": "text_transform",
          "label": "Text Transform",
          "default": "none",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "uppercase", "label": "Uppercase" },
            { "value": "lowercase", "label": "Lowercase" },
            { "value": "capitalize", "label": "Capitalize" }
          ]
        },
        {
          "type": "range",
          "id": "letter_spacing",
          "min": -5,
          "max": 10,
          "step": 0.5,
          "unit": "px",
          "label": "Letter Spacing",
          "default": 0
        },
        {
          "type": "range",
          "id": "line_height",
          "min": 0.8,
          "max": 2.0,
          "step": 0.1,
          "unit": "em",
          "label": "Line Height",
          "default": 1.2
        },
        {
          "type": "header",
          "content": "Colors"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color"
        },
        {
          "type": "color_background",
          "id": "bg_gradient",
          "label": "Background Gradient"
        },
        {
          "type": "color",
          "id": "highlight_color",
          "label": "Highlight Text Color"
        },
        {
          "type": "color_background",
          "id": "highlight_gradient",
          "label": "Highlight Text Gradient"
        }
      ]
    },
    {
      "type": "bs_subheading",
      "name": "Subheading",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "General Settings"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Our most loved products — chosen by thousands of customers."
        },
        {
          "type": "header",
          "content": "Visibility"
        },
        {
          "type": "checkbox",
          "id": "show_on_desktop",
          "label": "Show on Desktop",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_on_mobile",
          "label": "Show on Mobile",
          "default": true
        },
        {
          "type": "header",
          "content": "Layout"
        },
        {
          "type": "range",
          "id": "max_width",
          "min": 400,
          "max": 1600,
          "step": 50,
          "unit": "px",
          "label": "Max Width",
          "default": 600
        },
        {
          "type": "range",
          "id": "margin_top",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Top Margin (Desktop)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Bottom Margin (Desktop)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_top_mobile",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Top Margin (Mobile)",
          "default": 0
        },
        {
