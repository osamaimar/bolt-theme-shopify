{{ 'section-blog-list-sidebar.css' | asset_url | stylesheet_tag }}

<style>
  /* Section Spacing / Visibility overrides */
  #shopify-section-{{ section.id }} .blog-list-sidebar-section {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .blog-list-sidebar-section {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Container Width overrides */
  #shopify-section-{{ section.id }} .container-fluid {
    max-width: 100% !important;
    padding-left: var(--spacing-lg, 24px) !important;
    padding-right: var(--spacing-lg, 24px) !important;
  }
  #shopify-section-{{ section.id }} .container-narrow {
    max-width: 800px !important;
    padding-left: var(--spacing-lg, 24px) !important;
    padding-right: var(--spacing-lg, 24px) !important;
  }
  #shopify-section-{{ section.id }} .container {
    max-width: {{ section.settings.max_width | default: 1200 }}px !important;
    padding-left: var(--spacing-lg, 24px) !important;
    padding-right: var(--spacing-lg, 24px) !important;
    margin-left: auto !important;
    margin-right: auto !important;
  }

  /* Blocks Position align overrides - Scoped to header only */
  #shopify-section-{{ section.id }} .blog-sb-header {
    display: flex;
    flex-direction: column;
    align-items: {% if section.settings.blocks_position == 'left' %}flex-start{% elsif section.settings.blocks_position == 'right' %}flex-end{% else %}center{% endif %} !important;
    text-align: {% if section.settings.blocks_position == 'left' %}start{% elsif section.settings.blocks_position == 'right' %}end{% else %}center{% endif %} !important;
  }

  /* Standard Block Spacing overrides */
  #shopify-section-{{ section.id }} .blog-post-breadcrumb,
  #shopify-section-{{ section.id }} .blog-sb-title,
  #shopify-section-{{ section.id }} .blog-sb-results,
  #shopify-section-{{ section.id }} .blog-sb-list,
  #shopify-section-{{ section.id }} .blog-sidebar-widget {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 0px) !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .blog-post-breadcrumb,
    #shopify-section-{{ section.id }} .blog-sb-title,
    #shopify-section-{{ section.id }} .blog-sb-results,
    #shopify-section-{{ section.id }} .blog-sb-list,
    #shopify-section-{{ section.id }} .blog-sidebar-widget {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 0px)) !important;
    }
  }

  /* Heading Highlight styling */
  #shopify-section-{{ section.id }} .blog-sb-title span {
    background: var(--highlight-gradient, var(--color-accent)) !important;
    -webkit-background-clip: var(--highlight-clip, text) !important;
    background-clip: var(--highlight-clip, text) !important;
    -webkit-text-fill-color: var(--highlight-fill, transparent) !important;
    display: inline-block;
    color: var(--highlight-color, inherit) !important;
  }

  /* Responsive Font Sizing */
  #shopify-section-{{ section.id }} .blog-sb-title.size-small { font-size: 2rem !important; }
  #shopify-section-{{ section.id }} .blog-sb-title.size-medium { font-size: 2.5rem !important; }
  #shopify-section-{{ section.id }} .blog-sb-title.size-large { font-size: 3rem !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .blog-sb-title.size-small { font-size: 1.5rem !important; }
    #shopify-section-{{ section.id }} .blog-sb-title.size-medium { font-size: 1.8rem !important; }
    #shopify-section-{{ section.id }} .blog-sb-title.size-large { font-size: 2.2rem !important; }
  }

  #shopify-section-{{ section.id }} .blog-sidebar-widget-title.size-small { font-size: 1.15rem !important; }
  #shopify-section-{{ section.id }} .blog-sidebar-widget-title.size-medium { font-size: 1.35rem !important; }
  #shopify-section-{{ section.id }} .blog-sidebar-widget-title.size-large { font-size: 1.6rem !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .blog-sidebar-widget-title.size-small { font-size: 1.05rem !important; }
    #shopify-section-{{ section.id }} .blog-sidebar-widget-title.size-medium { font-size: 1.2rem !important; }
    #shopify-section-{{ section.id }} .blog-sidebar-widget-title.size-large { font-size: 1.4rem !important; }
  }

  #shopify-section-{{ section.id }} .blog-sidebar-widget-title svg {
    width: 1.1em !important;
    height: 1.1em !important;
  }

  /* Block-specific styling overrides */
  {%- for block in section.blocks -%}
    .block-{{ block.id }} {
      --m-t: {{ block.settings.margin_top | default: 0 }}px;
      --m-b: {{ block.settings.margin_bottom | default: 0 }}px;
      --m-t-m: {{ block.settings.margin_top_mobile | default: block.settings.margin_top | default: 0 }}px;
      --m-b-m: {{ block.settings.margin_bottom_mobile | default: block.settings.margin_bottom | default: 0 }}px;
    }

    {%- if 'left' != blank -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }} {
        text-align: {{ 'left' }} !important;
        {%- if block.type == 'breadcrumb' -%}
          justify-content: {% if 'left' == 'left' %}flex-start{% elsif 'left' == 'right' %}flex-end{% else %}center{% endif %} !important;
        {%- endif -%}
      }
    {%- endif -%}

    {%- if block.type == 'breadcrumb' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }} a,
      #shopify-section-{{ section.id }} .block-{{ block.id }} span {
        font-size: {% if block.settings.font_size == 'small' %}0.8rem{% elsif block.settings.font_size == 'large' %}1.05rem{% else %}0.9rem{% endif %} !important;
        font-weight: {% if block.settings.font_weight == 'bold' %}700{% elsif block.settings.font_weight == 'medium' %}500{% else %}400{% endif %} !important;
        font-style: {{ block.settings.font_style | default: 'normal' }} !important;
        text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
        letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
        line-height: {{ block.settings.line_height | default: 120 }}% !important;
      }
      {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} a,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-post-breadcrumb-current,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-post-breadcrumb-separator {
          color: {{ block.settings.text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.hover_text_color != blank and block.settings.hover_text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} a:hover {
          color: {{ block.settings.hover_text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.bg_gradient != blank and block.settings.bg_gradient != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          background: {{ block.settings.bg_gradient }} !important;
        }
      {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          background-color: {{ block.settings.bg_color }} !important;
          background-image: none !important;
        }
      {%- endif -%}
      {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          border-color: {{ block.settings.border_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.separator_color != blank and block.settings.separator_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-post-breadcrumb-separator {
          color: {{ block.settings.separator_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.current_color != blank and block.settings.current_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-post-breadcrumb-current {
          color: {{ block.settings.current_color }} !important;
        }
      {%- endif -%}

    {%- elsif block.type == 'title' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sb-title {
        font-weight: {% if block.settings.font_weight == 'bold' %}700{% elsif block.settings.font_weight == 'medium' %}500{% else %}400{% endif %} !important;
        font-style: {{ block.settings.font_style | default: 'normal' }} !important;
        text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
        letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
        line-height: {{ block.settings.line_height | default: 120 }}% !important;
      }
      {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sb-title {
          color: {{ block.settings.text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.bg_gradient != blank and block.settings.bg_gradient != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sb-title {
          background: {{ block.settings.bg_gradient }} !important;
        }
      {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sb-title {
          background-color: {{ block.settings.bg_color }} !important;
          background-image: none !important;
        }
      {%- endif -%}
      {%- if block.settings.highlight_gradient != blank and block.settings.highlight_gradient != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sb-title span {
          background: {{ block.settings.highlight_gradient }} !important;
          -webkit-background-clip: text !important;
          background-clip: text !important;
          -webkit-text-fill-color: transparent !important;
          color: transparent !important;
          display: inline-block !important;
        }
      {%- elsif block.settings.highlight_color != blank and block.settings.highlight_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sb-title span {
          color: {{ block.settings.highlight_color }} !important;
          -webkit-text-fill-color: {{ block.settings.highlight_color }} !important;
          background: none !important;
        }
      {%- endif -%}

    {%- elsif block.type == 'article_count' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sb-results {
        font-size: {% if block.settings.font_size == 'small' %}0.85rem{% elsif block.settings.font_size == 'large' %}1.1rem{% else %}0.95rem{% endif %} !important;
        font-weight: {% if block.settings.font_weight == 'bold' %}700{% elsif block.settings.font_weight == 'medium' %}500{% else %}400{% endif %} !important;
        font-style: {{ block.settings.font_style | default: 'normal' }} !important;
        text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
        letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
        line-height: {{ block.settings.line_height | default: 120 }}% !important;
      }
      {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sb-results {
          color: {{ block.settings.text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.bg_gradient != blank and block.settings.bg_gradient != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sb-results {
          background: {{ block.settings.bg_gradient }} !important;
        }
      {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sb-results {
          background-color: {{ block.settings.bg_color }} !important;
          background-image: none !important;
        }
      {%- endif -%}

    {%- elsif block.type == 'article_list' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }} {
        display: grid !important;
        grid-template-columns: repeat({{ block.settings.columns_desktop | default: 1 }}, 1fr) !important;
        gap: {{ block.settings.grid_gap | default: 28 }}px !important;
        margin-top: var(--m-t, 0px) !important;
        margin-bottom: var(--m-b, 0px) !important;
      }
      @media screen and (max-width: 990px) {
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          grid-template-columns: repeat({{ block.settings.columns_tablet | default: 1 }}, 1fr) !important;
        }
      }
      @media screen and (max-width: 768px) {
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          grid-template-columns: repeat({{ block.settings.columns_mobile | default: 1 }}, 1fr) !important;
          margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
          margin-bottom: var(--m-b-m, var(--m-b, 0px)) !important;
        }
      }

      /* Card layout adjustment for columns */
      #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card {
        border-radius: {{ block.settings.card_border_radius | default: 20 }}px !important;
      }
      {%- if block.settings.columns_desktop != '1' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card {
          grid-template-columns: 1fr !important;
        }
      {%- endif -%}
      @media screen and (max-width: 990px) {
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card {
          grid-template-columns: {% if block.settings.columns_tablet != '1' %}1fr{% else %}300px 1fr{% endif %} !important;
        }
      }
      @media screen and (max-width: 768px) {
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card {
          grid-template-columns: 1fr !important;
        }
      }
      {%- if block.settings.show_card_image == false -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card {
          grid-template-columns: 1fr !important;
        }
      {%- endif -%}

      /* Card aspect ratio and layout overrides */
      #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card-image-wrapper {
        min-height: auto !important;
      }
      {%- assign card_ratio = block.settings.image_ratio | default: '16/10' -%}
      {%- if card_ratio == '1/1' -%}{%- assign card_ratio = '1 / 1' -%}{%- endif -%}
      {%- if card_ratio == '3/4' -%}{%- assign card_ratio = '3 / 4' -%}{%- endif -%}
      {%- if card_ratio == '4/3' -%}{%- assign card_ratio = '4 / 3' -%}{%- endif -%}
      {%- if card_ratio == '16/9' -%}{%- assign card_ratio = '16 / 9' -%}{%- endif -%}

      {%- if card_ratio != 'auto' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card-image-wrapper {
          aspect-ratio: {{ card_ratio }} !important;
          height: auto !important;
        }
      {%- else -%}
        /* Auto aspect ratio: stretch vertically in list (horizontal) layout to match content height */
        @media screen and (min-width: 991px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card-image-wrapper {
            {%- if block.settings.columns_desktop == '1' -%}
              aspect-ratio: auto !important;
              height: 100% !important;
              min-height: 100% !important;
            {%- endif -%}
          }
        }
        @media screen and (max-width: 990px) and (min-width: 769px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card-image-wrapper {
            {%- if block.settings.columns_tablet == '1' -%}
              aspect-ratio: auto !important;
              height: 100% !important;
              min-height: 100% !important;
            {%- endif -%}
          }
        }
      {%- endif -%}

      /* Card styling */
      {%- if block.settings.card_style == 'flat' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card {
          background: transparent !important;
          border: none !important;
          box-shadow: none !important;
        }
      {%- elsif block.settings.card_style == 'standard' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card {
          background: var(--bg-secondary) !important;
          border: 1px solid var(--border-light) !important;
          box-shadow: none !important;
        }
      {%- endif -%}

      /* Color overrides */
      {%- if block.settings.card_bg_color != blank and block.settings.card_bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card {
          background: {{ block.settings.card_bg_color }} !important;
          background-color: {{ block.settings.card_bg_color }} !important;
          background-image: none !important;
        }
      {%- endif -%}
      {%- if block.settings.card_border_color != blank and block.settings.card_border_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card {
          border-color: {{ block.settings.card_border_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.post_title_color != blank and block.settings.post_title_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card-title a {
          color: {{ block.settings.post_title_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.post_title_hover_color != blank and block.settings.post_title_hover_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card-title a:hover {
          color: {{ block.settings.post_title_hover_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.post_excerpt_color != blank and block.settings.post_excerpt_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card-excerpt {
          color: {{ block.settings.post_excerpt_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.card_badge_bg_color != blank and block.settings.card_badge_bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card-badge {
          background-color: {{ block.settings.card_badge_bg_color }} !important;
          background-image: none !important;
        }
      {%- endif -%}
      {%- if block.settings.card_badge_text_color != blank and block.settings.card_badge_text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card-badge {
          color: {{ block.settings.card_badge_text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.card_category_color != blank and block.settings.card_category_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card-category {
          color: {{ block.settings.card_category_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.post_meta_text_color != blank and block.settings.post_meta_text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-meta-item {
          color: {{ block.settings.post_meta_text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.post_meta_icon_color != blank and block.settings.post_meta_icon_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-meta-item svg {
          color: {{ block.settings.post_meta_icon_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.post_read_more_color != blank and block.settings.post_read_more_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-read-link,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-read-link svg {
          color: {{ block.settings.post_read_more_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.post_read_more_hover_color != blank and block.settings.post_read_more_hover_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-read-link:hover,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-read-link:hover svg {
          color: {{ block.settings.post_read_more_hover_color }} !important;
        }
      {%- endif -%}

      /* Divider line */
      {%- if block.settings.show_divider -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card-bottom {
          border-top: 1px solid var(--border-light) !important;
          padding-top: var(--spacing-md) !important;
        }
      {%- else -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-sb-card-bottom {
          border-top: none !important;
          padding-top: 0 !important;
        }
      {%- endif -%}

      /* Pagination colors */
      {%- if block.settings.pagination_bg_color != blank and block.settings.pagination_bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .catalog-pagination .page-link {
          background-color: {{ block.settings.pagination_bg_color }} !important;
          background-image: none !important;
        }
      {%- endif -%}
      {%- if block.settings.pagination_text_color != blank and block.settings.pagination_text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .catalog-pagination .page-link {
          color: {{ block.settings.pagination_text_color }} !important;
        }
        #shopify-section-{{ section.id }} .catalog-pagination .page-link svg {
          color: {{ block.settings.pagination_text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.pagination_border_color != blank and block.settings.pagination_border_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .catalog-pagination .page-link {
          border-color: {{ block.settings.pagination_border_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.pagination_hover_bg_color != blank and block.settings.pagination_hover_bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .catalog-pagination .page-link:hover {
          background-color: {{ block.settings.pagination_hover_bg_color }} !important;
          border-color: {{ block.settings.pagination_hover_bg_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.pagination_hover_text_color != blank and block.settings.pagination_hover_text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .catalog-pagination .page-link:hover {
          color: {{ block.settings.pagination_hover_text_color }} !important;
        }
        #shopify-section-{{ section.id }} .catalog-pagination .page-link:hover svg {
