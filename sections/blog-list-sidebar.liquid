{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

{%- if section.settings.show_section -%}
<section 
  class="blog-list-sidebar-section color-{{ section.settings.color_scheme }}{% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    
    <div class="blog-sb-container{% unless section.settings.show_sidebar %} no-sidebar{% endunless %}">
      
      {%- comment -%}Main Content Area{%- endcomment -%}
      <div class="blog-sb-main">
        
        {%- comment -%}Header{%- endcomment -%}
        <div class="blog-sb-header">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'breadcrumb' -%}
                <nav class="blog-post-breadcrumb block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" aria-label="Breadcrumb" {{ block.shopify_attributes }}>
                  {%- if block.settings.show_home_link -%}
                    <a href="{{ routes.root_url }}">{{ 'general.home' | t }}</a>
                    {%- if block.settings.show_separator -%}
                      <span class="blog-post-breadcrumb-separator">/</span>
                    {%- endif -%}
                  {%- endif -%}
                  <span class="blog-post-breadcrumb-current" aria-current="page">{{ blog.title | default: section.settings.title }}</span>
                </nav>
              
              {%- when 'title' -%}
                {%- assign title_tag = block.settings.heading_tag | default: 'h1' -%}
                {%- assign title_text = block.settings.title | default: blog.title | default: section.settings.title -%}
                <{{ title_tag }} class="blog-sb-title size-{{ block.settings.font_size | default: 'large' }} block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
                  {{ title_text | replace: '[', '<span>' | replace: ']', '</span>' }}
                </{{ title_tag }}>
              
              {%- when 'article_count' -%}
                {%- if blog.articles_count > 0 -%}
                  <p class="blog-sb-results block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
                    {{ 'blog.showing_articles' | t: count: blog.articles_count }}
                  </p>
                {%- endif -%}
            {%- endcase -%}
          {%- endfor -%}
        </div>

        {%- comment -%}Blog Posts List{%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'article_list' -%}
            <div class="blog-sb-list block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
          {%- paginate blog.articles by block.settings.posts_per_page, window_size: block.settings.pagination_window -%}
            {%- for article in blog.articles -%}
            <article class="blog-sb-card card-style-{{ block.settings.card_style | default: 'glassmorphism' }}{% if block.settings.show_secondary_image %} hover-zoom{% endif %}">
              {%- if block.settings.show_card_image -%}
              <div class="blog-sb-card-image-wrapper">
                {%- if article.image -%}
                  {{ article.image | image_url: width: 1000 | image_tag: loading: 'lazy', sizes: '(min-width: 991px) 60vw, 100vw', alt: article.title, class: 'blog-sb-card-image' }}
                {%- else -%}
                  <div class="blog-sb-card-image-placeholder">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21 15 16 10 5 21"/>
                    </svg>
                  </div>
                {%- endif -%}
                {%- if block.settings.show_card_badge and article.tags.size > 0 -%}
                <span class="blog-sb-card-badge">{{ article.tags.first }}</span>
                {%- endif -%}
              </div>
              {%- endif -%}
              <div class="blog-sb-card-body">
                {%- if block.settings.show_card_category and article.tags.size > 0 -%}
                <span class="blog-sb-card-category">{{ article.tags.first }}</span>
                {%- endif -%}
                <h2 class="blog-sb-card-title">
                  <a href="{{ article.url }}">{{ article.title }}</a>
                </h2>
                {%- if block.settings.show_card_excerpt -%}
                <p class="blog-sb-card-excerpt">
                  {{ article.excerpt_or_content | strip_html | truncate: block.settings.excerpt_length }}
                </p>
                {%- endif -%}
                <div class="blog-sb-card-bottom">
                  <div class="blog-sb-card-meta">
                    {%- if block.settings.show_card_date -%}
                    <span class="blog-sb-meta-item">
                      {%- if block.settings.show_card_date_icon -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                      </svg>
                      {%- endif -%}
                      {{ article.published_at | date: '%b %d, %Y' }}
                    </span>
                    {%- endif -%}
                    {%- if block.settings.show_card_read_time -%}
                    <span class="blog-sb-meta-item">
                      {%- if block.settings.show_card_read_time_icon -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                      </svg>
                      {%- endif -%}
                      {{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min
                    </span>
                    {%- endif -%}
                  </div>
                  {%- if block.settings.show_card_read_more -%}
                  <a href="{{ article.url }}" class="blog-sb-read-link">
                    {%- assign read_more_val = block.settings.read_more_text | default: 'Read more' -%}{%- assign temp_key = 'custom_labels.' | append: read_more_val | handleize -%}{%- assign temp_trans = temp_key | t -%}{%- unless temp_trans contains 'translation' or temp_trans contains 'Translation' -%}{%- assign read_more_val = temp_trans -%}{%- endunless -%}
                    {{ read_more_val }}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="5" y1="12" x2="19" y2="12"/>
                      <polyline points="12 5 19 12 12 19"/>
                    </svg>
                  </a>
                  {%- endif -%}
                </div>
              </div>
            </article>
            {%- endfor -%}

            {%- comment -%}Pagination{%- endcomment -%}
            {%- if block.settings.show_pagination and paginate.pages > 1 -%}
            <nav class="catalog-pagination" role="navigation" aria-label="{{ 'general.pagination.label' | t | default: 'Pagination' }}">
              {%- if block.settings.show_prev_next and paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="page-link page-link--prev" aria-label="{{ 'general.pagination.previous' | t | default: 'Previous page' }}">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="15 18 9 12 15 6" />
                  </svg>
                </a>
              {%- endif -%}

              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" class="page-link">{{ part.title }}</a>
                {%- else -%}
                  {%- if part.title == '&hellip;' -%}
                    <span class="page-link page-link--ellipsis" aria-hidden="true">...</span>
                  {%- else -%}
                    <span class="page-link active" aria-current="page">{{ part.title }}</span>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}

              {%- if block.settings.show_prev_next and paginate.next -%}
                <a href="{{ paginate.next.url }}" class="page-link page-link--next" aria-label="{{ 'general.pagination.next' | t | default: 'Next page' }}">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="9 18 15 12 9 6" />
                  </svg>
                </a>
              {%- endif -%}
            </nav>
            {%- endif -%}
          {%- endpaginate -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.show_sidebar -%}
      {%- comment -%}Sidebar{%- endcomment -%}
      <aside class="blog-sidebar" role="complementary" aria-label="Blog sidebar">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'blog-search-widget' -%}
              {% render 'blog-search-widget', block: block %}

            {%- when 'blog-popular-posts-widget' -%}
              {% render 'blog-popular-posts-widget', block: block %}
            {%- when 'blog-tags-widget' -%}
              {% render 'blog-tags-widget', block: block, blog: blog, article: article %}
            {%- when 'blog-newsletter-widget' -%}
              {% render 'blog-newsletter-widget', block: block %}
            {%- when 'blog-recent-posts-widget' -%}
              {% render 'blog-recent-posts-widget', block: block, blog: blog %}
            {%- when 'blog-social-widget' -%}
              {% render 'blog-social-widget', block: block %}
            {%- when 'blog-custom-widget' -%}
              {% render 'blog-custom-widget', block: block %}
            {%- when 'blog-products-widget' -%}
              {% render 'blog-products-widget', block: block %}
          {%- endcase -%}
        {%- endfor -%}
      </aside>
      {%- endif -%}

    </div>
  </div>
</section>
{%- endif -%}





