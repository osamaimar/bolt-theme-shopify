{{ 'section-blog-newsletter-inline.css' | asset_url | stylesheet_tag }}

<style>
  /* Section Spacing / Visibility overrides */
  #shopify-section-{{ section.id }} .blog-newsletter-inline-section {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .blog-newsletter-inline-section {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Container Width overrides */
  #shopify-section-{{ section.id }} .container-fluid {
    max-width: 100% !important;
    padding-left: var(--spacing-lg, 24px) !important;
    padding-right: var(--spacing-lg, 24px) !important;
  }
  #shopify-section-{{ section.id }} .container-narrow {
    max-width: 800px !important;
    padding-left: var(--spacing-lg, 24px) !important;
    padding-right: var(--spacing-lg, 24px) !important;
  }
  #shopify-section-{{ section.id }} .container {
    max-width: {{ section.settings.max_width | default: 1200 }}px !important;
    padding-left: var(--spacing-lg, 24px) !important;
    padding-right: var(--spacing-lg, 24px) !important;
    margin-left: auto !important;
    margin-right: auto !important;
  }

  /* Blocks Position overrides */
  #shopify-section-{{ section.id }} .blog-newsletter-content {
    display: flex;
    flex-direction: column;
    align-items: {% if section.settings.blocks_position == 'left' %}flex-start{% elsif section.settings.blocks_position == 'right' %}flex-end{% else %}center{% endif %} !important;
    text-align: {% if section.settings.blocks_position == 'left' %}left{% elsif section.settings.blocks_position == 'right' %}right{% else %}center{% endif %} !important;
  }

  /* Heading Highlight styling */
  #shopify-section-{{ section.id }} .blog-newsletter-title span {
    background: var(--highlight-gradient, var(--color-accent)) !important;
    -webkit-background-clip: var(--highlight-clip, text) !important;
    background-clip: var(--highlight-clip, text) !important;
    -webkit-text-fill-color: var(--highlight-fill, transparent) !important;
    display: inline-block;
    color: var(--highlight-color, inherit) !important;
  }

  /* Standard Block Spacing overrides */
  #shopify-section-{{ section.id }} .blog-newsletter-title,
  #shopify-section-{{ section.id }} .blog-newsletter-text,
  #shopify-section-{{ section.id }} .blog-newsletter-form-wrapper {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 0px) !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .blog-newsletter-title,
    #shopify-section-{{ section.id }} .blog-newsletter-text,
    #shopify-section-{{ section.id }} .blog-newsletter-form-wrapper {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 0px)) !important;
    }
  }

  /* Responsive Font Sizing */
  #shopify-section-{{ section.id }} .blog-newsletter-title.size-small { font-size: 1.5rem !important; }
  #shopify-section-{{ section.id }} .blog-newsletter-title.size-medium { font-size: 2rem !important; }
  #shopify-section-{{ section.id }} .blog-newsletter-title.size-large { font-size: 2.5rem !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .blog-newsletter-title.size-small { font-size: 1.25rem !important; }
    #shopify-section-{{ section.id }} .blog-newsletter-title.size-medium { font-size: 1.5rem !important; }
    #shopify-section-{{ section.id }} .blog-newsletter-title.size-large { font-size: 1.8rem !important; }
  }

  #shopify-section-{{ section.id }} .blog-newsletter-text.size-small { font-size: 0.85rem !important; }
  #shopify-section-{{ section.id }} .blog-newsletter-text.size-medium { font-size: 1.05rem !important; }
  #shopify-section-{{ section.id }} .blog-newsletter-text.size-large { font-size: 1.2rem !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .blog-newsletter-text.size-small { font-size: 0.75rem !important; }
    #shopify-section-{{ section.id }} .blog-newsletter-text.size-medium { font-size: 0.95rem !important; }
    #shopify-section-{{ section.id }} .blog-newsletter-text.size-large { font-size: 1.05rem !important; }
  }

  /* Block Specific Advanced Styling overrides */
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'form' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: var(--m-t, 0px) !important;
          margin-bottom: var(--m-b, 0px) !important;
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
            margin-bottom: var(--m-b-m, var(--m-b, 0px)) !important;
          }
        }

        /* Alignment / Margins / Width */
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-newsletter-form {
          width: {{ block.settings.max_width | default: 480 }}px !important;
          max-width: 100% !important;
        }

        /* Typography overrides */
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-newsletter-input,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-newsletter-btn {
          font-size: {% if block.settings.font_size == 'small' %}0.85rem{% elsif block.settings.font_size == 'large' %}1.1rem{% else %}0.95rem{% endif %} !important;
          font-weight: {% if block.settings.font_weight == 'bold' %}var(--font-weight-bold, 700){% else %}var(--font-weight-normal, 400){% endif %} !important;
          font-style: {{ block.settings.font_style | default: 'normal' }} !important;
          text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
          letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
          line-height: {{ block.settings.line_height | default: 120 }}% !important;
        }

        /* Colors - Input */
        {%- if block.settings.input_bg_color != blank and block.settings.input_bg_color != 'rgba(0,0,0,0)' -%}
          #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-newsletter-input {
            background-color: {{ block.settings.input_bg_color }} !important;
          }
        {%- endif -%}
        {%- if block.settings.input_text_color != blank and block.settings.input_text_color != 'rgba(0,0,0,0)' -%}
          #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-newsletter-input {
            color: {{ block.settings.input_text_color }} !important;
          }
          #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-newsletter-input::placeholder {
            color: {{ block.settings.input_text_color }} !important;
            opacity: 0.7 !important;
          }
        {%- endif -%}
        {%- if block.settings.input_border_color != blank and block.settings.input_border_color != 'rgba(0,0,0,0)' -%}
          #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-newsletter-input {
            border-color: {{ block.settings.input_border_color }} !important;
          }
        {%- endif -%}

        /* Colors - Button */
        {%- if block.settings.btn_bg_gradient != blank and block.settings.btn_bg_gradient != 'rgba(0,0,0,0)' -%}
          #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-newsletter-btn {
            background: {{ block.settings.btn_bg_gradient }} !important;
          }
        {%- elsif block.settings.btn_bg_color != blank and block.settings.btn_bg_color != 'rgba(0,0,0,0)' -%}
          #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-newsletter-btn {
            background-color: {{ block.settings.btn_bg_color }} !important;
            background-image: none !important;
          }
        {%- endif -%}
        {%- if block.settings.btn_text_color != blank and block.settings.btn_text_color != 'rgba(0,0,0,0)' -%}
          #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-newsletter-btn {
            color: {{ block.settings.btn_text_color }} !important;
          }
        {%- endif -%}
        {%- if block.settings.btn_hover_bg_color != blank and block.settings.btn_hover_bg_color != 'rgba(0,0,0,0)' -%}
          #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-newsletter-btn:hover {
            background-color: {{ block.settings.btn_hover_bg_color }} !important;
            background-image: none !important;
          }
        {%- endif -%}
        {%- if block.settings.btn_hover_text_color != blank and block.settings.btn_hover_text_color != 'rgba(0,0,0,0)' -%}
          #shopify-section-{{ section.id }} .block-{{ block.id }} .blog-newsletter-btn:hover {
            color: {{ block.settings.btn_hover_text_color }} !important;
          }
        {%- endif -%}
    {%- endcase -%}
  {%- endfor -%}
</style>

{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

{%- if section.settings.show_section -%}
<section 
  class="blog-newsletter-inline-section color-{{ section.settings.color_scheme }}{% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    
    <div class="blog-newsletter">
      <div class="blog-newsletter-content">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'heading' -%}
              {%- assign heading_tag = block.settings.heading_tag | default: 'h2' -%}
              {%- assign h_color = block.settings.highlight_color -%}
              {%- assign h_gradient = block.settings.highlight_gradient -%}
              {%- if block.settings.title != blank -%}
                <{{ heading_tag }} class="blog-newsletter-title block-{{ block.id }} size-{{ block.settings.font_size }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                    {{ block.shopify_attributes }}
                    style="
                      --m-t: {{ block.settings.margin_top }}px; 
                      --m-b: {{ block.settings.margin_bottom }}px; 
                      --m-t-m: {{ block.settings.margin_top_mobile }}px; 
                      --m-b-m: {{ block.settings.margin_bottom_mobile }}px; 
                      font-weight: {% if block.settings.font_weight == 'bold' %}var(--font-weight-bold, 700){% else %}var(--font-weight-normal, 400){% endif %}; 
                      font-style: {{ block.settings.font_style }}; 
                      text-transform: {{ block.settings.text_transform }}; 
                      letter-spacing: {{ block.settings.letter_spacing }}px; 
                      line-height: {{ block.settings.line_height }}%; 
                      text-align: {{ 'center' }};
                      {% if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.text_color }} !important;{% endif %} 
                      {% if block.settings.bg_gradient != blank and block.settings.bg_gradient != 'rgba(0,0,0,0)' %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' %}background: {{ block.settings.bg_color }} !important;{% endif %}
                      {% if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' %}--highlight-gradient: {{ h_gradient }}; --highlight-clip: text; --highlight-fill: transparent; --highlight-color: transparent;
                      {% elsif h_color != blank and h_color != 'rgba(0,0,0,0)' %}--highlight-color: {{ h_color }}; --highlight-gradient: none; --highlight-clip: initial; --highlight-fill: {{ h_color }};
                      {% endif %}
                    ">
                  {{ block.settings.title | replace: '[', '<span>' | replace: ']', '</span>' }}
                </{{ heading_tag }}>
              {%- endif -%}
            
            {%- when 'subheading' -%}
              {%- if block.settings.subheading != blank -%}
                <p class="blog-newsletter-text block-{{ block.id }} size-{{ block.settings.font_size }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                   {{ block.shopify_attributes }}
                   style="
                     --m-t: {{ block.settings.margin_top }}px; 
                     --m-b: {{ block.settings.margin_bottom }}px; 
                     --m-t-m: {{ block.settings.margin_top_mobile }}px; 
                     --m-b-m: {{ block.settings.margin_bottom_mobile }}px; 
                     width: 100% !important; max-width: {{ block.settings.max_width }}px !important;
                     margin-left: {% if section.settings.blocks_position == 'left' %}0{% elsif section.settings.blocks_position == 'right' %}auto{% else %}auto{% endif %};
                     margin-right: {% if section.settings.blocks_position == 'right' %}0{% elsif section.settings.blocks_position == 'left' %}auto{% else %}auto{% endif %};
                     text-align: {{ 'center' }};
                     font-weight: {% if block.settings.font_weight == 'bold' %}var(--font-weight-bold, 700){% else %}var(--font-weight-normal, 400){% endif %}; 
                     font-style: {{ block.settings.font_style }}; 
                     text-transform: {{ block.settings.text_transform }}; 
                     letter-spacing: {{ block.settings.letter_spacing }}px; 
                     line-height: {{ block.settings.line_height }}em; 
                     {% if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.text_color }} !important;{% endif %} 
                     {% if block.settings.bg_gradient != blank and block.settings.bg_gradient != 'rgba(0,0,0,0)' %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' %}background: {{ block.settings.bg_color }} !important;{% endif %}
                   ">
                  {{ block.settings.subheading }}
                </p>
              {%- endif -%}
            
            {%- when 'form' -%}
              <div class="blog-newsletter-form-wrapper block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                   {{ block.shopify_attributes }}
                   style="
                     --m-t: {{ block.settings.margin_top }}px; 
                     --m-b: {{ block.settings.margin_bottom }}px; 
                     --m-t-m: {{ block.settings.margin_top_mobile }}px; 
                     --m-b-m: {{ block.settings.margin_bottom_mobile }}px; 
                     text-align: {{ section.settings.blocks_position }};
                   ">
                {%- capture form_id -%}nl-form-{{ section.id }}-{{ block.id }}{%- endcapture -%}
                {%- form 'customer', id: form_id, class: 'blog-newsletter-form' -%}
                  {%- if form.posted_successfully? -%}
                    <div class="blog-newsletter-success">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                        <polyline points="22 4 12 14.01 9 11.01"/>
                      </svg>
                      <span>{{ 'newsletter.success' | t | default: 'Thanks for subscribing!' }}</span>
                    </div>
                  {%- else -%}
                    <input type="hidden" name="contact[tags]" value="newsletter">
                    {%- assign default_placeholder_val = 'sections.footer.newsletter.placeholder' | t -%}{%- assign placeholder_val = block.settings.placeholder | default: default_placeholder_val -%}
                    {%- assign default_btn_text_val = 'sections.footer.newsletter.submit' | t -%}{%- assign btn_text_val = block.settings.button_text | default: default_btn_text_val -%}
                    <input 
                      type="email" 
                      name="contact[email]" 
                      class="blog-newsletter-input" 
                      placeholder="{{ placeholder_val }}"
                      required
                      aria-label="{{ placeholder_val }}"
                    >
                    <button type="submit" class="blog-newsletter-btn">
                      {{ btn_text_val }}
                    </button>
                    
                    {%- if form.errors -%}
                    <div class="blog-newsletter-error">
                      {{ form.errors | default_errors }}
                    </div>
                    {%- endif -%}
                  {%- endif -%}
                {%- endform -%}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Blog Newsletter Inline",
  "tag": "section",
  "class": "section-blog-newsletter-inline",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "standard",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "standard", "label": "Standard" },
        { "value": "narrow", "label": "Narrow" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Max Container Width",
      "default": 1200
    },
    {
      "type": "select",
      "id": "blocks_position",
      "label": "Blocks Position",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 40
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1",
      "options": [
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "inverse", "label": "Inverse" },
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "General Settings"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading text",
          "default": "Subscribe for Tech Updates",
          "info": "Use [text] to highlight text"
        },
        {
          "type": "select",
          "id": "heading_tag",
          "label": "Heading Tag",
          "default": "h2",
          "options": [
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" },
            { "value": "h4", "label": "H4" },
            { "value": "h5", "label": "H5" },
            { "value": "h6", "label": "H6" },
            { "value": "div", "label": "div" },
            { "value": "p", "label": "p" }
          ]
        },
        {
          "type": "header",
          "content": "Visibility"
        },
        {
          "type": "checkbox",
          "id": "show_on_desktop",
          "label": "Show on Desktop",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_on_mobile",
          "label": "Show on Mobile",
          "default": true
        },
        {
          "type": "header",
          "content": "Layout"
        },
        
        {
          "type": "range",
          "id": "margin_top",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "Top margin (desktop)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "Bottom margin (desktop)",
          "default": 12
        },
        {
          "type": "range",
          "id": "margin_top_mobile",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "Top margin (mobile)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom_mobile",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "Bottom margin (mobile)",
          "default": 10
        },
        {
          "type": "header",
          "content": "Typography"
        },
        {
          "type": "select",
          "id": "font_size",
          "label": "Font Size",
          "default": "large",
          "options": [
            { "value": "small", "label": "Small" },
            { "value": "medium", "label": "Medium" },
            { "value": "large", "label": "Large" }
          ]
        },
        {
          "type": "select",
          "id": "font_weight",
          "label": "Font Weight",
          "default": "bold",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "bold", "label": "Bold" }
          ]
        },
        {
          "type": "select",
          "id": "font_style",
          "label": "Font Style",
          "default": "normal",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "italic", "label": "Italic" }
          ]
        },
        {
          "type": "select",
          "id": "text_transform",
          "label": "Text Transform",
          "default": "none",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "uppercase", "label": "Uppercase" },
            { "value": "lowercase", "label": "Lowercase" },
            { "value": "capitalize", "label": "Capitalize" }
          ]
        },
        {
          "type": "range",
          "id": "letter_spacing",
          "min": 0,
          "max": 10,
          "step": 1,
          "unit": "px",
          "label": "Letter Spacing",
          "default": 0
        },
        {
          "type": "range",
          "id": "line_height",
          "min": 80,
          "max": 200,
          "step": 5,
          "unit": "%",
          "label": "Line Height",
          "default": 120
        },
        {
          "type": "header",
          "content": "Colors"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color"
        },
