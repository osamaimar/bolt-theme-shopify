{{ 'section-blog-sidebar-cta.css' | asset_url | stylesheet_tag }}

<style>
  /* Section Spacing / Visibility overrides */
  #shopify-section-{{ section.id }} .blog-sidebar-cta-section {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .blog-sidebar-cta-section {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Container Width overrides */
  #shopify-section-{{ section.id }} .container-fluid {
    max-width: 100% !important;
    padding-left: var(--spacing-lg, 24px) !important;
    padding-right: var(--spacing-lg, 24px) !important;
  }
  #shopify-section-{{ section.id }} .container-narrow {
    max-width: 800px !important;
    padding-left: var(--spacing-lg, 24px) !important;
    padding-right: var(--spacing-lg, 24px) !important;
    margin-left: auto !important;
    margin-right: auto !important;
  }
  #shopify-section-{{ section.id }} .container {
    max-width: {{ section.settings.max_width | default: 1200 }}px !important;
    padding-left: var(--spacing-lg, 24px) !important;
    padding-right: var(--spacing-lg, 24px) !important;
    margin-left: auto !important;
    margin-right: auto !important;
  }
  #shopify-section-{{ section.id }} .blog-sidebar-cta-wrapper {
    max-width: 100% !important;
  }

  /* Blocks Position overrides - Scoped to CTA Wrapper */
  #shopify-section-{{ section.id }} .blog-sidebar-cta-wrapper {
    display: flex;
    flex-direction: column;
    align-items: {% if section.settings.blocks_position == 'left' %}flex-start{% elsif section.settings.blocks_position == 'right' %}flex-end{% else %}center{% endif %} !important;
    text-align: {% if section.settings.blocks_position == 'left' %}left{% elsif section.settings.blocks_position == 'right' %}right{% else %}center{% endif %} !important;
  }

  /* Icon margin alignment override to respect blocks_position */
  #shopify-section-{{ section.id }} .blog-sidebar-cta-icon {
    {%- if section.settings.blocks_position == 'left' -%}
      margin-left: 0 !important;
      margin-right: auto !important;
    {%- elsif section.settings.blocks_position == 'right' -%}
      margin-left: auto !important;
      margin-right: 0 !important;
    {%- else -%}
      margin-left: auto !important;
      margin-right: auto !important;
    {%- endif -%}
  }

  /* Standard Block Spacing overrides */
  #shopify-section-{{ section.id }} .blog-sidebar-cta-icon,
  #shopify-section-{{ section.id }} .blog-sidebar-cta-heading,
  #shopify-section-{{ section.id }} .blog-sidebar-cta-text,
  #shopify-section-{{ section.id }} .blog-sidebar-cta-btn {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 0px) !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .blog-sidebar-cta-icon,
    #shopify-section-{{ section.id }} .blog-sidebar-cta-heading,
    #shopify-section-{{ section.id }} .blog-sidebar-cta-text,
    #shopify-section-{{ section.id }} .blog-sidebar-cta-btn {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 0px)) !important;
    }
  }

  /* Heading Highlight styling */
  #shopify-section-{{ section.id }} .blog-sidebar-cta-heading span {
    background: var(--highlight-gradient, var(--color-accent)) !important;
    -webkit-background-clip: var(--highlight-clip, text) !important;
    background-clip: var(--highlight-clip, text) !important;
    -webkit-text-fill-color: var(--highlight-fill, transparent) !important;
    display: inline-block;
    color: var(--highlight-color, inherit) !important;
  }

  /* Block-specific overrides */
  {%- for block in section.blocks -%}
    .block-{{ block.id }} {
      --m-t: {{ block.settings.margin_top | default: 0 }}px;
      --m-b: {{ block.settings.margin_bottom | default: 0 }}px;
      --m-t-m: {{ block.settings.margin_top_mobile | default: block.settings.margin_top | default: 0 }}px;
      --m-b-m: {{ block.settings.margin_bottom_mobile | default: block.settings.margin_bottom | default: 0 }}px;
    }

    {%- if 'center' != blank -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }} {
        text-align: {{ 'center' }} !important;
      }
    {%- endif -%}

    {%- if block.type == 'icon' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-icon {
        width: {{ block.settings.icon_size | default: 64 }}px !important;
        height: {{ block.settings.icon_size | default: 64 }}px !important;
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-icon svg {
        {%- assign svg_size = block.settings.icon_size | default: 64 | times: 0.4375 | round -%}
        width: {{ svg_size }}px !important;
        height: {{ svg_size }}px !important;
      }
      {%- if block.settings.icon_color != blank and block.settings.icon_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-icon {
          color: {{ block.settings.icon_color }} !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-icon svg {
          color: {{ block.settings.icon_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.bg_gradient != blank and block.settings.bg_gradient != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-icon {
          background: {{ block.settings.bg_gradient }} !important;
        }
      {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-icon {
          background: {{ block.settings.bg_color }} !important;
        }
      {%- endif -%}

    {%- elsif block.type == 'heading' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-heading {
        font-size: {% if block.settings.font_size == 'small' %}1.5rem{% elsif block.settings.font_size == 'large' %}2.2rem{% else %}1.8rem{% endif %} !important;
        font-weight: {% if block.settings.font_weight == 'bold' %}700{% elsif block.settings.font_weight == 'medium' %}500{% else %}400{% endif %} !important;
        font-style: {{ block.settings.font_style | default: 'normal' }} !important;
        text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
        letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
        line-height: {{ block.settings.line_height | default: 130 }}% !important;
      }
      {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-heading {
          color: {{ block.settings.text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.bg_gradient != blank and block.settings.bg_gradient != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-heading {
          background: {{ block.settings.bg_gradient }} !important;
        }
      {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-heading {
          background-color: {{ block.settings.bg_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.highlight_gradient != blank and block.settings.highlight_gradient != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-heading span {
          background: {{ block.settings.highlight_gradient }} !important;
          -webkit-background-clip: text !important;
          background-clip: text !important;
          -webkit-text-fill-color: transparent !important;
          color: transparent !important;
          display: inline-block !important;
        }
      {%- elsif block.settings.highlight_color != blank and block.settings.highlight_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-heading span {
          color: {{ block.settings.highlight_color }} !important;
          -webkit-text-fill-color: {{ block.settings.highlight_color }} !important;
          background: none !important;
        }
      {%- endif -%}

    {%- elsif block.type == 'subheading' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-text {
        font-size: {% if block.settings.font_size == 'small' %}0.85rem{% elsif block.settings.font_size == 'large' %}1.15rem{% else %}0.95rem{% endif %} !important;
        font-weight: {% if block.settings.font_weight == 'bold' %}700{% elsif block.settings.font_weight == 'medium' %}500{% else %}400{% endif %} !important;
        font-style: {{ block.settings.font_style | default: 'normal' }} !important;
        text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
        letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
        line-height: {{ block.settings.line_height | default: 170 }}% !important;
        max-width: {{ block.settings.max_width | default: 500 }}px !important;
        width: 100% !important;
      }
      {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-text {
          color: {{ block.settings.text_color }} !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-text * {
          color: {{ block.settings.text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.bg_gradient != blank and block.settings.bg_gradient != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-text {
          background: {{ block.settings.bg_gradient }} !important;
        }
      {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-text {
          background-color: {{ block.settings.bg_color }} !important;
        }
      {%- endif -%}

    {%- elsif block.type == 'button' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-btn {
        font-size: {% if block.settings.font_size == 'small' %}0.85rem{% elsif block.settings.font_size == 'large' %}1.15rem{% else %}0.95rem{% endif %} !important;
        font-weight: {% if block.settings.font_weight == 'bold' %}700{% elsif block.settings.font_weight == 'medium' %}500{% else %}400{% endif %} !important;
        font-style: {{ block.settings.font_style | default: 'normal' }} !important;
        text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
        letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
        line-height: {{ block.settings.line_height | default: 120 }}% !important;
      }
      {%- if block.settings.btn_bg_gradient != blank and block.settings.btn_bg_gradient != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-btn {
          background: {{ block.settings.btn_bg_gradient }} !important;
        }
      {%- elsif block.settings.btn_bg_color != blank and block.settings.btn_bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-btn {
          background-color: {{ block.settings.btn_bg_color }} !important;
          background-image: none !important;
        }
      {%- endif -%}
      {%- if block.settings.btn_text_color != blank and block.settings.btn_text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-btn {
          color: {{ block.settings.btn_text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.btn_hover_bg_color != blank and block.settings.btn_hover_bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-btn:hover {
          background-color: {{ block.settings.btn_hover_bg_color }} !important;
          background-image: none !important;
        }
      {%- endif -%}
      {%- if block.settings.btn_hover_text_color != blank and block.settings.btn_hover_text_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-btn:hover {
          color: {{ block.settings.btn_hover_text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.arrow_color != blank and block.settings.arrow_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-btn svg {
          color: {{ block.settings.arrow_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.arrow_hover_color != blank and block.settings.arrow_hover_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-btn:hover svg {
          color: {{ block.settings.arrow_hover_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.btn_shadow_color != blank and block.settings.btn_shadow_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.blog-sidebar-cta-btn:hover {
          box-shadow: 0 6px 20px {{ block.settings.btn_shadow_color }} !important;
        }
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
</style>

{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

{%- if section.settings.show_section -%}
<section 
  class="blog-sidebar-cta-section color-{{ section.settings.color_scheme }}{% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    
    <div class="blog-sidebar-cta-wrapper">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'icon' -%}
            <div class="blog-sidebar-cta-icon block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
              {%- if block.settings.custom_icon_svg != blank -%}
                {{ block.settings.custom_icon_svg }}
              {%- else -%}
                {%- case block.settings.icon -%}
                  {%- when 'message-circle' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                  {%- when 'phone' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  {%- when 'mail' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                  {%- when 'help-circle' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                  {%- when 'life-buoy' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="4.93" y1="4.93" x2="9.17" y2="9.17"/><line x1="14.83" y1="14.83" x2="19.07" y2="19.07"/><line x1="14.83" y1="9.17" x2="19.07" y2="4.93"/><line x1="14.83" y1="9.17" x2="18.36" y2="5.64"/><line x1="4.93" y1="19.07" x2="9.17" y2="14.83"/></svg>
                  {%- when 'headphones' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
                  {%- when 'chat' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                  {%- when 'support' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                  {%- when 'rss' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
                  {%- when 'bookmark' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
                  {%- when 'edit' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  {%- else -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                {%- endcase -%}
              {%- endif -%}
            </div>
            
          {%- when 'heading' -%}
            {%- if block.settings.title != blank -%}
              {%- assign heading_tag = block.settings.heading_tag | default: 'h2' -%}
              <{{ heading_tag }} class="blog-sidebar-cta-heading size-{{ block.settings.font_size | default: 'medium' }} block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
                {{ block.settings.title | replace: '[', '<span>' | replace: ']', '</span>' }}
              </{{ heading_tag }}>
            {%- endif -%}
            
          {%- when 'subheading' -%}
            {%- if block.settings.subheading != blank -%}
              <div class="blog-sidebar-cta-text block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
                {{ block.settings.subheading }}
              </div>
            {%- endif -%}
            
          {%- when 'button' -%}
            {%- if block.settings.button_text != blank and block.settings.button_link != blank -%}
              <a href="{{ block.settings.button_link }}" class="blog-sidebar-cta-btn block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
                {{ block.settings.button_text }}
                {%- if block.settings.show_arrow -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
                {%- endif -%}
              </a>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>

  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Blog Sidebar CTA",
  "tag": "section",
  "class": "section-blog-sidebar-cta",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
