{{ 'section-product.css' | asset_url | stylesheet_tag }}

{%- if section.settings.show_section -%}
{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}
<style>
  div#shopify-section-{{ section.id }} { 
    padding: 0 !important; 
    margin: 0 !important;
  }
  div#shopify-section-{{ section.id }} .pd-breadcrumb-outer {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
    {% if section.settings.bg_color != blank %}--section-bg: {{ section.settings.bg_color }};{% endif %}
    {% if section.settings.bg_gradient != blank %}--section-gradient: {{ section.settings.bg_gradient }};{% endif %}
    {% if section.settings.text_color != blank %}--section-text: {{ section.settings.text_color }};{% endif %}
  }
  #shopify-section-{{ section.id }} .pd-breadcrumb {
    justify-content: {% if 'left' == 'center' %}center{% elsif 'left' == 'right' %}flex-end{% else %}flex-start{% endif %};
  }
  @media screen and (max-width: 768px) {
    div#shopify-section-{{ section.id }} .pd-breadcrumb-outer {
      padding-top: {{ section.settings.padding_top_mobile }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
    }
  }
  #shopify-section-{{ section.id }} .pd-breadcrumb a,
  #shopify-section-{{ section.id }} .pd-breadcrumb svg {
    {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }};{% endif %}
  }
  #shopify-section-{{ section.id }} .pd-breadcrumb-current {
    {% if section.settings.highlight_text_color != blank %}
      color: {{ section.settings.highlight_text_color }} !important;
    {% elsif section.settings.text_color != blank %}
      color: {{ section.settings.text_color }} !important;
    {% endif %}
    {% if section.settings.highlight_text_gradient != blank %}
      background: {{ section.settings.highlight_text_gradient }};
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    {% endif %}
  }
  .pd-breadcrumb {
    display: inline-flex;
    align-items: center;
  }
</style>
<div class="pd-breadcrumb-outer {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
     style="background: var(--section-gradient, var(--section-bg, var(--bg-primary)));">
  <div class="pd-page {% if section.settings.container_width == 'full' %}pd-page--full{% elsif section.settings.container_width == 'narrow' %}pd-page--narrow{% endif %}"
       style="{% if section.settings.max_width != blank %}max-width: {{ section.settings.max_width }}px;{% endif %}">
    <nav class="pd-breadcrumb" id="pd-breadcrumb" aria-label="Breadcrumb" style="font-size: {{ section.settings.font_size }}rem; font-weight: {% if section.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ section.settings.font_style }}; text-transform: {{ section.settings.text_transform }}; letter-spacing: {{ section.settings.letter_spacing }}px; line-height: {{ section.settings.line_height }};">
      <a href="{{ routes.root_url }}">{{ 'general.breadcrumb.home' | t }}</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
      
      {%- if template contains 'product' -%}
        {%- if collection -%}
          <a href="{{ collection.url }}">{{ collection.title }}</a>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        {%- else -%}
          <a href="{{ routes.all_products_collection_url }}">{{ 'general.breadcrumb.products' | t }}</a>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        {%- endif -%}
        <span class="pd-breadcrumb-current">{{ product.title }}</span>
      {%- elsif template contains 'collection' and collection.handle -%}
        <span class="pd-breadcrumb-current">{{ collection.title }}</span>
      {%- elsif template contains 'blog' -%}
        <span class="pd-breadcrumb-current">{{ blog.title }}</span>
      {%- elsif template contains 'article' -%}
        <a href="{{ blog.url }}">{{ blog.title }}</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="pd-breadcrumb-current">{{ article.title }}</span>
      {%- elsif template contains 'page' -%}
        <span class="pd-breadcrumb-current">{{ page.title }}</span>
      {%- else -%}
        <span class="pd-breadcrumb-current">{{ page_title }}</span>
      {%- endif -%}
    </nav>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": {{ 'general.breadcrumb.home' | t | json }},
            "item": {{ shop.url | append: routes.root_url | json }}
          }
          {%- assign position = 2 -%}
          {%- if template contains 'product' -%}
            {%- if collection -%}
              ,{
                "@type": "ListItem",
                "position": {{ position }},
                "name": {{ collection.title | json }},
                "item": {{ shop.url | append: collection.url | json }}
              }
              {%- assign position = position | plus: 1 -%}
            {%- else -%}
              ,{
                "@type": "ListItem",
                "position": {{ position }},
                "name": {{ 'general.breadcrumb.products' | t | json }},
                "item": {{ shop.url | append: routes.all_products_collection_url | json }}
              }
              {%- assign position = position | plus: 1 -%}
            {%- endif -%}
            ,{
              "@type": "ListItem",
              "position": {{ position }},
              "name": {{ product.title | json }},
              "item": {{ shop.url | append: product.url | json }}
            }
          {%- elsif template contains 'collection' and collection.handle -%}
            ,{
              "@type": "ListItem",
              "position": {{ position }},
              "name": {{ collection.title | json }},
              "item": {{ shop.url | append: collection.url | json }}
            }
          {%- elsif template contains 'blog' -%}
            ,{
              "@type": "ListItem",
              "position": {{ position }},
              "name": {{ blog.title | json }},
              "item": {{ shop.url | append: blog.url | json }}
            }
          {%- elsif template contains 'article' -%}
            ,{
              "@type": "ListItem",
              "position": {{ position }},
              "name": {{ blog.title | json }},
              "item": {{ shop.url | append: blog.url | json }}
            }
            {%- assign position = position | plus: 1 -%}
            ,{
              "@type": "ListItem",
              "position": {{ position }},
              "name": {{ article.title | json }},
              "item": {{ shop.url | append: article.url | json }}
            }
          {%- elsif template contains 'page' -%}
            ,{
              "@type": "ListItem",
              "position": {{ position }},
              "name": {{ page.title | json }},
              "item": {{ shop.url | append: page.url | json }}
            }
          {%- else -%}
            ,{
              "@type": "ListItem",
              "position": {{ position }},
              "name": {{ page_title | json }},
              "item": {{ canonical_url | json }}
            }
          {%- endif -%}
        ]
      }
    </script>
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Breadcrumb",
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "standard",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "narrow", "label": "Narrow" },
        { "value": "full", "label": "Full Width" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Max Width",
      "default": 1400
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 0.5,
      "max": 2.0,
      "step": 0.1,
      "unit": "rem",
      "label": "Font size",
      "default": 0.9
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font Weight",
      "default": "normal",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "bold", "label": "Bold" }
      ]
    },
    {
      "type": "select",
      "id": "font_style",
      "label": "Font Style",
      "default": "normal",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "italic", "label": "Italic" }
      ]
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text Transform",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ]
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": -5,
      "max": 10,
      "step": 0.5,
      "unit": "px",
      "label": "Letter Spacing",
      "default": 0
    },
    {
      "type": "range",
      "id": "line_height",
      "min": 0.8,
      "max": 2.0,
      "step": 0.1,
      "unit": "em",
      "label": "Line Height",
      "default": 1.2
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 0
    },

    {
      "type": "header",
      "content": "Colors"
    },
    { "type": "color", "id": "text_color", "label": "Text Color" },
    { "type": "color", "id": "bg_color", "label": "Background Color" },
    { "type": "color_background", "id": "bg_gradient", "label": "Background Gradient" },
    { "type": "color", "id": "highlight_text_color", "label": "Highlight Text Color" },
    { "type": "color_background", "id": "highlight_text_gradient", "label": "Highlight Text Gradient" }
  ],
  "presets": [
    {
      "name": "Breadcrumb"
    }
  ]
}
{% endschema %}

