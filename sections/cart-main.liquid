<script>
  (function() {
    var updateBtn = document.getElementById('cart-update-btn');
    var cartForm = document.getElementById('cart-form');

    // Function to check if update button is hidden
    function isUpdateButtonHidden() {
      return updateBtn && updateBtn.classList.contains('hidden');
    }

    // Function to highlight update button when quantity changes
    function highlightUpdateButton() {
      if (updateBtn && !isUpdateButtonHidden()) {
        updateBtn.classList.add('needs-update');
      }
    }

    // Function to remove highlight from update button
    function removeHighlight() {
      if (updateBtn) {
        updateBtn.classList.remove('needs-update');
      }
    }

    // Function to submit form (for auto-refresh when update button is hidden)
    function submitForm() {
      if (cartForm) {
        cartForm.submit();
      }
    }

    // Quantity button handlers
    document.querySelectorAll('.qty-decrease').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var input = this.parentElement.querySelector('.qty-value');
        var val = parseInt(input.value, 10);
        if (val > 0) {
          input.value = val - 1;
          if (isUpdateButtonHidden()) {
            submitForm();
          } else {
            highlightUpdateButton();
          }
        }
      });
    });

    document.querySelectorAll('.qty-increase').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var input = this.parentElement.querySelector('.qty-value');
        var val = parseInt(input.value, 10);
        if (val < 999) {
          input.value = val + 1;
          if (isUpdateButtonHidden()) {
            submitForm();
          } else {
            highlightUpdateButton();
          }
        }
      });
    });

    // Handle quantity input changes
    document.querySelectorAll('.qty-value').forEach(function(input) {
      input.addEventListener('change', function() {
        if (isUpdateButtonHidden()) {
          submitForm();
        } else {
          highlightUpdateButton();
        }
      });
    });

    // Native form submission handles the update button via this click handler
    if (updateBtn) {
      updateBtn.addEventListener('click', function() {
        removeHighlight();
        var form = document.getElementById('cart-form');
        if (form) {
          // Add a temporary hidden input to trigger the 'update' action in Shopify
          var updateInput = document.createElement('input');
          updateInput.type = 'hidden';
          updateInput.name = 'update';
          updateInput.value = 'update';
          form.appendChild(updateInput);
          form.submit();
        }
      });
    }
  })();
</script>

