{{ 'section-cart-main.css' | asset_url | stylesheet_tag }}
{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

<style>
.cart-note-wrapper {
  margin-top: 30px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.cart-note-label {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--section-text, var(--text-primary));
}
.cart-note-textarea {
  min-height: 120px;
  padding: 15px;
  border-radius: var(--radius-md, 8px);
  border: 1px solid var(--border-medium, rgba(255, 255, 255, 0.15));
  background: var(--color-white-2, rgba(255, 255, 255, 0.02));
  color: var(--section-text, var(--text-primary));
  font-family: inherit;
  font-size: 0.9rem;
  resize: vertical;
  outline: none;
  transition: border-color 0.3s ease;
}
.cart-note-textarea:focus {
  border-color: var(--color-accent, #3b82f6);
}
.cart-discounts-list {
  list-style: none;
  padding: 0;
  margin: 6px 0 0;
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.cart-discount-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: 6px;
  padding: 3px 10px;
  border-radius: 6px;
  background: var(--color-accent-secondary-10);
  border: 1px solid var(--color-accent-secondary-20);
  color: var(--color-accent-secondary);
  font-size: var(--font-size-xs, 12px);
  font-weight: var(--font-weight-semibold, 600);
  line-height: 1.2;
  max-width: 100%;
  overflow: hidden;
  vertical-align: middle;
}
.cart-discount-badge .sp-badge__label {
  white-space: normal;
  text-overflow: clip;
  max-width: none;
}
</style>

{%- if section.settings.show_section -%}
  {%- assign cart_table_block = nil -%}
  {%- assign cart_totals_block = nil -%}
  {%- assign cart_note_block = nil -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'cart_table' -%}
      {%- assign cart_table_block = block -%}
    {%- endif -%}
    {%- if block.type == 'cart_totals' -%}
      {%- assign cart_totals_block = block -%}
    {%- endif -%}
    {%- if block.type == 'cart_note' -%}
      {%- assign cart_note_block = block -%}
    {%- endif -%}
  {%- endfor -%}

  {%- assign grid_cols = 0 -%}
  {%- if cart_table_block -%}
    {%- if cart_table_block.settings.show_product_column -%}{%- assign grid_cols = grid_cols | plus: 3 -%}{%- endif -%}
    {%- if cart_table_block.settings.show_price_column -%}{%- assign grid_cols = grid_cols | plus: 1 -%}{%- endif -%}
    {%- if cart_table_block.settings.show_quantity_column -%}{%- assign grid_cols = grid_cols | plus: 1.5 -%}{%- endif -%}
    {%- if cart_table_block.settings.show_total_column -%}{%- assign grid_cols = grid_cols | plus: 1 -%}{%- endif -%}
    {%- if cart_table_block.settings.show_remove_column -%}{%- assign grid_cols = grid_cols | plus: 0.5 -%}{%- endif -%}
  {%- endif -%}

<section 
  class="cart-main-section color-{{ section.settings.color_scheme }} section-{{ section.id }}{% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}"
  style="--section-bg: {% if section.settings.color_scheme == 'background-1' %}var(--bg-primary){% elsif section.settings.color_scheme == 'background-2' %}var(--bg-secondary){% elsif section.settings.color_scheme == 'accent-1' %}var(--color-primary){% elsif section.settings.color_scheme == 'accent-2' %}var(--color-accent){% else %}var(--bg-primary){% endif %}; --section-text: {% if section.settings.color_scheme == 'accent-1' %}var(--text-inverse){% elsif section.settings.color_scheme == 'accent-2' %}var(--bg-primary){% elsif section.settings.color_scheme == 'inverse' %}var(--text-inverse){% else %}var(--text-primary){% endif %}; --grid-template: {% if cart_table_block %}{% if cart_table_block.settings.show_product_column %}3fr {% endif %}{% if cart_table_block.settings.show_price_column %}1fr {% endif %}{% if cart_table_block.settings.show_quantity_column %}1.5fr {% endif %}{% if cart_table_block.settings.show_total_column %}1fr {% endif %}{% if cart_table_block.settings.show_remove_column %}40px{% endif %}{% else %}3fr 1fr 1.5fr 1fr 40px{% endif %};"
>
  <div class="cart-container {% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% endif %}"
       style="{% if section.settings.container_width != 'full' %}max-width: {{ section.settings.max_width | default: 1200 }}px;{% endif %} margin: 0 auto;">
    
    {%- for block in section.blocks -%}
      {%- case block.type -%}

        {%- when 'header' -%}
          {%- assign heading_tag = block.settings.heading_tag | default: 'h1' -%}
          {%- assign h_color = block.settings.highlight_color -%}
          {%- assign h_gradient = block.settings.highlight_gradient -%}
          <div class="cart-header-title {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
               {{ block.shopify_attributes }}
               style="
                 --m-t: {{ block.settings.margin_top | default: 0 }}px; 
                 --m-b: {{ block.settings.margin_bottom | default: 24 }}px; 
                 --m-t-m: {{ block.settings.margin_top_mobile | default: 0 }}px; 
                 --m-b-m: {{ block.settings.margin_bottom_mobile | default: 16 }}px; 
                 margin-top: var(--m-t) !important;
                 margin-bottom: var(--m-b) !important;
                 text-align: center;
                 {% if block.settings.text_color != blank %}color: {{ block.settings.text_color }} !important;{% endif %}
                 {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background-color: {{ block.settings.bg_color }} !important;{% endif %}
                 {% if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' %}--highlight-gradient: {{ h_gradient }}; --highlight-clip: text; --highlight-fill: transparent; --highlight-color: transparent;
                 {% elsif h_color != blank and h_color != 'rgba(0,0,0,0)' %}--highlight-color: {{ h_color }}; --highlight-gradient: none; --highlight-clip: initial; --highlight-fill: {{ h_color }};
                 {% endif %}
               ">
            <{{ heading_tag }}
               style="
                 margin: 0 !important;
                 font-size: {% if block.settings.font_size == 'small' %}24px{% elsif block.settings.font_size == 'large' %}48px{% else %}36px{% endif %} !important;
                 font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %} !important; 
                 font-style: {{ block.settings.font_style | default: 'normal' }}; 
                 text-transform: {{ block.settings.text_transform | default: 'none' }}; 
                 letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px; 
                 line-height: {{ block.settings.line_height | default: 120 }}% !important;
               "
            >
              {{ block.settings.title | replace: '[', '<span>' | replace: ']', '</span>' }}
              {%- if block.settings.show_cart_count and cart.item_count > 0 -%}
                <span> ({{ cart.item_count }})</span>
              {%- endif -%}
            </{{ heading_tag }}>
          </div>
      {%- endcase -%}
    {%- endfor -%}

    {%- if cart.item_count > 0 -%}
      {%- if cart_table_block or cart_totals_block -%}
      <form action="{{ routes.cart_url }}" method="post" id="cart-form">
      <div class="cart-grid">
        {%- if cart_table_block -%}
        {%- comment -%}Left Column: Cart Items{%- endcomment -%}
        <div class="cart-items-column" {{ cart_table_block.shopify_attributes }}>
            <div class="cart-list-wrapper">
              {%- comment -%}Table Header{%- endcomment -%}
              <div class="cart-row cart-heading-row">
                {%- assign default_product_label = 'cart.table_product' | t -%}{%- assign product_label = cart_table_block.settings.product_label | default: default_product_label -%}
                {%- assign default_price_label = 'cart.table_price' | t -%}{%- assign price_label = cart_table_block.settings.price_label | default: default_price_label -%}
                {%- assign default_quantity_label = 'cart.table_qty' | t -%}{%- assign quantity_label = cart_table_block.settings.quantity_label | default: default_quantity_label -%}
                {%- assign default_total_label = 'cart.table_total' | t -%}{%- assign total_label = cart_table_block.settings.total_label | default: default_total_label -%}
                <div class="cart-col{% unless cart_table_block.settings.show_product_column %} hidden{% endunless %}">{{ product_label }}</div>
                <div class="cart-col{% unless cart_table_block.settings.show_price_column %} hidden{% endunless %}">{{ price_label }}</div>
                <div class="cart-col{% unless cart_table_block.settings.show_quantity_column %} hidden{% endunless %}">{{ quantity_label }}</div>
                <div class="cart-col{% unless cart_table_block.settings.show_total_column %} hidden{% endunless %}">{{ total_label }}</div>
                <div class="cart-col cart-remove-col{% unless cart_table_block.settings.show_remove_column %} hidden{% endunless %}"></div>
              </div>

              {%- for item in cart.items -%}
                <div class="cart-row" data-cart-item data-line="{{ forloop.index }}">
                  {%- comment -%}Product Cell{%- endcomment -%}
                  <div class="cart-product-cell{% unless cart_table_block.settings.show_product_column %} hidden{% endunless %}">
                    <div class="cart-icon" aria-hidden="true">
                      {%- if item.image -%}
                        {{ item.image | image_url: width: 48 | image_tag: loading: 'lazy', alt: item.product.title, class: 'cart-item-image' }}
                      {%- else -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                          <circle cx="8.5" cy="8.5" r="1.5"/>
                          <polyline points="21 15 16 10 5 21"/>
                        </svg>
                      {%- endif -%}
                    </div>
                    <div class="cart-product-info">
                      <h4>
                        <a href="{{ item.url }}" class="cart-product-link">{{ item.product.title }}</a>
                      </h4>
                      {%- if cart_table_block.settings.show_variants -%}
                        {%- unless item.variant.title == 'Default Title' -%}
                          {%- for option in item.options_with_values -%}
                            <p class="cart-item-option">
                              <span class="cart-item-option-name">{{ option.name }}: </span>
                              <span class="cart-item-option-value">{{ option.value }}</span>
                            </p>
                          {%- endfor -%}
                        {%- endunless -%}
                      {%- endif -%}
                      {%- for property in item.properties -%}
                        {%- unless property.last == blank -%}
                          <p class="cart-item-property">{{ property.first }}: {{ property.last }}</p>
                        {%- endunless -%}
                      {%- endfor -%}
                      {%- if cart_table_block.settings.show_selling_plan and item.selling_plan_allocation -%}
                        {%- render 'selling-plan-badge', selling_plan_allocation: item.selling_plan_allocation -%}
                      {%- endif -%}
                      {%- if cart_table_block.settings.show_discounts and item.line_level_discount_allocations.size > 0 -%}
                        <ul class="cart-discounts-list" role="list" aria-label="{{ 'cart.discount_code' | t }}">
                          {%- for discount_allocation in item.line_level_discount_allocations -%}
                            <li class="cart-discount-badge">
                              <svg class="sp-badge__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                                <line x1="7" y1="7" x2="7.01" y2="7"></line>
                              </svg>
                              <span class="sp-badge__label">
                                {{ discount_allocation.discount_application.title }} (-{{ discount_allocation.amount | money }})
                              </span>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}
                    </div>
                  </div>

                  {%- comment -%}Price Cell{%- endcomment -%}
                  <div class="cart-price-cell{% unless cart_table_block.settings.show_price_column %} hidden{% endunless %}">
                    {%- if item.original_price != item.final_price -%}
                      <span class="cart-price-original">{{ item.original_price | money }}</span>
                      <span class="cart-price-final">{{ item.final_price | money }}</span>
                    {%- else -%}
                      {{ item.original_price | money }}
                    {%- endif -%}

                    {%- if cart_table_block.settings.show_unit_price and item.variant.unit_price_measurement != nil -%}
                      <div class="cart-unit-price">
                        <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}:&nbsp;</span>
                        {{ item.variant.unit_price | money }}
                        <span aria-hidden="true">/</span>
                        <span class="visually-hidden">&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span>
                        {%- if item.variant.unit_price_measurement.reference_value != 1 -%}
                          {{- item.variant.unit_price_measurement.reference_value -}}
                        {%- endif -%}
                        {{ item.variant.unit_price_measurement.reference_unit }}
                      </div>
                    {%- endif -%}
                  </div>

                  {%- comment -%}Quantity Cell{%- endcomment -%}
                  <div class="cart-qty-cell{% unless cart_table_block.settings.show_quantity_column %} hidden{% endunless %}">
                    <div class="cart-qty-ctrl">
                      <button
                        type="button"
                        class="qty-btn qty-decrease"
                        data-line="{{ forloop.index }}"
                        data-item-key="{{ item.key }}"
                        aria-label="{{ 'cart.decrease_quantity' | t }}"
                      >−</button>
                      <input
                        type="number"
                        name="updates[]"
                        id="Quantity-{{ forloop.index }}"
                        value="{{ item.quantity }}"
                        min="0"
                        max="999"
                        class="qty-value"
                        data-line="{{ forloop.index }}"
                        data-item-key="{{ item.key }}"
                        aria-label="{{ 'cart.quantity' | t }}"
                      >
                      <button
                        type="button"
                        class="qty-btn qty-increase"
                        data-line="{{ forloop.index }}"
                        data-item-key="{{ item.key }}"
                        aria-label="{{ 'cart.increase_quantity' | t }}"
                      >+</button>
                    </div>
                  </div>

                  {%- comment -%}Total Cell{%- endcomment -%}
                  <div class="cart-total-cell{% unless cart_table_block.settings.show_total_column %} hidden{% endunless %}">
                    {%- if item.original_line_price != item.final_line_price -%}
                      <span class="cart-price-original">{{ item.original_line_price | money }}</span>
                      <span class="cart-price-final">{{ item.final_line_price | money }}</span>
                    {%- else -%}
                      {{ item.original_line_price | money }}
                    {%- endif -%}
                  </div>

                  {%- comment -%}Remove Cell{%- endcomment -%}
                  <div class="cart-remove-cell{% unless cart_table_block.settings.show_remove_column %} hidden{% endunless %}">
                    <a
                      href="{{ item.url_to_remove }}"
                      class="cart-remove-btn"
                      aria-label="{{ 'cart.remove' | t | default: 'Remove' }} {{ item.product.title }}"
                    >
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="15" y1="9" x2="9" y2="15"></line>
                        <line x1="9" y1="9" x2="15" y2="15"></line>
                      </svg>
                    </a>
                  </div>
                </div>
              {%- endfor -%}
            </div>

            {%- comment -%}Action Buttons{%- endcomment -%}
            <div class="cart-actions">
              {%- assign default_update_text = 'cart.update' | t -%}{%- assign update_text = cart_table_block.settings.update_button_text | default: default_update_text -%}
              <button type="button" class="btn-outline{% unless cart_table_block.settings.show_update_button %} hidden{% endunless %}" id="cart-update-btn">
                {{ update_text }}
              </button>
              {%- assign default_clear_text = 'cart.clear' | t -%}{%- assign clear_text = cart_table_block.settings.clear_button_text | default: default_clear_text -%}
              <a href="{{ routes.cart_clear_url }}" class="btn-outline btn-clear{% unless cart_table_block.settings.show_clear_button %} hidden{% endunless %}">
                {{ clear_text }}
              </a>
            </div>

            {%- if cart_note_block -%}
              {%- assign note_bg_color = cart_note_block.settings.bg_color -%}
              {%- assign note_bg_gradient = cart_note_block.settings.bg_gradient -%}
              {%- assign note_border_color = cart_note_block.settings.border_color -%}
              {%- assign note_text_color = cart_note_block.settings.text_color -%}
              {%- assign note_label_color = cart_note_block.settings.label_color -%}
              {%- assign note_placeholder_color = cart_note_block.settings.placeholder_color -%}
              {%- if note_placeholder_color != blank -%}
                <style>
                  #CartNote-{{ section.id }}::placeholder {
                    color: {{ note_placeholder_color }} !important;
                    opacity: 1;
                  }
                </style>
              {%- endif -%}
              <div class="cart-note-wrapper {% unless cart_note_block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless cart_note_block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                   {{ cart_note_block.shopify_attributes }}
                   style="
                     --m-t: {{ cart_note_block.settings.margin_top | default: 30 }}px; 
                     --m-b: {{ cart_note_block.settings.margin_bottom | default: 0 }}px; 
                     --m-t-m: {{ cart_note_block.settings.margin_top_mobile | default: 20 }}px; 
                     --m-b-m: {{ cart_note_block.settings.margin_bottom_mobile | default: 0 }}px;
                     margin-top: var(--m-t) !important;
                     margin-bottom: var(--m-b) !important;
                     max-width: {{ cart_note_block.settings.max_width | default: 600 }}px;
                   ">
                <label for="CartNote-{{ section.id }}" 
                       class="cart-note-label"
                       style="
                         font-size: {% if cart_note_block.settings.font_size == 'small' %}13px{% elsif cart_note_block.settings.font_size == 'large' %}18px{% else %}15px{% endif %} !important;
                         font-weight: {% if cart_note_block.settings.font_weight == 'bold' %}700{% else %}500{% endif %} !important; 
                         font-style: {{ cart_note_block.settings.font_style | default: 'normal' }}; 
                         text-transform: {{ cart_note_block.settings.text_transform | default: 'none' }}; 
                         letter-spacing: {{ cart_note_block.settings.letter_spacing | default: 0 }}px; 
                         line-height: {{ cart_note_block.settings.line_height | default: 120 }}% !important;
                         {% if note_label_color != blank %}color: {{ note_label_color }} !important;{% endif %}
                       ">
                  {{ cart_note_block.settings.label | default: 'Order Note' }}
                </label>
                <textarea
                  name="note"
                  id="CartNote-{{ section.id }}"
                  class="cart-note-textarea"
                  placeholder="{{ cart_note_block.settings.placeholder }}"
                  style="
                    font-size: {% if cart_note_block.settings.textarea_font_size == 'small' %}13px{% elsif cart_note_block.settings.textarea_font_size == 'large' %}18px{% else %}15px{% endif %} !important;
                    font-weight: {% if cart_note_block.settings.textarea_font_weight == 'bold' %}700{% else %}400{% endif %} !important; 
                    font-style: {{ cart_note_block.settings.textarea_font_style | default: 'normal' }}; 
                    text-transform: {{ cart_note_block.settings.textarea_text_transform | default: 'none' }}; 
                    letter-spacing: {{ cart_note_block.settings.textarea_letter_spacing | default: 0 }}px; 
                    line-height: {{ cart_note_block.settings.textarea_line_height | default: 140 }}% !important;
                    {% if note_text_color != blank %}color: {{ note_text_color }} !important;{% endif %}
                    {% if note_bg_gradient != blank %}background: {{ note_bg_gradient }} !important;{% elsif note_bg_color != blank %}background-color: {{ note_bg_color }} !important;{% endif %}
                    {% if note_border_color != blank %}border-color: {{ note_border_color }} !important;{% endif %}
                  "
                >{{ cart.note }}</textarea>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if cart_totals_block -%}
        {%- comment -%}Right Column: Cart Totals{%- endcomment -%}
        <div class="cart-totals-column{% unless cart_totals_block.settings.show_cart_totals %} hidden{% endunless %}" {{ cart_totals_block.shopify_attributes }}>
            <div class="cart-totals-box">
              {%- assign default_cart_totals_title = 'cart.cart_totals' | t -%}{%- assign cart_totals_title = cart_totals_block.settings.cart_totals_title | default: default_cart_totals_title -%}
              <h3>{{ cart_totals_title }}</h3>

              {%- comment -%}Totals items (subtotal, discounts, tax, shipping, total){%- endcomment -%}
              {%- if cart_totals_block.settings.show_subtotal -%}
                <div class="summary-row">
                  {%- assign default_subtotal_label = 'cart.subtotal' | t -%}{%- assign subtotal_label = cart_totals_block.settings.subtotal_label | default: default_subtotal_label -%}
                  <span>{{ subtotal_label }}</span>
                  <span>{{ cart.items_subtotal_price | money }}</span>
                </div>
              {%- endif -%}

              {%- if cart_totals_block.settings.show_discounts and cart.cart_level_discount_applications.size > 0 -%}
                <div class="cart-discounts-totals">
                  {%- for discount_application in cart.cart_level_discount_applications -%}
                    <div class="summary-row cart-discount-row" style="color: var(--color-accent-secondary); font-weight: 500;">
                      <span class="cart-discount-title">
                        <svg class="sp-badge__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" style="width: 12px; height: 12px; margin-right: 4px; display: inline-block; vertical-align: middle;">
                          <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                          <line x1="7" y1="7" x2="7.01" y2="7"></line>
                        </svg>
                        {{ discount_application.title }}
                      </span>
                      <span class="cart-discount-amount">-{{ discount_application.total_allocated_amount | money }}</span>
                    </div>
                  {%- endfor -%}
                </div>
              {%- endif -%}

              {%- if cart_totals_block.settings.show_tax -%}
                <div class="summary-row">
                  {%- assign default_tax_label = 'cart.tax' | t -%}{%- assign tax_label = cart_totals_block.settings.tax_label | default: default_tax_label -%}
                  <span>{{ tax_label }}</span>
                  <span>
                    {%- if cart.taxes_included -%}
                      {%- assign default_tax_included_label = 'cart.included' | t -%}{%- assign tax_included_label = cart_totals_block.settings.tax_included_label | default: default_tax_included_label -%}
                      {{ tax_included_label }}
                    {%- else -%}
                      {{ cart.total_tax | money }}
                    {%- endif -%}
                  </span>
                </div>
              {%- endif -%}

              {%- if cart_totals_block.settings.show_shipping -%}
                <div class="summary-row">
                  {%- assign default_shipping_label = 'cart.shipping' | t -%}{%- assign shipping_label = cart_totals_block.settings.shipping_label | default: default_shipping_label -%}
                  <span>{{ shipping_label }}</span>
                  {%- assign default_shipping_note = 'cart.calculated_at_checkout' | t -%}{%- assign shipping_note = cart_totals_block.settings.shipping_note | default: default_shipping_note -%}
                  <span class="shipping-note">
                    {%- if shop.shipping_policy.url != blank -%}
                      <a href="{{ shop.shipping_policy.url }}">{{ shipping_note }}</a>
                    {%- else -%}
                      {{ shipping_note }}
                    {%- endif -%}
                  </span>
                </div>
