          "label": "Line Height",
          "default": 120
        },
        {
          "type": "header",
          "content": "Colors"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color"
        },
        {
          "type": "color_background",
          "id": "bg_gradient",
          "label": "Background Gradient"
        },
        {
          "type": "color",
          "id": "highlight_color",
          "label": "Highlight Text Color"
        },
        {
          "type": "color_background",
          "id": "highlight_gradient",
          "label": "Highlight Text Gradient"
        }
      ]
    },
