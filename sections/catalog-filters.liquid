    }
  ],
  "presets": [
    {
      "name": "Category Filters",
      "blocks": [
        { "type": "filter_item", "settings": { "label": "Laptops", "handle": "laptops" } },
        { "type": "filter_item", "settings": { "label": "Phones", "handle": "phones" } }
