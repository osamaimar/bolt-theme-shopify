{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile,
  padding_left: section.settings.padding_left,
  padding_right: section.settings.padding_right,
  padding_left_mobile: section.settings.padding_left_mobile,
  padding_right_mobile: section.settings.padding_right_mobile
%}
{%- if section.settings.show_section -%}
<section 
  class="catalog-filters-section color-{{ section.settings.color_scheme }}" 
  id="shopify-section-{{ section.id }}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}catalog-container{% endif %}">
    
    <div class="catalog-filter-bar" id="catalog-filter-bar-{{ section.id }}">
      {%- if section.settings.show_all_filter -%}
        <button class="filter-btn active" data-filter="all">{{ section.settings.all_label | default: 'All Products' }}</button>
      {%- endif -%}
      
      {%- comment -%}Render Filter Item Blocks{%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'filter_item' -%}
          <button class="filter-btn" data-filter="{{ block.settings.handle }}" {{ block.shopify_attributes }}>
            {{ block.settings.label }}
          </button>
        {%- endif -%}
      {%- endfor -%}

      {%- if section.settings.use_collection_tags and collection.all_tags.size > 0 -%}
        {%- for tag in collection.all_tags limit: section.settings.max_filters -%}
          <button class="filter-btn" data-filter="{{ tag | handle }}">{{ tag }}</button>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

<script>
function initStandaloneFilters() {
  const sectionId = '{{ section.id }}';
  const filterBar = document.getElementById('catalog-filter-bar-' + sectionId);
  const grid = document.querySelector('.cpd-product-grid');
  
  if (!filterBar || !grid) return;

  const productCards = grid.querySelectorAll('.cpd-product-card');
  const filterBtns = filterBar.querySelectorAll('.filter-btn');
  
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      const filterValue = btn.getAttribute('data-filter');
      
      productCards.forEach(card => {
        const categories = card.getAttribute('data-category').split(' ').filter(c => c.length > 0);
        if (filterValue === 'all' || categories.includes(filterValue)) {
          card.style.display = 'flex';
          card.style.opacity = '0';
          setTimeout(() => {
            card.style.opacity = '1';
            card.style.transition = 'opacity 0.4s ease';
          }, 10);
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
}

document.addEventListener('DOMContentLoaded', initStandaloneFilters);
document.addEventListener('shopify:section:load', (event) => {
  if (event.detail.sectionId === '{{ section.id }}') {
    initStandaloneFilters();
  }
});
</script>
{%- endif -%}

{% schema %}
{
  "name": "Category Filters",
  "tag": "section",
  "class": "section-catalog-filters",
  "settings": [
    {
      "type": "checkbox",
