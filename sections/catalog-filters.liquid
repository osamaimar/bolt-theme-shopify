  ],
  "blocks": [
    {
      "type": "filter_item",
      "name": "Category Filter",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Button Label",
          "default": "Category"
        },
        {
          "type": "text",
          "id": "handle",
          "label": "Filter Value (Product type or Tag)",
          "info": "Enter the product type or tag handle (e.g. 'laptops' for type Laptops)"
