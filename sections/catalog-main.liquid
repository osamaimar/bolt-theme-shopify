{{ 'section-catalog-main.css' | asset_url | stylesheet_tag }}
{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile,
  padding_left: section.settings.padding_left,
  padding_right: section.settings.padding_right,
  padding_left_mobile: section.settings.padding_left_mobile,
  padding_right_mobile: section.settings.padding_right_mobile
%}

{%- if section.settings.show_section -%}
<section 
  class="catalog-header-section color-{{ section.settings.color_scheme }}" 
  id="shopify-section-{{ section.id }}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}catalog-container{% endif %}">
    
    {%- comment -%}Breadcrumb{%- endcomment -%}
    {%- if section.settings.show_breadcrumb -%}
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol class="breadcrumb-list">
          <li class="breadcrumb-item">
            <a href="{{ routes.root_url }}">{{ 'general.home' | t }}</a>
          </li>
          <li class="breadcrumb-item" aria-current="page">
            <span>{{ collection.title }}</span>
          </li>
        </ol>
      </nav>
    {%- endif -%}

    {%- comment -%}Block Rendering Loop{%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        
        {%- when 'catalog_heading' -%}
          <div class="catalog-header" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h1 class="catalog-title">
                {{ block.settings.heading | replace: '[', '<span class="text-highlight">' | replace: ']', '</span>' }}
              </h1>
            {%- else -%}
              <h1 class="catalog-title">
                {{ collection.title }}
              </h1>
            {%- endif -%}
            
            {%- if block.settings.subheading != blank -%}
              <p class="catalog-subtitle">{{ block.settings.subheading }}</p>
            {%- endif -%}
          </div>

      {%- endcase -%}
    {%- endfor -%}

  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Catalog Header",
  "tag": "section",
  "class": "section-catalog-header",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Left",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Right",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_left_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Left (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Right (Mobile)",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumb",
      "default": false
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "standard",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "full", "label": "Full width" },
        { "value": "narrow", "label": "Narrow" }
      ]
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "inverse", "label": "Inverse" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "catalog_heading",
      "name": "Catalog Heading",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Premium [Electronics]",
          "info": "Use [text] to highlight text"
        },
        {
          "type": "inline_richtext",
          "id": "subheading",
          "label": "Subheading",
          "default": "Cutting-edge technology designed to power your lifestyle and enhance your productivity."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Catalog Header",
      "blocks": [
        { "type": "catalog_heading" }
      ]
    }
  ]
}
{% endschema %}



