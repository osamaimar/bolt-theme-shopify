<style>
  #shopify-section-{{ section.id }} { padding: 0 !important; }
  #shopify-section-{{ section.id }} .catalog-sidebar-header {
    padding-top: calc({{ section.settings.padding_top }}px + 80px) !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
    display: flow-root;
  }
  #shopify-section-{{ section.id }} .cpd-header {
    display: flex;
    flex-direction: column;
    align-items: {% if 'center' == 'left' %}flex-start{% elsif 'center' == 'right' %}flex-end{% else %}center{% endif %} !important;
    text-align: {% if 'center' == 'left' %}left{% elsif 'center' == 'right' %}right{% else %}center{% endif %} !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .catalog-sidebar-header {
      padding-top: calc({{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px + 80px) !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Container Width Overrides */
  {%- if section.settings.container_width == 'narrow' -%}
    #shopify-section-{{ section.id }} .cpd-page {
      max-width: 1100px !important;
    }
  {%- elsif section.settings.container_width == 'full' -%}
    #shopify-section-{{ section.id }} .cpd-page {
      max-width: 100% !important;
      padding-left: var(--spacing-2xl) !important;
      padding-right: var(--spacing-2xl) !important;
    }
  {%- else -%}
    #shopify-section-{{ section.id }} .cpd-page {
      max-width: {{ section.settings.max_width | default: 1200 }}px !important;
    }
  {%- endif -%}

  /* Standard Block Spacing overrides */
  #shopify-section-{{ section.id }} .catalog-header-block {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 0px) !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .catalog-header-block {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 0px)) !important;
    }
  }

  /* Responsive Font Sizing for Heading */
  #shopify-section-{{ section.id }} .catalog-title.size-small { font-size: 32px; }
  #shopify-section-{{ section.id }} .catalog-title.size-medium { font-size: 48px; }
  #shopify-section-{{ section.id }} .catalog-title.size-large { font-size: 64px; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .catalog-title.size-small { font-size: 24px; }
    #shopify-section-{{ section.id }} .catalog-title.size-medium { font-size: 32px; }
    #shopify-section-{{ section.id }} .catalog-title.size-large { font-size: 40px; }
  }

  /* Heading Highlight styling */
  #shopify-section-{{ section.id }} .catalog-title span {
    background: var(--highlight-gradient, var(--color-accent)) !important;
    -webkit-background-clip: var(--highlight-clip, text) !important;
    background-clip: var(--highlight-clip, text) !important;
    -webkit-text-fill-color: var(--highlight-fill, transparent) !important;
    display: inline-block;
    color: var(--highlight-color, inherit) !important;
  }

  /* Responsive Font Sizing for Subheading */
  #shopify-section-{{ section.id }} .cpd-header-desc.size-small { font-size: 14px; }
  #shopify-section-{{ section.id }} .cpd-header-desc.size-medium { font-size: 18px; }
  #shopify-section-{{ section.id }} .cpd-header-desc.size-large { font-size: 22px; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .cpd-header-desc.size-small { font-size: 12px; }
    #shopify-section-{{ section.id }} .cpd-header-desc.size-medium { font-size: 15px; }
    #shopify-section-{{ section.id }} .cpd-header-desc.size-large { font-size: 18px; }
  }

  /* Interactive Hover styles for Search Input */
  #shopify-section-{{ section.id }} #cpd-search {
    transition: all 0.3s ease;
  }
  {%- assign search_block = section.blocks | where: "type", "search_bar" | first -%}
  {%- if search_block -%}
    {%- if search_block.settings.hover_border_color != blank -%}
      #shopify-section-{{ section.id }} .cpd-search-bar:hover #cpd-search,
      #shopify-section-{{ section.id }} .cpd-search-bar:hover input,
      #shopify-section-{{ section.id }} #cpd-search:hover,
      #shopify-section-{{ section.id }} .cpd-search-bar input:hover {
        border-color: {{ search_block.settings.hover_border_color }} !important;
      }
    {%- endif -%}
    {%- if search_block.settings.hover_bg_color != blank -%}
      #shopify-section-{{ section.id }} .cpd-search-bar:hover #cpd-search,
      #shopify-section-{{ section.id }} .cpd-search-bar:hover input,
      #shopify-section-{{ section.id }} #cpd-search:hover,
      #shopify-section-{{ section.id }} .cpd-search-bar input:hover {
        background-color: {{ search_block.settings.hover_bg_color }} !important;
        background-image: none !important;
      }
    {%- endif -%}
    {%- if search_block.settings.hover_shadow_color != blank -%}
      #shopify-section-{{ section.id }} .cpd-search-bar:hover #cpd-search,
      #shopify-section-{{ section.id }} .cpd-search-bar:hover input,
      #shopify-section-{{ section.id }} #cpd-search:hover,
      #shopify-section-{{ section.id }} .cpd-search-bar input:hover {
        box-shadow: 0 4px 12px {{ search_block.settings.hover_shadow_color }} !important;
      }
    {%- endif -%}
    {%- if search_block.settings.placeholder_color != blank -%}
      #shopify-section-{{ section.id }} #cpd-search::placeholder,
      #shopify-section-{{ section.id }} .cpd-search-bar input::placeholder {
        color: {{ search_block.settings.placeholder_color }} !important;
      }
    {%- endif -%}
  {%- endif -%}
</style>

{%- if section.settings.show_section -%}
<section class="catalog-header-section catalog-sidebar-header cpd-header-outer color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}">
  <div class="cpd-page {% if section.settings.container_width == 'full' %}cpd-page--full{% endif %}"
       style="{% if section.settings.container_width != 'full' %}max-width: {{ section.settings.max_width | default: 1200 }}px;{% endif %} margin: 0 auto;">
    
    <div class="cpd-header">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            {%- assign heading_tag = block.settings.heading_tag | default: 'h1' -%}
            {%- assign h_color = block.settings.highlight_color -%}
            {%- assign h_gradient = block.settings.highlight_gradient -%}
            <{{ heading_tag }} class="catalog-title catalog-header-block size-{{ block.settings.font_size }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                id="block-{{ block.id }}"
                {{ block.shopify_attributes }} 
                style="
                  --m-t: {{ block.settings.margin_top }}px; 
                  --m-b: {{ block.settings.margin_bottom }}px; 
                  --m-t-m: {{ block.settings.margin_top_mobile }}px; 
                  --m-b-m: {{ block.settings.margin_bottom_mobile }}px; 
                  font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; 
                  font-style: {{ block.settings.font_style }}; 
                  text-transform: {{ block.settings.text_transform }}; 
                  letter-spacing: {{ block.settings.letter_spacing }}px; 
                  line-height: {{ block.settings.line_height }}; 
                  text-align: {{ 'center' }};
                  {% if block.settings.text_color != blank %}color: {{ block.settings.text_color }} !important;{% endif %} 
                  {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background-color: {{ block.settings.bg_color }} !important;{% endif %}
                  {% if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' %}--highlight-gradient: {{ h_gradient }}; --highlight-clip: text; --highlight-fill: transparent; --highlight-color: transparent;
                  {% elsif h_color != blank and h_color != 'rgba(0,0,0,0)' %}--highlight-color: {{ h_color }}; --highlight-gradient: none; --highlight-clip: initial; --highlight-fill: {{ h_color }};
                  {% endif %}
                ">
              {%- if block.settings.heading != blank -%}
                {{ block.settings.heading | replace: '[', '<span>' | replace: ']', '</span>' }}
              {%- else -%}
                {{ collection.title }}
              {%- endif -%}
            </{{ heading_tag }}>

          {%- when 'subheading' -%}
            {%- if block.settings.subheading != blank -%}
              <p class="cpd-header-desc catalog-header-block size-{{ block.settings.font_size }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                 id="block-{{ block.id }}"
                 {{ block.shopify_attributes }} 
                 style="
                   --m-t: {{ block.settings.margin_top }}px; 
                   --m-b: {{ block.settings.margin_bottom }}px; 
                   --m-t-m: {{ block.settings.margin_top_mobile }}px; 
                   --m-b-m: {{ block.settings.margin_bottom_mobile }}px; 
                   width: 100% !important; max-width: {{ block.settings.max_width }}px !important;
                   margin-left: {% if 'center' == 'left' %}0{% elsif 'center' == 'right' %}auto{% else %}auto{% endif %};
                   margin-right: {% if 'center' == 'right' %}0{% elsif 'center' == 'left' %}auto{% else %}auto{% endif %};
                   text-align: {{ 'center' }};
                   font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; 
                   font-style: {{ block.settings.font_style }}; 
                   text-transform: {{ block.settings.text_transform }}; 
                   letter-spacing: {{ block.settings.letter_spacing }}px; 
                   line-height: {{ block.settings.line_height }}; 
                   {% if block.settings.text_color != blank %}color: {{ block.settings.text_color }} !important;{% endif %} 
                   {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background-color: {{ block.settings.bg_color }} !important;{% endif %}
                 ">
                {{ block.settings.subheading }}
              </p>
            {%- endif -%}

          {%- when 'search_bar' -%}
            <div class="cpd-search-bar catalog-header-block {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                 id="block-{{ block.id }}"
                 {{ block.shopify_attributes }} 
                 style="
                   --m-t: {{ block.settings.margin_top }}px; 
                   --m-b: {{ block.settings.margin_bottom }}px; 
                   --m-t-m: {{ block.settings.margin_top_mobile }}px; 
                   --m-b-m: {{ block.settings.margin_bottom_mobile }}px; 
                   width: 100% !important; max-width: {{ block.settings.max_width }}px !important;
                   margin-left: {% if 'center' == 'left' %}0{% elsif 'center' == 'right' %}auto{% else %}auto{% endif %};
                   margin-right: {% if 'center' == 'right' %}0{% elsif 'center' == 'left' %}auto{% else %}auto{% endif %};
                 ">
              <svg class="cpd-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" {% if block.settings.icon_color != blank %}style="color: {{ block.settings.icon_color }} !important;"{% endif %}>
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
              </svg>
              <input 
                type="text" 
                id="cpd-search" 
                placeholder="{{ block.settings.search_placeholder | escape }}" 
                aria-label="{{ block.settings.search_placeholder | escape }}"
                style="
                  {% if block.settings.text_color != blank %}color: {{ block.settings.text_color }} !important;{% endif %}
                  {% if block.settings.border_color != blank %}border-color: {{ block.settings.border_color }} !important;{% endif %}
                  {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background-color: {{ block.settings.bg_color }} !important;{% endif %}
                "
              >
            </div>
          {%- when '@app' -%}
            {% render block %}
        {%- endcase -%}
      {%- endfor -%}
    </div>

  </div>
</section>
{%- endif -%}

{% schema %}
{
