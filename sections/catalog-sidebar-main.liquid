{{ 'section-catalog-main.css' | asset_url | stylesheet_tag }}
{{ 'section-catalog-sidebar.css' | asset_url | stylesheet_tag }}
{{ 'component-product-card.css' | asset_url | stylesheet_tag }}
<style>
  #shopify-section-{{ section.id }} { padding: 0 !important; }
  #shopify-section-{{ section.id }} .catalog-sidebar-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .catalog-sidebar-section {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  /* Container Width Overrides */
  {%- if section.settings.container_width == 'narrow' -%}
    #shopify-section-{{ section.id }} .catalog-v2-container {
      max-width: 1100px !important;
    }
  {%- elsif section.settings.container_width == 'full' -%}
    #shopify-section-{{ section.id }} .catalog-v2-container {
      max-width: 100% !important;
      padding-left: var(--spacing-2xl) !important;
      padding-right: var(--spacing-2xl) !important;
    }
  {%- else -%}
    #shopify-section-{{ section.id }} .catalog-v2-container {
      max-width: 1400px !important;
    }
  {%- endif -%}

  {%- assign pagination_block = section.blocks | where: "type", "pagination" | first -%}
  {%- if pagination_block -%}
    #block-{{ pagination_block.id }} {
      margin-top: {{ pagination_block.settings.margin_top | default: 60 }}px !important;
      margin-bottom: {{ pagination_block.settings.margin_bottom | default: 0 }}px !important;
      justify-content: {{ 'center' | default: 'center' }} !important;
      display: flex;
    }
    @media screen and (max-width: 768px) {
      #block-{{ pagination_block.id }} {
        margin-top: {{ pagination_block.settings.margin_top_mobile | default: 40 }}px !important;
        margin-bottom: {{ pagination_block.settings.margin_bottom_mobile | default: 0 }}px !important;
      }
    }
    #block-{{ pagination_block.id }} .page-link,
    #block-{{ pagination_block.id }} .cpd-page-link {
      transition: all 0.3s ease;
      font-size: {% if pagination_block.settings.font_size == 'small' %}12px{% elsif pagination_block.settings.font_size == 'large' %}18px{% else %}14px{% endif %} !important;
      font-weight: {% if pagination_block.settings.font_weight == 'bold' %}700{% else %}400{% endif %} !important;
      font-style: {{ pagination_block.settings.font_style | default: 'normal' }} !important;
      text-transform: {{ pagination_block.settings.text_transform | default: 'none' }} !important;
      letter-spacing: {{ pagination_block.settings.letter_spacing | default: 0 }}px !important;
      line-height: {{ pagination_block.settings.line_height | default: 120 }}% !important;
      {%- if pagination_block.settings.text_color != blank -%}
        color: {{ pagination_block.settings.text_color }} !important;
      {%- endif -%}
      {%- if pagination_block.settings.bg_gradient != blank -%}
        background: {{ pagination_block.settings.bg_gradient }} !important;
      {%- elsif pagination_block.settings.bg_color != blank -%}
        background-color: {{ pagination_block.settings.bg_color }} !important;
      {%- endif -%}
      {%- if pagination_block.settings.border_color != blank -%}
        border-color: {{ pagination_block.settings.border_color }} !important;
      {%- endif -%}
    }
    
    /* Pagination Hover States */
    {%- if pagination_block.settings.hover_border_color != blank -%}
      #block-{{ pagination_block.id }} .page-link:hover,
      #block-{{ pagination_block.id }} .cpd-page-link:hover {
        border-color: {{ pagination_block.settings.hover_border_color }} !important;
      }
    {%- endif -%}
    {%- if pagination_block.settings.hover_bg_color != blank -%}
      #block-{{ pagination_block.id }} .page-link:hover,
      #block-{{ pagination_block.id }} .cpd-page-link:hover {
        background-color: {{ pagination_block.settings.hover_bg_color }} !important;
        background-image: none !important;
      }
    {%- endif -%}
    {%- if pagination_block.settings.hover_shadow_color != blank -%}
      #block-{{ pagination_block.id }} .page-link:hover,
      #block-{{ pagination_block.id }} .cpd-page-link:hover {
        box-shadow: 0 4px 12px {{ pagination_block.settings.hover_shadow_color }} !important;
      }
    {%- endif -%}

    /* Pagination Active Page States */
    {%- if pagination_block.settings.active_text_color != blank -%}
      #block-{{ pagination_block.id }} .page-link.active,
      #block-{{ pagination_block.id }} .cpd-page-link.active {
        color: {{ pagination_block.settings.active_text_color }} !important;
      }
    {%- endif -%}
    {%- if pagination_block.settings.active_bg_gradient != blank -%}
      #block-{{ pagination_block.id }} .page-link.active,
      #block-{{ pagination_block.id }} .cpd-page-link.active {
        background: {{ pagination_block.settings.active_bg_gradient }} !important;
      }
    {%- elsif pagination_block.settings.active_bg_color != blank -%}
      #block-{{ pagination_block.id }} .page-link.active,
      #block-{{ pagination_block.id }} .cpd-page-link.active {
        background-color: {{ pagination_block.settings.active_bg_color }} !important;
        background-image: none !important;
      }
    {%- elsif pagination_block.settings.hover_bg_color != blank -%}
      #block-{{ pagination_block.id }} .page-link.active,
      #block-{{ pagination_block.id }} .cpd-page-link.active {
        background-color: {{ pagination_block.settings.hover_bg_color }} !important;
        background-image: none !important;
      }
    {%- endif -%}
    {%- if pagination_block.settings.active_border_color != blank -%}
      #block-{{ pagination_block.id }} .page-link.active,
      #block-{{ pagination_block.id }} .cpd-page-link.active {
        border-color: {{ pagination_block.settings.active_border_color }} !important;
      }
    {%- elsif pagination_block.settings.hover_border_color != blank -%}
      #block-{{ pagination_block.id }} .page-link.active,
      #block-{{ pagination_block.id }} .cpd-page-link.active {
        border-color: {{ pagination_block.settings.hover_border_color }} !important;
      }
    {%- endif -%}
  {%- endif -%}

  {%- assign grid_block = section.blocks | where: "type", "product_grid" | first -%}
  {%- if grid_block -%}
    {%- if grid_block.settings.bg_gradient != blank -%}
      #shopify-section-{{ section.id }} .cpd-product-card {
        background: {{ grid_block.settings.bg_gradient }} !important;
      }
    {%- elsif grid_block.settings.bg_color != blank -%}
      #shopify-section-{{ section.id }} .cpd-product-card {
        background-color: {{ grid_block.settings.bg_color }} !important;
      }
    {%- endif -%}
    {%- if grid_block.settings.vendor_color != blank -%}
      #shopify-section-{{ section.id }} .card-v2-category,
      #shopify-section-{{ section.id }} .cpd-product-category {
        color: {{ grid_block.settings.vendor_color }} !important;
      }
    {%- endif -%}
    {%- if grid_block.settings.name_color != blank -%}
      #shopify-section-{{ section.id }} .card-v2-title a,
      #shopify-section-{{ section.id }} .cpd-product-name a {
        color: {{ grid_block.settings.name_color }} !important;
      }
    {%- endif -%}
    {%- if grid_block.settings.price_color != blank -%}
      #shopify-section-{{ section.id }} .card-v2-price,
      #shopify-section-{{ section.id }} .cpd-product-price {
        color: {{ grid_block.settings.price_color }} !important;
      }
    {%- endif -%}
    {%- if grid_block.settings.btn_bg_color != blank -%}
      #shopify-section-{{ section.id }} .btn-v2-primary,
      #shopify-section-{{ section.id }} .cpd-product-cta {
        background-color: {{ grid_block.settings.btn_bg_color }} !important;
        border-color: {{ grid_block.settings.btn_bg_color }} !important;
      }
    {%- endif -%}
    {%- if grid_block.settings.btn_text_color != blank -%}
      #shopify-section-{{ section.id }} .btn-v2-primary,
      #shopify-section-{{ section.id }} .cpd-product-cta {
        color: {{ grid_block.settings.btn_text_color }} !important;
      }
      #shopify-section-{{ section.id }} .btn-v2-primary svg,
      #shopify-section-{{ section.id }} .cpd-product-cta svg {
        color: {{ grid_block.settings.btn_text_color }} !important;
      }
    {%- endif -%}
    {%- if grid_block.settings.quick_view_bg_color != blank -%}
      #shopify-section-{{ section.id }} .cpd-quick-view-btn,
      #shopify-section-{{ section.id }} .card-v2-quick-view-btn {
        background-color: {{ grid_block.settings.quick_view_bg_color }} !important;
      }
    {%- endif -%}
    {%- if grid_block.settings.quick_view_text_color != blank -%}
      #shopify-section-{{ section.id }} .cpd-quick-view-btn,
      #shopify-section-{{ section.id }} .card-v2-quick-view-btn {
        color: {{ grid_block.settings.quick_view_text_color }} !important;
      }
      #shopify-section-{{ section.id }} .cpd-quick-view-btn svg,
      #shopify-section-{{ section.id }} .card-v2-quick-view-btn svg {
        color: {{ grid_block.settings.quick_view_text_color }} !important;
      }
    {%- endif -%}
    {%- if grid_block.settings.quick_view_hover_bg_color != blank -%}
      #shopify-section-{{ section.id }} .cpd-quick-view-btn:hover,
      #shopify-section-{{ section.id }} .card-v2-quick-view-btn:hover {
        background-color: {{ grid_block.settings.quick_view_hover_bg_color }} !important;
        border-color: {{ grid_block.settings.quick_view_hover_bg_color }} !important;
      }
    {%- endif -%}
    {%- if grid_block.settings.quick_view_hover_text_color != blank -%}
      #shopify-section-{{ section.id }} .cpd-quick-view-btn:hover,
      #shopify-section-{{ section.id }} .card-v2-quick-view-btn:hover {
        color: {{ grid_block.settings.quick_view_hover_text_color }} !important;
      }
      #shopify-section-{{ section.id }} .cpd-quick-view-btn:hover svg,
      #shopify-section-{{ section.id }} .card-v2-quick-view-btn:hover svg {
        color: {{ grid_block.settings.quick_view_hover_text_color }} !important;
      }
    {%- endif -%}


    /* Product Grid Layout Margins */
    #catalog-grid-{{ section.id }} {
      margin-top: {{ grid_block.settings.margin_top | default: 0 }}px !important;
      margin-bottom: {{ grid_block.settings.margin_bottom | default: 0 }}px !important;
    }
    @media screen and (max-width: 768px) {
      #catalog-grid-{{ section.id }} {
        margin-top: {{ grid_block.settings.margin_top_mobile | default: 0 }}px !important;
        margin-bottom: {{ grid_block.settings.margin_bottom_mobile | default: 0 }}px !important;
      }
    }
  {%- endif -%}

  /* Hover Image Transition Styles */
  #shopify-section-{{ section.id }} .card-v2-image-box {
    position: relative;
  }
  #shopify-section-{{ section.id }} .card-v2-hover-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  #shopify-section-{{ section.id }} .theme-card-v2.has-hover-image:hover .card-v2-hover-image {
    opacity: 1;
    transform: scale(1.1);
  }
  #shopify-section-{{ section.id }} .theme-card-v2.has-hover-image:hover .card-v2-main-image {
    opacity: 0;
  }

  /* Quick View Glassmorphism Overlay */
  #shopify-section-{{ section.id }} .card-v2-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 2;
  }
  #shopify-section-{{ section.id }} .theme-card-v2:hover .card-v2-overlay {
    opacity: 1;
  }
  #shopify-section-{{ section.id }} .card-v2-quick-view-btn {
    padding: 10px 20px;
    background: var(--bg-glass);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    color: var(--text-inverse);
    font-size: 0.85rem;
    font-weight: var(--font-weight-bold);
    text-decoration: none;
    backdrop-filter: blur(10px);
    transition: all 0.3s ease;
  }
  #shopify-section-{{ section.id }} .card-v2-quick-view-btn:hover {
    background: var(--color-accent-secondary);
    color: var(--bg-secondary);
    border-color: var(--color-accent-secondary);
  }

  /* Filter Group Block Style Customizations */
  {%- for block in section.blocks -%}
    {%- if block.type == 'filter_group' -%}
      #block-{{ block.id }} {
        margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
        margin-bottom: {{ block.settings.margin_bottom | default: 32 }}px !important;
        {%- if block.settings.bg_gradient != blank -%}
          background: {{ block.settings.bg_gradient }} !important;
        {%- elsif block.settings.bg_color != blank -%}
          background-color: {{ block.settings.bg_color }} !important;
        {%- endif -%}
        {%- if block.settings.border_color != blank -%}
          border: 1px solid {{ block.settings.border_color }} !important;
          border-radius: var(--radius-lg, 12px) !important;
          padding: 16px !important;
        {%- endif -%}
      }
      @media screen and (max-width: 768px) {
        #block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom_mobile | default: 24 }}px !important;
        }
      }
      
      #block-{{ block.id }} .sidebar-section-title {
        {%- if block.settings.title_color != blank -%}
          color: {{ block.settings.title_color }} !important;
        {%- endif -%}
        font-size: {% if block.settings.title_font_size == 'small' %}0.85rem{% elsif block.settings.title_font_size == 'medium' %}1rem{% else %}1.2rem{% endif %} !important;
        font-weight: {% if block.settings.title_font_weight == 'bold' %}700{% else %}400{% endif %} !important;
        text-transform: {{ block.settings.title_text_transform | default: 'uppercase' }} !important;
      }

      {%- if block.settings.text_color != blank -%}
        #block-{{ block.id }} .filter-item,
        #block-{{ block.id }} .filter-label,
        #block-{{ block.id }} .filter-link,
        #block-{{ block.id }} .sidebar-section-content {
          color: {{ block.settings.text_color }} !important;
        }
      {%- endif -%}

      {%- if block.settings.active_color != blank -%}
        #block-{{ block.id }} .filter-item.is-active .filter-item-text,
        #block-{{ block.id }} .filter-checkbox:checked + .filter-item-text,
        #block-{{ block.id }} .filter-item.is-active {
          color: {{ block.settings.active_color }} !important;
        }
        #block-{{ block.id }} .filter-checkbox:checked::after {
          color: {{ block.settings.active_color }} !important;
        }
      {%- endif -%}

      {%- if block.settings.active_bg_color != blank -%}
        #block-{{ block.id }} .filter-item.is-active,
        #block-{{ block.id }} .filter-checkbox:checked {
          background-color: {{ block.settings.active_bg_color }} !important;
          border-color: {{ block.settings.active_bg_color }} !important;
        }
      {%- endif -%}

      /* Checkbox Custom Colors */
      {%- if block.settings.checkbox_bg_color != blank -%}
        #block-{{ block.id }} .filter-checkbox {
          background: {{ block.settings.checkbox_bg_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.checkbox_border_color != blank -%}
        #block-{{ block.id }} .filter-checkbox {
          border-color: {{ block.settings.checkbox_border_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.checkbox_hover_bg_color != blank -%}
        #block-{{ block.id }} .filter-item:hover .filter-checkbox {
          background: {{ block.settings.checkbox_hover_bg_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.checkbox_hover_border_color != blank -%}
        #block-{{ block.id }} .filter-item:hover .filter-checkbox {
          border-color: {{ block.settings.checkbox_hover_border_color }} !important;
        }
      {%- endif -%}

      /* Checkbox Active & Checkmark Custom Colors */
      {%- if block.settings.active_checkbox_bg_color != blank -%}
        #block-{{ block.id }} .filter-checkbox:checked {
          background: {{ block.settings.active_checkbox_bg_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.active_checkbox_border_color != blank -%}
        #block-{{ block.id }} .filter-checkbox:checked {
          border-color: {{ block.settings.active_checkbox_border_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.checkbox_checkmark_color != blank -%}
        #block-{{ block.id }} .filter-checkbox:checked::after {
          color: {{ block.settings.checkbox_checkmark_color }} !important;
        }
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
</style>

{%- if section.settings.show_section -%}
<section class="catalog-sidebar-section cpd-content-outer color-{{ section.settings.color_scheme }}" id="BoltSection-{{ section.id }}">
  <div class="catalog-v2-container">
      <!-- Sidebar Filters -->
      <aside class="catalog-sidebar">
        <div class="sidebar-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="4" y1="21" x2="4" y2="14" /><line x1="4" y1="10" x2="4" y2="3" />
            <line x1="12" y1="21" x2="12" y2="12" /><line x1="12" y1="8" x2="12" y2="3" />
            <line x1="20" y1="21" x2="20" y2="16" /><line x1="20" y1="12" x2="20" y2="3" />
            <line x1="1" y1="14" x2="7" y2="14" /><line x1="9" y1="8" x2="15" y2="8" /><line x1="17" y1="16" x2="23" y2="16" />
          </svg>
          {%- assign default_sidebar_title_val = 'collections.show_filters' | t -%}{%- assign sidebar_title_val = section.settings.sidebar_title | default: default_sidebar_title_val -%}
          {{ sidebar_title_val }}
        </div>

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'filter_group' -%}
              <div 
                class="sidebar-section group-type-{{ block.settings.source }} display-{{ block.settings.display_type }}{% if block.settings.collapsible %} is-collapsible{% endif %}{% if block.settings.default_open %} is-open{% endif %}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                id="block-{{ block.id }}"
                data-group-id="{{ block.id }}" 
                {{ block.shopify_attributes }}
              >
                <div class="sidebar-section-header">
                  <h4 class="sidebar-section-title">{{ block.settings.title }}</h4>
                  <div class="sidebar-section-actions">
                    <button class="group-clear-btn">{{ 'sections.cart.buttons.clear' | t | default: 'Clear' }}</button>
                    {%- if block.settings.collapsible -%}
                      <svg class="collapse-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="6 9 12 15 18 9" />
                      </svg>
                    {%- endif -%}
                  </div>
                </div>
                
                <div class="sidebar-section-content" style="{% unless block.settings.default_open %}display: none;{% endunless %}">
                  <div class="filter-list">
                    {%- if block.settings.source == 'manual' -%}
                      {%- assign items = block.settings.tags | default: block.settings.manual_tags | split: ',' -%}
                    {%- elsif block.settings.source == 'types' -%}
                      {%- assign items = collection.all_types -%}
                    {%- elsif block.settings.source == 'tags' -%}
                      {%- if block.settings.tag_prefix != blank -%}
                        {%- capture tag_list -%}{%- for tag in collection.all_tags -%}{%- if tag contains block.settings.tag_prefix -%}{{ tag }}|{%- endif -%}{%- endfor -%}{%- endcapture -%}
                        {%- assign items = tag_list | split: '|' -%}
                      {%- else -%}
                        {%- assign items = collection.all_tags -%}
                      {%- endif -%}
                    {%- elsif block.settings.source == 'vendors' -%}
                      {%- assign items = collection.all_vendors -%}
                    {%- endif -%}

                    {%- for item in items -%}
                      {%- assign clean_item = item | strip -%}
                      {%- if clean_item != blank -%}
                        {%- assign display_label = clean_item -%}
                        {%- if block.settings.source == 'tags' and block.settings.tag_prefix != blank and block.settings.strip_prefix -%}
                          {%- assign display_label = clean_item | replace: block.settings.tag_prefix, "" | strip -%}
                        {%- endif -%}
                        <label class="filter-item" title="{{ clean_item }}">
                          <input type="checkbox" class="filter-checkbox" data-group="{{ block.id }}" data-filter="{{ clean_item | handle }}" data-label="{{ clean_item | escape }}">
                          <span class="filter-item-text">{{ display_label }}</span>
                        </label>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>
              </div>

            {%- when 'newsletter' -%}
              <div class="blog-sidebar-widget blog-sidebar-widget--newsletter" {{ block.shopify_attributes }}>
                {%- if block.settings.title != blank -%}
                  <h4 class="sidebar-section-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;display:inline-block;vertical-align:middle;margin-right:8px;color:var(--color-accent-secondary);">
                      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                      <polyline points="22,6 12,13 2,6" />
                    </svg>
                    {{ block.settings.title }}
                  </h4>
                {%- endif -%}
                <p class="blog-sidebar-nl-text" style="margin-bottom: 12px; font-size: 0.9rem; color: var(--text-secondary);">{{ block.settings.description | default: 'Get weekly insights and tips delivered straight to your inbox.' }}</p>
                {%- capture form_id -%}sidebar-nl-form-{{ block.id }}{%- endcapture -%}
                {%- form 'customer', id: form_id, class: 'blog-sidebar-nl-form' -%}
                  <input type="hidden" name="contact[tags]" value="newsletter">
                  {%- if form.posted_successfully? -%}
                    <p class="form-success">{{ 'newsletter.success' | t | default: 'Thanks for subscribing!' }}</p>
                  {%- else -%}
                    {%- assign default_placeholder_val = 'sections.footer.newsletter.placeholder' | t -%}{%- assign placeholder_val = block.settings.placeholder | default: default_placeholder_val -%}
                    {%- assign default_btn_text_val = 'sections.footer.newsletter.submit' | t -%}{%- assign btn_text_val = block.settings.button_text | default: default_btn_text_val -%}
                    <input type="email" name="contact[email]" class="blog-sidebar-nl-input" placeholder="{{ placeholder_val }}" required aria-required="true" style="margin-bottom: 8px;">
                    <button type="submit" class="blog-sidebar-nl-btn">{{ btn_text_val }}</button>
                    {%- if form.errors -%}
                      <p class="form-error">{{ form.errors.messages.email }}</p>
                    {%- endif -%}
                  {%- endif -%}
                {%- endform -%}
              </div>

            {%- when 'promo_banner' -%}
              <div class="blog-sidebar-widget cpd-promo-banner-widget" style="padding: 0; overflow: hidden;" {{ block.shopify_attributes }}>
                <a href="{{ block.settings.link | default: '#' }}" style="text-decoration: none; display: block; overflow: hidden; position: relative;">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', alt: block.settings.heading, style: 'width: 100%; height: auto; display: block; transition: transform 0.5s ease;' }}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg', style: 'width: 100%; height: 200px; display: block; background: var(--color-white-5);' }}
                  {%- endif -%}
                  <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.8), transparent); display: flex; flex-direction: column; justify-content: flex-end; padding: 20px; text-align: left;">
                    {%- if block.settings.subheading != blank -%}
                      <span style="font-size: 0.75rem; color: var(--color-accent-secondary); text-transform: uppercase; font-weight: 700; letter-spacing: 1px; margin-bottom: 4px;">{{ block.settings.subheading }}</span>
                    {%- endif -%}
                    {%- if block.settings.heading != blank -%}
                      <h5 style="font-size: 1.1rem; color: #fff; font-weight: 700; margin: 0 0 8px 0; line-height: 1.3;">{{ block.settings.heading }}</h5>
                    {%- endif -%}
                    {%- if block.settings.button_text != blank -%}
                      <span style="font-size: 0.8rem; color: #fff; font-weight: 600; text-decoration: underline;">{{ block.settings.button_text }}</span>
                    {%- endif -%}
                  </div>
                </a>
              </div>

            {%- when 'custom_text' -%}
              <div class="blog-sidebar-widget" {{ block.shopify_attributes }}>
                {%- if block.settings.title != blank -%}
                  <h4 class="sidebar-section-title">{{ block.settings.title }}</h4>
                {%- endif -%}
                <div style="font-size: 0.95rem; color: var(--text-secondary); line-height: 1.6;">
                  {%- if block.settings.content_type == 'html' -%}
                    {{ block.settings.custom_html }}
                  {%- else -%}
                    {{ block.settings.custom_text | newline_to_br }}
                  {%- endif -%}
                </div>
              </div>

            {%- when 'featured_products' -%}
              <div class="blog-sidebar-widget" {{ block.shopify_attributes }}>
                {%- if block.settings.title != blank -%}
                  <h4 class="sidebar-section-title">{{ block.settings.title }}</h4>
                {%- endif -%}
                <div style="display: flex; flex-direction: column; gap: 15px;">
                  {%- assign sidebar_collection = collections[block.settings.collection] -%}
                  {%- if sidebar_collection != blank and sidebar_collection.products_count > 0 -%}
                    {%- for prod in sidebar_collection.products limit: block.settings.show_count -%}
                      <a href="{{ prod.url }}" style="display: flex; gap: 12px; text-decoration: none; align-items: center;" class="blog-sidebar-popular-item">
                        {%- if prod.featured_image != blank -%}
                          <img src="{{ prod.featured_image | image_url: width: 100, height: 100, crop: 'center' }}" class="blog-sidebar-popular-thumb" alt="{{ prod.title | escape }}" width="100" height="100" loading="lazy">
                        {%- else -%}
                          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg', style: 'width: 50px; height: 50px; border-radius: 8px; background: var(--color-white-5);' }}
                        {%- endif -%}
                        <div style="min-width: 0; display: flex; flex-direction: column; text-align: left;">
                          <span class="blog-sidebar-popular-title" style="font-size: 0.9rem; font-weight: 600; color: var(--text-inverse); text-overflow: ellipsis; white-space: nowrap; overflow: hidden; display: block;">{{ prod.title }}</span>
                          <span style="font-size: 0.85rem; color: var(--color-accent-secondary); font-weight: 700;">{{ prod.price | money }}</span>
                        </div>
                      </a>
                    {%- endfor -%}
                  {%- else -%}
                    {%- assign onboarding_val = 'collections.select_collection' | t -%}
                    <p style="font-size: 0.85rem; color: var(--text-lighter); margin: 0;">{{ onboarding_val }}</p>
                  {%- endif -%}
                </div>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </aside>

      <!-- Main Product Grid -->
      <section class="catalog-main">
        {%- paginate collection.products by section.settings.products_per_page -%}
          
          {%- assign grid_block = section.blocks | where: "type", "product_grid" | first -%}
          {%- if grid_block != blank -%}
            <div 
              class="theme-v2-grid{% unless grid_block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless grid_block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
              id="catalog-grid-{{ section.id }}"
              style="--columns-desktop: {{ grid_block.settings.columns_desktop | default: '3' }}; --columns-tablet: {{ grid_block.settings.columns_tablet | default: '2' }}; --columns-mobile: {{ grid_block.settings.columns_mobile | default: '1' }};"
              {{ grid_block.shopify_attributes }}
            >
              {%- for product in collection.products -%}
                {% render 'product-card-sidebar', 
                  product: product, 
                  show_vendor: grid_block.settings.show_vendor, 
                  show_price: grid_block.settings.show_price,
                  show_quick_view: grid_block.settings.show_quick_view,
                  show_add_to_cart: grid_block.settings.show_add_to_cart,
                  image_ratio: grid_block.settings.image_ratio,
                  hover_image: grid_block.settings.show_secondary_image,
                  show_rating: grid_block.settings.show_rating
                %}
              {%- else -%}
                <p class="catalog-empty">{{ 'collections.empty' | t | default: 'No products found in this collection.' }}</p>
              {%- endfor -%}
            </div>
          {%- else -%}
            <div 
              class="theme-v2-grid" 
              id="catalog-grid-{{ section.id }}"
              style="--columns-desktop: 3; --columns-tablet: 2; --columns-mobile: 1;"
            >
              {%- for product in collection.products -%}
                {% render 'product-card-sidebar', 
                  product: product, 
                  show_vendor: false, 
                  show_price: true,
                  show_quick_view: true,
                  show_add_to_cart: true,
                  image_ratio: '1/1',
                  hover_image: true,
                  show_rating: true
                %}
              {%- else -%}
                <p class="catalog-empty">{{ 'collections.empty' | t | default: 'No products found in this collection.' }}</p>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- assign pagination_block = section.blocks | where: "type", "pagination" | first -%}
          {%- if pagination_block != blank -%}
            {%- if paginate.pages > 1 -%}
              <div class="catalog-pagination {% unless pagination_block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless pagination_block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                   id="block-{{ pagination_block.id }}" 
                   {{ pagination_block.shopify_attributes }}
                   style="
                     justify-content: {{ 'center' | default: 'center' }};
                     margin-top: {{ pagination_block.settings.margin_top | default: 40 }}px;
                     margin-bottom: {{ pagination_block.settings.margin_bottom | default: 0 }}px;
                     display: flex;
                   ">
                {%- if paginate.previous -%}
                  <a href="{{ paginate.previous.url }}" class="page-link" aria-label="Previous">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="15 18 9 12 15 6" />
                    </svg>
                  </a>
                {%- endif -%}

                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}
                    <a href="{{ part.url }}" class="page-link">{{ part.title }}</a>
                  {%- else -%}
                    <span class="page-link active">{{ part.title }}</span>
                  {%- endif -%}
                {%- endfor -%}

                {%- if paginate.next -%}
                  <a href="{{ paginate.next.url }}" class="page-link" aria-label="Next">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="9 18 15 12 9 6" />
                    </svg>
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- else -%}
            {%- if paginate.pages > 1 and section.settings.show_pagination -%}
              <div class="catalog-pagination">
                {%- if paginate.previous -%}
                  <a href="{{ paginate.previous.url }}" class="page-link" aria-label="Previous">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="15 18 9 12 15 6" />
                    </svg>
                  </a>
                {%- endif -%}

                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}
                    <a href="{{ part.url }}" class="page-link">{{ part.title }}</a>
                  {%- else -%}
                    <span class="page-link active">{{ part.title }}</span>
                  {%- endif -%}
                {%- endfor -%}

                {%- if paginate.next -%}
                  <a href="{{ paginate.next.url }}" class="page-link" aria-label="Next">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="9 18 15 12 9 6" />
                    </svg>
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endif -%}
        {%- endpaginate -%}
      </section>
    </div>
</section>

<script>
function initSidebarGrid() {
  const sectionId = '{{ section.id }}';
  const filterSection = document.getElementById('BoltSection-{{ section.id }}');
  if (!filterSection) return;

  const checkboxes = filterSection.querySelectorAll('.filter-checkbox');
  const grid = document.getElementById('catalog-grid-' + sectionId);

  const parsePriceRange = (label) => {
    // Matches "$100 - $500", "Under $100", "$500+", etc.
    const cleanLabel = label.replace(/[$,\s]/g, '');
    if (cleanLabel.includes('-')) {
      const parts = cleanLabel.split('-');
      return { min: parseFloat(parts[0]) || 0, max: parseFloat(parts[1]) || Infinity };
    } else if (cleanLabel.includes('+')) {
      return { min: parseFloat(cleanLabel) || 0, max: Infinity };
    } else if (label.toLowerCase().includes('under') || cleanLabel.includes('<')) {
      return { min: 0, max: parseFloat(cleanLabel.replace(/[^0-9.]/g, '')) || Infinity };
    }
    return null;
  };

  const applyFilters = () => {
    // Synchronize active classes on filter items
    checkboxes.forEach(cb => {
      const label = cb.closest('.filter-item');
      if (label) {
        if (cb.checked) {
          label.classList.add('is-active');
        } else {
          label.classList.remove('is-active');
        }
      }
    });

    const groups = {};
    checkboxes.forEach(cb => {
      if (cb.checked) {
        const groupId = cb.getAttribute('data-group');
        if (!groups[groupId]) groups[groupId] = { tags: [], price: [] };
        
        const price = parsePriceRange(cb.getAttribute('data-label'));
        if (price) {
          groups[groupId].price.push(price);
        } else {
          groups[groupId].tags.push(cb.getAttribute('data-filter'));
        }
      }
    });

    const productCards = grid.querySelectorAll('.cpd-product-card');

    productCards.forEach(card => {
      const categoryAttr = (card.getAttribute('data-category') || '').toLowerCase();
      const categories = categoryAttr.split(' ').filter(c => c.length > 0);
      const productPrice = parseFloat(card.getAttribute('data-price')) || 0;
      
      let isVisible = true;

      // Group-aware filtering (AND logic between groups)
      for (const groupId in groups) {
        const group = groups[groupId];
        
        const matchesTags = group.tags.length === 0 || group.tags.some(f => 
          categories.some(cat => cat === f || cat.includes(f))
        );
        
        const matchesPrice = group.price.length === 0 || group.price.some(range => 
          productPrice >= range.min && productPrice <= range.max
        );

        if (!matchesTags || !matchesPrice) {
          isVisible = false;
          break;
        }
      }

      card.style.display = isVisible ? 'flex' : 'none';
      card.style.opacity = isVisible ? '1' : '0';
    });

    // Handle Clear buttons visibility
    for (const groupId in groups) {
      const clearBtn = filterSection.querySelector(`[data-group-id="${groupId}"] .group-clear-btn`);
      if (clearBtn) {
        clearBtn.style.opacity = '1';
        clearBtn.style.pointerEvents = 'auto';
      }
    }
    filterSection.querySelectorAll('.group-clear-btn').forEach(btn => {
      const groupId = btn.closest('.sidebar-section').getAttribute('data-group-id');
      if (!groups[groupId]) {
        btn.style.opacity = '0';
        btn.style.pointerEvents = 'none';
      }
    });
  };

  checkboxes.forEach(cb => cb.addEventListener('change', applyFilters));

  // Collapsible logic
  filterSection.querySelectorAll('.is-collapsible .sidebar-section-header').forEach(header => {
    header.addEventListener('click', () => {
      const section = header.closest('.sidebar-section');
      const content = section.querySelector('.sidebar-section-content');
      const icon = header.querySelector('.collapse-icon');
      const isOpen = section.classList.toggle('is-open');
      
      content.style.display = isOpen ? 'block' : 'none';
      if (icon) icon.style.transform = isOpen ? 'rotate(180deg)' : 'rotate(0deg)';
    });
  });

  // Group Clear logic
  filterSection.querySelectorAll('.group-clear-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const section = btn.closest('.sidebar-section');
      section.querySelectorAll('.filter-checkbox').forEach(cb => cb.checked = false);
      applyFilters();
    });
  });
  
  // Run once to initialize
  applyFilters();

  // Sorting Logic removed

  // Card Spotlight Effect (Shared)
  if (grid) {
    grid.querySelectorAll('.cpd-product-card').forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--mouse-x', ((e.clientX - rect.left) / rect.width) * 100 + '%');
        card.style.setProperty('--mouse-y', ((e.clientY - rect.top) / rect.height) * 100 + '%');
      });
    });
  }
}

document.addEventListener('DOMContentLoaded', initSidebarGrid);
document.addEventListener('shopify:section:load', (event) => {
  if (event.detail.sectionId === '{{ section.id }}') {
    initSidebarGrid();
  }
});
</script>

<style>
.cpd-sort-option.active {
  background: var(--color-accent-secondary) !important;
  color: var(--bg-secondary);
  font-weight: 700;
}
.page-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 8px;
  background: var(--bg-glass);
  border: 1px solid var(--border-light);
  color: #fff;
  text-decoration: none;
  font-weight: 600;
  transition: all 0.3s;
}
.page-link:hover {
  background: var(--color-accent-secondary);
  color: var(--bg-secondary);
  border-color: var(--color-accent-secondary);
  box-shadow: 0 0 15px rgba(var(--color-secondary-rgb), 0.3);
}
.page-link.active {
  background: var(--color-accent-secondary);
  color: var(--bg-secondary);
  border-color: var(--color-accent-secondary);
}
</style>
