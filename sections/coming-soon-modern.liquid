          {%- when 'footer_links' -%}
            <div class="csm-footer-container{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" style="width: 100%; display: flex; flex-direction: column; align-items: center; gap: 16px;">
              <div class="csm-footer-links" id="csm-footer-links-{{ block.id }}" {{ block.shopify_attributes }}>
                <a href="#csm-password-form-wrapper-{{ block.id }}" class="csm-password-toggle-btn" role="button" aria-expanded="false" aria-controls="csm-password-form-wrapper-{{ block.id }}">
                  {{ block.settings.password_text }}
                </a>
                <span class="csm-link-sep">·</span>
                {{ block.settings.owner_text }} <a href="{{ block.settings.login_link | default: '/admin' }}">{{ block.settings.login_text }}</a>
              </div>

              <div class="csm-password-form-wrapper" id="csm-password-form-wrapper-{{ block.id }}" style="display: none; width: 100%; max-width: 400px; margin-top: 16px;">
                {%- form 'storefront_password' -%}
                  {%- if form.errors -%}
                    <div class="form-message form-message--error" style="color: #ff4d4d; border: 1px solid rgba(255, 77, 77, 0.3); background: rgba(255, 77, 77, 0.1); padding: 12px 16px; border-radius: 8px; font-size: 0.9rem; text-align: center; margin-bottom: 12px; width: 100%; box-sizing: border-box;">
                      {{ form.errors | default_errors }}
                    </div>
                  {%- endif -%}
                  <div class="csm-form" style="display: flex; gap: 12px; width: 100%;">
                    <input 
                      type="password" 
                      name="password" 
                      id="password-input-{{ block.id }}" 
                      class="form-input" 
                      placeholder="{{ 'password.password' | t }}" 
                      required 
                    />
                    <button 
                      type="submit" 
                      class="btn-submit" 
                    >
                      {{ 'password.enter' | t }}
                    </button>
                  </div>
                {%- endform -%}
              </div>
            </div>

            <script>
              (function() {
                function initPasswordForm() {
                  var toggleBtn = document.querySelector('#csm-footer-links-{{ block.id }} .csm-password-toggle-btn');
                  var formWrapper = document.getElementById('csm-password-form-wrapper-{{ block.id }}');
                  if (!toggleBtn || !formWrapper) return;

                  var form = formWrapper.querySelector('form');
                  var input = document.getElementById('password-input-{{ block.id }}');
                  var button = formWrapper.querySelector('.btn-submit');
                  
                  var errorContainer = formWrapper.querySelector('.form-message--error');
                  if (!errorContainer) {
                    errorContainer = document.createElement('div');
                    errorContainer.className = 'form-message form-message--error';
                    errorContainer.style.cssText = 'color: #ff4d4d; border: 1px solid rgba(255, 77, 77, 0.3); background: rgba(255, 77, 77, 0.1); padding: 12px 16px; border-radius: 8px; font-size: 0.9rem; text-align: center; margin-bottom: 12px; width: 100%; box-sizing: border-box; display: none;';
                    form.insertBefore(errorContainer, form.firstChild);
                  }

                  {%- if form.errors -%}
                    formWrapper.style.display = 'block';
                    toggleBtn.setAttribute('aria-expanded', 'true');
                  {%- endif -%}

                  toggleBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    var isHidden = formWrapper.style.display === 'none';
                    formWrapper.style.display = isHidden ? 'block' : 'none';
                    toggleBtn.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
                    if (isHidden && input) {
                      input.focus();
                    }
                  });

                  form.addEventListener('submit', function(e) {
                    e.preventDefault();
                    
                    if (button) {
                      button.disabled = true;
                      button.dataset.originalText = button.textContent;
                      button.textContent = '...';
                    }
                    errorContainer.style.display = 'none';

                    var formData = new FormData(form);
                    
                    fetch(form.action || '/password', {
                      method: 'POST',
                      body: formData,
                      headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                      }
                    })
                    .then(function(response) {
                      return response.text();
                    })
                    .then(function(responseText) {
                      var parser = new DOMParser();
                      var htmlDoc = parser.parseFromString(responseText, 'text/html');
                      
                      var returnedErrors = htmlDoc.querySelector('.errors, .form-message--error, [id^="csm-password-form-wrapper-"] .form-message--error');
                      
                      if (returnedErrors) {
                        errorContainer.innerHTML = returnedErrors.innerHTML || returnedErrors.textContent;
                        errorContainer.style.display = 'block';
                        if (input) {
                          input.value = '';
                          input.focus();
                        }
                        if (button) {
                          button.disabled = false;
                          button.textContent = button.dataset.originalText || 'Enter';
                        }
                      } else {
                        window.location.href = '/' + window.location.search;
                      }
                    })
                    .catch(function(error) {
                      console.error('AJAX login error:', error);
                      errorContainer.textContent = 'An error occurred. Please try again.';
                      errorContainer.style.display = 'block';
                      if (button) {
                        button.disabled = false;
                        button.textContent = button.dataset.originalText || 'Enter';
                      }
                    });
                  });
                }

                if (document.readyState === 'loading') {
                  document.addEventListener('DOMContentLoaded', initPasswordForm);
                } else {
                  initPasswordForm();
                }
              })();
            </script>

        {%- endcase -%}
      {%- endfor -%}
      {%- if in_social_links == true -%}
        </div><!-- /.social-links -->
      {%- endif -%}
      {%- if in_social_group == true -%}
        </div><!-- /.csm-social -->
      {%- endif -%}
      {% # theme-check-enable UnclosedHTMLElement %}
    </div>
  </div>
</section>
{%- endif -%}

