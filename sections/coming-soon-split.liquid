{{ 'section-coming-soon-split.css' | asset_url | stylesheet_tag }}

{%- if section.settings.show_section -%}
{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile,
  padding_left: section.settings.padding_left,
  padding_right: section.settings.padding_right,
  padding_left_mobile: section.settings.padding_left_mobile,
  padding_right_mobile: section.settings.padding_right_mobile
%}
<style>
  #shopify-section-{{ section.id }} .coming-soon-section {
    min-height: {{ section.settings.min_height }}px;
  }

  #shopify-section-{{ section.id }} .progress-fill {
    width: {{ section.settings.progress_value }}%;
  }

  {%- if section.settings.show_progress -%}
    #shopify-section-{{ section.id }} .progress-value:after {
      content: '{{ section.settings.progress_value }}%';
    }
  {%- endif -%}
</style>

<section class="coming-soon-section color-{{ section.settings.color_scheme }}" id="shopify-section-{{ section.id }}">
  <div class="coming-soon-container">
    <!-- Left Column: Content -->
    <div class="coming-soon-content">
      {%- if section.settings.show_badge -%}
        <div class="coming-soon-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          {{ section.settings.badge_text }}
        </div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="coming-soon-title">
          {{ section.settings.heading | replace: '[', '<span class="title-accent">' | replace: ']', '</span>' }}
        </h1>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="coming-soon-description">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- if section.settings.show_progress -%}
        <div class="coming-soon-progress">
          <div class="progress-header">
            <span class="progress-label">{{ section.settings.progress_label }}</span>
            <span class="progress-value">{{ section.settings.progress_value }}%</span>
          </div>
          <div class="progress-track">
            <div class="progress-fill"></div>
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.show_features -%}
        <div class="coming-soon-features">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'feature' -%}
                <div class="feature-item" {{ block.shopify_attributes }}>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                  </svg>
                  {{ block.settings.text }}
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Right Column: Interactive Card -->
    <div class="coming-soon-card">
      {%- if section.settings.show_countdown -%}
        <div class="coming-soon-countdown">
          <div class="cs-countdown-block">
            <span class="cs-countdown-value" id="cs-days-{{ section.id }}">00</span>
            <span class="cs-countdown-label">{{ section.settings.days_label }}</span>
          </div>
          <div class="cs-countdown-block">
            <span class="cs-countdown-value" id="cs-hours-{{ section.id }}">00</span>
            <span class="cs-countdown-label">{{ section.settings.hours_label }}</span>
          </div>
          <div class="cs-countdown-block">
            <span class="cs-countdown-value" id="cs-minutes-{{ section.id }}">00</span>
            <span class="cs-countdown-label">{{ section.settings.minutes_label }}</span>
          </div>
          <div class="cs-countdown-block">
            <span class="cs-countdown-value" id="cs-seconds-{{ section.id }}">00</span>
            <span class="cs-countdown-label">{{ section.settings.seconds_label }}</span>
          </div>
        </div>

        <hr class="cs-card-divider" />
      {%- endif -%}

      {%- if section.settings.show_subscribe -%}
        <div class="coming-soon-subscribe">
          <p class="subscribe-title">{{ section.settings.subscribe_title }}</p>
          <p class="subscribe-text">{{ section.settings.subscribe_subtext }}</p>
          {%- capture form_id -%}cs-subscribe-form-{{ section.id }}{%- endcapture -%}
          {%- form 'customer', id: form_id, class: 'cs-subscribe-form' -%}
            {%- if form.posted_successfully? -%}
              <p class="form-message form-message--success">{{ section.settings.success_message }}</p>
            {%- else -%}
              <input type="email" name="contact[email]" class="form-input" placeholder="{{ section.settings.email_placeholder }}" aria-label="{{ section.settings.email_placeholder }}" required />
              <button type="submit" class="btn-submit">{{ section.settings.button_label }}</button>
            {%- endif -%}
          {%- endform -%}
        </div>

        <hr class="cs-card-divider" />
      {%- endif -%}

      {%- if section.settings.show_social -%}
        <div class="coming-soon-social">
          <p class="coming-soon-social-label">{{ section.settings.social_label }}</p>
          <div class="social-links">
            {%- if section.settings.show_facebook -%}
              <a href="{{ section.settings.facebook_link | default: '#' }}" class="social-link" title="Follow on Facebook" target="_blank" rel="noopener">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="icon-social">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.show_instagram -%}
              <a href="{{ section.settings.instagram_link | default: '#' }}" class="social-link" title="Follow on Instagram" target="_blank" rel="noopener">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-social">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.show_linkedin -%}
              <a href="{{ section.settings.linkedin_link | default: '#' }}" class="social-link" title="Follow on LinkedIn" target="_blank" rel="noopener">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="icon-social">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                  <rect x="2" y="9" width="4" height="12"></rect>
                  <circle cx="4" cy="4" r="2"></circle>
                </svg>
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_footer_links -%}
    <div class="coming-soon-footer-links">
      <a href="{{ section.settings.password_link | default: routes.account_login_url }}">{{ section.settings.password_text }}</a>
      <span class="link-separator">·</span>
      {{ section.settings.owner_text }} <a href="{{ section.settings.login_link | default: routes.account_login_url }}">{{ section.settings.login_text }}</a>
    </div>
  {%- endif -%}
</section>

<script>
(function() {
  var launchDate = new Date('{{ section.settings.launch_date | default: 'now' }}');
  if (isNaN(launchDate.getTime())) {
    launchDate = new Date();
    launchDate.setDate(launchDate.getDate() + 30);
  }

  function updateCountdown() {
    var now = new Date().getTime();
    var distance = launchDate.getTime() - now;

    if (distance < 0) {
      document.getElementById('cs-days-{{ section.id }}').textContent = '00';
      document.getElementById('cs-hours-{{ section.id }}').textContent = '00';
      document.getElementById('cs-minutes-{{ section.id }}').textContent = '00';
      document.getElementById('cs-seconds-{{ section.id }}').textContent = '00';
      return;
    }

    var days = Math.floor(distance / (1000 * 60 * 60 * 24));
    var hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    var seconds = Math.floor((distance % (1000 * 60)) / 1000);

    document.getElementById('cs-days-{{ section.id }}').textContent = days < 10 ? '0' + days : days;
    document.getElementById('cs-hours-{{ section.id }}').textContent = hours < 10 ? '0' + hours : hours;
    document.getElementById('cs-minutes-{{ section.id }}').textContent = minutes < 10 ? '0' + minutes : minutes;
    document.getElementById('cs-seconds-{{ section.id }}').textContent = seconds < 10 ? '0' + seconds : seconds;
  }

  updateCountdown();
  setInterval(updateCountdown, 1000);
})();
</script>
{%- endif -%}

