{{ 'section-contact-faq.css' | asset_url | stylesheet_tag }}

<style>
  /* Section Spacing / Visibility overrides */
  #shopify-section-{{ section.id }} .contact-faq-section {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .contact-faq-section {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Container Width overrides */
  #shopify-section-{{ section.id }} .container-fluid {
    max-width: 100% !important;
    padding-left: 2rem !important;
    padding-right: 2rem !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container-narrow {
    max-width: 800px !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container {
    max-width: {{ section.settings.max_width | default: 1340 }}px !important;
    margin: 0 auto !important;
  }

  /* Blocks Position align overrides */
  #shopify-section-{{ section.id }} .contact-faq-header {
    display: flex;
    flex-direction: column;
    {%- if section.settings.blocks_position == 'left' -%}
      align-items: flex-start !important;
      text-align: left !important;
    {%- elsif section.settings.blocks_position == 'right' -%}
      align-items: flex-end !important;
      text-align: right !important;
    {%- else -%}
      align-items: center !important;
      text-align: center !important;
    {%- endif -%}
  }

  /* Block Spacing overrides */
  #shopify-section-{{ section.id }} .section-title {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 20px) !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .section-title {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 20px)) !important;
    }
  }

  /* Responsive Font Sizing */
  #shopify-section-{{ section.id }} .section-title.size-small { font-size: 24px !important; }
  #shopify-section-{{ section.id }} .section-title.size-medium { font-size: 32px !important; }
  #shopify-section-{{ section.id }} .section-title.size-large { font-size: 40px !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .section-title.size-small { font-size: 20px !important; }
    #shopify-section-{{ section.id }} .section-title.size-medium { font-size: 26px !important; }
    #shopify-section-{{ section.id }} .section-title.size-large { font-size: 32px !important; }
  }

  {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'faq_item'
        assign b_align_alignment = 'left'
  endcase
-%}
    {%- if block.type == 'faq_item' -%}
      /* FAQ Item Block styling for {{ block.id }} */
      #shopify-section-{{ section.id }} .block-{{ block.id }} {
        margin-top: {{ block.settings.margin_top }}px !important;
        margin-bottom: {{ block.settings.margin_bottom }}px !important;
        text-align: {{ b_align_alignment }} !important;
        {% if block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' %}
          background: {{ block.settings.bg_color }} !important;
        {% endif %}
        {% if block.settings.bg_gradient != blank and block.settings.bg_gradient != 'rgba(0,0,0,0)' %}
          background: {{ block.settings.bg_gradient }} !important;
        {% endif %}
        {% if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' %}
          border-color: {{ block.settings.border_color }} !important;
        {% endif %}
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }}:hover {
        {% if block.settings.bg_hover_color != blank and block.settings.bg_hover_color != 'rgba(0,0,0,0)' %}
          background: {{ block.settings.bg_hover_color }} !important;
        {% endif %}
        {% if block.settings.bg_hover_gradient != blank and block.settings.bg_hover_gradient != 'rgba(0,0,0,0)' %}
          background: {{ block.settings.bg_hover_gradient }} !important;
        {% endif %}
        {% if block.settings.border_hover_color != blank and block.settings.border_hover_color != 'rgba(0,0,0,0)' %}
          border-color: {{ block.settings.border_hover_color }} !important;
        {% endif %}
      }

      /* Spacing on Mobile */
      @media screen and (max-width: 768px) {
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top_mobile }}px !important;
          margin-bottom: {{ block.settings.margin_bottom_mobile }}px !important;
        }
      }

      /* Viewport visibility */
      {%- unless block.settings.show_on_desktop -%}
        @media screen and (min-width: 1025px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            display: none !important;
          }
        }
      {%- endunless -%}
      {%- unless block.settings.show_on_tablet -%}
        @media screen and (min-width: 769px) and (max-width: 1024px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            display: none !important;
          }
        }
      {%- endunless -%}
      {%- unless block.settings.show_on_mobile -%}
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            display: none !important;
          }
        }
      {%- endunless -%}

      /* Question Typography & Colors */
      #shopify-section-{{ section.id }} .block-{{ block.id }} .card-title {
        font-size: {{ block.settings.font_size | replace: 'small', '14px' | replace: 'medium', '18px' | replace: 'large', '22px' }} !important;
        font-weight: {%- if block.settings.font_weight == 'bold' -%}700{%- else -%}400{%- endif -%} !important;
        font-style: {{ block.settings.font_style }} !important;
        text-transform: {{ block.settings.text_transform }} !important;
        letter-spacing: {{ block.settings.letter_spacing }}px !important;
        line-height: {{ block.settings.line_height }}% !important;
        {% if block.settings.question_color != blank and block.settings.question_color != 'rgba(0,0,0,0)' %}
          color: {{ block.settings.question_color }} !important;
        {% endif %}
      }

      /* Answer Typography & Colors */
      #shopify-section-{{ section.id }} .block-{{ block.id }} p {
        font-size: {{ block.settings.font_size | replace: 'small', '12px' | replace: 'medium', '14px' | replace: 'large', '16px' }} !important;
        font-weight: {%- if block.settings.font_weight == 'bold' -%}700{%- else -%}400{%- endif -%} !important;
        font-style: {{ block.settings.font_style }} !important;
        text-transform: {{ block.settings.text_transform }} !important;
        letter-spacing: {{ block.settings.letter_spacing }}px !important;
        line-height: {{ block.settings.line_height }}% !important;
        {% if block.settings.answer_color != blank and block.settings.answer_color != 'rgba(0,0,0,0)' %}
          color: {{ block.settings.answer_color }} !important;
        {% endif %}
      }
    {%- endif -%}
  {%- endfor -%}
</style>

{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

{%- if section.settings.show_section -%}
<section
  class="contact-faq-section color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}"
  id="shopify-section-{{ section.id }}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">

    {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'faq_item'
        assign b_align_alignment = 'left'
  endcase
-%}
      {%- if block.type == 'header' -%}
        {%- if block.settings.heading != blank -%}
          <div class="contact-faq-header">
            {%- assign heading_tag = block.settings.heading_tag | default: 'h2' -%}
            {%- assign h_color = block.settings.highlight_color -%}
            {%- assign h_gradient = block.settings.highlight_gradient -%}
            {%- assign head_text_align = b_align_alignment -%}
            {%- if head_text_align == blank -%}
              {%- if section.settings.blocks_position == 'left' -%}
                {%- assign head_text_align = 'left' -%}
              {%- elsif section.settings.blocks_position == 'right' -%}
                {%- assign head_text_align = 'right' -%}
              {%- else -%}
                {%- assign head_text_align = 'center' -%}
              {%- endif -%}
            {%- endif -%}
            <{{ heading_tag }}
              class="section-title size-{{ block.settings.font_size | default: 'large' }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}"
              {{ block.shopify_attributes }}
              style="
                --m-t: {{ block.settings.margin_top | default: 0 }}px;
                --m-b: {{ block.settings.margin_bottom | default: 20 }}px;
                --m-t-m: {{ block.settings.margin_top_mobile | default: 0 }}px;
                --m-b-m: {{ block.settings.margin_bottom_mobile | default: 16 }}px;
                font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                font-style: {{ block.settings.font_style | default: 'normal' }};
                text-transform: {{ block.settings.text_transform | default: 'none' }};
                letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                line-height: {{ block.settings.line_height | default: 120 }}%;
                text-align: {{ head_text_align }};
                width: 100% !important;
                max-width: {{ block.settings.max_width | default: 800 }}px !important;
                {%- if section.settings.blocks_position == 'left' -%}
                  margin-left: 0 !important;
                  margin-right: auto !important;
                {%- elsif section.settings.blocks_position == 'right' -%}
                  margin-left: auto !important;
                  margin-right: 0 !important;
                {%- else -%}
                  margin-left: auto !important;
                  margin-right: auto !important;
                {%- endif -%}
                {% if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.text_color }} !important;{% endif %}
                {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' %}background: {{ block.settings.bg_color }} !important;{% endif %}
              "
            >
              {%- if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' -%}
                {%- assign highlight_span = '<span class="highlight-text" style="background: ' | append: h_gradient | append: '; -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">' -%}
              {%- elsif h_color != blank and h_color != 'rgba(0,0,0,0)' -%}
                {%- assign highlight_span = '<span class="highlight-text" style="color: ' | append: h_color | append: ';">' -%}
              {%- else -%}
                {%- assign highlight_span = '<span class="highlight-text">' -%}
              {%- endif -%}
              {{ block.settings.heading | replace: '[', highlight_span | replace: ']', '</span>' }}
            </{{ heading_tag }}>
          </div>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}

    <div class="contact-faq-grid">
      {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'faq_item'
        assign b_align_alignment = 'left'
  endcase
-%}
        {%- case block.type -%}
          {%- when 'faq_item' -%}
            {%- assign show_block = true -%}
            {%- if block.settings.visibility_customer_status == 'logged_in' and customer == nil -%}
              {%- assign show_block = false -%}
            {%- elsif block.settings.visibility_customer_status == 'guest' and customer != nil -%}
              {%- assign show_block = false -%}
            {%- endif -%}

            {%- if show_block -%}
              <div class="contact-faq-card block-{{ block.id }}" {{ block.shopify_attributes }}>
                {%- if block.settings.show_question and block.settings.question != blank -%}
                  <h3 class="card-title">{{ block.settings.question }}</h3>
                {%- endif -%}
                {%- if block.settings.show_answer and block.settings.answer != blank -%}
                  <p>{{ block.settings.answer }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>

  </div>
</section>
{%- endif -%}

{% schema %}
{
