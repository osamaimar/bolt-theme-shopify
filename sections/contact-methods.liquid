{{ 'section-contact-methods.css' | asset_url | stylesheet_tag }}

<style>
  /* Section Spacing / Visibility overrides */
  #shopify-section-{{ section.id }} .contact-methods-section {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .contact-methods-section {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Container Width overrides */
  #shopify-section-{{ section.id }} .container-fluid {
    max-width: 100% !important;
    padding-left: 2rem !important;
    padding-right: 2rem !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container-narrow {
    max-width: 800px !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container {
    max-width: {{ section.settings.max_width | default: 1340 }}px !important;
    margin: 0 auto !important;
  }

  /* Blocks Position overrides */
  #shopify-section-{{ section.id }} .contact-methods-grid {
    {%- if section.settings.blocks_position == 'left' -%}
      justify-content: flex-start !important;
    {%- elsif section.settings.blocks_position == 'right' -%}
      justify-content: flex-end !important;
    {%- else -%}
      justify-content: center !important;
    {%- endif -%}
  }

  {%- for block in section.blocks -%}
    {%- if block.type == 'contact_method' -%}
      /* Block styling for {{ block.id }} */
      #shopify-section-{{ section.id }} .block-{{ block.id }} {
        margin-top: {{ block.settings.margin_top }}px !important;
        margin-bottom: {{ block.settings.margin_bottom }}px !important;
        text-align: {{ 'center' }} !important;
        {% if block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' %}
          background: {{ block.settings.bg_color }} !important;
        {% endif %}
        {% if block.settings.bg_gradient != blank and block.settings.bg_gradient != 'rgba(0,0,0,0)' %}
          background: {{ block.settings.bg_gradient }} !important;
        {% endif %}
        {% if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' %}
          border-color: {{ block.settings.border_color }} !important;
        {% endif %}
      }
      {% if block.settings.border_hover_color != blank and block.settings.border_hover_color != 'rgba(0,0,0,0)' %}
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover {
          border-color: {{ block.settings.border_hover_color }} !important;
        }
      {% endif %}

      /* Spacing on Mobile */
      @media screen and (max-width: 768px) {
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top_mobile }}px !important;
          margin-bottom: {{ block.settings.margin_bottom_mobile }}px !important;
        }
      }

      /* Viewport visibility */
      {%- unless block.settings.show_on_desktop -%}
        @media screen and (min-width: 1025px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            display: none !important;
          }
        }
      {%- endunless -%}
      {%- unless block.settings.show_on_tablet -%}
        @media screen and (min-width: 769px) and (max-width: 1024px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            display: none !important;
          }
        }
      {%- endunless -%}
      {%- unless block.settings.show_on_mobile -%}
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            display: none !important;
          }
        }
      {%- endunless -%}

      /* Typography & Color Overrides */
      /* Title */
      #shopify-section-{{ section.id }} .block-{{ block.id }} .card-title {
        font-size: {{ block.settings.title_font_size | replace: 'small', '16px' | replace: 'medium', '20px' | replace: 'large', '24px' }} !important;
        font-weight: {%- if block.settings.title_font_weight == 'bold' -%}700{%- else -%}400{%- endif -%} !important;
        font-style: {{ block.settings.font_style }} !important;
        text-transform: {{ block.settings.text_transform }} !important;
        letter-spacing: {{ block.settings.letter_spacing }}px !important;
        line-height: {{ block.settings.line_height }}% !important;
        {% if block.settings.title_color != blank and block.settings.title_color != 'rgba(0,0,0,0)' %}
          color: {{ block.settings.title_color }} !important;
        {% endif %}
      }

      /* Body lines default colors */
      #shopify-section-{{ section.id }} .block-{{ block.id }} p {
        font-size: {{ block.settings.text_font_size | replace: 'small', '14px' | replace: 'medium', '16px' | replace: 'large', '18px' }} !important;
        font-weight: {%- if block.settings.text_font_weight == 'bold' -%}700{%- else -%}400{%- endif -%} !important;
        font-style: {{ block.settings.font_style }} !important;
        text-transform: {{ block.settings.text_transform }} !important;
        letter-spacing: {{ block.settings.letter_spacing }}px !important;
        line-height: {{ block.settings.line_height }}% !important;
      }

      /* Line 1 Color */
      {% if block.settings.line_1_color != blank and block.settings.line_1_color != 'rgba(0,0,0,0)' %}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .card-line-1,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .card-line-1 a {
          color: {{ block.settings.line_1_color }} !important;
        }
      {% endif %}

      /* Line 2 Color */
      {% if block.settings.line_2_color != blank and block.settings.line_2_color != 'rgba(0,0,0,0)' %}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .card-line-2 {
          color: {{ block.settings.line_2_color }} !important;
        }
      {% endif %}

      /* Icon Colors */
      {% if block.settings.icon_color != blank and block.settings.icon_color != 'rgba(0,0,0,0)' %}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .contact-method-icon svg {
          stroke: {{ block.settings.icon_color }} !important;
        }
      {% endif %}
      {% if block.settings.icon_bg_color != blank and block.settings.icon_bg_color != 'rgba(0,0,0,0)' %}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .contact-method-icon {
          background: {{ block.settings.icon_bg_color }} !important;
        }
      {% endif %}
    {%- endif -%}
  {%- endfor -%}
</style>

{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

{%- if section.settings.show_section -%}
<section
  class="contact-methods-section color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}"
  id="shopify-section-{{ section.id }}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    <div class="contact-methods-grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'contact_method' -%}
            <div class="contact-method-card block-{{ block.id }}" {{ block.shopify_attributes }}>
              {%- if block.settings.show_icon -%}
                {%- if block.settings.custom_icon_svg != blank or block.settings.icon != blank -%}
                  <div class="contact-method-icon">
                    {%- if block.settings.custom_icon_svg != blank -%}
                      {{ block.settings.custom_icon_svg }}
                    {%- else -%}
                      {%- case block.settings.icon -%}
                        {%- when 'mail' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                        {%- when 'phone' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                        {%- when 'map-pin' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                        {%- when 'message-circle' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                        {%- when 'headphones' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
                        {%- when 'clock' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        {%- when 'globe' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                        {%- else -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                      {%- endcase -%}
                    {%- endif -%}
                  </div>
                {%- endif -%}
              {%- endif -%}
              {%- if block.settings.show_title and block.settings.title != blank -%}
                <h3 class="card-title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.show_line_1 and block.settings.line_1 != blank -%}
                <p class="card-line-1">
                  {%- if block.settings.link != blank -%}
                    <a href="{{ block.settings.link }}">{{ block.settings.line_1 }}</a>
                  {%- else -%}
                    {{ block.settings.line_1 }}
                  {%- endif -%}
                </p>
              {%- endif -%}
              {%- if block.settings.show_line_2 and block.settings.line_2 != blank -%}
                <p class="card-line-2">{{ block.settings.line_2 }}</p>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

