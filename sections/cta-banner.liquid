{{ 'section-home-ecommerce-minimal.css' | asset_url | stylesheet_tag }}

{%- if section.settings.show_section -%}
{% style %}
  #shopify-section-{{ section.id }} .hev-cta-block {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 0px) !important;
    color: var(--block-text-color, inherit) !important;
    background: var(--block-bg, transparent) !important;
  }
  #shopify-section-{{ section.id }} h2[class*="cta-heading"] span {
    background: var(--highlight-gradient, var(--color-accent)) !important;
    -webkit-background-clip: var(--highlight-clip, text) !important;
    background-clip: var(--highlight-clip, text) !important;
    -webkit-text-fill-color: var(--highlight-fill, transparent) !important;
    display: inline-block;
    color: var(--highlight-color, inherit) !important;
  }

  /* CTA Button Overrides */
  #shopify-section-{{ section.id }} .hev-cta-btn-primary,
  #shopify-section-{{ section.id }} .hev-cta-btn-outline {
    background-color: var(--btn-bg) !important;
    background-image: var(--btn-bg-img, none) !important;
    color: var(--btn-text) !important;
    border: 2px solid var(--btn-border) !important;
    font-size: var(--btn-size, inherit) !important;
    font-weight: var(--btn-weight, 700) !important;
    font-style: var(--btn-style, normal) !important;
    text-transform: var(--btn-transform, uppercase) !important;
    letter-spacing: var(--btn-spacing, 1px) !important;
    line-height: var(--btn-lh, 1.2) !important;
    transition: all 0.3s ease !important;
  }
  #shopify-section-{{ section.id }} .hev-cta-btn-primary:hover,
  #shopify-section-{{ section.id }} .hev-cta-btn-outline:hover {
    background-color: var(--btn-hover-bg) !important;
    background-image: none !important;
    color: var(--btn-hover-text) !important;
    border-color: var(--btn-hover-border) !important;
    box-shadow: 0 12px 32px var(--btn-hover-shadow, rgba(0,0,0,0)) !important;
    transform: translateY(-2px) !important;
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .hev-cta-block {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 0px)) !important;
    }
  }
{% endstyle %}

{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

<section class="hev-cta color-{{ section.settings.color_scheme }}{% if section.settings.enable_animation %} animate-on-scroll{% endif %} {% if section.settings.show_divider %}section-divider{% endif %} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}" id="shopify-section-{{ section.id }}">
    <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}"
         style="{% if section.settings.container_width != 'full' %}max-width: {{ section.settings.max_width }}px;{% endif %} margin: 0 auto;">
        <div class="hev-cta-card">
            <div class="hev-cta-bg {% if section.settings.enable_overlay %}hev-cta-bg--overlay{% endif %}">
                {%- if section.settings.background_image != blank -%}
                  {%- assign cta_bg_alt = section.settings.background_image.alt | default: section.settings.heading | default: 'CTA background' | escape -%}
                  {{ section.settings.background_image | image_url: width: 2000 | image_tag: loading: 'lazy', alt: cta_bg_alt }}
                {%- else -%}
                    {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
            </div>
            <div class="hev-cta-body hev-cta-body--{{ 'left' }}">
                {%- for block in section.blocks -%}
                    {%- case block.type -%}
                        {%- when 'cta_heading' -%}
                            {%- if block.settings.heading != blank -%}
                                {%- assign h_color = block.settings.highlight_color -%}
                                {%- assign h_gradient = block.settings.highlight_gradient -%}
                                <h2 class="hev-cta-block cta-heading--{{ block.settings.heading_size }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                                    style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px; font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; {% if block.settings.text_color != blank %}--block-text-color: {{ block.settings.text_color }};{% endif %} {% if block.settings.bg_gradient != blank %}--block-bg: {{ block.settings.bg_gradient }};{% elsif block.settings.bg_color != blank %}--block-bg: {{ block.settings.bg_color }};{% endif %}
                                    {% if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' %}--highlight-gradient: {{ h_gradient }}; --highlight-clip: text; --highlight-fill: transparent;
                                    {% elsif h_color != blank and h_color != 'rgba(0,0,0,0)' %}--highlight-color: {{ h_color }}; --highlight-gradient: none; --highlight-clip: initial; --highlight-fill: {{ h_color }};
                                    {% endif %}"
                                    {{ block.shopify_attributes }}>
                                    {{ block.settings.heading | replace: '[', '<span>' | replace: ']', '</span>' }}
                                </h2>
                            {%- endif -%}

                        {%- when 'cta_text' -%}
                            {%- if block.settings.text != blank -%}
                                <p class="hev-cta-block cta-text--{{ block.settings.text_size }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                                   style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px; font-size: {{ block.settings.font_size }}rem; max-width: {{ block.settings.max_width }}px; margin-inline: {% if 'left' == 'center' %}auto{% elsif 'left' == 'right' %}0 0{% else %}0 auto{% endif %}; font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; {% if block.settings.text_color != blank %}--block-text-color: {{ block.settings.text_color }};{% endif %} {% if block.settings.bg_gradient != blank %}--block-bg: {{ block.settings.bg_gradient }};{% elsif block.settings.bg_color != blank %}--block-bg: {{ block.settings.bg_color }};{% endif %}"
                                   {{ block.shopify_attributes }}>
                                    {{ block.settings.text }}
                                </p>
                            {%- endif -%}

                        {%- when '@app' -%}
                            <div {{ block.shopify_attributes }}>
                                {% render block %}
                            </div>
                    {%- endcase -%}
                {%- endfor -%}

                {%- assign has_buttons = false -%}
                {%- for block in section.blocks -%}
                    {%- if block.type == 'cta_button' -%}
                        {%- assign has_buttons = true -%}
                        {%- break -%}
                    {%- endif -%}
                {%- endfor -%}

                {%- if has_buttons -%}
                    <div class="hev-cta-actions hev-cta-actions--{{ 'left' }}">
                        {%- for block in section.blocks -%}
                            {%- if block.type == 'cta_button' -%}
                                {%- liquid
                                   assign btn_bg = block.settings.bg_color
                                   assign btn_text = block.settings.text_color
                                   assign btn_border = block.settings.border_color
                                   assign btn_hover_bg = block.settings.hover_bg_color
                                   assign btn_hover_text = block.settings.hover_text_color
                                   assign btn_hover_border = block.settings.hover_border_color
                                   assign btn_hover_shadow = block.settings.hover_shadow_color
                                   assign btn_bg_img = 'none'

                                   if block.settings.style == 'primary'
                                      assign default_bg = 'var(--color-accent)'
                                      assign default_bg_img = 'none'
                                      assign default_text = 'var(--bg-secondary)'
                                      assign default_border = 'transparent'
                                      assign default_hover_bg = 'var(--color-accent-secondary-dark, var(--color-accent-secondary))'
                                      assign default_hover_text = 'var(--bg-secondary)'
                                      assign default_hover_border = 'transparent'
                                      assign default_hover_shadow = 'var(--color-accent-secondary-20)'
                                   else
                                      assign default_bg = 'transparent'
                                      assign default_bg_img = 'none'
                                      assign default_text = 'var(--text-inverse)'
                                      assign default_border = 'var(--color-white-20)'
                                      assign default_hover_bg = 'var(--color-white-5)'
                                      assign default_hover_text = 'var(--text-inverse)'
                                      assign default_hover_border = 'var(--color-accent-secondary-40)'
                                      assign default_hover_shadow = 'rgba(0,0,0,0.1)'
                                   endif

                                   if btn_bg == blank or btn_bg == 'rgba(0,0,0,0)'
                                      assign btn_bg = default_bg
                                      assign btn_bg_img = default_bg_img
                                   endif
                                   if btn_text == blank or btn_text == 'rgba(0,0,0,0)'
                                      assign btn_text = default_text
                                   endif
                                   if btn_border == blank or btn_border == 'rgba(0,0,0,0)'
                                      assign btn_border = default_border
                                   endif
                                   if btn_hover_bg == blank or btn_hover_bg == 'rgba(0,0,0,0)'
                                      assign btn_hover_bg = default_hover_bg
                                   endif
                                   if btn_hover_text == blank or btn_hover_text == 'rgba(0,0,0,0)'
                                      assign btn_hover_text = default_hover_text
                                   endif
                                   if btn_hover_border == blank or btn_hover_border == 'rgba(0,0,0,0)'
                                      assign btn_hover_border = default_hover_border
                                   endif
                                   if btn_hover_shadow == blank or btn_hover_shadow == 'rgba(0,0,0,0)'
                                      assign btn_hover_shadow = default_hover_shadow
                                   endif
                                -%}
                                <a href="{{ block.settings.link | default: '#' }}" 
                                   class="{% if block.settings.style == 'primary' %}hev-cta-btn-primary{% else %}hev-cta-btn-outline{% endif %} cta-btn--{{ block.settings.button_size }} {% if block.settings.full_width_mobile %}cta-btn--full-mobile{% endif %} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                                   id="hev-cta-btn-{{ block.id }}"
                                   {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener"{% endif %}
                                   style="--btn-bg: {{ btn_bg }};
                                          --btn-bg-img: {{ btn_bg_img }};
                                          --btn-text: {{ btn_text }};
                                          --btn-border: {{ btn_border }};
                                          --btn-hover-bg: {{ btn_hover_bg }};
                                          --btn-hover-text: {{ btn_hover_text }};
                                          --btn-hover-border: {{ btn_hover_border }};
                                          --btn-hover-shadow: {{ btn_hover_shadow }};
                                          --btn-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                                          --btn-style: {{ block.settings.font_style }};
                                          --btn-transform: {{ block.settings.text_transform }};
                                          --btn-spacing: {{ block.settings.letter_spacing }}px;
                                          --btn-lh: {{ block.settings.line_height }};"
                                   {{ block.shopify_attributes }}>
                                    {{ block.settings.label }}
                                    {%- if block.settings.show_arrow -%}
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true" focusable="false">
                                            <path d="M5 12h14" />
                                            <path d="M12 5l7 7-7 7" />
                                        </svg>
                                    {%- endif -%}
                                </a>
                            {%- endif -%}
                        {%- endfor -%}
                    </div>
                {%- endif -%}
            </div>
        </div>
    </div>
</section>
{%- endif -%}

{% schema %}
