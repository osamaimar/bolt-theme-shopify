{{ 'section-home-ecommerce-minimal.css' | asset_url | stylesheet_tag }}

{%- if section.settings.show_section -%}
{% style %}
  .hev-deal-block {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 0px) !important;
    color: var(--block-text-color, inherit) !important;
    background: var(--block-bg, transparent) !important;
  }
  .hev-deal-block:not(.hev-deal-button-block):not(.hev-deal-image-block) *:not(span) {
    color: inherit !important;
  }
  .hev-deal-title span {
    background: var(--highlight-gradient, var(--color-accent)) !important;
    -webkit-background-clip: var(--highlight-clip, text) !important;
    background-clip: var(--highlight-clip, text) !important;
    -webkit-text-fill-color: var(--highlight-fill, transparent) !important;
    display: inline-block;
    color: var(--highlight-color, inherit) !important;
  }
  
  /* Button System */
  .hev-deal-btn {
    background: var(--btn-bg, var(--color-accent-secondary)) !important;
    color: var(--btn-text, var(--bg-secondary)) !important;
    border: 2px solid var(--btn-border, transparent) !important;
    box-shadow: var(--btn-shadow, 0 8px 24px var(--color-accent-secondary-20)) !important;
    transition: all 0.3s ease !important;
  }
  .hev-deal-btn:hover {
    background: var(--btn-hover-bg, var(--color-accent-secondary-dark, var(--color-accent-secondary))) !important;
    color: var(--btn-hover-text, var(--bg-secondary)) !important;
    border-color: var(--btn-hover-border, transparent) !important;
    box-shadow: 0 12px 32px var(--btn-hover-shadow-color, var(--color-accent-secondary-20)) !important;
    transform: translateY(-2px);
  }

  .hev-countdown-box {
    background: var(--box-bg, var(--bg-glass)) !important;
  }
  @media (max-width: 768px) {
    .hev-deal-block {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 0px)) !important;
    }
    .hev-countdown {
        flex-wrap: wrap;
        justify-content: center;
    }
  }
{% endstyle %}

{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}
<section class="hev-deal color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}" id="shopify-section-{{ section.id }}">
    <div class="{% if section.settings.container_width == 'full' %}container-full{% else %}container{% endif %}" style="max-width: {{ section.settings.max_width }}px; margin: 0 auto; text-align: {{ 'left' }};">
        <div class="hev-deal-grid">
            <div class="hev-deal-image">
                {%- assign image_block = section.blocks | where: 'type', 'image' | first -%}
                {%- if image_block -%}
                    <div class="hev-deal-block hev-deal-image-block {% unless image_block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless image_block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                         style="--m-t: {{ image_block.settings.margin_top }}px; --m-b: {{ image_block.settings.margin_bottom }}px; --m-t-m: {{ image_block.settings.margin_top_mobile }}px; --m-b-m: {{ image_block.settings.margin_bottom_mobile }}px;" 
                         {{ image_block.shopify_attributes }}>
                        {%- if image_block.settings.image != blank -%}
                            {%- assign deal_img_alt = image_block.settings.image.alt | default: 'Product image' | escape -%}
                            {{ image_block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', decoding: 'async', alt: deal_img_alt }}
                        {%- else -%}
                            <img src="{{ 'deal-headphones.png' | asset_url }}" loading="lazy" decoding="async" alt="Premium Wireless Headphones — Studio Edition" width="1200" height="auto">
                        {%- endif -%}
                    </div>
                {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
            </div>

            <div class="hev-deal-content">
                {%- for block in section.blocks -%}
                    {%- case block.type -%}
                        {%- when 'image' -%}
                            {%- continue -%}

                        {%- when 'title' -%}
                            {%- if block.settings.title != blank -%}
                                {%- assign h_color = block.settings.highlight_color -%}
                                {%- assign h_gradient = block.settings.highlight_gradient -%}
                                <h2 class="hev-deal-title hev-deal-block hev-deal-title--{{ block.settings.font_size }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                                    style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px; font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; {% if block.settings.text_color != blank %}--block-text-color: {{ block.settings.text_color }};{% endif %} {% if block.settings.bg_gradient != blank %}--block-bg: {{ block.settings.bg_gradient }};{% elsif block.settings.bg_color != blank %}--block-bg: {{ block.settings.bg_color }};{% endif %}
                                    {% if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' %}--highlight-gradient: {{ h_gradient }}; --highlight-clip: text; --highlight-fill: transparent;
                                    {% elsif h_color != blank and h_color != 'rgba(0,0,0,0)' %}--highlight-color: {{ h_color }}; --highlight-gradient: none; --highlight-clip: initial; --highlight-fill: {{ h_color }};
                                    {% endif %}" 
                                    {{ block.shopify_attributes }}>
                                    {{ block.settings.title | replace: '[', '<span>' | replace: ']', '</span>' }}
                                </h2>
                            {%- endif -%}

                        {%- when 'description' -%}
                            {%- if block.settings.description != blank -%}
                                <p class="hev-deal-desc hev-deal-block hev-deal-desc--{{ block.settings.font_size }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                                   style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px; font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; {% if block.settings.text_color != blank %}--block-text-color: {{ block.settings.text_color }};{% endif %} {% if block.settings.bg_gradient != blank %}--block-bg: {{ block.settings.bg_gradient }};{% elsif block.settings.bg_color != blank %}--block-bg: {{ block.settings.bg_color }};{% endif %}" 
                                   {{ block.shopify_attributes }}>
                                    {{ block.settings.description }}
                                </p>
                            {%- endif -%}

                        {%- when 'countdown' -%}
                            <div class="hev-countdown hev-deal-block hev-countdown--{{ block.settings.font_size }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" id="hev-countdown-{{ block.id }}" 
                                 data-end-date="{{ block.settings.end_date }}" 
                                 style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px; font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; {% if block.settings.text_color != blank %}--block-text-color: {{ block.settings.text_color }};{% endif %} {% if block.settings.bg_gradient != blank %}--box-bg: {{ block.settings.bg_gradient }};{% elsif block.settings.bg_color != blank %}--box-bg: {{ block.settings.bg_color }};{% endif %}" 
                                 {{ block.shopify_attributes }}>
                                {%- if block.settings.show_years -%}
                                <div class="hev-countdown-box">
                                    <div class="hev-countdown-value" data-countdown-years>00</div>
                                    <div class="hev-countdown-unit">{{ 'general.countdown.years' | t }}</div>
                                </div>
                                {%- endif -%}
                                {%- if block.settings.show_months -%}
                                <div class="hev-countdown-box">
                                    <div class="hev-countdown-value" data-countdown-months>00</div>
                                    <div class="hev-countdown-unit">{{ 'general.countdown.months' | t }}</div>
                                </div>
                                {%- endif -%}
                                {%- if block.settings.show_weeks -%}
                                <div class="hev-countdown-box">
                                    <div class="hev-countdown-value" data-countdown-weeks>00</div>
                                    <div class="hev-countdown-unit">{{ 'general.countdown.weeks' | t }}</div>
                                </div>
                                {%- endif -%}
                                {%- if block.settings.show_days -%}
                                <div class="hev-countdown-box">
                                    <div class="hev-countdown-value" data-countdown-days>00</div>
                                    <div class="hev-countdown-unit">{{ 'general.countdown.days' | t }}</div>
                                </div>
                                {%- endif -%}
                                {%- if block.settings.show_hours -%}
                                <div class="hev-countdown-box">
                                    <div class="hev-countdown-value" data-countdown-hours>00</div>
                                    <div class="hev-countdown-unit">{{ 'general.countdown.hours' | t }}</div>
                                </div>
                                {%- endif -%}
                                {%- if block.settings.show_minutes -%}
                                <div class="hev-countdown-box">
                                    <div class="hev-countdown-value" data-countdown-minutes>00</div>
                                    <div class="hev-countdown-unit">{{ 'general.countdown.minutes' | t }}</div>
                                </div>
                                {%- endif -%}
                                {%- if block.settings.show_seconds -%}
                                <div class="hev-countdown-box">
                                    <div class="hev-countdown-value" data-countdown-seconds>00</div>
                                    <div class="hev-countdown-unit">{{ 'general.countdown.seconds' | t }}</div>
                                </div>
                                {%- endif -%}
                            </div>

                            <script>
                                (function() {
                                    var countdownEl = document.getElementById('hev-countdown-{{ block.id }}');
                                    if (!countdownEl) return;

                                    var endDateStr = countdownEl.getAttribute('data-end-date');
                                    var endDate = endDateStr ? new Date(endDateStr).getTime() : Date.now() + (8 * 3600 + 42 * 60 + 15) * 1000;

                                    var showYears = {{ block.settings.show_years | json }};
                                    var showMonths = {{ block.settings.show_months | json }};
                                    var showWeeks = {{ block.settings.show_weeks | json }};
                                    var showDays = {{ block.settings.show_days | json }};
                                    var showHours = {{ block.settings.show_hours | json }};
                                    var showMinutes = {{ block.settings.show_minutes | json }};
                                    var showSeconds = {{ block.settings.show_seconds | json }};

                                    function pad(n) { return n < 10 ? '0' + n : n; }

                                    function updateCountdown() {
                                        var now = Date.now();
                                        var diff = Math.max(0, Math.floor((endDate - now) / 1000));

                                        if (diff <= 0) {
                                            ['years', 'months', 'weeks', 'days', 'hours', 'minutes', 'seconds'].forEach(function(unit) {
                                                var el = countdownEl.querySelector('[data-countdown-' + unit + ']');
                                                if (el) el.textContent = '00';
                                            });
                                            return;
                                        }

                                        var years = 0, months = 0, weeks = 0, days = 0, hours = 0, minutes = 0, seconds = 0;
                                        var remaining = diff;

                                        if (showYears) {
                                            years = Math.floor(remaining / (3600 * 24 * 365));
                                            remaining %= (3600 * 24 * 365);
                                        }
                                        if (showMonths) {
                                            months = Math.floor(remaining / (3600 * 24 * 30));
                                            remaining %= (3600 * 24 * 30);
                                        }
                                        if (showWeeks) {
                                            weeks = Math.floor(remaining / (3600 * 24 * 7));
                                            remaining %= (3600 * 24 * 7);
                                        }
                                        if (showDays) {
                                            days = Math.floor(remaining / (3600 * 24));
                                            remaining %= (3600 * 24);
                                        }
                                        if (showHours) {
                                            hours = Math.floor(remaining / 3600);
                                            remaining %= 3600;
                                        }
                                        if (showMinutes) {
                                            minutes = Math.floor(remaining / 60);
                                            remaining %= 60;
                                        }
                                        if (showSeconds) {
                                            seconds = remaining;
                                        }

                                        var yearsEl = countdownEl.querySelector('[data-countdown-years]');
                                        var monthsEl = countdownEl.querySelector('[data-countdown-months]');
                                        var weeksEl = countdownEl.querySelector('[data-countdown-weeks]');
                                        var daysEl = countdownEl.querySelector('[data-countdown-days]');
                                        var hoursEl = countdownEl.querySelector('[data-countdown-hours]');
                                        var minutesEl = countdownEl.querySelector('[data-countdown-minutes]');
                                        var secondsEl = countdownEl.querySelector('[data-countdown-seconds]');

                                        if (yearsEl) yearsEl.textContent = pad(years);
                                        if (monthsEl) monthsEl.textContent = pad(months);
                                        if (weeksEl) weeksEl.textContent = pad(weeks);
                                        if (daysEl) daysEl.textContent = pad(days);
                                        if (hoursEl) hoursEl.textContent = pad(hours);
                                        if (minutesEl) minutesEl.textContent = pad(minutes);
                                        if (secondsEl) secondsEl.textContent = pad(seconds);
                                    }

                                    updateCountdown();
                                    setInterval(updateCountdown, 1000);
                                })();
                            </script>

                        {%- when 'price' -%}
                            <div class="hev-deal-price-row hev-deal-block hev-deal-price--{{ block.settings.font_size }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                                 style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px; font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; {% if block.settings.bg_gradient != blank %}--block-bg: {{ block.settings.bg_gradient }};{% elsif block.settings.bg_color != blank %}--block-bg: {{ block.settings.bg_color }};{% endif %}" 
                                 {{ block.shopify_attributes }}>
                                {%- if block.settings.show_current_price and block.settings.current_price != blank -%}
                                    <span class="hev-deal-current-price" style="{% if block.settings.current_price_color != blank %}color: {{ block.settings.current_price_color }} !important;{% endif %}">{{ block.settings.current_price }}</span>
                                {%- endif -%}
                                {%- if block.settings.show_original_price and block.settings.original_price != blank -%}
                                    <span class="hev-deal-old-price" style="{% if block.settings.original_price_color != blank %}color: {{ block.settings.original_price_color }} !important;{% endif %}">{{ block.settings.original_price }}</span>
                                {%- endif -%}
                                {%- if block.settings.show_savings and block.settings.savings_text != blank -%}
                                    <span class="hev-deal-save" style="{% if block.settings.savings_text_color != blank %}color: {{ block.settings.savings_text_color }} !important;{% endif %} {% if block.settings.savings_bg_color != blank %}background: {{ block.settings.savings_bg_color }} !important;{% endif %}">{{ block.settings.savings_text }}</span>
                                {%- endif -%}
                            </div>

                        {%- when 'button' -%}
                            {%- if block.settings.label != blank -%}
                                {%- liquid
                                   assign btn_bg = block.settings.bg_color | default: 'var(--color-accent-secondary)'
                                   if block.settings.bg_gradient != blank
                                      assign btn_bg = block.settings.bg_gradient
                                   endif
                                   
                                   assign btn_text = block.settings.text_color | default: 'var(--bg-secondary)'
                                   assign btn_border = 'transparent'
                                   
                                   if block.settings.button_style == 'outline'
                                      assign btn_bg = 'transparent'
                                      assign btn_text = block.settings.bg_color | default: 'var(--text-inverse)'
                                      assign btn_border = block.settings.bg_color | default: 'var(--color-accent-secondary)'
                                   endif
                                -%}
                                <div class="hev-deal-btn-wrapper hev-deal-block hev-deal-button-block" style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px; display: flex; justify-content: {% if 'left' == 'center' %}center{% elsif 'left' == 'right' %}flex-end{% else %}flex-start{% endif %};">
                                    <a href="{{ block.settings.link | default: '#' }}" 
                                       class="hev-deal-btn hev-deal-btn--{{ block.settings.font_size }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                                       id="hev-grab-deal-btn-{{ block.id }}" 
                                       aria-label="{{ block.settings.label | escape }}" 
                                       style="font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }};
                                       --btn-bg: {{ btn_bg }};
                                       --btn-text: {{ btn_text }};
                                       --btn-border: {{ btn_border }};
                                       {% if block.settings.button_style == 'outline' %}--btn-shadow: none;{% endif %}
                                       {% if block.settings.hover_bg_color != blank %}--btn-hover-bg: {{ block.settings.hover_bg_color }};{% endif %}
                                       {% if block.settings.hover_text_color != blank %}--btn-hover-text: {{ block.settings.hover_text_color }};{% else %}--btn-hover-text: {{ btn_text }};{% endif %}
                                       {% if block.settings.hover_border_color != blank %}--btn-hover-border: {{ block.settings.hover_border_color }};{% endif %}
                                       {% if block.settings.hover_shadow_color != blank %}--btn-hover-shadow-color: {{ block.settings.hover_shadow_color }};{% endif %}"
                                       {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                                       {{ block.shopify_attributes }}>
                                        {{ block.settings.label }}
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true" focusable="false">
                                            <path d="M5 12h14" />
                                            <path d="M12 5l7 7-7 7" />
                                        </svg>
                                    </a>
                                </div>
                            {%- endif -%}

                        {%- when '@app' -%}
                            <div {{ block.shopify_attributes }}>
                                {% render block %}
                            </div>
                    {%- endcase -%}
                {%- endfor -%}
            </div>
        </div>
    </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Deal of the Day",
  "tag": "section",
  "class": "section-deal-of-the-day",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "full",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "full", "label": "Full Width" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Max Width",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 40
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "inverse", "label": "Inverse" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "General Settings"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        },
        {
          "type": "header",
          "content": "Visibility"
        },
        {
          "type": "checkbox",
          "id": "show_on_desktop",
          "label": "Show on Desktop",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_on_mobile",
          "label": "Show on Mobile",
          "default": true
        },
        {
          "type": "header",
          "content": "Layout"
        },
        {
          "type": "range",
          "id": "margin_top",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Top Margin (Desktop)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Bottom Margin (Desktop)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_top_mobile",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Top Margin (Mobile)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom_mobile",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Bottom Margin (Mobile)",
          "default": 0
        }
      ]
    },
    {
      "type": "title",
      "name": "Title",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "General Settings"
        },
