{{ 'section-error-404.css' | asset_url | stylesheet_tag }}

{%- if section.settings.show_section -%}
<style>
  /* Section Padding overrides */
  #shopify-section-{{ section.id }} .error-404-section {
    padding-top: calc({{ section.settings.padding_top }}px + 100px) !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .error-404-section {
      padding-top: calc({{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px + 80px) !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Container & Max Width overrides */
  #shopify-section-{{ section.id }} .container-narrow {
    max-width: 720px !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container {
    max-width: {{ section.settings.max_width | default: 1340 }}px !important;
    margin: 0 auto !important;
  }

  /* Blocks Position alignment overrides */
  #shopify-section-{{ section.id }} .error-404-container {
    max-width: 100% !important;
    display: flex;
    flex-direction: column;
    {%- if section.settings.blocks_position == 'left' -%}
      align-items: flex-start !important;
    {%- elsif section.settings.blocks_position == 'right' -%}
      align-items: flex-end !important;
    {%- else -%}
      align-items: center !important;
    {%- endif -%}
  }

  #shopify-section-{{ section.id }} .error-404-actions {
    {%- if section.settings.blocks_position == 'left' -%}
      align-self: flex-start !important;
      justify-content: flex-start !important;
    {%- elsif section.settings.blocks_position == 'right' -%}
      align-self: flex-end !important;
      justify-content: flex-end !important;
    {%- else -%}
      align-self: center !important;
      justify-content: center !important;
    {%- endif -%}
  }

  #shopify-section-{{ section.id }} .error-404-nav {
    display: flex !important;
    flex-wrap: wrap !important;
    gap: 20px !important;
    width: 100% !important;
    max-width: 100% !important;
    {%- if section.settings.blocks_position == 'left' -%}
      align-self: flex-start !important;
      justify-content: flex-start !important;
      margin-left: 0 !important;
      margin-right: auto !important;
    {%- elsif section.settings.blocks_position == 'right' -%}
      align-self: flex-end !important;
      justify-content: flex-end !important;
      margin-left: auto !important;
      margin-right: 0 !important;
    {%- else -%}
      align-self: center !important;
      justify-content: center !important;
      margin-left: auto !important;
      margin-right: auto !important;
    {%- endif -%}
  }

  #shopify-section-{{ section.id }} .error-404-nav-item {
    flex: 1 1 calc(33.333% - 14px) !important;
    min-width: 150px !important;
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .error-404-nav {
      max-width: 100% !important;
      gap: 12px !important;
    }
    #shopify-section-{{ section.id }} .error-404-nav-item {
      flex: 1 1 100% !important;
    }
  }

  /* Block specific overrides */
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'error_code' -%}
        #shopify-section-{{ section.id }} .error-404-code-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 24 }}px !important;
          {%- if section.settings.blocks_position == 'left' -%}
            margin-left: 0 !important;
            margin-right: auto !important;
          {%- elsif section.settings.blocks_position == 'right' -%}
            margin-left: auto !important;
            margin-right: 0 !important;
          {%- else -%}
            margin-left: auto !important;
            margin-right: auto !important;
          {%- endif -%}
          font-weight: {% if block.settings.font_weight == 'bold' %}900{% else %}400{% endif %} !important;
          font-style: {{ block.settings.font_style | default: 'normal' }} !important;
          text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
          letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
          {%- if block.settings.line_height != blank -%}
            line-height: {{ block.settings.line_height | divided_by: 100.0 }} !important;
          {%- endif -%}
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- endif -%}
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
            padding: 10px 20px !important;
            display: inline-block !important;
            border-radius: var(--radius-sm, 4px) !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.bg_color }} !important;
            background-image: none !important;
            padding: 10px 20px !important;
            display: inline-block !important;
            border-radius: var(--radius-sm, 4px) !important;
          {%- endif -%}
          {%- if block.settings.show_shadow -%}
            {%- if block.settings.shadow_color != blank and block.settings.shadow_color != 'rgba(0,0,0,0)' -%}
              filter: drop-shadow(0 15px 35px {{ block.settings.shadow_color }}) !important;
            {%- else -%}
              filter: drop-shadow(0 15px 35px var(--color-accent-20, rgba(255, 106, 60, 0.2))) !important;
            {%- endif -%}
          {%- else -%}
            filter: none !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .error-404-code-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 16 }}px !important;
          }
        }

      {%- when 'heading' -%}
        #shopify-section-{{ section.id }} .error-404-title-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 16 }}px !important;
          {%- if section.settings.blocks_position == 'left' -%}
            margin-left: 0 !important;
            margin-right: auto !important;
          {%- elsif section.settings.blocks_position == 'right' -%}
            margin-left: auto !important;
            margin-right: 0 !important;
          {%- else -%}
            margin-left: auto !important;
            margin-right: auto !important;
          {%- endif -%}
          font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %} !important;
          font-style: {{ block.settings.font_style | default: 'normal' }} !important;
          text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
          letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
          {%- if block.settings.line_height != blank -%}
            line-height: {{ block.settings.line_height | divided_by: 100.0 }} !important;
          {%- endif -%}
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- endif -%}
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
            padding: 8px 16px !important;
            display: inline-block !important;
            border-radius: var(--radius-sm, 4px) !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.bg_color }} !important;
            background-image: none !important;
            padding: 8px 16px !important;
            display: inline-block !important;
            border-radius: var(--radius-sm, 4px) !important;
          {%- endif -%}
          {%- if '' != blank -%}
            text-align: {{ '' }} !important;
          {%- else -%}
            text-align: center !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .error-404-title-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 12 }}px !important;
          }
        }

      {%- when 'description' -%}
        #shopify-section-{{ section.id }} .error-404-description-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 40 }}px !important;
          {%- if section.settings.blocks_position == 'left' -%}
            margin-left: 0 !important;
            margin-right: auto !important;
          {%- elsif section.settings.blocks_position == 'right' -%}
            margin-left: auto !important;
            margin-right: 0 !important;
          {%- else -%}
            margin-left: auto !important;
            margin-right: auto !important;
          {%- endif -%}
          max-width: {{ block.settings.max_width | default: 560 }}px !important;
          font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %} !important;
          font-style: {{ block.settings.font_style | default: 'normal' }} !important;
          text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
          letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
          {%- if block.settings.line_height != blank -%}
            line-height: {{ block.settings.line_height | divided_by: 100.0 }} !important;
          {%- endif -%}
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- endif -%}
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
            padding: 10px 20px !important;
            display: inline-block !important;
            border-radius: var(--radius-sm, 4px) !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.bg_color }} !important;
            background-image: none !important;
            padding: 10px 20px !important;
            display: inline-block !important;
            border-radius: var(--radius-sm, 4px) !important;
          {%- endif -%}
          {%- if '' != blank -%}
            text-align: {{ '' }} !important;
          {%- else -%}
            text-align: center !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .error-404-description-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 32 }}px !important;
          }
        }

      {%- when 'button' -%}
        #shopify-section-{{ section.id }} #error-404-btn-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 20 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 20 }}px !important;
          {%- if block.settings.font_size == 'small' -%}
            font-size: 0.85rem !important;
          {%- elsif block.settings.font_size == 'medium' -%}
            font-size: 1rem !important;
          {%- elsif block.settings.font_size == 'large' -%}
            font-size: 1.15rem !important;
          {%- endif -%}
          font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %} !important;
          font-style: {{ block.settings.font_style | default: 'normal' }} !important;
          text-transform: {{ block.settings.text_transform | default: 'uppercase' }} !important;
          letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
          {%- if block.settings.line_height != blank -%}
            line-height: {{ block.settings.line_height | divided_by: 100.0 }} !important;
          {%- endif -%}
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- endif -%}
          {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
            border-color: {{ block.settings.border_color }} !important;
          {%- endif -%}
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.bg_color }} !important;
            background-image: none !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} #error-404-btn-{{ block.id }} svg {
          {%- if block.settings.icon_color != blank and block.settings.icon_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.icon_color }} !important;
            stroke: {{ block.settings.icon_color }} !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} #error-404-btn-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 15 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 15 }}px !important;
          }
        }

      {%- when 'nav_item' -%}
        #shopify-section-{{ section.id }} #error-404-nav-item-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 0 }}px !important;
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.bg_color }} !important;
            background-image: none !important;
          {%- endif -%}
          {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
            border-color: {{ block.settings.border_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} #error-404-nav-item-{{ block.id }} .error-404-nav-label {
          font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %} !important;
          font-style: {{ block.settings.font_style | default: 'normal' }} !important;
          text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
          letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
          {%- if block.settings.line_height != blank -%}
            line-height: {{ block.settings.line_height | divided_by: 100.0 }} !important;
          {%- endif -%}
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} #error-404-nav-item-{{ block.id }} .error-404-nav-hint {
          {%- if block.settings.hint_color != blank and block.settings.hint_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.hint_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} #error-404-nav-item-{{ block.id }}:hover {
          {%- if block.settings.bg_hover_color != blank and block.settings.bg_hover_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.bg_hover_color }} !important;
            background-image: none !important;
          {%- endif -%}
          {%- if block.settings.border_hover_color != blank and block.settings.border_hover_color != 'rgba(0,0,0,0)' -%}
            border-color: {{ block.settings.border_hover_color }} !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} #error-404-nav-item-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 0 }}px !important;
          }
        }

      {%- when 'footer_note' -%}
        #shopify-section-{{ section.id }} .error-404-note-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 48 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 0 }}px !important;
          {%- if section.settings.blocks_position == 'left' -%}
            margin-left: 0 !important;
            margin-right: auto !important;
          {%- elsif section.settings.blocks_position == 'right' -%}
            margin-left: auto !important;
            margin-right: 0 !important;
          {%- else -%}
            margin-left: auto !important;
            margin-right: auto !important;
          {%- endif -%}
          font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %} !important;
          font-style: {{ block.settings.font_style | default: 'normal' }} !important;
          text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
          letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
          {%- if block.settings.line_height != blank -%}
            line-height: {{ block.settings.line_height | divided_by: 100.0 }} !important;
          {%- endif -%}
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- endif -%}
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
            padding: 8px 16px !important;
            border-radius: var(--radius-sm, 6px) !important;
            display: inline-block !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.bg_color }} !important;
            background-image: none !important;
            padding: 8px 16px !important;
            border-radius: var(--radius-sm, 6px) !important;
            display: inline-block !important;
          {%- endif -%}
          {%- if '' != blank -%}
            text-align: {{ '' }} !important;
          {%- else -%}
            text-align: center !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .error-404-note-{{ block.id }} a {
          {%- if block.settings.link_color != blank and block.settings.link_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.link_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .error-404-note-{{ block.id }} a:hover {
          {%- if block.settings.link_hover_color != blank and block.settings.link_hover_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.link_hover_color }} !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .error-404-note-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 36 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 0 }}px !important;
          }
        }

      {%- when 'divider' -%}
        {% # theme-check-disable BlockIdUsage %}
        #shopify-section-{{ section.id }} #error-404-divider-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 32 }}px !important;
          width: {{ block.settings.width | default: 100 }}% !important;
          {%- if block.settings.divider_style == 'solid' -%}
            height: {{ block.settings.thickness | default: 1 }}px !important;
            border: none !important;
            {%- if block.settings.divider_color != blank and block.settings.divider_color != 'rgba(0,0,0,0)' -%}
              background: {{ block.settings.divider_color }} !important;
            {%- else -%}
              {%- if block.id == 'divider' -%}
                background: var(--color-accent) !important;
                border-radius: var(--radius-xs, 2px) !important;
              {%- else -%}
                background: var(--border-light, #2a2a2a) !important;
              {%- endif -%}
            {%- endif -%}
          {%- else -%}
            height: 0 !important;
            background: transparent !important;
            border-bottom: none !important;
            border-left: none !important;
            border-right: none !important;
            border-top: {{ block.settings.thickness | default: 1 }}px {{ block.settings.divider_style | default: 'solid' }} {% if block.settings.divider_color != blank and block.settings.divider_color != 'rgba(0,0,0,0)' %}{{ block.settings.divider_color }}{% else %}{% if block.id == 'divider' %}var(--color-accent, #ff6a3c){% else %}var(--border-light, #2a2a2a){% endif %}{% endif %} !important;
            border-radius: 0 !important;
          {%- endif -%}
          {%- if section.settings.blocks_position == 'left' -%}
            margin-left: 0 !important;
            margin-right: auto !important;
          {%- elsif section.settings.blocks_position == 'right' -%}
            margin-left: auto !important;
            margin-right: 0 !important;
          {%- else -%}
            margin-left: auto !important;
            margin-right: auto !important;
          {%- endif -%}
        }
        {% # theme-check-enable BlockIdUsage %}
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} #error-404-divider-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 32 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 24 }}px !important;
          }
        }
    {%- endcase -%}
  {%- endfor -%}
</style>

{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

<section class="error-404-section color-{{ section.settings.color_scheme }}{% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}">
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    <div class="error-404-container">
      
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'error_code' -%}
            {%- if block.settings.error_code != blank -%}
              <p class="error-404-code error-404-code-{{ block.id }} size-{{ block.settings.font_size | default: 'large' }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" aria-hidden="true" {{ block.shopify_attributes }}>{{ block.settings.error_code }}</p>
            {%- endif -%}

          {%- when 'divider' -%}
            <hr id="error-404-divider-{{ block.id }}" class="error-404-divider{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }} />

          {%- when 'heading' -%}
            {%- if block.settings.title != blank -%}
              {%- assign heading_tag = block.settings.heading_tag | default: 'h1' -%}
              {%- assign h_color = block.settings.highlight_color -%}
              {%- assign h_gradient = block.settings.highlight_gradient -%}
              {%- if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' -%}
                {%- assign highlight_span = '<span class="error-404-accent" style="background: ' | append: h_gradient | append: '; -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">' -%}
              {%- elsif h_color != blank and h_color != 'rgba(0,0,0,0)' -%}
                {%- assign highlight_span = '<span class="error-404-accent" style="color: ' | append: h_color | append: ';">' -%}
              {%- else -%}
                {%- assign highlight_span = '<span class="error-404-accent">' -%}
              {%- endif -%}
              {%- assign title_val = block.settings.title | default: 'Page [Not Found]' -%}{%- assign temp_key = 'custom_labels.' | append: title_val | handleize -%}{%- assign temp_trans = temp_key | t -%}{%- unless temp_trans contains 'translation' or temp_trans contains 'Translation' -%}{%- assign title_val = temp_trans -%}{%- endunless -%}
              <{{ heading_tag }} class="error-404-title error-404-title-{{ block.id }} size-{{ block.settings.font_size | default: 'large' }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
                {{ title_val | replace: '[', highlight_span | replace: ']', '</span>' }}
              </{{ heading_tag }}>
            {%- endif -%}

          {%- when 'description' -%}
            {%- if block.settings.description != blank -%}
              {%- assign desc_tag = block.settings.description_tag | default: 'p' -%}
              {%- assign h_color = block.settings.highlight_color -%}
              {%- assign h_gradient = block.settings.highlight_gradient -%}
              {%- if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' -%}
                {%- assign highlight_span = '<span class="error-404-accent" style="background: ' | append: h_gradient | append: '; -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">' -%}
              {%- elsif h_color != blank and h_color != 'rgba(0,0,0,0)' -%}
                {%- assign highlight_span = '<span class="error-404-accent" style="color: ' | append: h_color | append: ';">' -%}
              {%- else -%}
                {%- assign highlight_span = '<span class="error-404-accent">' -%}
              {%- endif -%}
              {%- assign desc_val = block.settings.description | default: "The page you're looking for doesn't exist or may have been moved." -%}{%- assign temp_key = 'custom_labels.' | append: desc_val | handleize -%}{%- assign temp_trans = temp_key | t -%}{%- unless temp_trans contains 'translation' or temp_trans contains 'Translation' -%}{%- assign desc_val = temp_trans -%}{%- endunless -%}
              <{{ desc_tag }} class="error-404-description error-404-description-{{ block.id }} size-{{ block.settings.font_size | default: 'medium' }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
                {{ desc_val | replace: '[', highlight_span | replace: ']', '</span>' }}
              </{{ desc_tag }}>
            {%- endif -%}

          {%- when 'button' -%}
            {%- assign prev_index = forloop.index0 | minus: 1 -%}
            {%- assign next_index = forloop.index0 | plus: 1 -%}
            {%- assign prev_type = '' -%}
            {%- assign next_type = '' -%}
            
            {%- if prev_index >= 0 -%}
              {%- assign prev_type = section.blocks[prev_index].type -%}
            {%- endif -%}
            {%- if next_index < section.blocks.size -%}
              {%- assign next_type = section.blocks[next_index].type -%}
            {%- endif -%}

            {%- if prev_type != 'button' -%}
              {% # theme-check-disable UnclosedHTMLElement %}
              <div class="error-404-actions">
              {% # theme-check-enable UnclosedHTMLElement %}
            {%- endif -%}

            {%- capture button_icon -%}
              {%- if block.settings.show_icon and block.settings.icon != 'none' -%}
                {%- case block.settings.icon -%}
                  {%- when 'arrow' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 12h14"></path>
                      <path d="m12 5 7 7-7 7"></path>
                    </svg>
                  {%- when 'check' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  {%- when 'info' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"></circle>
                      <line x1="12" y1="16" x2="12" y2="12"></line>
                      <line x1="12" y1="8" x2="12.01" y2="8"></line>
                    </svg>
                  {%- when 'mail' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                    </svg>
                  {%- when 'external' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                      <polyline points="15 3 21 3 21 9"></polyline>
                      <line x1="10" y1="14" x2="21" y2="3"></line>
                    </svg>
                  {%- when 'download' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                      <polyline points="7 10 12 15 17 10"></polyline>
                      <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                {%- endcase -%}
              {%- endif -%}
            {%- endcapture -%}

            {%- if block.settings.show_button -%}
              {%- assign btn_label = block.settings.label | default: 'Button' -%}{%- assign temp_key = 'custom_labels.' | append: btn_label | handleize -%}{%- assign temp_trans = temp_key | t -%}{%- unless temp_trans contains 'translation' or temp_trans contains 'Translation' -%}{%- assign btn_label = temp_trans -%}{%- endunless -%}
              <a href="{{ block.settings.url }}" id="error-404-btn-{{ block.id }}" class="error-404-btn error-404-btn--{{ block.settings.style }} btn-style-{{ block.settings.style }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}"{% if block.settings.open_in_new_tab %} target="_blank" rel="noopener"{% endif %} {{ block.shopify_attributes }}>
                {%- if block.settings.icon_position == 'left' -%}
                  {{ button_icon }}
                  {{ btn_label }}
                {%- else -%}
                  {{ btn_label }}
                  {{ button_icon }}
                {%- endif -%}
              </a>
            {%- endif -%}

            {%- if next_type != 'button' -%}
              {% # theme-check-disable UnclosedHTMLElement %}
              </div>
              {% # theme-check-enable UnclosedHTMLElement %}
            {%- endif -%}

          {%- when 'nav_item' -%}
            {%- assign prev_index = forloop.index0 | minus: 1 -%}
            {%- assign next_index = forloop.index0 | plus: 1 -%}
            {%- assign prev_type = '' -%}
            {%- assign next_type = '' -%}
            
            {%- if prev_index >= 0 -%}
              {%- assign prev_type = section.blocks[prev_index].type -%}
            {%- endif -%}
            {%- if next_index < section.blocks.size -%}
              {%- assign next_type = section.blocks[next_index].type -%}
            {%- endif -%}

            {%- if prev_type != 'nav_item' -%}
              {% # theme-check-disable UnclosedHTMLElement %}
              <div class="error-404-nav">
              {% # theme-check-enable UnclosedHTMLElement %}
            {%- endif -%}

            {%- assign nav_label = block.settings.label | default: 'Home' -%}{%- assign temp_key = 'custom_labels.' | append: nav_label | handleize -%}{%- assign temp_trans = temp_key | t -%}{%- unless temp_trans contains 'translation' or temp_trans contains 'Translation' -%}{%- assign nav_label = temp_trans -%}{%- endunless -%}
            {%- assign nav_hint = block.settings.hint | default: 'Return to main page' -%}{%- assign temp_key_hint = 'custom_labels.' | append: nav_hint | handleize -%}{%- assign temp_trans_hint = temp_key_hint | t -%}{%- unless temp_trans_hint contains 'translation' or temp_trans_hint contains 'Translation' -%}{%- assign nav_hint = temp_trans_hint -%}{%- endunless -%}
            <a href="{{ block.settings.link }}" id="error-404-nav-item-{{ block.id }}" class="error-404-nav-item{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
              {%- if block.settings.show_nav_item -%}
                <span class="error-404-nav-label">{{ nav_label }}</span>
              {%- endif -%}
              {%- if block.settings.show_hint and block.settings.hint != blank -%}
                <span class="error-404-nav-hint">{{ nav_hint }}</span>
              {%- endif -%}
            </a>

            {%- if next_type != 'nav_item' -%}
              {% # theme-check-disable UnclosedHTMLElement %}
              </div>
              {% # theme-check-enable UnclosedHTMLElement %}
            {%- endif -%}

          {%- when 'footer_note' -%}
            {%- if block.settings.footer_note != blank -%}
              {%- assign note_val = block.settings.footer_note | default: '<p>Need help? <a href="/pages/contact">Get in touch</a> with our team.</p>' -%}{%- assign temp_key = 'custom_labels.' | append: note_val | handleize -%}{%- assign temp_trans = temp_key | t -%}{%- unless temp_trans contains 'translation' or temp_trans contains 'Translation' -%}{%- assign note_val = temp_trans -%}{%- endunless -%}
              <div class="error-404-note error-404-note-{{ block.id }} size-{{ block.settings.font_size | default: 'small' }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
                {{ note_val }}
              </div>
            {%- endif -%}

        {%- endcase -%}
      {%- endfor -%}

    </div>
  </div>
</section>
{%- endif -%}

