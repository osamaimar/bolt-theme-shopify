{{ 'section-faq-cta-sidebar.css' | asset_url | stylesheet_tag }}

<style>
  /* Section Spacing / Visibility overrides */
  #shopify-section-{{ section.id }} .faq-cta-sidebar-section {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .faq-cta-sidebar-section {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Container Width overrides */
  #shopify-section-{{ section.id }} .container-fluid {
    max-width: 100% !important;
    padding-left: 2rem !important;
    padding-right: 2rem !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container-narrow {
    max-width: 800px !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container {
    max-width: {{ section.settings.max_width | default: 1000 }}px !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
    margin: 0 auto !important;
  }

  /* Blocks Position align overrides */
  #shopify-section-{{ section.id }} .faq-cta-sidebar-wrapper {
    display: flex;
    flex-direction: column;
    width: 100%;
    {%- if section.settings.blocks_position == 'left' -%}
      align-items: flex-start !important;
      text-align: left !important;
    {%- elsif section.settings.blocks_position == 'right' -%}
      align-items: flex-end !important;
      text-align: right !important;
    {%- else -%}
      align-items: center !important;
      text-align: center !important;
    {%- endif -%}
    {%- if section.settings.card_bg_gradient != blank -%}
      background: {{ section.settings.card_bg_gradient }} !important;
    {%- elsif section.settings.card_bg_color != blank and section.settings.card_bg_color != 'rgba(0,0,0,0)' -%}
      background: {{ section.settings.card_bg_color }} !important;
    {%- endif -%}
  }

  /* Background pattern styling */
  #shopify-section-{{ section.id }} .bg-pattern {
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(var(--color-secondary-rgb), 0.4) 0%, rgba(0,0,0,0) 70%);
    pointer-events: none;
    opacity: 0.6;
    z-index: 1;
  }
  #shopify-section-{{ section.id }} .pattern-top-left {
    top: -150px;
    left: -150px;
  }
  #shopify-section-{{ section.id }} .pattern-bottom-right {
    bottom: -150px;
    right: -150px;
  }

  /* Responsive Font Sizing scoped specifically to element types */
  #shopify-section-{{ section.id }} .faq-cta-sidebar-heading.size-small { font-size: 1.5rem !important; }
  #shopify-section-{{ section.id }} .faq-cta-sidebar-heading.size-medium { font-size: 1.75rem !important; }
  #shopify-section-{{ section.id }} .faq-cta-sidebar-heading.size-large { font-size: 2.0rem !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .faq-cta-sidebar-heading.size-small { font-size: 1.25rem !important; }
    #shopify-section-{{ section.id }} .faq-cta-sidebar-heading.size-medium { font-size: 1.35rem !important; }
    #shopify-section-{{ section.id }} .faq-cta-sidebar-heading.size-large { font-size: 1.5rem !important; }
  }

  #shopify-section-{{ section.id }} .faq-cta-sidebar-text.size-small { font-size: 0.95rem !important; }
  #shopify-section-{{ section.id }} .faq-cta-sidebar-text.size-medium { font-size: 1.05rem !important; }
  #shopify-section-{{ section.id }} .faq-cta-sidebar-text.size-large { font-size: 1.2rem !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .faq-cta-sidebar-text.size-small { font-size: 0.9rem !important; }
    #shopify-section-{{ section.id }} .faq-cta-sidebar-text.size-medium { font-size: 1.0rem !important; }
    #shopify-section-{{ section.id }} .faq-cta-sidebar-text.size-large { font-size: 1.1rem !important; }
  }

  #shopify-section-{{ section.id }} .faq-cta-sidebar-btn.size-small { font-size: 0.85rem !important; padding: 10px 24px !important; }
  #shopify-section-{{ section.id }} .faq-cta-sidebar-btn.size-medium { font-size: 0.95rem !important; padding: 14px 40px !important; }
  #shopify-section-{{ section.id }} .faq-cta-sidebar-btn.size-large { font-size: 1.1rem !important; padding: 16px 48px !important; }

  /* Dynamic block styling generated per block instance */
  {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subtitle'
        assign b_align_alignment = ''
      when 'button'
        assign b_align_alignment = 'center'
  endcase
-%}
    {%- case block.type -%}
      {%- when 'icon' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          width: {{ block.settings.icon_size | default: 64 }}px !important;
          height: {{ block.settings.icon_size | default: 64 }}px !important;
          margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 24 }}px !important;
          display: inline-flex !important;
          align-items: center !important;
          justify-content: center !important;
          position: relative;
          z-index: 2;
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
            border-radius: 50% !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.bg_color }} !important;
            border-radius: 50% !important;
          {%- else -%}
            background: var(--color-accent-secondary-10) !important;
            border-radius: 50% !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} svg {
          width: calc({{ block.settings.icon_size | default: 64 }}px * 0.5) !important;
          height: calc({{ block.settings.icon_size | default: 64 }}px * 0.5) !important;
          {%- if block.settings.icon_color != blank and block.settings.icon_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.icon_color }} !important;
          {%- else -%}
            color: var(--color-accent-secondary) !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 16 }}px !important;
          }
        }
        {%- unless block.settings.show_on_desktop -%}
          @media screen and (min-width: 769px) {
            #shopify-section-{{ section.id }} .block-{{ block.id }} {
              display: none !important;
            }
          }
        {%- endunless -%}
        {%- unless block.settings.show_on_mobile -%}
          @media screen and (max-width: 768px) {
            #shopify-section-{{ section.id }} .block-{{ block.id }} {
              display: none !important;
            }
          }
        {%- endunless -%}
      {%- when 'header' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 16 }}px !important;
          width: 100% !important;
          max-width: {{ block.settings.max_width | default: 800 }}px !important;
          position: relative;
          z-index: 2;
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.bg_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }},
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-cta-sidebar-heading {
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 16 }}px !important;
          }
        }
      {%- when 'subtitle' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 32 }}px !important;
          width: 100% !important;
          max-width: {{ block.settings.max_width | default: 500 }}px !important;
          position: relative;
          z-index: 2;
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.bg_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }},
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-cta-sidebar-text {
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 20 }}px !important;
          }
        }
      {%- when 'button' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 20 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 20 }}px !important;
          width: 100% !important;
          position: relative;
          z-index: 2;
          text-align: {{ b_align_alignment | default: 'center' }} !important;
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 15 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 15 }}px !important;
          }
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-cta-sidebar-btn {
          font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %} !important;
          font-style: {{ block.settings.font_style | default: 'normal' }} !important;
          text-transform: {{ block.settings.text_transform | default: 'uppercase' }} !important;
          letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
          line-height: {{ block.settings.line_height | default: 115 }}% !important;
          display: inline-flex !important;
          align-items: center !important;
          justify-content: center !important;
          gap: 10px !important;
          transition: all 0.3s ease !important;
        }
        
        #shopify-section-{{ section.id }} .block-{{ block.id }} .button-preset-primary {
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
            border: none !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background: {{ block.settings.bg_color }} !important;
            {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
              border: 1px solid {{ block.settings.border_color }} !important;
            {%- else -%}
              border: 1px solid {{ block.settings.bg_color }} !important;
            {%- endif -%}
          {%- else -%}
            background: var(--color-accent-secondary) !important;
            {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
              border: 1px solid {{ block.settings.border_color }} !important;
            {%- else -%}
              border: 1px solid var(--color-accent-secondary) !important;
            {%- endif -%}
          {%- endif -%}
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- else -%}
            color: var(--bg-secondary) !important;
          {%- endif -%}
        }
        
        #shopify-section-{{ section.id }} .block-{{ block.id }} .button-preset-secondary {
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
            border: none !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background: {{ block.settings.bg_color }} !important;
            {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
              border: 1px solid {{ block.settings.border_color }} !important;
            {%- else -%}
              border: 1px solid {{ block.settings.bg_color }} !important;
            {%- endif -%}
          {%- else -%}
            background: var(--color-accent-primary, #ffffff) !important;
            {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
              border: 1px solid {{ block.settings.border_color }} !important;
            {%- else -%}
              border: 1px solid var(--color-accent-primary, #ffffff) !important;
            {%- endif -%}
          {%- endif -%}
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- else -%}
            color: var(--bg-primary, #000000) !important;
          {%- endif -%}
        }

        #shopify-section-{{ section.id }} .block-{{ block.id }} .button-preset-outline {
          background: transparent !important;
          {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
            border: 1px solid {{ block.settings.border_color }} !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            border: 1px solid {{ block.settings.bg_color }} !important;
          {%- else -%}
            border: 1px solid var(--color-accent-secondary) !important;
          {%- endif -%}
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- else -%}
            color: var(--color-accent-secondary) !important;
          {%- endif -%}
        }
        
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-cta-sidebar-btn svg {
          width: 16px !important;
          height: 16px !important;
          {%- if block.settings.icon_color != blank and block.settings.icon_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.icon_color }} !important;
          {%- endif -%}
        }

        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-cta-sidebar-btn:hover {
          {%- if block.settings.hover_bg_gradient != blank -%}
            background: {{ block.settings.hover_bg_gradient }} !important;
            border: none !important;
          {%- elsif block.settings.hover_bg_color != blank and block.settings.hover_bg_color != 'rgba(0,0,0,0)' -%}
            background: {{ block.settings.hover_bg_color }} !important;
            border: 1px solid {{ block.settings.hover_bg_color }} !important;
          {%- endif -%}
          {%- if block.settings.hover_text_color != blank and block.settings.hover_text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.hover_text_color }} !important;
          {%- endif -%}
          {%- if block.settings.hover_border_color != blank and block.settings.hover_border_color != 'rgba(0,0,0,0)' -%}
            border: 1px solid {{ block.settings.hover_border_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-cta-sidebar-btn:hover svg {
          {%- if block.settings.hover_icon_color != blank and block.settings.hover_icon_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.hover_icon_color }} !important;
          {%- endif -%}
        }
    {%- endcase -%}
  {%- endfor -%}
</style>

{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

{%- if section.settings.show_section -%}
<section 
  class="faq-cta-sidebar-section color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}"
  id="shopify-section-{{ section.id }}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    
    <div class="faq-cta-sidebar-wrapper" style="border-radius: {{ section.settings.card_border_radius | default: 20 }}px;">
      {%- if section.settings.show_background_pattern -%}
        <div class="bg-pattern pattern-top-left"></div>
        <div class="bg-pattern pattern-bottom-right"></div>
      {%- endif -%}

      {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subtitle'
        assign b_align_alignment = ''
      when 'button'
        assign b_align_alignment = 'center'
  endcase
-%}
        {%- case block.type -%}
          {%- when 'icon' -%}
            <div 
              class="faq-cta-sidebar-icon block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.custom_icon_svg != blank -%}
                {{ block.settings.custom_icon_svg }}
              {%- else -%}
                {%- case block.settings.icon -%}
                  {%- when 'laptop' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                  {%- when 'phone' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  {%- when 'headphones' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
                  {%- when 'tools' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                  {%- when 'gamepad' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="12" x2="10" y2="12"/><line x1="8" y1="10" x2="8" y2="14"/><line x1="15" y1="13" x2="15.01" y2="13"/><line x1="18" y1="11" x2="18.01" y2="11"/><rect x="2" y="6" width="20" height="12" rx="3"/></svg>
                  {%- when 'watch' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="7"/><polyline points="12 9 12 12 13.5 13.5"/><path d="M16.51 17.35l-.35 3.65a1 1 0 0 1-1 .9h-6.32a1 1 0 0 1-1-.9l-.35-3.65m9.02-10.7l.35-3.65a1 1 0 0 0-1-.9h-6.32a1 1 0 0 0-1 .9l-.35 3.65"/></svg>
                  {%- when 'shipping' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  {%- when 'support' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                  {%- when 'secure' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  {%- when 'returns' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
                  {%- when 'check' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  {%- when 'heart' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                  {%- when 'star' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  {%- when 'award' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                  {%- when 'target' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                  {%- when 'zap' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                  {%- when 'gift' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                  {%- when 'user' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  {%- when 'user-plus' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                  {%- when 'message-circle' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                  {%- when 'mail' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                  {%- when 'help-circle' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                  {%- when 'life-buoy' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="4.93" y1="4.93" x2="9.17" y2="9.17"/><line x1="14.83" y1="14.83" x2="19.07" y2="19.07"/><line x1="14.83" y1="9.17" x2="19.07" y2="4.93"/><line x1="14.83" y1="9.17" x2="18.36" y2="5.64"/><line x1="4.93" y1="19.07" x2="9.17" y2="14.83"/></svg>
                  {%- when 'chat' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                  {%- else -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                {%- endcase -%}
              {%- endif -%}
            </div>
            
          {%- when 'header' -%}
            {%- if block.settings.heading != blank -%}
              {%- assign heading_tag = block.settings.heading_tag | default: 'h2' -%}
              {%- assign h_color = block.settings.highlight_color -%}
              {%- assign h_gradient = block.settings.highlight_gradient -%}
              {%- assign head_text_align = b_align_alignment -%}
              {%- if head_text_align == blank -%}
                {%- if section.settings.blocks_position == 'left' -%}
                  {%- assign head_text_align = 'left' -%}
                {%- elsif section.settings.blocks_position == 'right' -%}
                  {%- assign head_text_align = 'right' -%}
                {%- else -%}
                  {%- assign head_text_align = 'center' -%}
                {%- endif -%}
              {%- endif -%}
              <div 
                class="block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                {{ block.shopify_attributes }}
              >
                <{{ heading_tag }} 
                  class="faq-cta-sidebar-heading size-{{ block.settings.font_size | default: 'large' }}"
                  style="
                    font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                    font-style: {{ block.settings.font_style | default: 'normal' }};
                    text-transform: {{ block.settings.text_transform | default: 'none' }};
                    letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                    line-height: {{ block.settings.line_height | default: 120 }}%;
                    text-align: {{ head_text_align }};
                    width: 100% !important;
                    margin-left: auto !important;
                    margin-right: auto !important;
                  "
                >
                  {%- if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' -%}
                    {%- assign highlight_span = '<span class="highlight-text" style="background: ' | append: h_gradient | append: ' !important; -webkit-background-clip: text !important; background-clip: text !important; -webkit-text-fill-color: transparent !important;color: transparent !important;">' -%}
                  {%- elsif h_color != blank and h_color != 'rgba(0,0,0,0)' -%}
                    {%- assign highlight_span = '<span class="highlight-text" style="color: ' | append: h_color | append: ' !important;">' -%}
                  {%- else -%}
                    {%- assign highlight_span = '<span class="highlight-text">' -%}
                  {%- endif -%}
                  {{ block.settings.heading | replace: '[', highlight_span | replace: ']', '</span>' }}
                </{{ heading_tag }}>
              </div>
            {%- endif -%}
            
          {%- when 'subtitle' -%}
            {%- if block.settings.description != blank -%}
              {%- assign subheading_tag = block.settings.subheading_tag | default: 'p' -%}
              {%- assign sub_text_align = b_align_alignment -%}
              {%- if sub_text_align == blank -%}
                {%- if section.settings.blocks_position == 'left' -%}
                  {%- assign sub_text_align = 'left' -%}
                {%- elsif section.settings.blocks_position == 'right' -%}
                  {%- assign sub_text_align = 'right' -%}
                {%- else -%}
                  {%- assign sub_text_align = 'center' -%}
                {%- endif -%}
              {%- endif -%}
              <div 
                class="block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                {{ block.shopify_attributes }}
              >
                <{{ subheading_tag }} 
                  class="faq-cta-sidebar-text size-{{ block.settings.font_size | default: 'medium' }}"
                  style="
                    font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                    font-style: {{ block.settings.font_style | default: 'normal' }};
                    text-transform: {{ block.settings.text_transform | default: 'none' }};
                    letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                    line-height: {{ block.settings.line_height | default: 160 }}%;
                    text-align: {{ sub_text_align }};
                    width: 100% !important;
                    margin-left: auto !important;
                    margin-right: auto !important;
                  "
                >
                  {{ block.settings.description }}
                </{{ subheading_tag }}>
              </div>
            {%- endif -%}
            
          {%- when 'button' -%}
            {%- if block.settings.label != blank -%}
              {%- assign btn_style = block.settings.style | default: 'primary' -%}
              {%- assign target_tab = '' -%}
              {%- if block.settings.open_in_new_tab -%}
                {%- assign target_tab = 'target="_blank" rel="noopener"' -%}
              {%- endif -%}
              
              <div 
                class="block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                {{ block.shopify_attributes }}
              >
                <a 
                  href="{{ block.settings.url | default: '#' }}" 
                  class="faq-cta-sidebar-btn button-preset-{{ btn_style }} size-{{ block.settings.font_size | default: 'medium' }}"
                  {{ target_tab }}
                >
                  {{ block.settings.label }}
                  {%- if block.settings.show_icon -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="5" y1="12" x2="19" y2="12"/>
                      <polyline points="12 5 19 12 12 19"/>
                    </svg>
                  {%- endif -%}
                </a>
              </div>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>

  </div>
</section>
{%- endif -%}

