{{ 'section-faq-cta-standard.css' | asset_url | stylesheet_tag }}

<style>
  /* Section Spacing / Visibility overrides */
  #shopify-section-{{ section.id }} .faq-cta-section {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .faq-cta-section {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Container Width overrides */
  #shopify-section-{{ section.id }} .container-fluid {
    max-width: 100% !important;
    padding-left: 2rem !important;
    padding-right: 2rem !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container-narrow {
    max-width: 800px !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container {
    max-width: {{ section.settings.max_width | default: 1000 }}px !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
    margin: 0 auto !important;
  }

  /* Card styling overrides */
  #shopify-section-{{ section.id }} .faq-cta-wrapper {
    {%- if section.settings.card_border_radius != blank -%}
      border-radius: {{ section.settings.card_border_radius }}px !important;
    {%- endif -%}
    {%- if section.settings.card_bg_gradient != blank -%}
      background: {{ section.settings.card_bg_gradient }} !important;
    {%- elsif section.settings.card_bg_color != blank and section.settings.card_bg_color != 'rgba(0,0,0,0)' -%}
      background: {{ section.settings.card_bg_color }} !important;
    {%- endif -%}
    display: flex;
    flex-direction: column;
    width: 100%;
    {%- if section.settings.blocks_position == 'left' -%}
      align-items: flex-start !important;
      text-align: left !important;
    {%- elsif section.settings.blocks_position == 'right' -%}
      align-items: flex-end !important;
      text-align: right !important;
    {%- else -%}
      align-items: center !important;
      text-align: center !important;
    {%- endif -%}
  }

  /* Background pattern styling */
  #shopify-section-{{ section.id }} .bg-pattern {
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(var(--color-secondary-rgb), 0.4) 0%, rgba(0,0,0,0) 70%);
    pointer-events: none;
    opacity: 0.6;
    z-index: 1;
  }
  #shopify-section-{{ section.id }} .pattern-top-left {
    top: -150px;
    left: -150px;
  }
  #shopify-section-{{ section.id }} .pattern-bottom-right {
    bottom: -150px;
    right: -150px;
  }

  /* Responsive Font Sizing scoped specifically to element types */
  #shopify-section-{{ section.id }} .faq-cta-heading.size-small { font-size: 1.5rem !important; }
  #shopify-section-{{ section.id }} .faq-cta-heading.size-medium { font-size: 1.75rem !important; }
  #shopify-section-{{ section.id }} .faq-cta-heading.size-large { font-size: 2.0rem !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .faq-cta-heading.size-small { font-size: 1.25rem !important; }
    #shopify-section-{{ section.id }} .faq-cta-heading.size-medium { font-size: 1.35rem !important; }
    #shopify-section-{{ section.id }} .faq-cta-heading.size-large { font-size: 1.5rem !important; }
  }

  #shopify-section-{{ section.id }} .faq-cta-text.size-small { font-size: 0.95rem !important; }
  #shopify-section-{{ section.id }} .faq-cta-text.size-medium { font-size: 1.05rem !important; }
  #shopify-section-{{ section.id }} .faq-cta-text.size-large { font-size: 1.2rem !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .faq-cta-text.size-small { font-size: 0.9rem !important; }
    #shopify-section-{{ section.id }} .faq-cta-text.size-medium { font-size: 1.0rem !important; }
    #shopify-section-{{ section.id }} .faq-cta-text.size-large { font-size: 1.1rem !important; }
  }

  #shopify-section-{{ section.id }} .faq-cta-btn.size-small { font-size: 0.85rem !important; padding: 10px 24px !important; }
  #shopify-section-{{ section.id }} .faq-cta-btn.size-medium { font-size: 0.95rem !important; padding: 14px 40px !important; }
  #shopify-section-{{ section.id }} .faq-cta-btn.size-large { font-size: 1.1rem !important; padding: 16px 48px !important; }

  /* Dynamic block styling generated per block instance */
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'icon' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          width: {{ block.settings.icon_size | default: 64 }}px !important;
          height: {{ block.settings.icon_size | default: 64 }}px !important;
          margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 24 }}px !important;
          display: inline-flex !important;
          align-items: center !important;
          justify-content: center !important;
          position: relative;
          z-index: 2;
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
            border-radius: 50% !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.bg_color }} !important;
            border-radius: 50% !important;
          {%- else -%}
            background: var(--color-accent-secondary-10) !important;
            border-radius: 50% !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} svg {
          width: calc({{ block.settings.icon_size | default: 64 }}px * 0.5) !important;
          height: calc({{ block.settings.icon_size | default: 64 }}px * 0.5) !important;
          {%- if block.settings.icon_color != blank and block.settings.icon_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.icon_color }} !important;
          {%- else -%}
            color: var(--color-accent-secondary) !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 16 }}px !important;
          }
        }
        {%- unless block.settings.show_on_desktop -%}
          @media screen and (min-width: 769px) {
            #shopify-section-{{ section.id }} .block-{{ block.id }} {
              display: none !important;
            }
          }
        {%- endunless -%}
        {%- unless block.settings.show_on_mobile -%}
          @media screen and (max-width: 768px) {
            #shopify-section-{{ section.id }} .block-{{ block.id }} {
              display: none !important;
            }
          }
        {%- endunless -%}
      {%- when 'header' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 16 }}px !important;
          width: 100% !important;
          max-width: {{ block.settings.max_width | default: 800 }}px !important;
          position: relative;
          z-index: 2;
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.bg_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }},
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-cta-heading {
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 16 }}px !important;
          }
        }
      {%- when 'subtitle' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 32 }}px !important;
          width: 100% !important;
          max-width: {{ block.settings.max_width | default: 500 }}px !important;
          position: relative;
          z-index: 2;
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.bg_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }},
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-cta-text {
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 20 }}px !important;
          }
        }
      {%- when 'button' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 20 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 20 }}px !important;
          width: 100% !important;
          position: relative;
          z-index: 2;
          text-align: {{ 'center' | default: 'center' }} !important;
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 16 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 16 }}px !important;
          }
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-cta-btn {
          font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %} !important;
          font-style: {{ block.settings.font_style | default: 'normal' }} !important;
          text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
          letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
          line-height: {{ block.settings.line_height | default: 115 }}% !important;
          display: inline-flex !important;
          align-items: center !important;
          justify-content: center !important;
          gap: 10px !important;
          transition: all 0.3s ease !important;
        }
        
        #shopify-section-{{ section.id }} .block-{{ block.id }} .button-preset-primary {
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
            border: none !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background: {{ block.settings.bg_color }} !important;
            {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
              border: 1px solid {{ block.settings.border_color }} !important;
            {%- else -%}
              border: 1px solid {{ block.settings.bg_color }} !important;
            {%- endif -%}
          {%- else -%}
            background: var(--color-accent-secondary) !important;
            {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
              border: 1px solid {{ block.settings.border_color }} !important;
            {%- else -%}
              border: 1px solid var(--color-accent-secondary) !important;
            {%- endif -%}
          {%- endif -%}
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- else -%}
            color: var(--bg-secondary) !important;
          {%- endif -%}
        }
        
        #shopify-section-{{ section.id }} .block-{{ block.id }} .button-preset-secondary {
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
            border: none !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background: {{ block.settings.bg_color }} !important;
            {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
              border: 1px solid {{ block.settings.border_color }} !important;
            {%- else -%}
              border: 1px solid {{ block.settings.bg_color }} !important;
            {%- endif -%}
          {%- else -%}
            background: var(--color-accent-primary, #ffffff) !important;
            {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
              border: 1px solid {{ block.settings.border_color }} !important;
            {%- else -%}
              border: 1px solid var(--color-accent-primary, #ffffff) !important;
            {%- endif -%}
          {%- endif -%}
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- else -%}
            color: var(--bg-primary, #000000) !important;
          {%- endif -%}
        }

        #shopify-section-{{ section.id }} .block-{{ block.id }} .button-preset-outline {
          background: transparent !important;
          {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
            border: 1px solid {{ block.settings.border_color }} !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            border: 1px solid {{ block.settings.bg_color }} !important;
          {%- else -%}
            border: 1px solid var(--color-accent-secondary) !important;
          {%- endif -%}
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- else -%}
            color: var(--color-accent-secondary) !important;
          {%- endif -%}
        }

        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-cta-btn:hover {
          {%- if block.settings.hover_bg_color != blank and block.settings.hover_bg_color != 'rgba(0,0,0,0)' -%}
            background: {{ block.settings.hover_bg_color }} !important;
            border: 1px solid {{ block.settings.hover_bg_color }} !important;
          {%- endif -%}
          {%- if block.settings.hover_text_color != blank and block.settings.hover_text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.hover_text_color }} !important;
          {%- endif -%}
          {%- if block.settings.hover_border_color != blank and block.settings.hover_border_color != 'rgba(0,0,0,0)' -%}
            border: 1px solid {{ block.settings.hover_border_color }} !important;
          {%- endif -%}
          {%- if block.settings.hover_shadow_color != blank and block.settings.hover_shadow_color != 'rgba(0,0,0,0)' -%}
            box-shadow: 0 8px 24px {{ block.settings.hover_shadow_color }} !important;
          {%- endif -%}
        }
    {%- endcase -%}
  {%- endfor -%}
</style>

{%- if section.settings.show_section -%}
{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}
<section 
  class="faq-cta-section color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}"
  id="shopify-section-{{ section.id }}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    
    <div class="faq-cta-wrapper">
      {%- if section.settings.show_background_pattern -%}
        <div class="bg-pattern pattern-top-left"></div>
        <div class="bg-pattern pattern-bottom-right"></div>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'icon' -%}
            {%- if block.settings.icon != blank or block.settings.custom_icon_svg != blank -%}
              <div class="faq-cta-icon block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
                {%- if block.settings.custom_icon_svg != blank -%}
                  {{ block.settings.custom_icon_svg }}
                {%- else -%}
                  {%- case block.settings.icon -%}
                    {%- when 'message-circle' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                    {%- when 'phone' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.5 19.5 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    {%- when 'mail' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    {%- when 'help-circle' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    {%- when 'life-buoy' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="4.93" y1="4.93" x2="9.17" y2="9.17"/><line x1="14.83" y1="14.83" x2="19.07" y2="19.07"/><line x1="14.83" y1="9.17" x2="19.07" y2="4.93"/><line x1="14.83" y1="9.17" x2="18.36" y2="5.64"/><line x1="4.93" y1="19.07" x2="9.17" y2="14.83"/></svg>
                    {%- when 'headphones' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
                    {%- when 'chat' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    {%- when 'support' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                  {%- endcase -%}
                {%- endif -%}
              </div>
            {%- endif -%}
            
          {%- when 'header' -%}
            {%- if block.settings.heading != blank -%}
              {%- assign heading_tag = block.settings.heading_tag | default: 'h2' -%}
              {%- assign h_color = block.settings.highlight_color -%}
              {%- assign h_gradient = block.settings.highlight_gradient -%}
              <div class="faq-cta-heading-container block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
                <{{ heading_tag }} 
                  class="faq-cta-heading size-{{ block.settings.font_size | default: 'large' }}"
                  style="
                    font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                    font-style: {{ block.settings.font_style | default: 'normal' }};
                    text-transform: {{ block.settings.text_transform | default: 'none' }};
                    letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                    line-height: {{ block.settings.line_height | default: 120 }}%;
                  "
                >
                  {%- if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' -%}
                    {%- assign highlight_span = '<span class="highlight-text" style="background: ' | append: h_gradient | append: ' !important; -webkit-background-clip: text !important; background-clip: text !important; -webkit-text-fill-color: transparent !important;color: transparent !important;">' -%}
                  {%- elsif h_color != blank and h_color != 'rgba(0,0,0,0)' -%}
                    {%- assign highlight_span = '<span class="highlight-text" style="color: ' | append: h_color | append: ' !important;">' -%}
                  {%- else -%}
                    {%- assign highlight_span = '<span class="highlight-text">' -%}
                  {%- endif -%}
                  {{ block.settings.heading | replace: '[', highlight_span | replace: ']', '</span>' }}
                </{{ heading_tag }}>
              </div>
            {%- endif -%}
            
          {%- when 'subtitle' -%}
            {%- if block.settings.description != blank -%}
              {%- assign subheading_tag = block.settings.subheading_tag | default: 'p' -%}
              <div class="faq-cta-text-container block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
                <{{ subheading_tag }} 
                  class="faq-cta-text size-{{ block.settings.font_size | default: 'medium' }}"
                  style="
                    font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                    font-style: {{ block.settings.font_style | default: 'normal' }};
                    text-transform: {{ block.settings.text_transform | default: 'none' }};
                    letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                    line-height: {{ block.settings.line_height | default: 170 }}%;
                  "
                >
                  {{ block.settings.description }}
                </{{ subheading_tag }}>
              </div>
            {%- endif -%}
            
          {%- when 'button' -%}
            {%- if block.settings.label != blank and block.settings.url != blank -%}
              {%- assign btn_target = '' -%}
              {%- if block.settings.open_in_new_tab -%}
                {%- assign btn_target = ' target="_blank" rel="noopener noreferrer"' -%}
              {%- endif -%}
              <div class="faq-cta-btn-container block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
                <a 
                  href="{{ block.settings.url }}" 
                  class="faq-cta-btn size-{{ block.settings.font_size | default: 'medium' }} button-preset-{{ block.settings.style | default: 'primary' }}"
                  {{ btn_target }}
                >
                  {{ block.settings.label }}
                  {%- if block.settings.show_icon -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="5" y1="12" x2="19" y2="12"/>
                      <polyline points="12 5 19 12 12 19"/>
                    </svg>
                  {%- endif -%}
                </a>
              </div>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>

  </div>
</section>
{%- endif -%}

