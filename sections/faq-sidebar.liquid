            font-size: {% if a_size == 'x-small' %}0.7rem{% elsif a_size == 'small' %}0.8rem{% elsif a_size == 'large' %}1.0rem{% elsif a_size == 'x-large' %}1.1rem{% elsif a_size == 'xx-large' %}1.25rem{% elsif a_size == 'xxx-large' %}1.4rem{% else %}0.9rem{% endif %} !important;
          }
        }
    {%- endcase -%}
  {%- endfor -%}
</style>

{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

{%- if section.settings.show_section -%}
<section 
  class="faq-sidebar-section color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}"
  id="shopify-section-{{ section.id }}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    
    {%- comment -%}Render structural blocks (header, subtitle, search) outside layout{%- endcomment -%}
    {%- assign has_search = false -%}
    {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subtitle'
        assign b_align_alignment = ''
      when 'results_info'
        assign b_align_alignment = 'left'
      when 'sidebar_title'
        assign b_align_alignment = 'left'
  endcase
-%}
      {%- case block.type -%}
        {%- when 'header' -%}
          {%- if block.settings.heading != blank -%}
            {%- assign heading_tag = block.settings.heading_tag | default: 'h1' -%}
            {%- assign h_color = block.settings.highlight_color -%}
            {%- assign h_gradient = block.settings.highlight_gradient -%}
            {%- assign head_text_align = b_align_alignment -%}
            {%- if head_text_align == blank -%}
              {%- if section.settings.blocks_position == 'left' -%}
                {%- assign head_text_align = 'left' -%}
              {%- elsif section.settings.blocks_position == 'right' -%}
                {%- assign head_text_align = 'right' -%}
              {%- else -%}
                {%- assign head_text_align = 'center' -%}
              {%- endif -%}
            {%- endif -%}
            <div 
              class="faq-modern-header block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
              {{ block.shopify_attributes }} 
              style="padding-bottom: 0;"
            >
              <{{ heading_tag }} 
                class="main-title size-{{ block.settings.font_size | default: 'large' }}"
                style="
                  font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                  font-style: {{ block.settings.font_style | default: 'normal' }};
                  text-transform: {{ block.settings.text_transform | default: 'none' }};
                  letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                  line-height: {{ block.settings.line_height | default: 120 }}%;
                  text-align: {{ head_text_align }};
                  width: 100% !important;
                "
              >
                {%- if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' -%}
                  {%- assign highlight_span = '<span class="highlight-text" style="background: ' | append: h_gradient | append: ' !important; -webkit-background-clip: text !important; background-clip: text !important; -webkit-text-fill-color: transparent !important;color: transparent !important;">' -%}
                {%- elsif h_color != blank and h_color != 'rgba(0,0,0,0)' -%}
                  {%- assign highlight_span = '<span class="highlight-text" style="color: ' | append: h_color | append: ' !important;">' -%}
                {%- else -%}
                  {%- assign highlight_span = '<span class="highlight-text">' -%}
                {%- endif -%}
                {{ block.settings.heading | replace: '[', highlight_span | replace: ']', '</span>' }}
              </{{ heading_tag }}>
            </div>
          {%- endif -%}
          
        {%- when 'subtitle' -%}
          {%- if block.settings.subheading != blank -%}
            {%- assign subheading_tag = block.settings.subheading_tag | default: 'p' -%}
            {%- assign sub_text_align = b_align_alignment -%}
            {%- if sub_text_align == blank -%}
              {%- if section.settings.blocks_position == 'left' -%}
                {%- assign sub_text_align = 'left' -%}
              {%- elsif section.settings.blocks_position == 'right' -%}
                {%- assign sub_text_align = 'right' -%}
              {%- else -%}
                {%- assign sub_text_align = 'center' -%}
              {%- endif -%}
            {%- endif -%}
            <div 
              class="faq-modern-header block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
              {{ block.shopify_attributes }} 
              style="padding-top: 10px; padding-bottom: 0;"
            >
              <{{ subheading_tag }} 
                class="page-intro-text size-{{ block.settings.font_size | default: 'medium' }}"
                style="
                  font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                  font-style: {{ block.settings.font_style | default: 'normal' }};
                  text-transform: {{ block.settings.text_transform | default: 'none' }};
                  letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                  line-height: {{ block.settings.line_height | default: 160 }}%;
                  text-align: {{ sub_text_align }};
                  width: 100% !important;
                "
              >
                {{ block.settings.subheading }}
              </{{ subheading_tag }}>
            </div>
          {%- endif -%}

        {%- when 'search' -%}
          {%- assign has_search = true -%}
          <div 
            class="faq-modern-search block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
            {{ block.shopify_attributes }}
          >
            <div class="search-input-wrapper">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/>
                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
              </svg>
              <input 
                type="text" 
                class="faq-search-input" 
                id="faq-search-{{ section.id }}"
                placeholder="{{ block.settings.search_placeholder | default: 'Search for a question...' }}"
              />
            </div>
          </div>
      {%- endcase -%}
    {%- endfor -%}

    {%- comment -%}Two-Column Layout{%- endcomment -%}
    <div class="faq-modern-layout">
      
      {%- comment -%}Sidebar{%- endcomment -%}
      <aside class="faq-sidebar">
        {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subtitle'
        assign b_align_alignment = ''
      when 'results_info'
        assign b_align_alignment = 'left'
      when 'sidebar_title'
        assign b_align_alignment = 'left'
  endcase
-%}
          {%- if block.type == 'sidebar_title' -%}
            <h2 
              class="sidebar-title block-{{ block.id }} size-{{ block.settings.font_size | default: 'medium' }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
              {{ block.shopify_attributes }}
            >
              {{ block.settings.sidebar_title }}
            </h2>
          {%- endif -%}
        {%- endfor -%}
        <ul class="category-list">
          {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subtitle'
        assign b_align_alignment = ''
      when 'results_info'
        assign b_align_alignment = 'left'
      when 'sidebar_title'
        assign b_align_alignment = 'left'
  endcase
-%}
            {%- if block.type == 'category' -%}
              <li class="category-item block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
                <a href="#" class="category-link{% if forloop.first %} active{% endif %}" data-category="{{ block.settings.category_value }}">
                  {%- if block.settings.show_icon -%}
                    {%- if block.settings.custom_icon_svg != blank -%}
                      {{ block.settings.custom_icon_svg }}
                    {%- else -%}
                      {%- case block.settings.icon -%}
                        {%- when 'laptop' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                        {%- when 'shipping' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                        {%- when 'support' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                        {%- when 'tools' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                        {%- when 'pricing' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                        {%- when 'message' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        {%- when 'check' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        {%- when 'heart' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        {%- when 'star' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        {%- when 'shield' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        {%- when 'users' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        {%- when 'file' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                        {%- when 'search' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        {%- else -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                      {%- endcase -%}
                    {%- endif -%}
                  {%- endif -%}
                  {{ block.settings.category_label }}
                </a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </aside>

      {%- comment -%}Main FAQ Accordion{%- endcomment -%}
      <section class="faq-content-area">
        {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subtitle'
        assign b_align_alignment = ''
      when 'results_info'
        assign b_align_alignment = 'left'
      when 'sidebar_title'
        assign b_align_alignment = 'left'
  endcase
-%}
          {%- if block.type == 'results_info' -%}
            {%- assign q_size = section.blocks | where: 'type', 'question' | size -%}
            {%- capture count_html -%}<strong>{{ q_size }}</strong>{%- endcapture -%}
            <p 
              class="results-info block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text | default: 'Showing [count] questions' | replace: '[count]', count_html }}
            </p>
          {%- endif -%}
        {%- endfor -%}

        <div class="modern-accordion" id="faq-accordion-{{ section.id }}">
          {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subtitle'
        assign b_align_alignment = ''
      when 'results_info'
        assign b_align_alignment = 'left'
      when 'sidebar_title'
        assign b_align_alignment = 'left'
  endcase
-%}
            {%- if block.type == 'question' -%}
              <div 
                class="modern-accordion-item block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                data-category="{{ block.settings.category }}" 
                {{ block.shopify_attributes }}
              >
                <button class="modern-accordion-header" type="button" aria-expanded="false">
                  {{ block.settings.question }}
                  {%- if block.settings.show_icon -%}
                    <span class="modern-accordion-indicator" style="display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; width: 16px; height: 16px;">
                      {%- if block.settings.icon != blank -%}
                        {%- case block.settings.icon -%}
                          {%- when 'chevron' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 100%; height: 100%;"><polyline points="6 9 12 15 18 9"/></svg>
                          {%- when 'plus' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 100%; height: 100%;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                          {%- when 'arrow' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 100%; height: 100%;"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
                          {%- when 'caret' -%}<svg viewBox="0 0 24 24" fill="currentColor" style="width: 100%; height: 100%;"><path d="M7 10l5 5 5-5H7z"/></svg>
                        {%- endcase -%}
                      {%- else -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 100%; height: 100%;">
                          <polyline points="6 9 12 15 18 9"/>
                        </svg>
                      {%- endif -%}
                    </span>
                  {%- endif -%}
                </button>
                <div class="modern-accordion-content">
                  <div class="modern-accordion-inner rte">
                    {{ block.settings.answer }}
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </section>
    </div>

  </div>
</section>

{%- if has_search -%}
<script>
(function() {
  var sectionId = '{{ section.id }}';
  var searchInput = document.getElementById('faq-search-' + sectionId);
  var accordionItems = document.querySelectorAll('#shopify-section-' + sectionId + ' .modern-accordion-item');
  
  if (searchInput) {
    searchInput.addEventListener('input', function() {
      var query = this.value.toLowerCase();
      accordionItems.forEach(function(item) {
        var question = item.querySelector('.modern-accordion-header').textContent.toLowerCase();
        var answer = item.querySelector('.modern-accordion-inner').textContent.toLowerCase();
        if (question.indexOf(query) > -1 || answer.indexOf(query) > -1) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  }
})();
</script>
{%- endif -%}

<script>
(function() {
  var sectionId = '{{ section.id }}';
  var section = document.getElementById('shopify-section-' + sectionId);
  if (!section) return;
  var categoryLinks = section.querySelectorAll('.category-link');
  var accordionItems = section.querySelectorAll('.modern-accordion-item');
  var headers = section.querySelectorAll('.modern-accordion-header');
  
  // Category filter
  categoryLinks.forEach(function(link) {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      var category = this.getAttribute('data-category');
      
      categoryLinks.forEach(function(l) { l.classList.remove('active'); });
      this.classList.add('active');
      
      accordionItems.forEach(function(item) {
        if (category === 'all' || item.getAttribute('data-category') === category) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });
  
  // Accordion toggle
  headers.forEach(function(header) {
    header.addEventListener('click', function() {
      var item = this.parentElement;
      var content = this.nextElementSibling;
      var isActive = item.classList.contains('active');
      
      // Close all
      section.querySelectorAll('.modern-accordion-item').forEach(function(i) {
        i.classList.remove('active');
        i.querySelector('.modern-accordion-content').style.maxHeight = null;
      });
      
      // Open clicked if wasn't active
      if (!isActive) {
        item.classList.add('active');
        content.style.maxHeight = content.scrollHeight + 'px';
      }
    });
  });
})();
</script>
{%- endif -%}

