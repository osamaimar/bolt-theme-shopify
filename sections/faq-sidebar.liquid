          #shopify-section-{{ section.id }} .block-{{ block.id }} .modern-accordion-inner a,
          #shopify-section-{{ section.id }} .block-{{ block.id }} .modern-accordion-inner span,
          #shopify-section-{{ section.id }} .block-{{ block.id }} .modern-accordion-inner div {
