        }
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .modern-accordion-header {
          {%- if block.settings.hover_question_text_color != blank and block.settings.hover_question_text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.hover_question_text_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .modern-accordion-indicator {
          {%- if block.settings.hover_icon_bg_color != blank and block.settings.hover_icon_bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.hover_icon_bg_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .modern-accordion-indicator svg {
          {%- if block.settings.hover_icon_color != blank and block.settings.hover_icon_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.hover_icon_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .modern-accordion-inner,
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .modern-accordion-inner p,
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .modern-accordion-inner li,
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .modern-accordion-inner a,
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .modern-accordion-inner span,
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .modern-accordion-inner div {
          {%- if block.settings.hover_answer_text_color != blank and block.settings.hover_answer_text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.hover_answer_text_color }} !important;
          {%- endif -%}
        }
        {%- if block.settings.hover_answer_link_color != blank and block.settings.hover_answer_link_color != 'rgba(0,0,0,0)' -%}
          #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .modern-accordion-inner a {
            color: {{ block.settings.hover_answer_link_color }} !important;
          }
        {%- endif -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .modern-accordion-indicator svg {
          {%- if block.settings.hover_indicator_color != blank and block.settings.hover_indicator_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.hover_indicator_color }} !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} .modern-accordion-header {
            {%- assign q_size = block.settings.font_size | default: 'medium' -%}
            font-size: {% if q_size == 'x-small' %}0.75rem{% elsif q_size == 'small' %}0.85rem{% elsif q_size == 'large' %}1.05rem{% elsif q_size == 'x-large' %}1.2rem{% elsif q_size == 'xx-large' %}1.35rem{% elsif q_size == 'xxx-large' %}1.6rem{% else %}0.95rem{% endif %} !important;
          }
          #shopify-section-{{ section.id }} .block-{{ block.id }} .modern-accordion-inner,
          #shopify-section-{{ section.id }} .block-{{ block.id }} .modern-accordion-inner p,
