{{ 'section-faq-standard.css' | asset_url | stylesheet_tag }}

<style>
  /* Section Spacing / Visibility overrides */
  #shopify-section-{{ section.id }} .faq-standard-section {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .faq-standard-section {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Container Width overrides */
  #shopify-section-{{ section.id }} .container-fluid {
    max-width: 100% !important;
    padding-left: 2rem !important;
    padding-right: 2rem !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container-narrow {
    max-width: 800px !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container {
    max-width: {{ section.settings.max_width | default: 1340 }}px !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
    margin: 0 auto !important;
  }

  /* Accordion arrow transition indicators */
  #shopify-section-{{ section.id }} .faq-accordion-arrow {
    transition: transform 0.3s ease !important;
  }
  #shopify-section-{{ section.id }} .faq-accordion-item.open .faq-accordion-arrow {
    transform: rotate(180deg) !important;
  }

  /* Responsive Font Sizing scoped specifically to element types */
  #shopify-section-{{ section.id }} .main-title.size-small { font-size: 2.5rem !important; }
  #shopify-section-{{ section.id }} .main-title.size-medium { font-size: 3.0rem !important; }
  #shopify-section-{{ section.id }} .main-title.size-large { font-size: 3.5rem !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .main-title.size-small { font-size: 2.0rem !important; }
    #shopify-section-{{ section.id }} .main-title.size-medium { font-size: 2.25rem !important; }
    #shopify-section-{{ section.id }} .main-title.size-large { font-size: 2.5rem !important; }
  }

  #shopify-section-{{ section.id }} .page-intro-text.size-small { font-size: 1.0rem !important; }
  #shopify-section-{{ section.id }} .page-intro-text.size-medium { font-size: 1.25rem !important; }
  #shopify-section-{{ section.id }} .page-intro-text.size-large { font-size: 1.5rem !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .page-intro-text.size-small { font-size: 0.95rem !important; }
    #shopify-section-{{ section.id }} .page-intro-text.size-medium { font-size: 1.125rem !important; }
    #shopify-section-{{ section.id }} .page-intro-text.size-large { font-size: 1.35rem !important; }
  }

  /* Dynamic block styling generated per block instance */
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'header' -%}
        {%- assign head_align = section.settings.blocks_position | default: 'center' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 20 }}px !important;
          max-width: {{ block.settings.max_width | default: 800 }}px !important;
          width: 100% !important;
          {%- if head_align == 'left' -%}
            margin-left: 0 !important;
            margin-right: auto !important;
          {%- elsif head_align == 'right' -%}
            margin-left: auto !important;
            margin-right: 0 !important;
          {%- else -%}
            margin-left: auto !important;
            margin-right: auto !important;
          {%- endif -%}
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.bg_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }},
        #shopify-section-{{ section.id }} .block-{{ block.id }} .main-title {
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 16 }}px !important;
          }
        }
      {%- when 'subtitle' -%}
        {%- assign sub_align = section.settings.blocks_position | default: 'center' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 28 }}px !important;
          max-width: {{ block.settings.max_width | default: 800 }}px !important;
          width: 100% !important;
          {%- if sub_align == 'left' -%}
            margin-left: 0 !important;
            margin-right: auto !important;
          {%- elsif sub_align == 'right' -%}
            margin-left: auto !important;
            margin-right: 0 !important;
          {%- else -%}
            margin-left: auto !important;
            margin-right: auto !important;
          {%- endif -%}
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.bg_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }},
        #shopify-section-{{ section.id }} .block-{{ block.id }} .page-intro-text {
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 20 }}px !important;
          }
        }
      {%- when 'search' -%}
        {%- assign search_align = section.settings.blocks_position | default: 'center' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 28 }}px !important;
          max-width: {{ block.settings.max_width | default: 500 }}px !important;
          width: 100% !important;
          {%- if search_align == 'left' -%}
            margin-left: 0 !important;
            margin-right: auto !important;
          {%- elsif search_align == 'right' -%}
            margin-left: auto !important;
            margin-right: 0 !important;
          {%- else -%}
            margin-left: auto !important;
            margin-right: auto !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 20 }}px !important;
          }
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-search-input {
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.bg_color }} !important;
          {%- endif -%}
          {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
            border-color: {{ block.settings.border_color }} !important;
          {%- endif -%}
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- endif -%}
          {%- if block.settings.show_icon == false -%}
            padding-left: 20px !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-search-input::placeholder {
          {%- if block.settings.placeholder_color != blank and block.settings.placeholder_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.placeholder_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-search-icon,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-search-icon svg {
          {%- if block.settings.icon_color != blank and block.settings.icon_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.icon_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-search-icon svg {
          width: 100% !important;
          height: 100% !important;
          display: block !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-search-input:focus {
          {%- if block.settings.hover_border_color != blank and block.settings.hover_border_color != 'rgba(0,0,0,0)' -%}
            border-color: {{ block.settings.hover_border_color }} !important;
          {%- endif -%}
          {%- if block.settings.hover_bg_color != blank and block.settings.hover_bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.hover_bg_color }} !important;
          {%- endif -%}
          {%- if block.settings.hover_shadow_color != blank and block.settings.hover_shadow_color != 'rgba(0,0,0,0)' -%}
            box-shadow: 0 0 10px {{ block.settings.hover_shadow_color }} !important;
          {%- endif -%}
        }

      {%- when 'category' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 0 }}px !important;
          font-size: {% if block.settings.font_size == 'small' %}0.85rem{% elsif block.settings.font_size == 'large' %}1.05rem{% else %}0.95rem{% endif %} !important;
          font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %} !important;
          font-style: {{ block.settings.font_style | default: 'normal' }} !important;
          text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
          letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
          line-height: {{ block.settings.line_height | default: 120 }}% !important;
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.text_color }} !important;
          {%- endif -%}
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
            border-color: transparent !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background: {{ block.settings.bg_color }} !important;
            border-color: {{ block.settings.bg_color }} !important;
          {%- endif -%}
          {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
            border-color: {{ block.settings.border_color }} !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 0 }}px !important;
          }
        }
        #shopify-section-{{ section.id }} .faq-category-btn.block-{{ block.id }}.active {
          {%- if block.settings.active_text_color != blank and block.settings.active_text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.active_text_color }} !important;
          {%- endif -%}
          {%- if block.settings.active_bg_gradient != blank -%}
            background: {{ block.settings.active_bg_gradient }} !important;
            border-color: transparent !important;
          {%- elsif block.settings.active_bg_color != blank and block.settings.active_bg_color != 'rgba(0,0,0,0)' -%}
            background: {{ block.settings.active_bg_color }} !important;
            border-color: {{ block.settings.active_bg_color }} !important;
          {%- endif -%}
          {%- if block.settings.active_border_color != blank and block.settings.active_border_color != 'rgba(0,0,0,0)' -%}
            border-color: {{ block.settings.active_border_color }} !important;
          {%- endif -%}
        }
      {%- when 'question' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom | default: 12 }}px !important;
          {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
            border-color: {{ block.settings.border_color }} !important;
          {%- endif -%}
          {%- if block.settings.bg_gradient != blank -%}
            background: {{ block.settings.bg_gradient }} !important;
          {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
            background: {{ block.settings.bg_color }} !important;
          {%- endif -%}
          transition: all 0.3s ease !important;
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} {
            margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
            margin-bottom: {{ block.settings.margin_bottom_mobile | default: 12 }}px !important;
          }
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-accordion-question,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-question-text {
          {%- assign q_size = block.settings.font_size | default: 'medium' -%}
          font-size: {% if q_size == 'x-small' %}0.8rem{% elsif q_size == 'small' %}0.9rem{% elsif q_size == 'large' %}1.15rem{% elsif q_size == 'x-large' %}1.3rem{% elsif q_size == 'xx-large' %}1.5rem{% elsif q_size == 'xxx-large' %}1.8rem{% else %}1.0rem{% endif %} !important;
          {%- assign q_weight = block.settings.font_weight | default: 'bold' -%}
          font-weight: {% if q_weight == 'normal' %}400{% elsif q_weight == 'bold' %}700{% else %}{{ q_weight }}{% endif %} !important;
          font-style: {{ block.settings.font_style | default: 'normal' }} !important;
          text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
          letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
          line-height: {{ block.settings.line_height | default: 120 }}% !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-question-text {
          {%- if block.settings.question_text_color != blank and block.settings.question_text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.question_text_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }}.open .faq-question-text {
          {%- if block.settings.active_question_text_color != blank and block.settings.active_question_text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.active_question_text_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-question-icon {
          {%- if block.settings.icon_bg_color != blank and block.settings.icon_bg_color != 'rgba(0,0,0,0)' -%}
            background: {{ block.settings.icon_bg_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-question-icon svg {
          {%- if block.settings.icon_color != blank and block.settings.icon_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.icon_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }}.open .faq-question-icon {
          {%- if block.settings.active_icon_bg_color != blank and block.settings.active_icon_bg_color != 'rgba(0,0,0,0)' -%}
            background: {{ block.settings.active_icon_bg_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }}.open .faq-question-icon svg {
          {%- if block.settings.active_icon_color != blank and block.settings.active_icon_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.active_icon_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-accordion-arrow {
          {%- if block.settings.indicator_color != blank and block.settings.indicator_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.indicator_color }} !important;
          {%- elsif block.settings.icon_color != blank and block.settings.icon_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.icon_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }}.open .faq-accordion-arrow {
          {%- if block.settings.active_indicator_color != blank and block.settings.active_indicator_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.active_indicator_color }} !important;
          {%- elsif block.settings.active_icon_color != blank and block.settings.active_icon_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.active_icon_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-accordion-answer-inner,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-accordion-answer-inner p,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-accordion-answer-inner li,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-accordion-answer-inner a,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-accordion-answer-inner span,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-accordion-answer-inner div {
          {%- assign a_size = block.settings.answer_font_size | default: 'medium' -%}
          font-size: {% if a_size == 'x-small' %}0.75rem{% elsif a_size == 'small' %}0.85rem{% elsif a_size == 'large' %}1.05rem{% elsif a_size == 'x-large' %}1.2rem{% elsif a_size == 'xx-large' %}1.4rem{% elsif a_size == 'xxx-large' %}1.6rem{% else %}0.95rem{% endif %} !important;
          {%- assign a_weight = block.settings.answer_font_weight | default: 'normal' -%}
          font-weight: {% if a_weight == 'normal' %}400{% elsif a_weight == 'bold' %}700{% else %}{{ a_weight }}{% endif %} !important;
          font-style: {{ block.settings.answer_font_style | default: 'normal' }} !important;
          text-transform: {{ block.settings.answer_text_transform | default: 'none' }} !important;
          letter-spacing: {{ block.settings.answer_letter_spacing | default: 0 }}px !important;
          line-height: {{ block.settings.answer_line_height | default: 160 }}% !important;
          {%- if block.settings.answer_text_color != blank and block.settings.answer_text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.answer_text_color }} !important;
          {%- endif -%}
        }
        {%- if block.settings.answer_bg_color != blank and block.settings.answer_bg_color != 'rgba(0,0,0,0)' -%}
          #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-accordion-answer {
            background-color: {{ block.settings.answer_bg_color }} !important;
          }
        {%- endif -%}
        {%- if block.settings.answer_link_color != blank and block.settings.answer_link_color != 'rgba(0,0,0,0)' -%}
          #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-accordion-answer-inner a {
            color: {{ block.settings.answer_link_color }} !important;
          }
        {%- endif -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}.open {
          {%- if block.settings.active_bg_color != blank and block.settings.active_bg_color != 'rgba(0,0,0,0)' -%}
            background: {{ block.settings.active_bg_color }} !important;
          {%- endif -%}
          {%- if block.settings.active_border_color != blank and block.settings.active_border_color != 'rgba(0,0,0,0)' -%}
            border-color: {{ block.settings.active_border_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }}.open .faq-accordion-answer-inner,
        #shopify-section-{{ section.id }} .block-{{ block.id }}.open .faq-accordion-answer-inner p,
        #shopify-section-{{ section.id }} .block-{{ block.id }}.open .faq-accordion-answer-inner li,
        #shopify-section-{{ section.id }} .block-{{ block.id }}.open .faq-accordion-answer-inner a,
        #shopify-section-{{ section.id }} .block-{{ block.id }}.open .faq-accordion-answer-inner span,
        #shopify-section-{{ section.id }} .block-{{ block.id }}.open .faq-accordion-answer-inner div {
          {%- if block.settings.active_answer_text_color != blank and block.settings.active_answer_text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.active_answer_text_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }}.open .faq-accordion-answer {
          {%- if block.settings.active_answer_bg_color != blank and block.settings.active_answer_bg_color != 'rgba(0,0,0,0)' -%}
            background-color: {{ block.settings.active_answer_bg_color }} !important;
          {%- endif -%}
        }
        {%- if block.settings.active_answer_link_color != blank and block.settings.active_answer_link_color != 'rgba(0,0,0,0)' -%}
          #shopify-section-{{ section.id }} .block-{{ block.id }}.open .faq-accordion-answer-inner a {
            color: {{ block.settings.active_answer_link_color }} !important;
          }
        {%- endif -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover {
          {%- if block.settings.hover_bg_color != blank and block.settings.hover_bg_color != 'rgba(0,0,0,0)' -%}
            background: {{ block.settings.hover_bg_color }} !important;
          {%- endif -%}
          {%- if block.settings.hover_border_color != blank and block.settings.hover_border_color != 'rgba(0,0,0,0)' -%}
            border-color: {{ block.settings.hover_border_color }} !important;
          {%- endif -%}
          {%- if block.settings.hover_shadow_color != blank and block.settings.hover_shadow_color != 'rgba(0,0,0,0)' -%}
            box-shadow: 0 4px 20px {{ block.settings.hover_shadow_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .faq-question-text {
          {%- if block.settings.hover_question_text_color != blank and block.settings.hover_question_text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.hover_question_text_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .faq-question-icon {
          {%- if block.settings.hover_icon_bg_color != blank and block.settings.hover_icon_bg_color != 'rgba(0,0,0,0)' -%}
            background: {{ block.settings.hover_icon_bg_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .faq-question-icon svg {
          {%- if block.settings.hover_icon_color != blank and block.settings.hover_icon_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.hover_icon_color }} !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .faq-accordion-answer-inner,
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .faq-accordion-answer-inner p,
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .faq-accordion-answer-inner li,
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .faq-accordion-answer-inner a,
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .faq-accordion-answer-inner span,
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .faq-accordion-answer-inner div {
          {%- if block.settings.hover_answer_text_color != blank and block.settings.hover_answer_text_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.hover_answer_text_color }} !important;
          {%- endif -%}
        }
        {%- if block.settings.hover_answer_link_color != blank and block.settings.hover_answer_link_color != 'rgba(0,0,0,0)' -%}
          #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .faq-accordion-answer-inner a {
            color: {{ block.settings.hover_answer_link_color }} !important;
          }
        {%- endif -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover .faq-accordion-arrow {
          {%- if block.settings.hover_indicator_color != blank and block.settings.hover_indicator_color != 'rgba(0,0,0,0)' -%}
            color: {{ block.settings.hover_indicator_color }} !important;
          {%- endif -%}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-accordion-question,
          #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-question-text {
            {%- assign q_size = block.settings.font_size | default: 'medium' -%}
            font-size: {% if q_size == 'x-small' %}0.75rem{% elsif q_size == 'small' %}0.85rem{% elsif q_size == 'large' %}1.05rem{% elsif q_size == 'x-large' %}1.2rem{% elsif q_size == 'xx-large' %}1.35rem{% elsif q_size == 'xxx-large' %}1.6rem{% else %}0.95rem{% endif %} !important;
          }
          #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-accordion-answer-inner,
          #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-accordion-answer-inner p,
          #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-accordion-answer-inner li,
          #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-accordion-answer-inner a,
          #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-accordion-answer-inner span,
          #shopify-section-{{ section.id }} .block-{{ block.id }} .faq-accordion-answer-inner div {
            {%- assign a_size = block.settings.answer_font_size | default: 'medium' -%}
            font-size: {% if a_size == 'x-small' %}0.7rem{% elsif a_size == 'small' %}0.8rem{% elsif a_size == 'large' %}1.0rem{% elsif a_size == 'x-large' %}1.1rem{% elsif a_size == 'xx-large' %}1.25rem{% elsif a_size == 'xxx-large' %}1.4rem{% else %}0.9rem{% endif %} !important;
          }
        }
    {%- endcase -%}
  {%- endfor -%}
</style>

{%- if section.settings.show_section -%}
{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}
<section 
  class="faq-standard-section color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}"
  id="shopify-section-{{ section.id }}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    
    {%- assign has_search = false -%}
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'header' -%}
          {%- if block.settings.heading != blank -%}
            {%- assign heading_tag = block.settings.heading_tag | default: 'h1' -%}
            {%- assign h_color = block.settings.highlight_color -%}
            {%- assign h_gradient = block.settings.highlight_gradient -%}
            {%- assign head_text_align = '' -%}
            {%- if head_text_align == blank -%}
              {%- if section.settings.blocks_position == 'left' -%}
                {%- assign head_text_align = 'left' -%}
              {%- elsif section.settings.blocks_position == 'right' -%}
                {%- assign head_text_align = 'right' -%}
              {%- else -%}
                {%- assign head_text_align = 'center' -%}
              {%- endif -%}
            {%- endif -%}
            <div 
              class="faq-page-header block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
              {{ block.shopify_attributes }} 
              style="padding-bottom: 0;"
            >
              <{{ heading_tag }} 
                class="main-title size-{{ block.settings.font_size | default: 'large' }}"
                style="
                  font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                  font-style: {{ block.settings.font_style | default: 'normal' }};
                  text-transform: {{ block.settings.text_transform | default: 'none' }};
                  letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                  line-height: {{ block.settings.line_height | default: 120 }}%;
                  text-align: {{ head_text_align }};
                  width: 100% !important;
                "
              >
                {%- if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' -%}
                  {%- assign highlight_span = '<span class="highlight-text" style="background: ' | append: h_gradient | append: ' !important; -webkit-background-clip: text !important; background-clip: text !important; -webkit-text-fill-color: transparent !important;color: transparent !important;">' -%}
                {%- elsif h_color != blank and h_color != 'rgba(0,0,0,0)' -%}
                  {%- assign highlight_span = '<span class="highlight-text" style="color: ' | append: h_color | append: ' !important;">' -%}
                {%- else -%}
                  {%- assign highlight_span = '<span class="highlight-text">' -%}
                {%- endif -%}
                {{ block.settings.heading | replace: '[', highlight_span | replace: ']', '</span>' }}
              </{{ heading_tag }}>
            </div>
          {%- endif -%}
          
        {%- when 'subtitle' -%}
          {%- if block.settings.subheading != blank -%}
            {%- assign subheading_tag = block.settings.subheading_tag | default: 'p' -%}
            {%- assign sub_text_align = '' -%}
            {%- if sub_text_align == blank -%}
              {%- if section.settings.blocks_position == 'left' -%}
                {%- assign sub_text_align = 'left' -%}
              {%- elsif section.settings.blocks_position == 'right' -%}
                {%- assign sub_text_align = 'right' -%}
              {%- else -%}
                {%- assign sub_text_align = 'center' -%}
              {%- endif -%}
            {%- endif -%}
            <div 
              class="faq-page-header block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
              {{ block.shopify_attributes }} 
              style="padding-top: 10px; padding-bottom: 0;"
            >
              <{{ subheading_tag }} 
                class="page-intro-text size-{{ block.settings.font_size | default: 'medium' }}"
                style="
                  font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                  font-style: {{ block.settings.font_style | default: 'normal' }};
                  text-transform: {{ block.settings.text_transform | default: 'none' }};
                  letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                  line-height: {{ block.settings.line_height | default: 160 }}%;
                  text-align: {{ sub_text_align }};
                  width: 100% !important;
                "
              >
                {{ block.settings.subheading }}
              </{{ subheading_tag }}>
            </div>
          {%- endif -%}

        {%- when 'search' -%}
          {%- assign has_search = true -%}
          <div 
            class="faq-search-wrapper-container block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}"
            {{ block.shopify_attributes }}
          >
            <div class="faq-search-wrapper">
              {%- if block.settings.show_icon != false -%}
                {%- case block.settings.icon -%}
                  {%- when 'search-2' -%}
                    <svg class="faq-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
                  {%- when 'support' -%}
                    <svg class="faq-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  {%- when 'info' -%}
                    <svg class="faq-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                  {%- when 'message' -%}
                    <svg class="faq-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                  {%- when 'help' -%}
                    <svg class="faq-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                  {%- else -%}
                    <svg class="faq-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                {%- endcase -%}
              {%- endif -%}
              <input 
                type="text" 
                class="faq-search-input" 
                id="faq-search-{{ section.id }}"
                placeholder="{{ block.settings.search_placeholder | default: 'Search for a question...' }}"
              />
            </div>
          </div>
      {%- endcase -%}
    {%- endfor -%}

    {%- comment -%}Category Tabs{%- endcomment -%}
    {%- if section.settings.show_categories -%}
      <div class="faq-categories" id="faq-categories-{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'category' -%}
            <button 
              class="faq-category-btn block-{{ block.id }} {% if forloop.first %} active{% endif %} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
              data-category="{{ block.settings.category_value }}"
              {{ block.shopify_attributes }}
              style="
                font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                font-style: {{ block.settings.font_style | default: 'normal' }};
                text-transform: {{ block.settings.text_transform | default: 'none' }};
                letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                line-height: {{ block.settings.line_height | default: 120 }}%;
              "
            >
              {{ block.settings.category_label }}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%}Accordion List{%- endcomment -%}
    <div class="faq-accordion-list" id="faq-accordion-list-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'question' -%}
          <div 
            class="faq-accordion-item block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
            data-category="{{ block.settings.category }}" 
            {{ block.shopify_attributes }}
          >
            <button class="faq-accordion-question" type="button" aria-expanded="false">
              <span class="faq-question-content">
                {%- assign show_block_icon = false -%}
                {%- if block.settings.show_icon != false -%}
                  {%- if block.settings.icon != blank or block.settings.custom_icon_svg != blank -%}
                    {%- assign show_block_icon = true -%}
                  {%- endif -%}
                {%- endif -%}
                {%- if show_block_icon -%}
                  <span class="faq-question-icon">
                    {%- if block.settings.custom_icon_svg != blank -%}
                      {{ block.settings.custom_icon_svg }}
                    {%- else -%}
                      {%- case block.settings.icon -%}
                        {%- when 'laptop' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                        {%- when 'shipping' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                        {%- when 'support' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                        {%- when 'tools' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                        {%- when 'pricing' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                        {%- when 'message' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        {%- when 'check' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        {%- when 'info' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                      {%- endcase -%}
                    {%- endif -%}
                  </span>
                {%- endif -%}
                <span class="faq-question-text">{{ block.settings.question }}</span>
              </span>
              {%- if block.settings.show_indicator_icon -%}
                <span class="faq-accordion-arrow-wrapper" style="display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; width: 20px; height: 20px;">
                  {%- case block.settings.indicator_icon -%}
                    {%- when 'chevron' -%}
                      <svg class="faq-accordion-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 100%; height: 100%;"><polyline points="6 9 12 15 18 9"/></svg>
                    {%- when 'plus' -%}
                      <svg class="faq-accordion-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 100%; height: 100%;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    {%- when 'arrow' -%}
                      <svg class="faq-accordion-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 100%; height: 100%;"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
                    {%- when 'caret' -%}
                      <svg class="faq-accordion-arrow" viewBox="0 0 24 24" fill="currentColor" style="width: 100%; height: 100%;"><path d="M7 10l5 5 5-5H7z"/></svg>
                    {%- else -%}
                      <svg class="faq-accordion-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 100%; height: 100%;"><polyline points="6 9 12 15 18 9"/></svg>
                  {%- endcase -%}
                </span>
              {%- endif -%}
            </button>
            <div class="faq-accordion-answer">
              <div class="faq-accordion-answer-inner rte">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%}No Results{%- endcomment -%}
    <div class="faq-no-results" id="faq-no-results-{{ section.id }}">
      <p>{{ 'general.faq.no_results_html' | t }}</p>
    </div>

  </div>
</section>

<script>
(function() {
  var sectionId = '{{ section.id }}';
  var section = document.getElementById('shopify-section-' + sectionId);
  if (!section) return;
  var categoryBtns = section.querySelectorAll('.faq-category-btn');
  var accordionItems = section.querySelectorAll('.faq-accordion-item');
  var headers = section.querySelectorAll('.faq-accordion-question');
  var searchInput = document.getElementById('faq-search-' + sectionId);
  var noResults = document.getElementById('faq-no-results-' + sectionId);
  
  {%- if section.settings.show_categories -%}
  // Category filter
  categoryBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var category = this.getAttribute('data-category');
      
      categoryBtns.forEach(function(b) { b.classList.remove('active'); });
      this.classList.add('active');
      
      var visibleCount = 0;
      accordionItems.forEach(function(item) {
        if (category === 'all' || item.getAttribute('data-category') === category) {
          item.style.display = '';
          visibleCount++;
        } else {
          item.style.display = 'none';
        }
      });
      
      if (noResults) {
        noResults.classList.toggle('visible', visibleCount === 0);
      }
    });
  });
  {%- endif -%}
  
  {%- if has_search -%}
  // Search functionality
  if (searchInput) {
    searchInput.addEventListener('input', function() {
      var query = this.value.toLowerCase().trim();
      var visibleCount = 0;
      
      accordionItems.forEach(function(item) {
        var question = item.querySelector('.faq-question-text').textContent.toLowerCase();
        var answer = item.querySelector('.faq-accordion-answer-inner').textContent.toLowerCase();
        
        if (!query || question.indexOf(query) > -1 || answer.indexOf(query) > -1) {
          item.style.display = '';
          visibleCount++;
        } else {
          item.style.display = 'none';
        }
      });
      
      if (noResults) {
        noResults.classList.toggle('visible', visibleCount === 0 && query.length > 0);
      }
      
      // Reset category buttons when searching
      if (query && categoryBtns.length) {
        categoryBtns.forEach(function(b) { b.classList.remove('active'); });
      }
    });
  }
  {%- endif -%}
  
  // Accordion toggle
  headers.forEach(function(header) {
    header.addEventListener('click', function() {
      var item = this.parentElement;
      var content = this.nextElementSibling;
      var isOpen = item.classList.contains('open');
      
      // Close all
      section.querySelectorAll('.faq-accordion-item').forEach(function(i) {
        i.classList.remove('open');
        i.querySelector('.faq-accordion-question').setAttribute('aria-expanded', 'false');
        i.querySelector('.faq-accordion-answer').style.maxHeight = null;
      });
      
      // Open clicked if wasn't open
      if (!isOpen) {
        item.classList.add('open');
        this.setAttribute('aria-expanded', 'true');
        content.style.maxHeight = content.scrollHeight + 'px';
      }
    });
  });
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "FAQ Standard",
  "tag": "section",
  "class": "section-faq-standard",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Filter"
    },
    {
      "type": "checkbox",
      "id": "show_categories",
      "label": "Show category filters",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "blocks_position",
      "label": "Blocks Position",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "standard",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "standard", "label": "Standard" },
        { "value": "narrow", "label": "Narrow" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Maximum width",
      "default": 1340
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
