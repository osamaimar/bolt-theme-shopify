{{ 'section-featured-collections.css' | asset_url | stylesheet_tag }}

{%- if section.settings.show_section -%}
{% render 'section-padding',
  section_id: section.id,
  padding_left: section.settings.padding_left,
  padding_right: section.settings.padding_right,
  padding_left_mobile: section.settings.padding_left_mobile,
  padding_right_mobile: section.settings.padding_right_mobile
%}
<style>
  #shopify-section-{{ section.id }} { padding: 0 !important; }
  #shopify-section-{{ section.id }} .hec-collections {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .hec-collections {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
</style>

<section class="hec-collections color-{{ section.settings.color_scheme }}" id="shopify-section-{{ section.id }}">
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    <div class="hec-section-header">
      <div class="hec-section-header-text">
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading | replace: '[', '<span>' | replace: ']', '</span>' }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p>{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
      
      {%- if section.settings.show_view_all and section.settings.view_all_label != blank -%}
        <a href="{{ routes.collections_url }}" class="hec-section-link{% unless section.settings.show_link_mobile %} hidden-mobile{% endunless %}" id="view-all-collections-{{ section.id }}">
          {{ section.settings.view_all_label }}
          {% render 'icon-arrow' %}
        </a>
      {%- endif -%}
    </div>

    <div class="hec-collections-grid" style="--columns-desktop: {{ section.settings.columns }};">
      {%- for block in section.blocks -%}
        {%- if block.type == 'collection' -%}
          {%- if block.settings.collection != blank -%}
            {% render 'collection-card', collection: block.settings.collection, show_count: section.settings.show_count %}
          {%- else -%}
            <article class="ccg-card onboarding-placeholder" {{ block.shopify_attributes }}>
              <a href="#" class="ccg-card-wrapper-link">
                <div class="ccg-card-img">
                  {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
                <div class="ccg-card-overlay"></div>
                <div class="ccg-card-content">
                  <h3 class="ccg-card-title">{{ 'collections.title_placeholder' | t }}</h3>
                  {% if section.settings.show_count %}
                    <span class="ccg-card-count">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                          <rect x="3" y="3" width="7" height="7" />
                          <rect x="14" y="3" width="7" height="7" />
                          <rect x="3" y="14" width="7" height="7" />
                          <rect x="14" y="14" width="7" height="7" />
                      </svg>
                      {{ 'collections.zero_products' | t }}
                    </span>
                  {% endif %}
                </div>
              </a>
            </article>
          {%- endif -%}
        {%- elsif block.type == '@app' -%}
          {% render block %}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Featured Collections",
  "tag": "section",
  "class": "section-featured-collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Collection"
    },
    {
      "type": "inline_richtext",
          "id": "subheading",
      "label": "Subheading",
      "default": "Explore our curated collections designed for every style and occasion."
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show \"View All\" link",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "\"View All\" link text",
      "default": "View All Collections"
    },
    {
      "type": "checkbox",
      "id": "show_link_mobile",
      "label": "Show \"View All\" link on Mobile",
      "default": false
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns per row",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "full",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "standard", "label": "Standard" },
        { "value": "narrow", "label": "Narrow" }
      ]
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "inverse", "label": "Inverse" }
      ]
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Left",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Right",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_left_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Left (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Right (Mobile)",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "Featured Collections",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
