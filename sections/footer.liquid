{% schema %}
{
  "name": "t:sections.footer.name",
  "class": "section-footer",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "standard",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "full", "label": "Full width" },
        { "value": "narrow", "label": "Narrow" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Container max width",
      "default": 1340
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.footer.settings.color_scheme.label",
      "default": "background-2",
      "options": [
        { "value": "background-1", "label": "t:sections.footer.settings.color_scheme.options.background_1" },
        { "value": "background-2", "label": "t:sections.footer.settings.color_scheme.options.background_2" },
        { "value": "inverse", "label": "t:sections.footer.settings.color_scheme.options.inverse" },
        { "value": "accent-1", "label": "t:sections.footer.settings.color_scheme.options.accent_1" },
        { "value": "accent-2", "label": "t:sections.footer.settings.color_scheme.options.accent_2" }
      ]
    },
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "t:sections.footer.blocks.brand.name",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "General Settings"
        },
        {
          "type": "range",
          "id": "logo_size",
          "min": 50,
          "max": 300,
          "step": 10,
          "default": 110,
          "unit": "px",
          "label": "Custom logo size"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:sections.footer.blocks.brand.settings.text.label",
          "default": "<p>Your premier electronics destination, dedicated to providing the latest technology and gadgets that enhance your daily life.</p>"
        },
        {
          "type": "header",
          "content": "Visibility Settings"
        },
        {
          "type": "checkbox",
          "id": "show_on_desktop",
          "label": "Show on desktop",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_on_mobile",
          "label": "Show on mobile",
          "default": true
        },
        {
          "type": "header",
          "content": "Layout Settings"
        },
        {
          "type": "range",
          "id": "max_width",
          "min": 200,
          "max": 600,
          "step": 20,
          "unit": "px",
          "label": "Column max width",
          "default": 400
        },
        {
          "type": "range",
          "id": "margin_top",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Top margin (Desktop)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Bottom margin (Desktop)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_top_mobile",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Top margin (Mobile)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom_mobile",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Bottom margin (Mobile)",
          "default": 0
        },

        {
          "type": "header",
          "content": "Body Text Typography Settings"
        },
        {
          "type": "select",
          "id": "font_size_body",
          "label": "Body font size",
          "default": "medium",
          "options": [
            { "value": "small", "label": "Small" },
            { "value": "medium", "label": "Medium" },
            { "value": "large", "label": "Large" }
          ]
        },
        {
          "type": "select",
          "id": "font_weight_body",
          "label": "Body font weight",
          "default": "normal",
          "options": [
