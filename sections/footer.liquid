{{ 'section-footer.css' | asset_url | stylesheet_tag }}

{%- if section.settings.show_section -%}
{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

<style>
  #shopify-section-{{ section.id }} { padding: 0 !important; }
  #shopify-section-{{ section.id }} .apex-footer {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .apex-footer {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  /* Container Width Overrides */
  #shopify-section-{{ section.id }} .container-fluid {
    max-width: 100% !important;
    padding-left: 2rem !important;
    padding-right: 2rem !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container-narrow {
    max-width: 800px !important;
    margin: 0 auto !important;
  }
  #shopify-section-{{ section.id }} .container {
    max-width: {{ section.settings.max_width | default: 1340 }}px !important;
    margin: 0 auto !important;
  }

  {%- for block in section.blocks -%}
    /* Block-Level Scoped Styles for Block: {{ block.id }} */
    #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} {
      {%- if 'left' != blank -%}text-align: {{ 'left' }} !important;{%- endif -%}
      {%- if block.settings.margin_top != blank -%}margin-top: {{ block.settings.margin_top }}px !important;{%- endif -%}
      {%- if block.settings.margin_bottom != blank -%}margin-bottom: {{ block.settings.margin_bottom }}px !important;{%- endif -%}
      {%- if block.settings.bg_gradient != blank -%}
        background: {{ block.settings.bg_gradient }} !important;
      {%- elsif block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' -%}
        background-color: {{ block.settings.bg_color }} !important;
        background-image: none !important;
      {%- endif -%}
    }

    @media screen and (max-width: 768px) {
      #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} {
        {%- if block.settings.margin_top_mobile != blank -%}margin-top: {{ block.settings.margin_top_mobile }}px !important;{%- endif -%}
        {%- if block.settings.margin_bottom_mobile != blank -%}margin-bottom: {{ block.settings.margin_bottom_mobile }}px !important;{%- endif -%}
      }
    }

    {%- case block.type -%}
      {%- when 'brand' -%}
        {%- assign logo_w = block.settings.logo_size | default: 110 -%}
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} {
          {%- if block.settings.max_width != blank -%}max-width: {{ block.settings.max_width }}px !important;{%- endif -%}
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .footer-logo {
          {%- if 'left' == 'center' -%}
            justify-content: center !important;
          {%- elsif 'left' == 'right' -%}
            justify-content: flex-end !important;
          {%- else -%}
            justify-content: flex-start !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .logo-text {
          font-size: {{ logo_w | divided_by: 5.0 | at_least: 14 }}px !important;
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .logo-image {
          width: {{ logo_w }}px !important;
          max-height: none !important;
          height: auto !important;
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .footer-desc {
          {%- if block.settings.font_size_body == 'small' -%}font-size: 0.85rem !important;
          {%- elsif block.settings.font_size_body == 'large' -%}font-size: 1.15rem !important;
          {%- else -%}font-size: 0.95rem !important;
          {%- endif -%}
          {%- if block.settings.font_weight_body == 'bold' -%}font-weight: 700 !important;{%- elsif block.settings.font_weight_body == 'normal' -%}font-weight: 400 !important;{%- endif -%}
          {%- if block.settings.font_style_body != blank -%}font-style: {{ block.settings.font_style_body }} !important;{%- endif -%}
          {%- if block.settings.text_transform_body != blank -%}text-transform: {{ block.settings.text_transform_body }} !important;{%- endif -%}
          {%- if block.settings.letter_spacing_body != blank -%}letter-spacing: {{ block.settings.letter_spacing_body }}px !important;{%- endif -%}
          {%- if block.settings.line_height_body != blank -%}line-height: {{ block.settings.line_height_body | divided_by: 100.0 }} !important;{%- endif -%}
          {%- if block.settings.body_text_color != blank and block.settings.body_text_color != 'rgba(0,0,0,0)' -%}color: {{ block.settings.body_text_color }} !important;{%- endif -%}
        }

      {%- when 'menu' -%}
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .footer-heading {
          {%- if block.settings.font_size == 'small' -%}font-size: 1.0rem !important;
          {%- elsif block.settings.font_size == 'large' -%}font-size: 1.5rem !important;
          {%- else -%}font-size: 1.2rem !important;
          {%- endif -%}
          {%- if block.settings.font_weight == 'bold' -%}font-weight: 700 !important;{%- elsif block.settings.font_weight == 'normal' -%}font-weight: 400 !important;{%- endif -%}
          {%- if block.settings.font_style != blank -%}font-style: {{ block.settings.font_style }} !important;{%- endif -%}
          {%- if block.settings.text_transform != blank -%}text-transform: {{ block.settings.text_transform }} !important;{%- endif -%}
          {%- if block.settings.letter_spacing != blank -%}letter-spacing: {{ block.settings.letter_spacing }}px !important;{%- endif -%}
          {%- if block.settings.line_height != blank -%}line-height: {{ block.settings.line_height | divided_by: 100.0 }} !important;{%- endif -%}
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}color: {{ block.settings.text_color }} !important;{%- endif -%}
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .footer-menu {
          {%- if block.settings.menu_layout == 'two_columns' -%}
            display: grid !important;
            grid-template-columns: repeat(2, 1fr) !important;
            gap: 10px 16px !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .footer-menu li {
          {%- if block.settings.link_spacing != blank and block.settings.menu_layout == 'list' -%}margin-bottom: {{ block.settings.link_spacing }}px !important;{%- endif -%}
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .footer-menu a {
          {%- if block.settings.font_size_menu_item == 'small' -%}font-size: 0.8rem !important;
          {%- elsif block.settings.font_size_menu_item == 'large' -%}font-size: 1.1rem !important;
          {%- else -%}font-size: 0.95rem !important;
          {%- endif -%}
          {%- if block.settings.font_weight_menu_item == 'bold' -%}font-weight: 700 !important;{%- elsif block.settings.font_weight_menu_item == 'normal' -%}font-weight: 400 !important;{%- endif -%}
          {%- if block.settings.font_style_menu_item != blank -%}font-style: {{ block.settings.font_style_menu_item }} !important;{%- endif -%}
          {%- if block.settings.text_transform_menu_item != blank -%}text-transform: {{ block.settings.text_transform_menu_item }} !important;{%- endif -%}
          {%- if block.settings.letter_spacing_menu_item != blank -%}letter-spacing: {{ block.settings.letter_spacing_menu_item }}px !important;{%- endif -%}
          {%- if block.settings.line_height_menu_item != blank -%}line-height: {{ block.settings.line_height_menu_item | divided_by: 100.0 }} !important;{%- endif -%}
          {%- if block.settings.link_color != blank and block.settings.link_color != 'rgba(0,0,0,0)' -%}color: {{ block.settings.link_color }} !important;{%- endif -%}
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .footer-menu a:hover {
          {%- if block.settings.link_hover_color != blank and block.settings.link_hover_color != 'rgba(0,0,0,0)' -%}color: {{ block.settings.link_hover_color }} !important;{%- endif -%}
        }

      {%- when 'text' -%}
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .footer-heading {
          {%- if block.settings.font_size == 'small' -%}font-size: 1.0rem !important;
          {%- elsif block.settings.font_size == 'large' -%}font-size: 1.5rem !important;
          {%- else -%}font-size: 1.2rem !important;
          {%- endif -%}
          {%- if block.settings.font_weight == 'bold' -%}font-weight: 700 !important;{%- elsif block.settings.font_weight == 'normal' -%}font-weight: 400 !important;{%- endif -%}
          {%- if block.settings.font_style != blank -%}font-style: {{ block.settings.font_style }} !important;{%- endif -%}
          {%- if block.settings.text_transform != blank -%}text-transform: {{ block.settings.text_transform }} !important;{%- endif -%}
          {%- if block.settings.letter_spacing != blank -%}letter-spacing: {{ block.settings.letter_spacing }}px !important;{%- endif -%}
          {%- if block.settings.line_height != blank -%}line-height: {{ block.settings.line_height | divided_by: 100.0 }} !important;{%- endif -%}
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}color: {{ block.settings.text_color }} !important;{%- endif -%}
        }

      {%- when 'newsletter' -%}
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .footer-heading {
          {%- if block.settings.font_size == 'small' -%}font-size: 1.0rem !important;
          {%- elsif block.settings.font_size == 'large' -%}font-size: 1.5rem !important;
          {%- else -%}font-size: 1.2rem !important;
          {%- endif -%}
          {%- if block.settings.font_weight == 'bold' -%}font-weight: 700 !important;{%- elsif block.settings.font_weight == 'normal' -%}font-weight: 400 !important;{%- endif -%}
          {%- if block.settings.font_style != blank -%}font-style: {{ block.settings.font_style }} !important;{%- endif -%}
          {%- if block.settings.text_transform != blank -%}text-transform: {{ block.settings.text_transform }} !important;{%- endif -%}
          {%- if block.settings.letter_spacing != blank -%}letter-spacing: {{ block.settings.letter_spacing }}px !important;{%- endif -%}
          {%- if block.settings.line_height != blank -%}line-height: {{ block.settings.line_height | divided_by: 100.0 }} !important;{%- endif -%}
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}color: {{ block.settings.text_color }} !important;{%- endif -%}
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .footer-newsletter-subheading {
          {%- if block.settings.subheading_color != blank and block.settings.subheading_color != 'rgba(0,0,0,0)' -%}color: {{ block.settings.subheading_color }} !important;{%- endif -%}
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .footer-newsletter-input {
          {%- if block.settings.input_bg != blank and block.settings.input_bg != 'rgba(0,0,0,0)' -%}background-color: {{ block.settings.input_bg }} !important;{%- endif -%}
          {%- if block.settings.input_border_color != blank and block.settings.input_border_color != 'rgba(0,0,0,0)' -%}border-color: {{ block.settings.input_border_color }} !important;{%- endif -%}
          {%- if block.settings.input_text_color != blank and block.settings.input_text_color != 'rgba(0,0,0,0)' -%}color: {{ block.settings.input_text_color }} !important;{%- endif -%}
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .footer-newsletter-btn {
          {%- if block.settings.button_bg_color != blank and block.settings.button_bg_color != 'rgba(0,0,0,0)' -%}background-color: {{ block.settings.button_bg_color }} !important;{%- endif -%}
          {%- if block.settings.button_text_color != blank and block.settings.button_text_color != 'rgba(0,0,0,0)' -%}color: {{ block.settings.button_text_color }} !important;{%- endif -%}
          {%- if block.settings.button_border_radius != blank -%}border-radius: {{ block.settings.button_border_radius }}px !important;{%- endif -%}
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .footer-newsletter-btn:hover {
          {%- if block.settings.button_hover_bg_color != blank and block.settings.button_hover_bg_color != 'rgba(0,0,0,0)' -%}background-color: {{ block.settings.button_hover_bg_color }} !important;{%- endif -%}
          {%- if block.settings.button_hover_text_color != blank and block.settings.button_hover_text_color != 'rgba(0,0,0,0)' -%}color: {{ block.settings.button_hover_text_color }} !important;{%- endif -%}
        }

      {%- when 'social_links', 'footer_socials' -%}
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }}.social-links,
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .social-links {
          display: flex !important;
          flex-wrap: wrap !important;
          max-width: 100% !important;
          gap: 16px !important;
          {%- if 'left' == 'center' -%}
            justify-content: center !important;
          {%- elsif 'left' == 'right' -%}
            justify-content: flex-end !important;
          {%- else -%}
            justify-content: flex-start !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .social-link {
          {%- if block.settings.icon_size != blank -%}width: {{ block.settings.icon_size | plus: 16 }}px !important; height: {{ block.settings.icon_size | plus: 16 }}px !important;{%- endif -%}
          {%- if block.settings.icon_bg_color != blank and block.settings.icon_bg_color != 'rgba(0,0,0,0)' -%}background-color: {{ block.settings.icon_bg_color }} !important;{%- endif -%}
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}color: {{ block.settings.text_color }} !important;{%- endif -%}
          {%- if block.settings.border_radius != blank -%}border-radius: {{ block.settings.border_radius }}px !important;{%- endif -%}
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .icon-social {
          {%- if block.settings.icon_size != blank -%}
            width: {{ block.settings.icon_size }}px !important;
            height: {{ block.settings.icon_size }}px !important;
            font-size: {{ block.settings.icon_size | times: 0.83 | round }}px !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .social-link:hover {
          {%- if block.settings.icon_hover_bg_color != blank and block.settings.icon_hover_bg_color != 'rgba(0,0,0,0)' -%}background-color: {{ block.settings.icon_hover_bg_color }} !important;{%- endif -%}
          {%- if block.settings.icon_hover_color != blank and block.settings.icon_hover_color != 'rgba(0,0,0,0)' -%}color: {{ block.settings.icon_hover_color }} !important;{%- endif -%}
        }

      {%- when 'payment_methods', 'payment_icons' -%}
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }}.footer-payment-icons,
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .footer-payment-icons {
          max-width: 100% !important;
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .footer-payment-list {
          display: flex !important;
          flex-wrap: wrap !important;
          max-width: 100% !important;
          gap: 8px !important;
          list-style: none !important;
          padding: 0 !important;
          margin: 0 !important;
          {%- if 'left' == 'center' -%}
            justify-content: center !important;
          {%- elsif 'left' == 'right' -%}
            justify-content: flex-end !important;
          {%- else -%}
            justify-content: flex-start !important;
          {%- endif -%}
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .payment-icon,
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .footer-payment-item--svg svg {
          height: {{ block.settings.icon_height | default: 24 }}px !important;
          width: auto !important;
        }

      {%- when 'contact_info' -%}
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} .footer-heading {
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}color: {{ block.settings.text_color }} !important;{%- endif -%}
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} ul {
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}color: {{ block.settings.text_color }} !important;{%- endif -%}
        }
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} svg {
          {%- if block.settings.icon_color != blank and block.settings.icon_color != 'rgba(0,0,0,0)' -%}color: {{ block.settings.icon_color }} !important;{%- endif -%}
        }

      {%- when 'copyright' -%}
        #shopify-section-{{ section.id }} #ftr-block-{{ block.id }} p {
          {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}color: {{ block.settings.text_color }} !important;{%- endif -%}
          {%- if block.settings.font_size == 'small' -%}font-size: 0.8rem !important;
          {%- elsif block.settings.font_size == 'large' -%}font-size: 1.1rem !important;
          {%- else -%}font-size: 0.9rem !important;
          {%- endif -%}
          {%- if block.settings.font_weight == 'bold' -%}font-weight: 700 !important;{%- elsif block.settings.font_weight == 'normal' -%}font-weight: 400 !important;{%- endif -%}
          {%- if block.settings.font_style != blank -%}font-style: {{ block.settings.font_style }} !important;{%- endif -%}
          {%- if block.settings.text_transform != blank -%}text-transform: {{ block.settings.text_transform }} !important;{%- endif -%}
          {%- if block.settings.letter_spacing != blank -%}letter-spacing: {{ block.settings.letter_spacing }}px !important;{%- endif -%}
          {%- if block.settings.line_height != blank -%}line-height: {{ block.settings.line_height | divided_by: 100.0 }} !important;{%- endif -%}
        }
    {%- endcase -%}
  {%- endfor -%}
</style>

<footer class="apex-footer color-{{ section.settings.color_scheme }}{% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}" data-section-id="{{ section.id }}">
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    <div class="footer-grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when 'brand' -%}
            {%- liquid
              assign text_direction = request.locale.direction | default: 'ltr'
              if request.locale.iso_code == 'ar' or request.locale.iso_code == 'he' or request.locale.iso_code == 'fa' or request.locale.iso_code == 'ur'
                assign text_direction = 'rtl'
              endif

              assign logo_img = settings.logo_ltr
              if text_direction == 'rtl' and settings.logo_rtl != blank
                assign logo_img = settings.logo_rtl
              elsif settings.logo_ltr == blank and settings.logo_rtl != blank
                assign logo_img = settings.logo_rtl
              endif
              assign logo_w = block.settings.logo_size | default: 110
            -%}
            <div class="footer-col footer-col--wide{% if block.settings.mobile_width == 'half' %} footer-col--mobile-half{% endif %}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" id="ftr-block-{{ block.id }}" {{ block.shopify_attributes }}>
              <div class="footer-logo">
                <a href="{{ routes.root_url }}" class="logo-section" aria-label="{{ shop.name }}">
                  {%- if logo_img != blank -%}
                    {{ logo_img | image_url: width: logo_w | image_tag:
                      class: 'logo-image',
                      loading: 'lazy',
                      alt: shop.name
                    }}
                  {%- else -%}
                    <span class="logo-text">{{ shop.name }}</span>
                  {%- endif -%}
                </a>
              </div>
              {%- if block.settings.text != blank -%}
                <div class="footer-desc">{{ block.settings.text }}</div>
              {%- endif -%}
            </div>

          {%- when 'menu' -%}
            <div class="footer-col footer-col--menu{% if block.settings.mobile_width == 'half' %} footer-col--mobile-half{% endif %}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" id="ftr-block-{{ block.id }}" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank and block.settings.show_heading -%}
                <h3 class="footer-heading">{{ block.settings.heading | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="footer-menu" role="list">
                  {%- for link in linklists[block.settings.menu].links -%}
                    <li>
                      <a href="{{ link.url }}">{{ link.title | escape }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>

          {%- when 'text' -%}
            <div class="footer-col footer-col--text{% if block.settings.mobile_width == 'half' %} footer-col--mobile-half{% endif %}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" id="ftr-block-{{ block.id }}" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="footer-heading">{{ block.settings.heading | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="footer-desc">{{ block.settings.text }}</div>
              {%- endif -%}
            </div>

          {%- when 'newsletter' -%}
            <div class="footer-col footer-col--wide{% if block.settings.mobile_width == 'half' %} footer-col--mobile-half{% endif %}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" id="ftr-block-{{ block.id }}" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="footer-heading">{{ block.settings.heading | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.subheading != blank -%}
                <p class="footer-newsletter-subheading">{{ block.settings.subheading | escape }}</p>
              {%- endif -%}
              {%- form 'customer', class: 'footer-newsletter-form' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <div class="footer-newsletter-group">
                  <label class="visually-hidden" for="FooterNewsletterEmail-{{ section.id }}">
                    {{ 'sections.footer.newsletter.placeholder' | t }}
                  </label>
                  <input
                    type="email"
                    name="contact[email]"
                    id="FooterNewsletterEmail-{{ section.id }}"
                    class="footer-newsletter-input"
                    value="{{ form.email }}"
                    aria-required="true"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    {% if form.errors %}
                      autofocus
                      aria-invalid="true"
                      aria-describedby="FooterNewsletter-error-{{ section.id }}"
                    {% endif %}
                    placeholder="{{ 'sections.footer.newsletter.placeholder' | t }}"
                    required
                  >
                  {%- assign default_button_label_val = 'sections.footer.newsletter.submit' | t -%}{%- assign button_label_val = block.settings.button_label | default: default_button_label_val -%}
