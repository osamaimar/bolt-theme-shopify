    <div class="footer-bottom">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'copyright' -%}
            <div class="footer-copy{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" id="ftr-block-{{ block.id }}" {{ block.shopify_attributes }}>
              {%- assign default_copy = '© ' | append: 'now' | date: '%Y' | append: ' [StoreName]. All rights reserved.' -%}
