{{ 'section-gift-card.css' | asset_url | stylesheet_tag }}
<script src="{{ 'qr-code.js' | asset_url }}" defer="defer"></script>

<style>
  /* Standard Block Spacing overrides */
  #section-{{ section.id }} .gc-header-block {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 0px) !important;
  }
  #section-{{ section.id }} .gc-block {
    margin-top: var(--m-t, 20px) !important;
    margin-bottom: var(--m-b, 20px) !important;
  }
  @media screen and (max-width: 768px) {
    #section-{{ section.id }} .gc-header-block {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 0px)) !important;
    }
    #section-{{ section.id }} .gc-block {
      margin-top: var(--m-t-m, var(--m-t, 15px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 15px)) !important;
    }
  }

  /* Responsive Font Sizing for Heading */
  #section-{{ section.id }} .gc-title.size-small { font-size: 2.2rem; }
  #section-{{ section.id }} .gc-title.size-medium { font-size: 2.8rem; }
  #section-{{ section.id }} .gc-title.size-large { font-size: 3.5rem; }
  @media screen and (max-width: 768px) {
    #section-{{ section.id }} .gc-title.size-small { font-size: 1.8rem; }
    #section-{{ section.id }} .gc-title.size-medium { font-size: 2.2rem; }
    #section-{{ section.id }} .gc-title.size-large { font-size: 2.5rem; }
  }

  /* Heading Highlight styling */
  #section-{{ section.id }} .gc-title span {
    background: var(--highlight-gradient, var(--color-accent)) !important;
    -webkit-background-clip: var(--highlight-clip, text) !important;
    background-clip: var(--highlight-clip, text) !important;
    -webkit-text-fill-color: var(--highlight-fill, transparent) !important;
    display: inline-block;
    color: var(--highlight-color, inherit) !important;
  }

  /* Responsive Font Sizing for Subheading */
  #section-{{ section.id }} .gc-subtitle.size-small { font-size: 0.95rem; }
  #section-{{ section.id }} .gc-subtitle.size-medium { font-size: 1.15rem; }
  #section-{{ section.id }} .gc-subtitle.size-large { font-size: 1.35rem; }
  @media screen and (max-width: 768px) {
    #section-{{ section.id }} .gc-subtitle.size-small { font-size: 0.85rem; }
    #section-{{ section.id }} .gc-subtitle.size-medium { font-size: 0.95rem; }
    #section-{{ section.id }} .gc-subtitle.size-large { font-size: 1.15rem; }
  }

  /* Footer Button overrides */
  #section-{{ section.id }} .gc-footer-btn {
    transition: all 0.3s ease;
  }
  #section-{{ section.id }} .gc-footer-btn-wrapper {
    display: flex;
    justify-content: var(--btn-align, center);
    width: 100%;
    margin-top: var(--btn-m-t, 20px) !important;
    margin-bottom: var(--btn-m-b, 20px) !important;
  }
  @media screen and (max-width: 768px) {
    #section-{{ section.id }} .gc-footer-btn-wrapper {
      margin-top: var(--btn-m-t-m, var(--btn-m-t, 20px)) !important;
      margin-bottom: var(--btn-m-b-m, var(--btn-m-b, 20px)) !important;
    }
  }
  #section-{{ section.id }} .gc-footer-btn.size-small {
    padding: 10px 20px;
    font-size: 0.9rem;
  }
  #section-{{ section.id }} .gc-footer-btn.size-medium {
    padding: 14px 28px;
    font-size: 1.0rem;
  }
  #section-{{ section.id }} .gc-footer-btn.size-large {
    padding: 18px 36px;
    font-size: 1.1rem;
  }
</style>

{%- if section.settings.show_section -%}
<style>
  #section-{{ section.id }} {
    padding-top: calc({{ section.settings.padding_top }}px + 100px) !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
  #section-{{ section.id }} .gc-section-container {
    max-width: {{ section.settings.max_width | default: 1340 }}px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: {% if section.settings.blocks_position == 'left' %}flex-start{% elsif section.settings.blocks_position == 'right' %}flex-end{% else %}center{% endif %};
  }
  @media screen and (max-width: 768px) {
    #section-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px + 80px) !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }
</style>
<div class="gc-section color-{{ section.settings.color_scheme }}{% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}" id="section-{{ section.id }}">
  <div class="gc-section-container {% if section.settings.container_width == 'wide' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    <div class="gc-header" style="text-align: {{ 'center' }}; width: 100%; display: flex; flex-direction: column; align-items: center;">
      {%- liquid
        assign text_direction = request.locale.direction | default: 'ltr'
        if request.locale.iso_code == 'ar' or request.locale.iso_code == 'he' or request.locale.iso_code == 'fa' or request.locale.iso_code == 'ur'
          assign text_direction = 'rtl'
        endif

        assign store_logo = settings.logo_ltr
        if text_direction == 'rtl' and settings.logo_rtl != blank
          assign store_logo = settings.logo_rtl
        elsif settings.logo_ltr == blank and settings.logo_rtl != blank
          assign store_logo = settings.logo_rtl
        endif
      -%}
      {%- if store_logo != blank -%}
        <div class="gc-logo-wrapper" style="margin-bottom: 20px;">
          <img src="{{ store_logo | image_url: width: 400 }}" 
               alt="{{ shop.name }}" 
               style="width: {{ section.settings.logo_width | default: 150 }}px; max-width: 100%; height: auto; display: block; margin: 0 auto;"
               width="{{ store_logo.width }}"
               height="{{ store_logo.height }}"
               loading="lazy"
          >
        </div>
      {%- elsif section.settings.show_shop_name -%}
        <div class="gc-shop-name" style="font-size: 1.5rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: var(--text-primary); margin-bottom: 20px;">
          {{ shop.name }}
        </div>
      {%- endif -%}
    {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'heading'
        assign b_align_alignment = 'center'
      when 'subheading'
        assign b_align_alignment = 'center'
      when 'balance'
        assign b_align_alignment = 'center'
      when 'code'
        assign b_align_alignment = 'space-between'
      when 'qr_code'
        assign b_align_alignment = 'left'
      when 'info_grid'
        assign b_align_alignment = 'left'
      when 'button'
        assign b_align_alignment = 'center'
  endcase
-%}
      {%- case block.type -%}
        {%- when 'heading' -%}
          {%- if block.settings.show_on_desktop or block.settings.show_on_mobile -%}
            {%- assign heading_tag = block.settings.heading_tag | default: 'h1' -%}
            {%- assign h_color = block.settings.highlight_color -%}
            {%- assign h_gradient = block.settings.highlight_gradient -%}
            <{{ heading_tag }} class="gc-title gc-header-block size-{{ block.settings.font_size | default: 'large' }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                {{ block.shopify_attributes }} 
                style="
                  --m-t: {{ block.settings.margin_top | default: 0 }}px; 
                  --m-b: {{ block.settings.margin_bottom | default: 20 }}px; 
                  --m-t-m: {{ block.settings.margin_top_mobile | default: 0 }}px; 
                  --m-b-m: {{ block.settings.margin_bottom_mobile | default: 15 }}px; 
                  font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; 
                  font-style: {{ block.settings.font_style | default: 'normal' }}; 
                  text-transform: {{ block.settings.text_transform | default: 'none' }}; 
                  letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px; 
                  line-height: {{ block.settings.line_height | default: 120 | divided_by: 100.0 }}; 
                  text-align: {{ b_align_alignment | default: 'center' }};
                  {% if block.settings.text_color != blank %}color: {{ block.settings.text_color }} !important;{% endif %} 
                  {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background-color: {{ block.settings.bg_color }} !important;{% endif %}
                  {% if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' %}--highlight-gradient: {{ h_gradient }}; --highlight-clip: text; --highlight-fill: transparent; --highlight-color: transparent;
                  {% elsif h_color != blank and h_color != 'rgba(0,0,0,0)' %}--highlight-color: {{ h_color }}; --highlight-gradient: none; --highlight-clip: initial; --highlight-fill: {{ h_color }};
                  {% endif %}
                ">
              {{ block.settings.title | default: 'Gift Card' | replace: '[', '<span>' | replace: ']', '</span>' }}
            </{{ heading_tag }}>
          {%- endif -%}
        {%- when 'subheading' -%}
          {%- if block.settings.show_on_desktop or block.settings.show_on_mobile -%}
            {%- assign subheading_tag = block.settings.subheading_tag | default: 'p' -%}
            <{{ subheading_tag }} class="gc-subtitle gc-header-block size-{{ block.settings.font_size | default: 'medium' }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                {{ block.shopify_attributes }} 
                style="
                  --m-t: {{ block.settings.margin_top | default: 0 }}px; 
                  --m-b: {{ block.settings.margin_bottom | default: 28 }}px; 
                  --m-t-m: {{ block.settings.margin_top_mobile | default: 0 }}px; 
                  --m-b-m: {{ block.settings.margin_bottom_mobile | default: 20 }}px; 
                  width: 100% !important; max-width: {{ block.settings.max_width | default: 800 }}px !important;
                  text-align: {{ b_align_alignment | default: 'center' }};
                  font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; 
                  font-style: {{ block.settings.font_style | default: 'normal' }}; 
                  text-transform: {{ block.settings.text_transform | default: 'none' }}; 
                  letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px; 
                  line-height: {{ block.settings.line_height | default: 170 | divided_by: 100.0 }}; 
                  {% if block.settings.text_color != blank %}color: {{ block.settings.text_color }} !important;{% endif %} 
                  {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background-color: {{ block.settings.bg_color }} !important;{% endif %}
                ">
              {{ block.settings.subheading }}
            </{{ subheading_tag }}>
          {%- endif -%}
      {%- endcase -%}
    {%- endfor -%}
  </div>

  <div class="gc-card-box"{% if section.settings.background_image != blank %} style="background-image: url('{{ section.settings.background_image | image_url: width: 1200 }}'); background-size: cover; background-position: center;"{% endif %}>
    {% if section.settings.background_image != blank %}
      <div class="gc-card-overlay" style="position: absolute; top:0; left:0; width:100%; height:100%; background: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}; z-index: 0; pointer-events: none; border-radius: inherit;"></div>
    {% endif %}
    <div class="gc-card-content" style="text-align: {{ 'center' }}; position: relative; z-index: 1;">
      {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'heading'
        assign b_align_alignment = 'center'
      when 'subheading'
        assign b_align_alignment = 'center'
      when 'balance'
        assign b_align_alignment = 'center'
      when 'code'
        assign b_align_alignment = 'space-between'
      when 'qr_code'
        assign b_align_alignment = 'left'
      when 'info_grid'
        assign b_align_alignment = 'left'
      when 'button'
        assign b_align_alignment = 'center'
      when 'apple_wallet'
        assign b_align_alignment = 'center'
  endcase
-%}
        {%- case block.type -%}
          {%- when 'icon' -%}
            {%- if block.settings.show_on_desktop != false or block.settings.show_on_mobile != false -%}
              <div class="gc-gift-icon gc-block {% unless block.settings.show_on_desktop != false %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile != false %} hidden-mobile{% endunless %}" 
                   {{ block.shopify_attributes }}
                   style="
                     --m-t: {{ block.settings.margin_top | default: 20 }}px;
                     --m-b: {{ block.settings.margin_bottom | default: 20 }}px;
                     --m-t-m: {{ block.settings.margin_top_mobile | default: 15 }}px;
                     --m-b-m: {{ block.settings.margin_bottom_mobile | default: 15 }}px;
                     margin-left: {% if b_align_alignment == 'left' %}0{% elsif b_align_alignment == 'right' %}auto{% else %}auto{% endif %};
                     margin-right: {% if b_align_alignment == 'right' %}0{% elsif b_align_alignment == 'left' %}auto{% else %}auto{% endif %};
                     text-align: {{ b_align_alignment | default: 'center' }};
                     width: {{ block.settings.icon_size | default: 64 }}px !important;
                     height: {{ block.settings.icon_size | default: 64 }}px !important;
                     {% if block.settings.bg_gradient != blank or block.settings.bg_color != blank %}padding: 12px !important;{% endif %}
                     {% if block.settings.icon_color != blank %}color: {{ block.settings.icon_color }} !important;{% endif %}
                     {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background-color: {{ block.settings.bg_color }} !important;{% endif %}
                   ">
                <div style="width: 100%; height: 100%; display: inline-flex; align-items: center; justify-content: center; color: inherit;">
                  {%- if block.settings.custom_icon_svg != blank -%}
                    {{ block.settings.custom_icon_svg }}
                  {%- else -%}
                    {%- case block.settings.icon -%}
                      {%- when 'gift' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"></polyline><rect x="2" y="7" width="20" height="5"></rect><line x1="12" y1="22" x2="12" y2="7"></line><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path></svg>
                      {%- when 'shipping' -%}{% render 'icon-shipping' %}
                      {%- when 'returns' -%}{% render 'icon-returns' %}
                      {%- when 'secure' -%}{% render 'icon-secure' %}
                      {%- when 'support' -%}{% render 'icon-support' %}
                      {%- when 'quality' -%}{% render 'icon-check' %}
                      {%- when 'warranty' -%}{% render 'icon-secure' %}
                      {%- when 'laptop' -%}{% render 'icon-laptop' %}
                      {%- when 'phone' -%}{% render 'icon-phone' %}
                      {%- when 'headphones' -%}{% render 'icon-headphones' %}
                      {%- when 'tools' -%}{% render 'icon-tools' %}
                      {%- when 'gamepad' -%}{% render 'icon-gamepad' %}
                      {%- when 'watch' -%}{% render 'icon-watch' %}
                      {%- when 'check' -%}{% render 'icon-check' %}
                      {%- when 'heart' -%}{% render 'icon-heart' %}
                      {%- when 'star' -%}{% render 'icon-star' %}
                    {%- endcase -%}
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}

          {%- when 'balance' -%}
            {%- if block.settings.show_on_desktop != false or block.settings.show_on_mobile != false -%}
              {%- assign balance_with_currency = gift_card.balance | money | strip -%}
              {%- assign balance_without_currency = gift_card.balance | money_without_currency | strip -%}
              {%- assign currency_symbol = balance_with_currency | replace: balance_without_currency, '' | strip -%}

              {%- assign balance_with_currency_first_char = balance_with_currency | slice: 0 -%}
              {%- assign currency_symbol_first_char = currency_symbol | slice: 0 -%}
              {%- if balance_with_currency_first_char == currency_symbol_first_char -%}
                {%- assign symbol_at_start = true -%}
              {%- else -%}
                {%- assign symbol_at_start = false -%}
              {%- endif -%}

              {%- assign decimal_sep = '' -%}
              {%- assign decimal_part = '' -%}
              {%- assign integer_part = balance_without_currency -%}
              {%- assign last_3 = balance_without_currency | slice: -3, 1 -%}
              {%- if last_3 == '.' or last_3 == ',' -%}
                {%- assign decimal_sep = last_3 -%}
                {%- assign len = balance_without_currency | size -%}
                {%- assign int_len = len | minus: 3 -%}
                {%- assign integer_part = balance_without_currency | slice: 0, int_len -%}
                {%- assign decimal_part = balance_without_currency | slice: -2, 2 -%}
              {%- endif -%}

              <div class="gc-block {% unless block.settings.show_on_desktop != false %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile != false %} hidden-mobile{% endunless %}" 
                   {{ block.shopify_attributes }}
                   style="
                     --m-t: {{ block.settings.margin_top | default: 20 }}px;
                     --m-b: {{ block.settings.margin_bottom | default: 20 }}px;
                     --m-t-m: {{ block.settings.margin_top_mobile | default: 15 }}px;
                     --m-b-m: {{ block.settings.margin_bottom_mobile | default: 15 }}px;
                     text-align: {{ b_align_alignment | default: 'center' }};
                     font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                     font-style: {{ block.settings.font_style | default: 'normal' }};
                     text-transform: {{ block.settings.text_transform | default: 'none' }};
                     letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                     line-height: {{ block.settings.line_height | default: 120 | divided_by: 100.0 }};
                     font-size: {% if block.settings.font_size == 'small' %}0.85em{% elsif block.settings.font_size == 'large' %}1.25em{% else %}inherit{% endif %};
                     {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background-color: {{ block.settings.bg_color }} !important;{% endif %}
                     padding: 10px; border-radius: 8px;
                   ">
                <span class="gc-balance-label" style="{% if block.settings.label_color != blank %}color: {{ block.settings.label_color }} !important;{% endif %}">{{ block.settings.balance_label | default: 'Balance' }}</span>
                <h2 class="gc-balance-amount">{%- if symbol_at_start -%}<span class="gc-balance-currency" style="{% if block.settings.currency_color != blank %}color: {{ block.settings.currency_color }} !important;{% endif %}">{{ currency_symbol }}</span>{%- endif -%}<span class="gc-balance-integer" style="{% if block.settings.integer_color != blank %}color: {{ block.settings.integer_color }} !important;{% endif %}">{{ integer_part }}</span>{%- if decimal_sep != blank -%}<span class="gc-balance-dot" style="{% if block.settings.dot_color != blank %}color: {{ block.settings.dot_color }} !important;{% endif %}">{{ decimal_sep }}</span><span class="gc-balance-decimal" style="{% if block.settings.decimal_color != blank %}color: {{ block.settings.decimal_color }} !important;{% endif %}">{{ decimal_part }}</span>{%- endif -%}{%- if symbol_at_start == false and currency_symbol != blank -%}<span class="gc-balance-currency" style="{% if block.settings.currency_color != blank %}color: {{ block.settings.currency_color }} !important;{% endif %}">{{ currency_symbol }}</span>{%- endif -%}</h2>
              </div>
            {%- endif -%}

          {%- when 'code' -%}
            {%- if block.settings.show_on_desktop != false or block.settings.show_on_mobile != false -%}
              <div class="gc-code-container gc-block {% unless block.settings.show_on_desktop != false %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile != false %} hidden-mobile{% endunless %}" 
                   {{ block.shopify_attributes }}
                   style="
                     --m-t: {{ block.settings.margin_top | default: 20 }}px;
                     --m-b: {{ block.settings.margin_bottom | default: 20 }}px;
                     --m-t-m: {{ block.settings.margin_top_mobile | default: 15 }}px;
                     --m-b-m: {{ block.settings.margin_bottom_mobile | default: 15 }}px;
                     justify-content: {% if b_align_alignment == 'left' %}flex-start{% elsif b_align_alignment == 'right' %}flex-end{% elsif b_align_alignment == 'center' %}center{% else %}space-between{% endif %};
                     gap: 15px;
                     text-align: {% if b_align_alignment == 'space-between' %}left{% else %}{{ b_align_alignment | default: 'left' }}{% endif %};
                     --code-font-scale: {% if block.settings.font_size == 'small' %}0.85{% elsif block.settings.font_size == 'large' %}1.15{% else %}1{% endif %};
                     --code-font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                     --code-font-style: {{ block.settings.font_style | default: 'normal' }};
                     --code-text-transform: {{ block.settings.text_transform | default: 'none' }};
                     --code-letter-spacing: {{ block.settings.letter_spacing | default: 2 }}px;
                     --code-line-height: {{ block.settings.line_height | default: 120 | divided_by: 100.0 }};
                     {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background-color: {{ block.settings.bg_color }} !important;{% endif %}
                     {% if block.settings.border_color != blank %}border-color: {{ block.settings.border_color }} !important;{% endif %}
                   ">
                {%- if block.settings.show_code_text != false -%}
                  <p class="gc-code-text" id="gc-code" style="{% if block.settings.code_text_color != blank %}color: {{ block.settings.code_text_color }} !important;{% else %}color: inherit;{% endif %} margin: 0;">{{ gift_card.code | format_code | replace: ' ', '-' }}</p>
                {%- endif -%}
                {%- if block.settings.show_copy_button != false -%}
                  <button class="gc-copy-btn" id="gc-copy-btn" data-success-text="{{ block.settings.copy_success_text | escape }}"
                          style="
                            {% if block.settings.button_bg_color != blank %}background: {{ block.settings.button_bg_color }} !important;{% endif %}
                            {% if block.settings.button_text_color != blank %}color: {{ block.settings.button_text_color }} !important;{% endif %}
                            {% if block.settings.button_border_color != blank %}border: 1px solid {{ block.settings.button_border_color }} !important;{% endif %}
                          ">{{ block.settings.copy_button_text }}</button>
                {%- endif -%}
              </div>
            {%- endif -%}

          {%- when 'info_grid' -%}
            {%- if block.settings.show_on_desktop != false or block.settings.show_on_mobile != false -%}
              <div class="gc-info-grid gc-block {% unless block.settings.show_on_desktop != false %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile != false %} hidden-mobile{% endunless %}" 
                   {{ block.shopify_attributes }}
                   style="
                     --m-t: {{ block.settings.margin_top | default: 20 }}px;
                     --m-b: {{ block.settings.margin_bottom | default: 20 }}px;
                     --m-t-m: {{ block.settings.margin_top_mobile | default: 15 }}px;
                     --m-b-m: {{ block.settings.margin_bottom_mobile | default: 15 }}px;
                     text-align: {{ b_align_alignment | default: 'center' }};
                     font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                     font-style: {{ block.settings.font_style | default: 'normal' }};
                     text-transform: {{ block.settings.text_transform | default: 'none' }};
                     letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                     line-height: {{ block.settings.line_height | default: 120 | divided_by: 100.0 }};
                     font-size: {% if block.settings.font_size == 'small' %}0.85em{% elsif block.settings.font_size == 'large' %}1.15em{% else %}inherit{% endif %};
                     
                      {% if block.settings.label_color != blank %}--label-color: {{ block.settings.label_color }};{% endif %}
                      {% if block.settings.value_color != blank %}--value-color: {{ block.settings.value_color }};{% endif %}
                      {% if block.settings.icon_color != blank %}--icon-color: {{ block.settings.icon_color }};{% endif %}
