{
  "type": "header",
  "name": "t:general.header",
  "sections": {
    "header": {
      "type": "header",
      "settings": {
        "show_section": true,
        "show_on_desktop": true,
        "show_on_mobile": true,
        "container_width": "full",
        "max_width": 1340,
        "logo_position": "middle-left",
        "sticky_header": "on-scroll",
        "color_scheme": "background-1"
      },
      "blocks": {
        "logo_block": {
          "type": "logo",
          "settings": {
            "show_on_desktop": true,
            "show_on_mobile": true,
            "logo_text": "Bolt [Electronics]"
          }
        },
        "nav_block": {
          "type": "navigation",
          "settings": {
            "show_on_desktop": true,
            "show_on_mobile": false,
            "menu": "main-menu"
          }
        },
        "icons_block": {
          "type": "icons",
          "settings": {
            "show_on_desktop": true,
            "show_on_mobile": true,
            "show_search": true,
            "show_cart_icon": true,
            "show_account_icon": true
          }
        }
      },
      "block_order": [
        "logo_block",
        "nav_block",
        "icons_block"
      ]
    }
  },
  "order": [
    "header"
  ]
}