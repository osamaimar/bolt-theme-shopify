{{ 'section-hero.css' | asset_url | stylesheet_tag }}

{%- if section.settings.show_section -%}
{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile,
  padding_left: section.settings.padding_left,
  padding_right: section.settings.padding_right,
  padding_left_mobile: section.settings.padding_left_mobile,
  padding_right_mobile: section.settings.padding_right_mobile
%}
<style>
  #shopify-section-{{ section.id }} {
    --hero-min-height: {{ section.settings.min_height }}px;
    --hero-overlay-color: {{ section.settings.overlay_color.red }}, {{ section.settings.overlay_color.green }}, {{ section.settings.overlay_color.blue }};
    --hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }
  
  #shopify-section-{{ section.id }} .hec-hero {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .hec-hero {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
  
  .hec-hero-card-overlay {
    background: rgba(var(--hero-overlay-color), var(--hero-overlay-opacity));
  }
</style>

<section class="hec-hero color-{{ section.settings.color_scheme }}" id="shopify-section-{{ section.id }}" style="min-height: var(--hero-min-height); text-align: {{ 'left' }};">
  <div class="container hec-hero-grid">
    <!-- Left: Copy -->
    <div class="hec-hero-content" style="text-align: {{ 'left' }};">
      {%- if section.settings.heading != blank -%}
        <h1 class="hec-hero-title">
          {{ section.settings.heading | replace: '[', '<span>' | replace: ']', '</span>' }}
        </h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="hec-hero-desc">
          {{ section.settings.subheading }}
        </p>
      {%- endif -%}

      <div class="hec-hero-actions" style="justify-content: {% if 'left' == 'center' %}center{% elsif 'left' == 'right' %}flex-end{% else %}flex-start{% endif %};">
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="hec-hero-btn-primary" id="hec-shop-now-btn-{{ section.id }}">
            {{ section.settings.button_label }}
            {% render 'icon-arrow' %}
          </a>
        {%- endif -%}
        
        {%- if section.settings.secondary_button_label != blank -%}
          <a href="{{ section.settings.secondary_button_link }}" class="hec-hero-btn-secondary" id="hec-browse-btn-{{ section.id }}">
            {{ section.settings.secondary_button_label }}
          </a>
        {%- endif -%}
      </div>
      
      {%- for block in section.blocks -%}
        {%- if block.type == '@app' -%}
          <div class="hero-app-block" {{ block.shopify_attributes }}>
            {% render block %}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Right: Featured Product Card -->
    <div class="hec-hero-visual">
      <div class="hec-hero-card">
        {%- if section.settings.image != blank -%}
          {%- assign hero_img_alt = section.settings.image.alt | default: section.settings.featured_product_title | default: 'Hero image' | escape -%}
          {{ section.settings.image | image_url: width: 2000 | image_tag: 
            loading: 'eager', 
            fetchpriority: 'high',
            decoding: 'async',
            widths: '600, 900, 1200, 1500, 2000',
            alt: hero_img_alt 
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        
        <div class="hec-hero-card-overlay"></div>

        <div class="hec-hero-card-content">
          {%- if section.settings.featured_product_title != blank -%}
            <div class="hec-hero-card-title">{{ section.settings.featured_product_title }}</div>
          {%- endif -%}
          
          {%- if section.settings.featured_product_price != blank -%}
            <div class="hec-hero-card-price">
              {{ section.settings.featured_product_price }}
              {%- if section.settings.featured_product_original_price != blank -%}
                <span class="original-price">{{ section.settings.featured_product_original_price }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section-hero-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Future-Proof Your Life with Premium Tech"
    },
    {
      "type": "inline_richtext",
          "id": "subheading",
      "label": "Subheading",
      "default": "Discover the latest in high-performance computing, smart home ecosystems, and mobile innovation."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "Browse Catalog"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Featured Card"
    },
    {
      "type": "text",
      "id": "featured_product_title",
      "label": "Card title",
      "default": "Ultimate Gaming Console Bundle"
    },
    {
      "type": "text",
      "id": "featured_product_price",
      "label": "Card price",
      "default": "$89.00"
    },
    {
      "type": "text",
      "id": "featured_product_original_price",
      "label": "Card original price",
      "default": "$129.00"
    },
    {
      "type": "header",
      "content": "Aesthetics"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 40
    },
    
    {
      "type": "range",
      "id": "min_height",
      "min": 300,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Minimum height",
      "default": 700
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "inverse", "label": "Inverse" },
        { "value": "accent", "label": "Accent" }
      ]
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 128
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Left",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Right",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_left_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Left (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Right (Mobile)",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
