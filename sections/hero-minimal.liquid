{{ 'section-home-ecommerce-minimal.css' | asset_url | stylesheet_tag }}

{%- if section.settings.show_section -%}
{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile,
  padding_left: section.settings.padding_left,
  padding_right: section.settings.padding_right,
  padding_left_mobile: section.settings.padding_left_mobile,
  padding_right_mobile: section.settings.padding_right_mobile
%}
<style>
  #hev-hero-{{ section.id }} {
    min-height: {% if section.settings.full_height %}100vh{% else %}{{ section.settings.min_height }}px{% endif %};
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: {% if 'center' == 'center' %}center{% elsif 'center' == 'right' %}flex-end{% else %}flex-start{% endif %};
  }
  #hev-hero-{{ section.id }} .hev-hero-inner {
    max-width: {{ section.settings.max_width }}px;
    width: 100%;
    margin: 0 auto;
    text-align: {{ 'center' }};
  }
  .hev-hero-block {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 0px) !important;
    color: var(--block-text-color, inherit) !important;
    background: var(--block-bg, transparent) !important;
  }
  .hev-hero-block:not(.hev-hero-button-block):not(.hev-hero-stat) * {
    color: inherit !important;
  }
  @media (max-width: 768px) {
    .hev-hero-block {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 0px)) !important;
    }
  }
  #hev-hero-{{ section.id }} .hev-hero-stat {
    padding: 28px var(--spacing-lg);
  }
  .hev-hero-title span {
    background: var(--highlight-gradient, var(--color-accent)) !important;
    -webkit-background-clip: var(--highlight-clip, text) !important;
    background-clip: var(--highlight-clip, text) !important;
    -webkit-text-fill-color: var(--highlight-fill, transparent) !important;
  }
  /* Explicit override for highlight color */
  .hev-hero-title span {
    color: var(--highlight-color, inherit) !important;
  }
  #hev-hero-{{ section.id }} .hev-hero-stat-value {
    font-size: 1.6rem;
    font-weight: inherit;
    margin-bottom: var(--spacing-xs);
  }
  #hev-hero-{{ section.id }} .hev-hero-stat-label {
    font-size: 0.82rem;
    font-weight: inherit;
  }
  @media (max-width: 1024px) {
    #hev-hero-{{ section.id }} .hev-hero-stat {
      padding: 20px var(--spacing-md);
    }
  }
  @media (max-width: 768px) {
    #hev-hero-{{ section.id }} .hev-hero-stat {
      padding: 16px var(--spacing-sm);
    }
  }
</style>

<section class="hev-hero color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}" id="hev-hero-{{ section.id }}">
    <div class="{% if section.settings.container_width == 'full' %}container-fluid{% else %}container{% endif %}">
    <div class="hev-hero-bg">
        {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 2000 | image_tag: 
                loading: 'eager', 
                widths: '600, 900, 1200, 1500, 2000',
                sizes: '100vw',
                alt: section.settings.image.alt | default: 'Hero background',
                width: 2000,
                height: 1333
            }}
        {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
    </div>

    <div class="hev-hero-inner">
        {%- for block in section.blocks -%}
            {%- case block.type -%}
                {%- when 'hero_heading' -%}
                    {%- if block.settings.heading != blank -%}
                        {%- assign heading_tag = block.settings.heading_tag | default: 'h1' -%}
                        {%- assign h_color = block.settings.highlight_color -%}
                        {%- assign h_gradient = block.settings.highlight_gradient -%}
                        <{{ heading_tag }} class="hev-hero-title hev-hero-block hev-hero-title--{{ block.settings.font_size }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                            style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px; text-align: {{ 'center' }}; font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; {% if block.settings.text_color != blank %}--block-text-color: {{ block.settings.text_color }};{% endif %} {% if block.settings.bg_gradient != blank %}--block-bg: {{ block.settings.bg_gradient }};{% elsif block.settings.bg_color != blank %}--block-bg: {{ block.settings.bg_color }};{% endif %} 
                            {% if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' %}--highlight-gradient: {{ h_gradient }}; --highlight-clip: text; --highlight-fill: transparent;
                            {% elsif h_color != blank and h_color != 'rgba(0,0,0,0)' %}--highlight-color: {{ h_color }}; --highlight-gradient: none; --highlight-clip: initial; --highlight-fill: {{ h_color }};
                            {% endif %}" 
                            {{ block.shopify_attributes }}>
                            {{ block.settings.heading | replace: '[', '<span>' | replace: ']', '</span>' }}
                        </{{ heading_tag }}>
                    {%- endif -%}

                {%- when 'hero_subheading' -%}
                    {%- if block.settings.subheading != blank -%}
                        <p class="hev-hero-subtitle hev-hero-block {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                           style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px; font-size: {{ block.settings.font_size }}rem; text-align: {{ 'center' }}; max-width: {{ block.settings.max_width }}px; font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; {% if block.settings.text_color != blank %}--block-text-color: {{ block.settings.text_color }};{% endif %} {% if block.settings.bg_gradient != blank %}--block-bg: {{ block.settings.bg_gradient }};{% elsif block.settings.bg_color != blank %}--block-bg: {{ block.settings.bg_color }};{% endif %}" 
                           {{ block.shopify_attributes }}>
                            {{ block.settings.subheading }}
                        </p>
                    {%- endif -%}

                {%- when 'hero_button' -%}
                    {%- assign prev_index = forloop.index0 | minus: 1 -%}
                    {%- assign next_index = forloop.index0 | plus: 1 -%}
                    
                    {%- comment -%} theme-check-disable UnclosedHTMLElement {%- endcomment -%}
                    {%- if forloop.first or section.blocks[prev_index].type != 'hero_button' -%}
                        <div class="hev-hero-cta-group {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" style="justify-content: {% if 'center' == 'center' %}center{% elsif 'center' == 'right' %}flex-end{% else %}flex-start{% endif %};">
                    {%- endif -%}

                    {%- if block.settings.label != blank -%}
                        <div class="hev-hero-block hev-hero-button-block" style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px;">
                            <a href="{{ block.settings.link | default: '#' }}" 
                               class="{% if block.settings.style == 'primary' %}hev-hero-cta-primary{% else %}hev-hero-cta-outline{% endif %}" 
                               style="font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; {% if block.settings.text_color != blank %}color: {{ block.settings.text_color }} !important;{% endif %} {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important; border: none !important;{% elsif block.settings.bg_color != blank %}background: {{ block.settings.bg_color }} !important; border: none !important;{% endif %}"
                               {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener"{% endif %}
                               {{ block.shopify_attributes }}>
                                {{ block.settings.label }}
                                {%- if block.settings.style == 'primary' -%}
                                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true" focusable="false">
                                        <path d="M5 12h14" />
                                        <path d="M12 5l7 7-7 7" />
                                    </svg>
                                {%- endif -%}
                            </a>
                        </div>
                    {%- endif -%}

                    {%- if forloop.last or section.blocks[next_index].type != 'hero_button' -%}
                        </div>
                    {%- endif -%}
                    {%- comment -%} theme-check-enable UnclosedHTMLElement {%- endcomment -%}

                {%- when '@app' -%}
                    <div {{ block.shopify_attributes }}>
                        {% render block %}
                    </div>
            {%- endcase -%}
        {%- endfor -%}
    </div>
    </div>

    {%- if section.settings.show_stats_bar -%}
        <div class="hev-hero-stats">
            <div class="hev-hero-stats-inner">
                {%- for block in section.blocks -%}
                    {%- case block.type -%}
                        {%- when 'stat' -%}
                            <div class="hev-hero-stat hev-hero-block" 
                                 style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px; text-align: {{ 'center' }}; font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; {% if block.settings.bg_gradient != blank %}--block-bg: {{ block.settings.bg_gradient }};{% elsif block.settings.bg_color != blank %}--block-bg: {{ block.settings.bg_color }};{% endif %}" 
                                 {{ block.shopify_attributes }}>
                                <div class="hev-hero-stat-value" style="{% if block.settings.value_color != blank and block.settings.value_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.value_color }} !important;{% endif %}">{{ block.settings.value }}</div>
                                <div class="hev-hero-stat-label" style="{% if block.settings.label_color != blank and block.settings.label_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.label_color }} !important;{% endif %}">{{ block.settings.label }}</div>
                            </div>
                    {%- endcase -%}
                {%- endfor -%}
            </div>
        </div>
    {%- endif -%}
</section>
{%- endif -%}

{% schema %}
{
  "name": "Hero - Minimal Ecommerce",
  "tag": "section",
  "class": "section-hero-minimal",
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_stats_bar",
      "label": "Show stats bar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "full",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "narrow", "label": "Narrow" },
        { "value": "full", "label": "Full Width" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Max Width",
      "default": 1200
    },
    {
      "type": "checkbox",
      "id": "full_height",
      "label": "Full Viewport Height (100vh)",
      "default": true
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 400,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Max Height",
      "default": 700
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "paragraph",
      "content": "Typography settings are managed within individual blocks."
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 40
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
