  ],
  "blocks": [
    {
      "type": "hero_heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "General Settings"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Future Tech [Latest Gadgets]",
