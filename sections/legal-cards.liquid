{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subheading'
        assign b_align_alignment = ''
      when 'card'
        assign b_align_alignment = 'left'
      when 'button'
        assign b_align_alignment = 'center'
  endcase
-%}
      {%- case block.type -%}
        {%- when 'divider' -%}
          {%- assign thickness = block.settings.thickness | default: 1 -%}
          {%- assign d_style = block.settings.divider_style | default: 'solid' -%}
          {%- assign d_width = block.settings.width | default: 100 -%}
          {%- assign d_color = block.settings.divider_color -%}
          <hr 
            class="legal-divider {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
            {{ block.shopify_attributes }}
            style="
              --d-m-t: {{ block.settings.margin_top | default: 48 }}px;
              --d-m-b: {{ block.settings.margin_bottom | default: 32 }}px;
              --d-m-t-m: {{ block.settings.margin_top_mobile | default: 32 }}px;
              --d-m-b-m: {{ block.settings.margin_bottom_mobile | default: 24 }}px;
              width: {{ d_width }}% !important;
              {%- if section.settings.blocks_position == 'left' -%}
                margin-left: 0 !important;
                margin-right: auto !important;
              {%- elsif section.settings.blocks_position == 'right' -%}
                margin-left: auto !important;
                margin-right: 0 !important;
              {%- else -%}
                margin-left: auto !important;
                margin-right: auto !important;
              {%- endif -%}
              border: none !important;
              border-top: {{ thickness }}px {{ d_style }} {% if d_color != blank and d_color != 'rgba(0,0,0,0)' %}{{ d_color }}{% else %}var(--border-light, rgba(255,255,255,0.1)){% endif %} !important;
              background: none !important;
              height: 0 !important;
            "
          >
        {%- when 'button' -%}
          {%- assign btn_align = b_align_alignment -%}
          {%- if btn_align == blank -%}
            {%- assign btn_align = section.settings.blocks_position -%}
          {%- endif -%}
          {%- if btn_align == 'space-between' or btn_align == blank -%}
            {%- assign btn_align = 'center' -%}
          {%- endif -%}
          <div class="legal-download-wrapper {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
               {{ block.shopify_attributes }}
               style="
                 --b-m-t: {{ block.settings.margin_top | default: 20 }}px;
                 --b-m-b: {{ block.settings.margin_bottom | default: 20 }}px;
                 --b-m-t-m: {{ block.settings.margin_top_mobile | default: 16 }}px;
                 --b-m-b-m: {{ block.settings.margin_bottom_mobile | default: 16 }}px;
                 display: flex !important;
                 width: 100% !important;
                 justify-content: {% if btn_align == 'left' %}flex-start{% elsif btn_align == 'right' %}flex-end{% else %}center{% endif %} !important;
               "
          >
            <a 
              href="{{ block.settings.download_link | default: '#' }}" 
              class="legal-download-btn btn-style-{{ block.settings.style | default: 'outline' }} size-{{ block.settings.font_size | default: 'medium' }}"
              download
              style="
                font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                font-style: {{ block.settings.font_style | default: 'normal' }};
                text-transform: {{ block.settings.text_transform | default: 'none' }};
                letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                line-height: {{ block.settings.line_height | default: 115 }}%;
                {% if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.text_color }} !important;{% endif %}
                {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background: {{ block.settings.bg_color }} !important;{% endif %}
                {% if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' %}border-color: {{ block.settings.border_color }} !important;{% endif %}
              "
            >
              {%- if block.settings.show_icon != false -%}
                {%- assign icon_type = block.settings.icon_type | default: 'download' -%}
                {%- if icon_type == 'download' and block.settings.download_icon != blank -%}
                  {%- assign icon_type = 'custom' -%}
                {%- endif -%}
                <span class="btn-icon" {% if block.settings.icon_color != blank %}style="color: {{ block.settings.icon_color }} !important;"{% endif %}>
                  {%- case icon_type -%}
                    {%- when 'download' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="7 10 12 15 17 10"></polyline>
                        <line x1="12" y1="15" x2="12" y2="3"></line>
                      </svg>
                    {%- when 'external' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                        <polyline points="15 3 21 3 21 9"></polyline>
                        <line x1="10" y1="14" x2="21" y2="3"></line>
                      </svg>
                    {%- when 'arrow' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                      </svg>
                    {%- when 'check' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    {%- when 'info' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="16" x2="12" y2="12"></line>
                        <line x1="12" y1="8" x2="12.01" y2="8"></line>
                      </svg>
                    {%- when 'mail' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                        <polyline points="22,6 12,13 2,6"></polyline>
                      </svg>
                    {%- when 'custom' -%}
                      {%- if block.settings.download_icon != blank -%}
                        {{ block.settings.download_icon }}
                      {%- endif -%}
                  {%- endcase -%}
                </span>
              {%- endif -%}
              {{ block.settings.download_text | default: 'Download PDF Version' }}
            </a>
          </div>
      {%- endcase -%}
    {%- endfor -%}

  </div>
</section>
{%- endif -%}

