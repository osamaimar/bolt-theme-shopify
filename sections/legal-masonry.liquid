                            {%- when 'award' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                            {%- when 'users' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            {%- when 'globe' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                            {%- when 'search' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                            {%- when 'file' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                            {%- when 'settings' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                            {%- when 'shield' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            {%- when 'lock' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                            {%- when 'info' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                          {%- endcase -%}
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  {%- endif -%}
                  {%- if block.settings.show_heading != false and block.settings.heading != blank -%}
                    <h2>{{ block.settings.heading }}</h2>
                  {%- endif -%}
                  {%- if block.settings.show_content != false and block.settings.content != blank -%}
                    <div class="legal-card-content rte">
                      {{ block.settings.content }}
                    </div>
                  {%- endif -%}
                </article>
            {%- endcase -%}
          {%- endfor -%}
        {%- endif -%}
      </div>

      {%- comment -%}Download Button & Divider{%- endcomment -%}
      {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subtitle'
        assign b_align_alignment = ''
      when 'button'
        assign b_align_alignment = 'center'
      when 'card'
        assign b_align_alignment = 'left'
  endcase
-%}
        {%- case block.type -%}
          {%- when 'divider' -%}
            {%- assign thickness = block.settings.thickness | default: 1 -%}
            {%- assign d_style = block.settings.divider_style | default: 'solid' -%}
            {%- assign d_width = block.settings.width | default: 100 -%}
            {%- assign d_color = block.settings.divider_color -%}
            <hr 
              class="legal-divider {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
              {{ block.shopify_attributes }}
              style="
                --d-m-t: {{ block.settings.margin_top | default: 48 }}px;
                --d-m-b: {{ block.settings.margin_bottom | default: 32 }}px;
                --d-m-t-m: {{ block.settings.margin_top_mobile | default: 32 }}px;
                --d-m-b-m: {{ block.settings.margin_bottom_mobile | default: 24 }}px;
                width: {{ d_width }}% !important;
                {%- if section.settings.blocks_position == 'left' -%}
                  margin-inline-start: 0 !important;
                  margin-inline-end: auto !important;
                {%- elsif section.settings.blocks_position == 'right' -%}
                  margin-inline-start: auto !important;
                  margin-inline-end: 0 !important;
                {%- else -%}
                  margin-inline-start: auto !important;
                  margin-inline-end: auto !important;
                {%- endif -%}
                border: none !important;
                border-top: {{ thickness }}px {{ d_style }} {% if d_color != blank and d_color != 'rgba(0,0,0,0)' %}{{ d_color }}{% else %}var(--border-light, rgba(255,255,255,0.1)){% endif %} !important;
                background: none !important;
                height: 0 !important;
              "
            >
          {%- when 'button' -%}
            {%- assign btn_align = b_align_alignment -%}
            {%- if btn_align == blank -%}
              {%- assign btn_align = section.settings.blocks_position -%}
            {%- endif -%}
            {%- if btn_align == 'space-between' or btn_align == blank -%}
              {%- assign btn_align = 'center' -%}
            {%- endif -%}
            <div class="legal-download-wrapper {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                 {{ block.shopify_attributes }}
                 style="
                   --b-m-t: {{ block.settings.margin_top | default: 20 }}px;
                   --b-m-b: {{ block.settings.margin_bottom | default: 20 }}px;
                   --b-m-t-m: {{ block.settings.margin_top_mobile | default: 16 }}px;
                   --b-m-b-m: {{ block.settings.margin_bottom_mobile | default: 16 }}px;
                   display: flex !important;
                   width: 100% !important;
                   justify-content: {% if btn_align == 'left' %}flex-start{% elsif btn_align == 'right' %}flex-end{% else %}center{% endif %} !important;
                 "
            >
              <a 
                href="{{ block.settings.download_link | default: '#' }}" 
                class="legal-download-btn btn-style-{{ block.settings.style | default: 'outline' }} size-{{ block.settings.font_size | default: 'medium' }}"
                download
                style="
                  font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                  font-style: {{ block.settings.font_style | default: 'normal' }};
                  text-transform: {{ block.settings.text_transform | default: 'none' }};
                  letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                  line-height: {{ block.settings.line_height | default: 115 }}%;
                  {% if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.text_color }} !important;{% endif %}
                  {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background: {{ block.settings.bg_color }} !important;{% endif %}
                  {% if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' %}border-color: {{ block.settings.border_color }} !important;{% endif %}
                "
              >
                {%- if block.settings.show_icon != false -%}
                  {%- assign icon_type = block.settings.icon_type | default: 'download' -%}
                  {%- if icon_type == 'download' and block.settings.download_icon != blank -%}
                    {%- assign icon_type = 'custom' -%}
                  {%- endif -%}
                  <span class="btn-icon" {% if block.settings.icon_color != blank %}style="color: {{ block.settings.icon_color }} !important;"{% endif %}>
                    {%- case icon_type -%}
                      {%- when 'download' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                          <polyline points="7 10 12 15 17 10"></polyline>
                          <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                      {%- when 'external' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                          <polyline points="15 3 21 3 21 9"></polyline>
                          <line x1="10" y1="14" x2="21" y2="3"></line>
                        </svg>
                      {%- when 'arrow' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <line x1="5" y1="12" x2="19" y2="12"></line>
                          <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                      {%- when 'check' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                      {%- when 'info' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="12" r="10"></circle>
                          <line x1="12" y1="16" x2="12" y2="12"></line>
                          <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                      {%- when 'mail' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                          <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                      {%- when 'custom' -%}
                        {%- if block.settings.download_icon != blank -%}
                          {{ block.settings.download_icon }}
                        {%- endif -%}
                    {%- endcase -%}
                  </span>
                {%- endif -%}
                {{ block.settings.download_text | default: 'Download PDF Version' }}
              </a>
            </div>
        {%- endcase -%}
      {%- endfor -%}

    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Legal Masonry",
  "tag": "section",
  "class": "section-legal-masonry",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "standard",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "standard", "label": "Standard" },
        { "value": "narrow", "label": "Narrow" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Container max width",
      "default": 1200
    },
    {
      "type": "select",
      "id": "blocks_position",
      "label": "Blocks position",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Masonry Grid"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Number of columns",
      "default": "3",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ]
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Card gap",
      "default": 30
    },

    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1",
      "options": [
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "inverse", "label": "Inverse" },
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" }
      ]
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "header",
      "name": "Header",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "General Settings"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "[Privacy] Policy",
          "info": "Use [text] to highlight text with accent color"
        },
        {
          "type": "select",
          "id": "heading_tag",
          "label": "Heading Tag",
          "info": "Specify heading code types for SEO and search engines.",
          "default": "h1",
          "options": [
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" },
            { "value": "h4", "label": "H4" },
            { "value": "h5", "label": "H5" },
            { "value": "h6", "label": "H6" },
            { "value": "div", "label": "div" },
            { "value": "span", "label": "span" },
            { "value": "p", "label": "p" }
          ]
        },
        {
          "type": "header",
          "content": "Visibility"
        },
        {
          "type": "checkbox",
          "id": "show_on_desktop",
          "label": "Show on Desktop",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_on_mobile",
          "label": "Show on Mobile",
          "default": true
        },
        {
          "type": "header",
          "content": "Layout"
        },
        
        {
          "type": "range",
          "id": "max_width",
          "min": 400,
          "max": 1200,
          "step": 10,
          "unit": "px",
          "label": "Maximum width",
          "default": 800
        },
        {
          "type": "range",
          "id": "margin_top",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Top Margin (Desktop)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Bottom Margin (Desktop)",
          "default": 20
        },
        {
          "type": "range",
          "id": "margin_top_mobile",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Top Margin (Mobile)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom_mobile",
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Bottom Margin (Mobile)",
          "default": 16
        },
        {
          "type": "header",
          "content": "Typography"
        },
        {
          "type": "select",
          "id": "font_size",
          "label": "Font Size",
          "default": "large",
          "options": [
            { "value": "small", "label": "Small" },
            { "value": "medium", "label": "Medium" },
            { "value": "large", "label": "Large" }
          ]
        },
        {
          "type": "select",
          "id": "font_weight",
          "label": "Font Weight",
          "default": "bold",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "bold", "label": "Bold" }
          ]
        },
        {
          "type": "select",
          "id": "font_style",
          "label": "Font Style",
          "default": "normal",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "italic", "label": "Italic" }
          ]
        },
        {
          "type": "select",
          "id": "text_transform",
          "label": "Text Transform",
          "default": "none",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "uppercase", "label": "Uppercase" },
            { "value": "lowercase", "label": "Lowercase" },
            { "value": "capitalize", "label": "Capitalize" }
          ]
        },
        {
          "type": "range",
          "id": "letter_spacing",
          "min": -5,
          "max": 10,
          "step": 0.5,
          "unit": "px",
          "label": "Letter Spacing",
          "default": 0
        },
        {
          "type": "range",
          "id": "line_height",
          "min": 80,
          "max": 200,
          "step": 5,
          "unit": "%",
          "label": "Line Height",
          "default": 120
        },
        {
          "type": "header",
          "content": "Colors"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color"
        },
        {
          "type": "color_background",
          "id": "bg_gradient",
          "label": "Background Gradient"
        },
        {
          "type": "color",
          "id": "highlight_color",
          "label": "Highlight Text Color"
        },
        {
          "type": "color_background",
          "id": "highlight_gradient",
          "label": "Highlight Text Gradient"
        }
      ]
    },
    {
      "type": "subtitle",
      "name": "Subtitle",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "General Settings"
        },
        {
          "type": "inline_richtext",
          "id": "subheading",
          "label": "Subheading",
          "default": "Effective date: March 2026 | Last updated: March 2026"
        },
        {
          "type": "select",
          "id": "subheading_tag",
          "label": "Subheading Tag",
          "default": "p",
          "options": [
