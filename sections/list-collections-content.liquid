{%- if section.settings.show_section -%}
{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

{{ 'section-list-collections.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }} {
    --section-bg: {% if section.settings.color_scheme == 'background-1' %}var(--bg-primary){% elsif section.settings.color_scheme == 'background-2' %}var(--bg-secondary){% elsif section.settings.color_scheme == 'accent-1' %}var(--color-primary){% elsif section.settings.color_scheme == 'accent-2' %}var(--color-accent){% elsif section.settings.color_scheme == 'default' %}var(--bg-primary){% else %}var(--bg-primary){% endif %};
    --section-text: {% if section.settings.color_scheme == 'accent-1' %}var(--text-inverse){% elsif section.settings.color_scheme == 'accent-2' %}var(--bg-primary){% elsif section.settings.color_scheme == 'inverse' %}var(--text-inverse){% else %}var(--text-primary){% endif %};
  }

  .ccg-content-outer.section-{{ section.id }} {
    background: var(--section-bg);
    color: var(--section-text);
  }

  {%- for block in section.blocks -%}
    {%- if block.type == 'toolbar' -%}
      #block-{{ block.id }} {
        margin-top: {{ block.settings.margin_top_mobile }}px !important;
        margin-bottom: {{ block.settings.margin_bottom_mobile }}px !important;
        padding-top: {{ block.settings.padding_vertical }}px !important;
        padding-bottom: {{ block.settings.padding_vertical }}px !important;
      }
      @media screen and (min-width: 750px) {
        #block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top }}px !important;
          margin-bottom: {{ block.settings.margin_bottom }}px !important;
        }
      }
      {%- if block.settings.style == 'bordered' -%}
        #block-{{ block.id }} {
          border: 1px solid var(--border-light);
          border-radius: 12px;
          padding-left: 20px !important;
          padding-right: 20px !important;
        }
      {%- elsif block.settings.style == 'glass' -%}
        #block-{{ block.id }} {
          background: rgba(255, 255, 255, 0.05) !important;
          backdrop-filter: blur(10px);
          border: 1px solid rgba(255, 255, 255, 0.1);
          border-radius: 12px;
          padding-left: 20px !important;
          padding-right: 20px !important;
        }
      {%- endif -%}

      {%- if block.settings.text_color != blank -%}
        #block-{{ block.id }},
        #block-{{ block.id }} .ccg-count-label,
        #block-{{ block.id }} input {
          color: {{ block.settings.text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.bg_gradient != blank -%}
        #block-{{ block.id }} {
          background: {{ block.settings.bg_gradient }} !important;
        }
      {%- elsif block.settings.bg_color != blank -%}
        #block-{{ block.id }} {
          background-color: {{ block.settings.bg_color }} !important;
          background-image: none !important;
        }
      {%- endif -%}
      {%- if block.settings.border_color != blank -%}
        #block-{{ block.id }} {
          border-color: {{ block.settings.border_color }} !important;
        }
      {%- endif -%}
      
      /* Dropdown and other options colors */
      {%- if block.settings.dropdown_bg_gradient != blank -%}
        #block-{{ block.id }} select, #block-{{ block.id }} .dropdown-menu { background: {{ block.settings.dropdown_bg_gradient }} !important; }
      {%- elsif block.settings.dropdown_bg_color != blank -%}
        #block-{{ block.id }} select, #block-{{ block.id }} .dropdown-menu { background-color: {{ block.settings.dropdown_bg_color }} !important; background-image: none !important; }
      {%- endif -%}
      {%- if block.settings.dropdown_border_color != blank -%}
        #block-{{ block.id }} select, #block-{{ block.id }} .dropdown-menu { border-color: {{ block.settings.dropdown_border_color }} !important; }
      {%- endif -%}
      {%- if block.settings.dropdown_text_color != blank -%}
        #block-{{ block.id }} select, #block-{{ block.id }} .dropdown-menu, #block-{{ block.id }} select option { color: {{ block.settings.dropdown_text_color }} !important; }
      {%- endif -%}
    {%- endif -%}

    {%- if block.type == 'collection_grid' -%}
      .section-{{ section.id }} .ccg-gallery {
        margin-top: {{ block.settings.margin_top_mobile }}px !important;
        margin-bottom: {{ block.settings.margin_bottom_mobile }}px !important;
        gap: {{ block.settings.grid_gap }}px !important;
        --columns-desktop: {{ block.settings.columns_desktop }};
        --columns-tablet: {{ block.settings.columns_tablet }};
        --columns-mobile: {{ block.settings.columns_mobile }};
      }
      @media screen and (min-width: 750px) {
        .section-{{ section.id }} .ccg-gallery {
          margin-top: {{ block.settings.margin_top }}px !important;
          margin-bottom: {{ block.settings.margin_bottom }}px !important;
        }
      }
      
      /* Card Aspect Ratio & Fit Customization */
      .section-{{ section.id }} .ccg-card-img {
        --image-aspect-ratio: {{ block.settings.image_aspect_ratio }} !important;
        aspect-ratio: {{ block.settings.image_aspect_ratio }} !important;
      }
      .section-{{ section.id }} .ccg-card-img img {
        --image-fit: {{ block.settings.image_fit }} !important;
        object-fit: {{ block.settings.image_fit }} !important;
      }

      /* Card Background, Borders, Typography Colors */
      .section-{{ section.id }} .ccg-card {
        {%- if block.settings.card_bg_color != blank -%}
          background-color: {{ block.settings.card_bg_color }} !important;
        {%- else -%}
          background-color: var(--bg-card, rgba(var(--bg-card-rgb, 6, 26, 51), 0.6)) !important;
        {%- endif -%}
        {%- if block.settings.border_color != blank -%}
          border: 1px solid {{ block.settings.border_color }} !important;
        {%- else -%}
          border: 1px solid rgba(var(--color-accent-rgb, 133, 187, 255), 0.15) !important;
        {%- endif -%}
      }
      {%- if block.settings.title_color != blank -%}
        .section-{{ section.id }} .ccg-card-title {
          color: {{ block.settings.title_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.category_color != blank -%}
        .section-{{ section.id }} .ccg-card-category {
          color: {{ block.settings.category_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.desc_color != blank -%}
        .section-{{ section.id }} .ccg-card-desc {
          color: {{ block.settings.desc_color }} !important;
        }
      {%- endif -%}

      /* Explore Button styling overrides */
      .section-{{ section.id }} .ccg-card-link {
        {%- if block.settings.btn_text_color != blank -%}
          color: {{ block.settings.btn_text_color }} !important;
        {%- endif -%}
        {%- if block.settings.btn_border_color != blank -%}
          border-color: {{ block.settings.btn_border_color }} !important;
        {%- endif -%}
        {%- if block.settings.btn_bg_gradient != blank -%}
          background: {{ block.settings.btn_bg_gradient }} !important;
        {%- elsif block.settings.btn_bg_color != blank -%}
          background-color: {{ block.settings.btn_bg_color }} !important;
          background-image: none !important;
        {%- endif -%}
      }

      /* Count bubble styling overrides */
      .section-{{ section.id }} .ccg-card-count {
        {%- if block.settings.count_text_color != blank -%}
          color: {{ block.settings.count_text_color }} !important;
        {%- endif -%}
        {%- if block.settings.count_bg_gradient != blank -%}
          background: {{ block.settings.count_bg_gradient }} !important;
        {%- elsif block.settings.count_bg_color != blank -%}
          background-color: {{ block.settings.count_bg_color }} !important;
          background-image: none !important;
        {%- endif -%}
      }
    {%- endif -%}
  {%- endfor -%}
{%- endstyle -%}

<div class="list-collections-content ccg-content-outer section-{{ section.id }} color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}">
  <div class="ccg-page {% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}"
       style="{% if section.settings.container_width != 'full' %}max-width: {{ section.settings.max_width }}px;{% endif %} margin: 0 auto;">
    
    {%- assign collections_per_page = 12 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'collection_grid' -%}
        {%- assign collections_per_page = block.settings.collections_per_page -%}
      {%- endif -%}
    {%- endfor -%}

    {%- paginate collections by collections_per_page -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'toolbar' -%}
            <!-- ===================== Unified Toolbar Block ===================== -->
            <div class="ccg-filter-bar ccg-filter-bar--{{ block.settings.style }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" id="block-{{ block.id }}" {{ block.shopify_attributes }}>
              {%- if block.settings.show_results_count -%}
                <span class="ccg-count-label" id="ccg-count-label"
                      data-showing-singular="{{ 'collections.showing_collections' | t: count: '##' }}"
                      data-showing-plural="{{ 'collections.showing_collections_plural' | t: count: '##' }}">
                  {%- if paginate.items > 0 -%}
                    {%- assign current_first_item = paginate.current_offset | plus: 1 -%}
                    {%- assign current_last_item = paginate.current_offset | plus: paginate.page_size -%}
                    {%- if current_last_item > paginate.items -%}
                      {%- assign current_last_item = paginate.items -%}
                    {%- endif -%}
                    {{ 'collections.showing_range_collections' | t: first: current_first_item, last: current_last_item, total: paginate.items }}
                  {%- else -%}
                    {{ 'collections.showing_zero_collections' | t }}
                  {%- endif -%}
                </span>
              {%- endif -%}

              {%- if block.settings.show_search -%}
                <!-- Search Bar (Optional, kept for flexibility) -->
                <div class="ccg-search-wrap" style="margin-left: auto;">
                  <svg class="ccg-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                  </svg>
                  <input type="text" id="ccg-search-input" placeholder="{{ block.settings.search_placeholder | default: 'Search collections...' }}" aria-label="Search collections">
                </div>
              {%- endif -%}
            </div>

        {%- when 'collection_grid' -%}
          <!-- ===================== Gallery Grid ===================== -->
          <div class="ccg-gallery {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" id="ccg-gallery" data-no-results-text="{{ 'collections.no_collections_found' | t }}" {{ block.shopify_attributes }}>
              {%- if collections.size > 0 -%}
                {%- for collection in collections -%}
                  <article class="ccg-card ccg-card--{{ block.settings.card_style | default: 'default' }}" 
                    data-title="{{ collection.title | escape }}"
                    data-count="{{ collection.all_products_count }}"
                    onclick="window.location.href='{{ collection.url }}'">
                    <div class="ccg-card-img">
                      {%- if collection.image != blank -%}
                        {{ collection.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: collection.title, width: 800, height: 800 }}
                      {%- else -%}
                        {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}
                    </div>
                    {%- if block.settings.show_image_overlay -%}
                      <div class="ccg-card-overlay"></div>
                    {%- endif -%}
                    
                    {%- if block.settings.show_badge and collection.metafields.custom.badge_text != blank -%}
                      {%- assign badge_text = collection.metafields.custom.badge_text -%}
                      {%- assign badge_style = collection.metafields.custom.badge_style | default: 'featured' -%}
                      {%- assign badge_text_color = collection.metafields.custom.badge_text_color -%}
                      
                      {%- if badge_style contains '#' or badge_style contains 'rgb' or badge_style contains 'hsl' or badge_style contains 'linear-gradient' -%}
                        {%- assign inline_styles = 'background: ' | append: badge_style | append: ' !important;' -%}
                        {%- if badge_text_color != blank -%}
                          {%- assign inline_styles = inline_styles | append: ' color: ' | append: badge_text_color | append: ' !important;' -%}
                        {%- else -%}
                          {%- assign inline_styles = inline_styles | append: ' color: #ffffff !important;' -%}
                        {%- endif -%}
                        {%- assign inline_styles = inline_styles | append: ' border: none !important;' -%}
                        
                        <span class="ccg-card-badge" style="{{ inline_styles }}">
                          {{ badge_text }}
                        </span>
                      {%- else -%}
                        {%- assign inline_styles = '' -%}
                        {%- if badge_text_color != blank -%}
                          {%- assign inline_styles = 'color: ' | append: badge_text_color | append: ' !important;' -%}
                        {%- endif -%}
                        
                        <span class="ccg-card-badge {{ badge_style }}"{% if inline_styles != blank %} style="{{ inline_styles }}"{% endif %}>
                          {{ badge_text }}
                        </span>
                      {%- endif -%}
                    {%- endif -%}
                    
                    {%- if block.settings.show_product_count -%}
                      <span class="ccg-card-count">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <rect x="3" y="3" width="7" height="7" />
                          <rect x="14" y="3" width="7" height="7" />
                          <rect x="3" y="14" width="7" height="7" />
                          <rect x="14" y="14" width="7" height="7" />
                        </svg>
                        {%- assign default_prod_count_val = 'collections.showing_collections_plural' | t -%}{%- assign prod_count_val = block.settings.product_count_label | default: default_prod_count_val -%}
                        {{ collection.all_products_count }} {{ prod_count_val }}
                      </span>
                    {%- endif -%}
                    
                    <div class="ccg-card-content">
                      {%- if block.settings.show_category -%}
                        <div class="ccg-card-category">{{ collection.title }}</div>
                      {%- endif -%}
                      {%- if block.settings.show_collection_title -%}
                        <h3 class="ccg-card-title">{{ collection.title }}</h3>
                      {%- endif -%}
                      {%- if block.settings.show_collection_description and collection.description != blank -%}
                        <p class="ccg-card-desc">
                          {{ collection.description | strip_html | truncatewords: block.settings.description_max_length | default: 120 }}
                        </p>
                      {%- endif -%}
                      {%- if block.settings.show_view_all_link -%}
                        <div class="ccg-card-bottom">
                          <a href="{{ collection.url }}" class="ccg-card-link" aria-label="{{ block.settings.view_all_label | default: 'View all' }} {{ collection.title }}">
                            {{ block.settings.view_all_label | default: 'View all' }} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                          </a>
                        </div>
                      {%- endif -%}
                    </div>
                  </article>
                {%- endfor -%}
              {%- else -%}
                <div class="ccg-no-results">
                  <p>{{ 'collections.no_collections_found' | t }}</p>
                </div>
              {%- endif -%}
          </div>

          {%- if block.settings.show_pagination and paginate.pages > 1 -%}
            <div class="ccg-pagination">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="ccg-page-link ccg-page-link-arrow" aria-label="Previous Page">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="15 18 9 12 15 6" />
                  </svg>
                </a>
              {%- endif -%}

              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" class="ccg-page-link">{{ part.title }}</a>
                {%- else -%}
                  {%- if part.title == paginate.current_page -%}
                    <span class="ccg-page-link active" aria-current="page">{{ part.title }}</span>
                  {%- else -%}
                    <span class="ccg-page-dots">{{ part.title }}</span>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}

              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="ccg-page-link ccg-page-link-arrow" aria-label="Next Page">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="9 18 15 12 9 6" />
                  </svg>
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
      {%- endcase -%}
    {%- endfor -%}
    {%- endpaginate -%}
  </div>
</div>
{%- endif -%}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInputs = document.querySelectorAll('#ccg-search-input, #ccg-search');
    const gallery = document.getElementById('ccg-gallery');
    const cards = Array.from(document.querySelectorAll('.ccg-card'));
    const countLabel = document.getElementById('ccg-count-label');

    if (countLabel) {
      countLabel.dataset.originalText = countLabel.textContent.trim();
    }

    function filterAndSort(e) {
      const searchTerm = e ? e.target.value.toLowerCase() : (searchInputs[0] ? searchInputs[0].value.toLowerCase() : '');

      if (e) {
        searchInputs.forEach(input => {
          if (input !== e.target) {
            input.value = e.target.value;
          }
        });
      }

      let visibleCount = 0;

      cards.forEach(card => {
        const title = card.getAttribute('data-title').toLowerCase();
        const matchesSearch = title.includes(searchTerm);
        
        if (matchesSearch) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      if (countLabel) {
        if (searchTerm) {
          const singPattern = countLabel.dataset.showingSingular || 'Showing ## collection';
          const plurPattern = countLabel.dataset.showingPlural || 'Showing ## collections';
          const pattern = visibleCount === 1 ? singPattern : plurPattern;
          countLabel.textContent = pattern.replace('##', visibleCount);
        } else {
          countLabel.textContent = countLabel.dataset.originalText;
        }
      }

      // Handle no results
      let noResults = gallery ? gallery.querySelector('.ccg-no-results') : null;
      if (visibleCount === 0) {
        if (!noResults && gallery) {
          const noResultsText = gallery.dataset.noResultsText || 'No collections found matching your selection.';
          noResults = document.createElement('div');
          noResults.className = 'ccg-no-results';
          noResults.innerHTML = `<p>${noResultsText}</p>`;
          gallery.appendChild(noResults);
        }
      } else if (noResults) {
        noResults.remove();
      }
    }

    searchInputs.forEach(input => {
      input.addEventListener('input', filterAndSort);
    });

    // === Card Spotlight Effect ===
    cards.forEach(el => {
      el.addEventListener('mousemove', (e) => {
        const rect = el.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        el.style.setProperty('--mouse-x', `${x}%`);
        el.style.setProperty('--mouse-y', `${y}%`);
      });
    });
  });
</script>

{% schema %}
{
  "name": "List Collections Content",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "standard",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "full", "label": "Full width" },
        { "value": "narrow", "label": "Narrow" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Max Width",
      "default": 1350
    },
    {
      "type": "select",
      "id": "blocks_position",
      "label": "Blocks Position",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" },
        { "value": "space-between", "label": "Space Between" }
      ]
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 28
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "inverse", "label": "Inverse" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "toolbar",
      "name": "Unified Toolbar",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "General Settings"
        },
        { "type": "select", "id": "style", "label": "Style", "default": "flat", "options": [{ "value": "flat", "label": "Flat" }, { "value": "bordered", "label": "Bordered" }, { "value": "glass", "label": "Glassmorphism" }] },
        { "type": "checkbox", "id": "show_sorting", "label": "Show sorting", "default": true },
        { "type": "checkbox", "id": "show_view_toggle", "label": "Show view toggle", "default": true },
        { "type": "checkbox", "id": "show_results_count", "label": "Show results count", "default": true },
        {
          "type": "checkbox",
          "id": "show_search",
          "label": "Show search bar",
          "default": true
        },
        { "type": "range", "id": "padding_vertical", "min": 0, "max": 40, "step": 2, "unit": "px", "label": "Vertical Padding (Inner)", "default": 12 },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "search_placeholder",
          "label": "Search Placeholder",
          "default": "Search collections..."
        },
        {
