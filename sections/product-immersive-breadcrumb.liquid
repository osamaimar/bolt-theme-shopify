{{ 'section-product-immersive.css' | asset_url | stylesheet_tag }}

{%- if section.settings.show_section -%}
{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

<style>
  div#shopify-section-{{ section.id }} { 
    padding: 0 !important; 
    margin: 0 !important;
  }
  div#shopify-section-{{ section.id }} .pdi-breadcrumb-outer {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
    {% if section.settings.bg_color != blank %}--section-bg: {{ section.settings.bg_color }};{% endif %}
    {% if section.settings.bg_gradient != blank %}--section-gradient: {{ section.settings.bg_gradient }};{% endif %}
    {% if section.settings.text_color != blank %}--section-text: {{ section.settings.text_color }};{% endif %}
  }
  #shopify-section-{{ section.id }} .pdi-breadcrumb {
    justify-content: {% if 'left' == 'center' %}center{% elsif 'left' == 'right' %}flex-end{% else %}flex-start{% endif %};
  }
  @media screen and (max-width: 768px) {
    div#shopify-section-{{ section.id }} .pdi-breadcrumb-outer {
      padding-top: {{ section.settings.padding_top_mobile }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
    }
  }
  #shopify-section-{{ section.id }} .pdi-breadcrumb a {
    {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }};{% endif %}
  }
  #shopify-section-{{ section.id }} .pdi-breadcrumb span[aria-current="page"] {
    {% if section.settings.highlight_text_color != blank %}
      color: {{ section.settings.highlight_text_color }} !important;
    {% endif %}
    {% if section.settings.highlight_text_gradient != blank %}
      background: {{ section.settings.highlight_text_gradient }};
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    {% endif %}
  }
</style>

<div class="pdi-breadcrumb-outer {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}"
     style="background: var(--section-gradient, var(--section-bg, var(--bg-primary)));">
  <div class="pdi-page {% if section.settings.container_width == 'full' %}pdi-page--full{% elsif section.settings.container_width == 'narrow' %}pdi-page--narrow{% endif %}"
       style="{% if section.settings.max_width != blank %}max-width: {{ section.settings.max_width }}px;{% endif %}">
    <nav class="pdi-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">{{ 'general.breadcrumb.home' | t }}</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <polyline points="9 18 15 12 9 6" />
      </svg>
      
      {%- if collection -%}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="9 18 15 12 9 6" />
        </svg>
      {%- else -%}
        <a href="{{ routes.all_products_collection_url }}">{{ 'general.breadcrumb.products' | t }}</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="9 18 15 12 9 6" />
        </svg>
      {%- endif -%}
      
      <span aria-current="page">{{ product.title }}</span>
    </nav>

    {%- for block in section.blocks -%}
      {%- if block.type == '@app' -%}
        <div class="pdi-breadcrumb-app-block" {{ block.shopify_attributes }}>
          {% render block %}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Immersive Breadcrumb",
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    { "type": "header", "content": "Layout" },
    
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "standard",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "narrow", "label": "Narrow" },
        { "value": "full", "label": "Full Width" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Max Width",
      "default": 1400
    },
    { "type": "header", "content": "Section Padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Top Desktop", "default": 100 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Bottom Desktop", "default": 0 },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Top Mobile", "default": 44 },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Bottom Mobile", "default": 20 },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "text_color", "label": "Text Color" },
    { "type": "color", "id": "bg_color", "label": "Background Color" },
    { "type": "color_background", "id": "bg_gradient", "label": "Background Gradient" },
    { "type": "color", "id": "highlight_text_color", "label": "Highlight Text Color" },
    { "type": "color_background", "id": "highlight_text_gradient", "label": "Highlight Text Gradient" }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ]
}
{% endschema %}

