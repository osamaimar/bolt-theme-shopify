{{ 'section-product.css' | asset_url | stylesheet_tag }}

{%- if section.settings.show_section -%}
{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}

<style>
  #shopify-section-{{ section.id }} { padding: 0 !important; }
  #shopify-section-{{ section.id }} .pd-main-outer {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .pd-main-outer {
      padding-top: {{ section.settings.padding_top_mobile }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
    }
  }

  {%- for block in section.blocks -%}
    {%- if block.type != '@app' -%}
      #block-{{ block.id }} {
        margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
        margin-bottom: {{ block.settings.margin_bottom | default: 0 }}px !important;
        {% if block.settings.text_color != blank %}--block-text-color: {{ block.settings.text_color }};{% endif %}
        {% if block.settings.bg_color != blank %}--block-bg: {{ block.settings.bg_color }};{% endif %}
        {% if block.settings.bg_gradient != blank %}--block-gradient: {{ block.settings.bg_gradient }};{% endif %}
      }
      #block-{{ block.id }} {
        color: var(--block-text-color, inherit) !important;
        {% if block.type != 'price' and block.type != 'highlights' and block.type != 'rating' %}
          background: var(--block-gradient, var(--block-bg, transparent)) !important;
        {% endif %}
      }
      @media screen and (max-width: 768px) {
        #block-{{ block.id }} {
          margin-top: {{ block.settings.margin_top_mobile | default: 0 }}px !important;
          margin-bottom: {{ block.settings.margin_bottom_mobile | default: 0 }}px !important;
        }
      }
    {%- endif -%}
  {%- endfor -%}
</style>

<div class="pd-main-outer color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}">
  <div class="pd-page {% if section.settings.container_width == 'full' %}pd-page--full{% elsif section.settings.container_width == 'narrow' %}pd-page--narrow{% endif %}">
    <div class="pd-product-main">
      
      <!-- Gallery Column -->
      <div class="pd-gallery">
        <div class="pd-gallery-main" id="pd-gallery-main-{{ section.id }}">
          <button class="pd-gallery-nav pd-gallery-prev" id="pd-gallery-prev-{{ section.id }}" aria-label="Previous media">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button class="pd-gallery-nav pd-gallery-next" id="pd-gallery-next-{{ section.id }}" aria-label="Next media">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
          
          {%- assign featured_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media -%}
          <div class="pd-gallery-viewer" id="pd-gallery-viewer-{{ section.id }}">
            {%- if featured_media -%}
              {%- for media in product.media -%}
                <div class="pd-media-item {% if media == featured_media %}active{% endif %}" data-media-id="{{ media.id }}" data-media-type="{{ media.media_type }}">
                  {%- case media.media_type -%}
                    {%- when 'image' -%}
                      <img src="{{ media | image_url: width: 1200 }}" alt="{{ media.alt | escape }}" width="{{ media.width }}" height="{{ media.height }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" />
                    {%- when 'external_video' -%}
                      <div class="pd-external-video-wrapper">
                        {{ media | external_video_tag: class: 'pd-video-external' }}
                      </div>
                    {%- when 'video' -%}
                      {{ media | video_tag: controls: true, class: 'pd-video-native' }}
                    {%- when 'model' -%}
                      {{ media | model_viewer_tag: interaction_prompt: 'always', class: 'pd-model-viewer' }}
                  {%- endcase -%}
                </div>
              {%- endfor -%}
            {%- else -%}
              <div class="pd-media-item active">
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>
        </div>
        <div class="pd-gallery-thumbs-wrapper">
          <button class="pd-thumb-nav pd-thumb-prev" id="pd-thumb-prev-{{ section.id }}" aria-label="Previous thumbnails">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          
          <div class="pd-gallery-thumbs" id="pd-gallery-thumbs-{{ section.id }}">
            <div class="pd-thumbs-track">
              {%- for media in product.media -%}
                <div class="pd-gallery-thumb {% if media == featured_media %}active{% endif %}" data-index="{{ forloop.index0 }}" data-media-id="{{ media.id }}">
                  <img src="{{ media | image_url: width: 150, height: 150, crop: 'center' }}" alt="{{ media.alt | escape }}" loading="lazy" width="150" height="150" />
                  {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                    <div class="pd-thumb-icon">
                      <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                    </div>
                  {%- elsif media.media_type == 'model' -%}
                    <div class="pd-thumb-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="21 8 21 16 12 21 3 16 3 8 12 3 21 8"/><polyline points="3 8 12 13 21 8"/><line x1="12" y1="13" x2="12" y2="21"/></svg>
                    </div>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          </div>

          <button class="pd-thumb-nav pd-thumb-next" id="pd-thumb-next-{{ section.id }}" aria-label="Next thumbnails">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>

      <!-- Info Column -->
      <div class="pd-info" style="text-align: {{ 'left' }};">
        {%- for block in section.blocks -%}
          <div class="pd-info-block-wrapper {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" id="block-{{ block.id }}" {{ block.shopify_attributes }}>
            {%- case block.type -%}
              {%- when 'title' -%}
                <h1 class="pd-title pd-title--{{ block.settings.font_size }}" style="text-align: {{ 'left' }}; margin: 0; font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }};">
                  {%- if block.settings.highlight_first_word or block.settings.highlight_last_word -%}
                    {%- assign words = product.title | split: ' ' -%}
                    {%- for word in words -%}
                      {%- assign should_highlight = false -%}
                      {%- if forloop.first and block.settings.highlight_first_word -%}
                        {%- assign should_highlight = true -%}
                      {%- elsif forloop.last and block.settings.highlight_last_word -%}
                        {%- assign should_highlight = true -%}
                      {%- endif -%}

                      {%- if should_highlight -%}
                        <span style="
                          {%- if block.settings.highlight_gradient != blank -%}
                            background: {{ block.settings.highlight_gradient }};
                            -webkit-background-clip: text;
                            -webkit-text-fill-color: transparent;
                            background-clip: text;
                          {%- elsif block.settings.highlight_color != blank -%}
                            color: {{ block.settings.highlight_color }} !important;
                            background: none !important;
                            -webkit-text-fill-color: {{ block.settings.highlight_color }} !important;
                          {%- endif -%}">{{ word }}</span>
                      {%- else -%}
                        {{ word }}
                      {%- endif -%}
                      {% unless forloop.last %} {% endunless %}
                    {%- endfor -%}
                  {%- else -%}
                    {{ product.title }}
                  {%- endif -%}
                </h1>

              {%- when 'rating' -%}
                {%- assign rating_value = product.metafields.reviews.rating.value | default: block.settings.rating_value -%}
                {%- assign review_count = product.metafields.reviews.rating_count | default: block.settings.review_count -%}
                <div class="pd-rating-row" style="justify-content: {% if 'left' == 'center' %}center{% elsif 'left' == 'right' %}flex-end{% else %}flex-start{% endif %};">
                  <div class="pd-stars" id="pd-stars-{{ section.id }}">
                    {%- assign stars_active = rating_value | floor -%}
                    {%- for i in (1..5) -%}
                      <svg viewBox="0 0 24 24" class="{% if i > stars_active %}empty{% endif %}" style="{% if i <= stars_active and block.settings.star_color != blank %}fill: {{ block.settings.star_color }} !important; color: {{ block.settings.star_color }} !important;{% endif %}"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    {%- endfor -%}
                    <span class="pd-rating-value pd-rating-value--{{ block.settings.font_size }}" style="font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; {% if block.settings.rating_value_color != blank %}color: {{ block.settings.rating_value_color }} !important;{% endif %}">{{ rating_value }}</span>
                  </div>
                  <span class="pd-review-count"><a href="#pd-tab-reviews" class="pd-review-count--{{ block.settings.font_size }}" style="font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; {% if block.settings.review_count_color != blank %}color: {{ block.settings.review_count_color }} !important;{% endif %}">{{ review_count }} {{ 'products.product.reviews' | t }}</a></span>
                </div>

              {%- when 'price' -%}
                <div class="pd-price-block" style="justify-content: {% if 'left' == 'center' %}center{% elsif 'left' == 'right' %}flex-end{% else %}flex-start{% endif %}; background: var(--block-gradient, var(--block-bg, var(--bg-glass))); border: {% if block.settings.bg_color != blank or block.settings.bg_gradient != blank %}none{% else %}1px solid var(--border-light){% endif %};">
                  <span class="pd-price pd-price--{{ block.settings.font_size }}" style="font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; color: var(--block-text-color, var(--color-accent-secondary));">
                  {{ product.price | money_without_trailing_zeros }}</span>
                  {%- if product.compare_at_price > product.price -%}
                    <span class="pd-old-price" style="font-size: calc({{ block.settings.font_size }}rem * 0.7);">{{ product.compare_at_price | money_without_trailing_zeros }}</span>
                    {%- if block.settings.show_savings -%}
                      {%- assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
                      <span class="pd-discount-label">-{{ savings }}% {{ 'products.product.off' | t }}</span>
                    {%- endif -%}
                  {%- endif -%}
                </div>

              {%- when 'description' -%}
                <div class="pd-short-desc pd-short-desc--{{ block.settings.font_size }}" style="text-align: {{ 'left' }}; font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; {% if block.settings.text_color != blank %}color: {{ block.settings.text_color }} !important;{% endif %}">
                  {{ product.description | strip_html | truncatewords: block.settings.word_count }}
                </div>

              {%- when 'highlights' -%}
                <div class="pd-highlights pd-highlights--{{ block.settings.columns }}" style="justify-content: {% if 'left' == 'center' %}center{% elsif 'left' == 'right' %}flex-end{% else %}flex-start{% endif %};">
                  {%- for i in (1..4) -%}
                    {%- capture icon_select_id -%}h{{ i }}_icon_select{%- endcapture -%}
                    {%- capture icon_custom_id -%}h{{ i }}_icon_custom{%- endcapture -%}
                    {%- capture text_id -%}h{{ i }}_text{%- endcapture -%}
                    
                    {%- if block.settings[text_id] != blank -%}
                      <div class="pd-highlight-item pd-highlight-item--{{ block.settings.font_size }}" style="font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; {% if block.settings.bg_color != blank %}background: {{ block.settings.bg_color }} !important; padding: 10px 16px; border-radius: 50px;{% endif %}">
                        {%- if block.settings.show_icons -%}
                        <div class="pd-highlight-icon" style="{% if block.settings.icon_color != blank %}color: {{ block.settings.icon_color }} !important; fill: {{ block.settings.icon_color }} !important;{% endif %} {% if block.settings.icon_bg_color != blank %}background: {{ block.settings.icon_bg_color }} !important;{% endif %}">
                          {%- case block.settings[icon_select_id] -%}
                            {%- when 'check' -%}
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                            {%- when 'shield' -%}
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            {%- when 'battery' -%}
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="6" width="18" height="12" rx="2" ry="2"/><line x1="23" y1="13" x2="23" y2="11"/></svg>
                            {%- when 'headphones' -%}
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
                            {%- when 'star' -%}
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            {%- when 'truck' -%}
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                            {%- when 'zap' -%}
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                            {%- when 'heart' -%}
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                            {%- when 'custom' -%}
                              {{ block.settings[icon_custom_id] }}
                          {%- endcase -%}
                        </div>
                        {%- endif -%}
                        <span class="pd-highlight-text" style="{% if block.settings.text_color != blank %}color: {{ block.settings.text_color }} !important;{% endif %}">{{ block.settings[text_id] }}</span>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>

              {%- when 'buy_buttons' -%}
                {%- assign product_form_id = 'product-form-' | append: section.id -%}
                {%- form 'product', product, class: 'product-form pd-main-product-form', id: product_form_id -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  <input type="hidden" name="quantity" class="pd-qty-hidden" value="1">

                  <div class="pd-actions-row">
                    {%- if block.settings.show_qty -%}
                    <div class="pd-qty-selector" style="{% if block.settings.qty_bg_color != blank %}background: {{ block.settings.qty_bg_color }} !important; border-color: {{ block.settings.qty_bg_color }} !important;{% endif %} {% if block.settings.qty_text_color != blank %}color: {{ block.settings.qty_text_color }} !important;{% endif %}">
                      <button type="button" class="pd-qty-btn" id="pd-qty-minus" aria-label="Decrease quantity" style="color: inherit;">−</button>
                      <span class="pd-qty-value" id="pd-qty-value" style="color: inherit;">1</span>
                      <button type="button" class="pd-qty-btn" id="pd-qty-plus" aria-label="Increase quantity" style="color: inherit;">+</button>
                    </div>
                    {%- endif -%}

                    <button type="submit" class="pd-add-cart-btn" id="pd-add-cart" style="font-size: {{ block.settings.font_size }}rem; {% if block.settings.atc_bg_color != blank %}background: {{ block.settings.atc_bg_color }} !important; border-color: {{ block.settings.atc_bg_color }} !important;{% endif %} {% if block.settings.atc_text_color != blank %}color: {{ block.settings.atc_text_color }} !important;{% endif %}">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                      {%- if block.settings.button_label == blank or block.settings.button_label == 'Add to Cart' -%}
                        {%- assign button_label_val = 'products.product.add_to_cart' | t -%}
                      {%- else -%}
                        {%- assign button_label_val = block.settings.button_label -%}
                      {%- endif -%}
                      <span>{{ button_label_val }}</span>
                    </button>
                  </div>

                  {%- if block.settings.show_accelerated_checkout -%}
                    <div class="pd-accelerated-checkout">
                      {{ form | payment_button }}
                    </div>
                  {%- endif -%}
                {%- endform -%}

              {%- when 'pickup_availability' -%}
                {% render 'pickup-availability',
                  product: product,
                  block: block,
                  section: section
                %}

              {%- when 'variants' -%}
                <div class="pd-variants" id="block-{{ block.id }}" 
                     data-gallery-sync="{{ block.settings.enable_gallery_sync }}" 
                     data-sold-out-handling="{{ block.settings.sold_out_handling }}"
                     style="
                       {% if block.settings.btn_bg_color != blank %}--btn-bg: {{ block.settings.btn_bg_color }};{% endif %}
                       {% if block.settings.btn_text_color != blank %}--btn-text: {{ block.settings.btn_text_color }};{% endif %}
                       {% if block.settings.btn_border_color != blank %}--btn-border: {{ block.settings.btn_border_color }};{% endif %}
                       {% if block.settings.btn_hover_bg_color != blank %}--btn-hover-bg: {{ block.settings.btn_hover_bg_color }};{% endif %}
                       {% if block.settings.btn_hover_text_color != blank %}--btn-hover-text: {{ block.settings.btn_hover_text_color }};{% endif %}
                       {% if block.settings.btn_hover_border_color != blank %}--btn-hover-border: {{ block.settings.btn_hover_border_color }};{% endif %}
                       {% if block.settings.active_bg_color != blank %}--active-bg: {{ block.settings.active_bg_color }};{% endif %}
                       {% if block.settings.active_text_color != blank %}--active-text: {{ block.settings.active_text_color }};{% endif %}
                       {% if block.settings.active_border_color != blank %}--active-border: {{ block.settings.active_border_color }};{% endif %}
                       {% if block.settings.swatch_border_color != blank %}--swatch-border: {{ block.settings.swatch_border_color }};{% endif %}
                       {% if block.settings.swatch_hover_border_color != blank %}--swatch-hover-border: {{ block.settings.swatch_hover_border_color }};{% endif %}
                       {% if block.settings.swatch_active_border_color != blank %}--swatch-active-border: {{ block.settings.swatch_active_border_color }};{% endif %}
                       {% if block.settings.label_color != blank %}--label-color: {{ block.settings.label_color }};{% endif %}
                       {% if block.settings.selected_value_color != blank %}--selected-val-color: {{ block.settings.selected_value_color }};{% endif %}
                     "
                     {{ block.shopify_attributes }}>
                  {%- for option in product.options_with_values -%}
                    {%- assign is_color = false -%}
                    {%- assign downcased_name = option.name | downcase -%}
                    {%- if downcased_name contains 'color' or downcased_name contains 'colour' -%}
                      {%- assign is_color = true -%}
                    {%- endif -%}
                    
                    <div class="pd-variant-group" data-option-name="{{ option.name | escape }}">
                      {%- if block.settings.show_label -%}
                        <div class="pd-variant-label">
                          <span class="pd-variant-option-name">{{ option.name }}:</span>
                          <span class="pd-variant-selected-val" data-option-index="{{ forloop.index0 }}">
                            {{ product.selected_or_first_available_variant.options[forloop.index0] }}
                          </span>
                        </div>
                      {%- endif -%}
                      
                      <div class="pd-variant-options {% if block.settings.sold_out_handling == 'hide' %}sold-out-hide{% endif %}" data-option-index="{{ forloop.index0 }}">
                        {%- for value in option.values -%}
                          {%- assign option_active = false -%}
                          {%- if product.selected_or_first_available_variant.options[forloop.parentloop.index0] == value -%}
                            {%- assign option_active = true -%}
                          {%- endif -%}
                          
                          {%- if is_color and block.settings.color_style == 'swatches' -%}
                            {%- assign color_name = value | downcase | strip -%}
                            {%- assign swatch_color = color_name -%}
                            {%- if color_name == 'rose gold' -%}{%- assign swatch_color = '#e0a899' -%}
                            {%- elsif color_name == 'gold' -%}{%- assign swatch_color = '#e5c158' -%}
                            {%- elsif color_name == 'matte black' -%}{%- assign swatch_color = '#1c1c1c' -%}
                            {%- elsif color_name == 'space gray' or color_name == 'space grey' -%}{%- assign swatch_color = '#555559' -%}
                            {%- elsif color_name == 'midnight' -%}{%- assign swatch_color = '#1a1f2c' -%}
                            {%- elsif color_name == 'silver' -%}{%- assign swatch_color = '#d1d1d6' -%}
                            {%- elsif color_name == 'white' -%}{%- assign swatch_color = '#ffffff' -%}
                            {%- elsif color_name == 'cream' or color_name == 'off white' -%}{%- assign swatch_color = '#faf6ee' -%}
                            {%- elsif color_name == 'charcoal' -%}{%- assign swatch_color = '#36454f' -%}
                            {%- elsif color_name == 'navy' or color_name == 'navy blue' -%}{%- assign swatch_color = '#1b263b' -%}
                            {%- elsif color_name == 'olive' or color_name == 'forest green' -%}{%- assign swatch_color = '#2e3d30' -%}
                            {%- elsif color_name == 'burgundy' -%}{%- assign swatch_color = '#800020' -%}
                            {%- elsif color_name == 'starlight' -%}{%- assign swatch_color = '#f0eae0' -%}
                            {%- elsif color_name == 'graphite' -%}{%- assign swatch_color = '#4b4c4d' -%}
                            {%- elsif color_name == 'titanium' -%}{%- assign swatch_color = '#8a8b8c' -%}
                            {%- endif -%}
                            <button
                              type="button"
                              class="pd-variant-swatch {% if option_active %}active{% endif %}"
                              data-value="{{ value | escape }}"
                              data-option-index="{{ forloop.parentloop.index0 }}"
                              style="background-color: {{ swatch_color }};"
                              aria-label="{{ value | escape }}"
                              title="{{ value | escape }}"
                            ></button>
                          {%- else -%}
                            <button
                              type="button"
                              class="pd-variant-btn {% if option_active %}active{% endif %}"
                              data-value="{{ value | escape }}"
                              data-option-index="{{ forloop.parentloop.index0 }}"
                            >{{ value }}</button>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    </div>
                  {%- endfor -%}
                  <input type="hidden" name="id" class="pd-variant-id-input" value="{{ product.selected_or_first_available_variant.id }}">
                </div>

              {%- when 'divider' -%}
                <div class="pd-divider {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                     style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px; 
                            {% if block.settings.border_color != blank %}background-color: {{ block.settings.border_color }} !important;{% endif %} 
                            height: {{ block.settings.thickness }}px !important; 
                            max-width: {{ block.settings.max_width }}px; 
                            margin-left: {% if 'left' == 'center' %}auto{% elsif 'left' == 'right' %}auto{% else %}0{% endif %}; 
                            margin-right: {% if 'left' == 'center' %}auto{% elsif 'left' == 'left' %}auto{% else %}0{% endif %};"
                     {{ block.shopify_attributes }}></div>

              {%- when '@app' -%}
                {% render block %}

            {%- endcase -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>
{%- endif -%}

<script>
