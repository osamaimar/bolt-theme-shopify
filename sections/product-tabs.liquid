        { "type": "text", "id": "spec_2_label", "label": "Spec 2 Label", "default": "Frequency Resp." },
        { "type": "text", "id": "spec_2_value", "label": "Spec 2 Value", "default": "20Hz - 40kHz (Hi-Res)" },
        { "type": "text", "id": "spec_3_label", "label": "Spec 3 Label", "default": "Battery Life" },
        { "type": "text", "id": "spec_3_value", "label": "Spec 3 Value", "default": "Up to 40 Hours" },
        { "type": "text", "id": "spec_4_label", "label": "Spec 4 Label", "default": "Charging Port" },
        { "type": "text", "id": "spec_4_value", "label": "Spec 4 Value", "default": "USB-C" },
        { "type": "text", "id": "spec_5_label", "label": "Spec 5 Label", "default": "Bluetooth" },
        { "type": "text", "id": "spec_5_value", "label": "Spec 5 Value", "default": "V5.2" },
        { "type": "text", "id": "spec_6_label", "label": "Spec 6 Label", "default": "Warranty" },
        { "type": "text", "id": "spec_6_value", "label": "Spec 6 Value", "default": "2-Year Manufacturer" },
        { "type": "header", "content": "Visibility" },
        { "type": "checkbox", "id": "show_on_desktop", "label": "Show on Desktop", "default": true },
        { "type": "checkbox", "id": "show_on_mobile", "label": "Show on Mobile", "default": true },
        { "type": "header", "content": "Margin" },
        { "type": "range", "id": "margin_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Margin Top", "default": 0 },
        { "type": "range", "id": "margin_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Margin Bottom", "default": 0 },
