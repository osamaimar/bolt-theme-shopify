{%- if section.settings.show_section -%}
{%- unless search.performed -%}
{{ 'section-search.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} {
    padding: 0 !important;
  }
  #shopify-section-{{ section.id }} .search-empty-state-outer {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
    display: flow-root !important;
  }
  {%- unless section.settings.show_on_desktop -%}
    @media screen and (min-width: 769px) {
      #shopify-section-{{ section.id }} .search-empty-state-outer {
        display: none !important;
      }
    }
  {%- endunless -%}
  {%- unless section.settings.show_on_mobile -%}
    @media screen and (max-width: 768px) {
      #shopify-section-{{ section.id }} .search-empty-state-outer {
        display: none !important;
      }
    }
  {%- endunless -%}
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .search-empty-state-outer {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Section container layout */
  #shopify-section-{{ section.id }} .search-container {
    {% if section.settings.container_width == 'narrow' %}
      max-width: 800px !important;
    {% elsif section.settings.container_width == 'standard' %}
      max-width: {{ section.settings.max_width }}px !important;
    {% elsif section.settings.container_width == 'full' %}
      max-width: 100% !important;
      padding-left: 5% !important;
      padding-right: 5% !important;
    {% endif %}
    margin: 0 auto !important;
  }

  #shopify-section-{{ section.id }} .search-empty-state {
    display: flex;
    flex-direction: column;
    align-items: {% if section.settings.blocks_position == 'left' %}flex-start{% elsif section.settings.blocks_position == 'right' %}flex-end{% else %}center{% endif %} !important;
    text-align: {% if section.settings.blocks_position == 'left' %}left{% elsif section.settings.blocks_position == 'right' %}right{% else %}center{% endif %} !important;
  }
  
  #shopify-section-{{ section.id }} .search-empty-state-inner {
    display: flex;
    flex-direction: column;
    align-items: {% if section.settings.blocks_position == 'left' %}flex-start{% elsif section.settings.blocks_position == 'right' %}flex-end{% else %}center{% endif %} !important;
    width: 100% !important;
  }

  /* Block Spacing overrides */
  #shopify-section-{{ section.id }} .empty-state-block {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 0px) !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .empty-state-block {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 0px)) !important;
    }
  }

  /* Typography size definitions */
  #shopify-section-{{ section.id }} .search-empty-title.size-small { font-size: 20px; }
  #shopify-section-{{ section.id }} .search-empty-title.size-medium { font-size: 28px; }
  #shopify-section-{{ section.id }} .search-empty-title.size-large { font-size: 36px; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .search-empty-title.size-small { font-size: 16px; }
    #shopify-section-{{ section.id }} .search-empty-title.size-medium { font-size: 22px; }
    #shopify-section-{{ section.id }} .search-empty-title.size-large { font-size: 28px; }
  }

  /* Heading Highlight styling */
  #shopify-section-{{ section.id }} .search-empty-title span {
    background: var(--highlight-gradient, var(--color-accent)) !important;
    -webkit-background-clip: var(--highlight-clip, text) !important;
    background-clip: var(--highlight-clip, text) !important;
    -webkit-text-fill-color: var(--highlight-fill, transparent) !important;
    display: inline-block;
    color: var(--highlight-color, inherit) !important;
  }

  #shopify-section-{{ section.id }} .search-empty-text.size-small { font-size: 13px; }
  #shopify-section-{{ section.id }} .search-empty-text.size-medium { font-size: 15px; }
  #shopify-section-{{ section.id }} .search-empty-text.size-large { font-size: 18px; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .search-empty-text.size-small { font-size: 12px; }
    #shopify-section-{{ section.id }} .search-empty-text.size-medium { font-size: 14px; }
    #shopify-section-{{ section.id }} .search-empty-text.size-large { font-size: 16px; }
  }
  {%- for block in section.blocks -%}
    {%- unless block.settings.show_on_desktop -%}
      @media screen and (min-width: 769px) {
        #shopify-section-{{ section.id }} #block-{{ block.id }} {
          display: none !important;
        }
      }
    {%- endunless -%}
    {%- unless block.settings.show_on_mobile -%}
      @media screen and (max-width: 768px) {
        #shopify-section-{{ section.id }} #block-{{ block.id }} {
          display: none !important;
        }
      }
    {%- endunless -%}
  {%- endfor -%}
</style>



<div class="search-empty-state-outer color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}">
  <div class="search-container {% if section.settings.container_width == 'full' %}search-container--full{% endif %}">
    <div class="search-empty-state">
      <div class="search-empty-state-inner">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'icon' -%}
              <div class="search-empty-icon empty-state-block {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                   id="block-{{ block.id }}"
                   {{ block.shopify_attributes }}
                   style="
                     --m-t: {{ block.settings.margin_top }}px; 
                     --m-b: {{ block.settings.margin_bottom }}px; 
                     --m-t-m: {{ block.settings.margin_top_mobile }}px; 
                     --m-b-m: {{ block.settings.margin_bottom_mobile }}px;
                     {% if block.settings.icon_color != blank %}color: {{ block.settings.icon_color }} !important;{% endif %}
                     {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background-color: {{ block.settings.bg_color }} !important;{% endif %}
                   ">
                {%- if block.settings.icon != blank -%}
                  {%- if block.settings.icon == 'search-plus' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width: {{ block.settings.icon_size }}px; height: {{ block.settings.icon_size }}px;">
                      <circle cx="11" cy="11" r="8"></circle>
                      <path d="m21 21-4.3-4.3"></path>
                      <line x1="11" y1="8" x2="11" y2="14"></line>
                      <line x1="8" y1="11" x2="14" y2="11"></line>
                    </svg>
                  {%- elsif block.settings.icon == 'search' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width: {{ block.settings.icon_size }}px; height: {{ block.settings.icon_size }}px;">
                      <circle cx="11" cy="11" r="8"></circle>
                      <path d="m21 21-4.3-4.3"></path>
                    </svg>
                  {%- elsif block.settings.icon == 'box' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width: {{ block.settings.icon_size }}px; height: {{ block.settings.icon_size }}px;">
                      <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                      <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                      <line x1="12" y1="22.08" x2="12" y2="12"></line>
                    </svg>
                  {%- endif -%}
                {%- elsif block.settings.custom_icon_svg != blank -%}
                  <div class="custom-icon-wrapper" style="width: {{ block.settings.icon_size }}px; height: {{ block.settings.icon_size }}px; display: inline-flex; align-items: center; justify-content: center;">
                    {{ block.settings.custom_icon_svg }}
                  </div>
                {%- endif -%}
              </div>

            {%- when 'heading' -%}
              {%- assign heading_tag = block.settings.heading_tag | default: 'h3' -%}
              {%- assign h_color = block.settings.highlight_color -%}
              {%- assign h_gradient = block.settings.highlight_gradient -%}
              <{{ heading_tag }} class="search-empty-title empty-state-block size-{{ block.settings.font_size }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                   id="block-{{ block.id }}"
                   {{ block.shopify_attributes }}
                   style="
                     --m-t: {{ block.settings.margin_top }}px; 
                     --m-b: {{ block.settings.margin_bottom }}px; 
                     --m-t-m: {{ block.settings.margin_top_mobile }}px; 
                     --m-b-m: {{ block.settings.margin_bottom_mobile }}px; 
                     font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; 
                     font-style: {{ block.settings.font_style }}; 
                     text-transform: {{ block.settings.text_transform }}; 
                     letter-spacing: {{ block.settings.letter_spacing }}px; 
                     line-height: {{ block.settings.line_height }}; 
                     text-align: {{ 'center' }};
                     {% if block.settings.text_color != blank %}color: {{ block.settings.text_color }} !important;{% endif %} 
                     {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background-color: {{ block.settings.bg_color }} !important;{% endif %}
                     {% if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' %}--highlight-gradient: {{ h_gradient }}; --highlight-clip: text; --highlight-fill: transparent; --highlight-color: transparent;
                     {% elsif h_color != blank and h_color != 'rgba(0,0,0,0)' %}--highlight-color: {{ h_color }}; --highlight-gradient: none; --highlight-clip: initial; --highlight-fill: {{ h_color }};
                     {% endif %}
                   ">
                {{ block.settings.heading | replace: '[', '<span>' | replace: ']', '</span>' }}
              </{{ heading_tag }}>

            {%- when 'text' -%}
              {%- if block.settings.text != blank -%}
                {%- assign text_tag = block.settings.text_tag | default: 'p' -%}
                <{{ text_tag }} class="search-empty-text empty-state-block size-{{ block.settings.font_size }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                     id="block-{{ block.id }}"
                     {{ block.shopify_attributes }}
                     style="
                       --m-t: {{ block.settings.margin_top }}px; 
                       --m-b: {{ block.settings.margin_bottom }}px; 
                       --m-t-m: {{ block.settings.margin_top_mobile }}px; 
                       --m-b-m: {{ block.settings.margin_bottom_mobile }}px; 
                       width: 100% !important; max-width: {{ block.settings.max_width }}px !important;
                       margin-left: {% if section.settings.blocks_position == 'left' %}0{% elsif section.settings.blocks_position == 'right' %}auto{% else %}auto{% endif %} !important;
                       margin-right: {% if section.settings.blocks_position == 'right' %}0{% elsif section.settings.blocks_position == 'left' %}auto{% else %}auto{% endif %} !important;
                       text-align: {{ 'center' }};
                       font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; 
                       font-style: {{ block.settings.font_style }}; 
                       text-transform: {{ block.settings.text_transform }}; 
                       letter-spacing: {{ block.settings.letter_spacing }}px; 
                       line-height: {{ block.settings.line_height }}; 
                       {% if block.settings.text_color != blank %}color: {{ block.settings.text_color }} !important;{% endif %} 
                       {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background-color: {{ block.settings.bg_color }} !important;{% endif %}
                     ">
                  {{ block.settings.text }}
                </{{ text_tag }}>
              {%- endif -%}
          {%- endcase -%}
        {%- endfor -%}
        </div>
    </div>
  </div>
</div>
{%- endunless -%}
{%- endif -%}

{% schema %}
{
  "name": "Search Empty State",
  "tag": "section",
  "class": "section-search-empty-state",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
