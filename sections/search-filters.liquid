{%- if section.settings.show_section -%}
{{ 'section-search.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} {
    padding: 0 !important;
  }
  #shopify-section-{{ section.id }} .search-filters-outer {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
    display: flow-root !important;
  }
  {%- unless section.settings.show_on_desktop -%}
    @media screen and (min-width: 769px) {
      #shopify-section-{{ section.id }} .search-filters-outer {
        display: none !important;
      }
    }
  {%- endunless -%}
  {%- unless section.settings.show_on_mobile -%}
    @media screen and (max-width: 768px) {
      #shopify-section-{{ section.id }} .search-filters-outer {
        display: none !important;
      }
    }
  {%- endunless -%}
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .search-filters-outer {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Scoped max-width for the section container */
  #shopify-section-{{ section.id }} .search-container {
    {% if section.settings.container_width == 'narrow' %}
      max-width: 800px !important;
    {% elsif section.settings.container_width == 'standard' %}
      max-width: {{ section.settings.max_width }}px !important;
    {% elsif section.settings.container_width == 'full' %}
      max-width: 100% !important;
      padding-left: 5% !important;
      padding-right: 5% !important;
    {% endif %}
    margin: 0 auto !important;
  }

  /* Scoped Category Chip style overrides */
  {%- for block in section.blocks -%}
    {%- if block.type == 'category_chip' -%}
      #shopify-section-{{ section.id }} #chip-{{ block.id }} {
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        vertical-align: middle !important;
        overflow: visible !important;
        margin-top: {{ block.settings.margin_top }}px !important;
        margin-bottom: {{ block.settings.margin_bottom }}px !important;
        font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
        font-style: {{ block.settings.font_style }};
        text-transform: {{ block.settings.text_transform }};
        letter-spacing: {{ block.settings.letter_spacing }}px;
        line-height: {{ block.settings.line_height }}%;
        {% if block.settings.text_color != blank %}
          color: {{ block.settings.text_color }} !important;
        {% endif %}
        {% if block.settings.bg_gradient != blank %}
          background: {{ block.settings.bg_gradient }} !important;
        {% elsif block.settings.bg_color != blank %}
          background-color: {{ block.settings.bg_color }} !important;
          background-image: none !important;
        {% endif %}
        {% if block.settings.border_color != blank %}
          border: 1px solid {{ block.settings.border_color }} !important;
        {% endif %}
      }

      @media screen and (max-width: 768px) {
        #shopify-section-{{ section.id }} #chip-{{ block.id }} {
          margin-top: {{ block.settings.margin_top_mobile }}px !important;
          margin-bottom: {{ block.settings.margin_bottom_mobile }}px !important;
        }
      }

      /* Hover States */
      #shopify-section-{{ section.id }} #chip-{{ block.id }}:hover {
        {% if block.settings.hover_text_color != blank %}
          color: {{ block.settings.hover_text_color }} !important;
        {% endif %}
        {% if block.settings.hover_bg_gradient != blank %}
          background: {{ block.settings.hover_bg_gradient }} !important;
        {% elsif block.settings.hover_bg_color != blank %}
          background-color: {{ block.settings.hover_bg_color }} !important;
          background-image: none !important;
        {% endif %}
        {% if block.settings.hover_border_color != blank %}
          border: 1px solid {{ block.settings.hover_border_color }} !important;
        {% endif %}
      }

      /* Active States */
      #shopify-section-{{ section.id }} #chip-{{ block.id }}.active {
        {% if block.settings.active_text_color != blank %}
          color: {{ block.settings.active_text_color }} !important;
        {% endif %}
        {% if block.settings.active_bg_gradient != blank %}
          background: {{ block.settings.active_bg_gradient }} !important;
        {% elsif block.settings.active_bg_color != blank %}
          background-color: {{ block.settings.active_bg_color }} !important;
          background-image: none !important;
        {% endif %}
        {% if block.settings.active_border_color != blank %}
          border: 1px solid {{ block.settings.active_border_color }} !important;
          box-shadow: 0 0 0 1px {{ block.settings.active_border_color }} !important;
        {% endif %}
      }
    {%- endif -%}
  {%- endfor -%}

  {%- for block in section.blocks -%}
    {%- unless block.settings.show_on_desktop -%}
      @media screen and (min-width: 769px) {
        #shopify-section-{{ section.id }} #chip-{{ block.id }} {
          display: none !important;
        }
      }
    {%- endunless -%}
    {%- unless block.settings.show_on_mobile -%}
      @media screen and (max-width: 768px) {
        #shopify-section-{{ section.id }} #chip-{{ block.id }} {
          display: none !important;
        }
      }
    {%- endunless -%}
  {%- endfor -%}

  /* Font sizes categories */
  #shopify-section-{{ section.id }} .filter-chip.size-small { font-size: 12px; padding: 6px 14px; }
  #shopify-section-{{ section.id }} .filter-chip.size-medium { font-size: 14px; padding: 8px 18px; }
  #shopify-section-{{ section.id }} .filter-chip.size-large { font-size: 16px; padding: 10px 22px; }
</style>

<div class="search-filters-outer color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}">
  <div class="search-container {% if section.settings.container_width == 'full' %}search-container--full{% endif %}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
    <div class="search-filters-content">
      {%- liquid
        assign justify_content = 'center'
        if section.settings.blocks_position == 'left'
          assign justify_content = 'flex-start'
        elsif section.settings.blocks_position == 'right'
          assign justify_content = 'flex-end'
        endif
        assign search_terms_down = search.terms | remove: '*' | downcase
      -%}
      {%- if section.settings.show_heading and section.settings.heading != blank -%}
        <h2 class="filters-heading text-{{ section.settings.blocks_position | default: 'center' }}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}
      <div class="search-filters" id="search-filters" data-source="{{ section.settings.filter_source }}" style="justify-content: {{ justify_content }};">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- liquid
              assign chip_category_down = block.settings.category | downcase
              assign is_active = false
              if search_terms_down == chip_category_down
                assign is_active = true
              endif
            -%}
            <button id="chip-{{ block.id }}" class="filter-chip {% if is_active %}active{% endif %} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %} size-{{ block.settings.font_size }}" 
                    data-category="{{ block.settings.category | escape }}"
                    {{ block.shopify_attributes }}>
              {{ block.settings.label }}
            </button>
          {%- endfor -%}
        {%- else -%}
          {%- liquid
            assign search_terms_down = search.terms | remove: '*' | downcase
            
            # Check for active Shopify filters
            assign active_filters = ""
            for filter in search.filters
              for value in filter.active_values
                assign val_down = value.label | downcase
                assign active_filters = active_filters | append: val_down | append: ","
              endfor
            endfor

            # Collect unique options from search results based on source
            assign options_all = ""
            for item in search.results
              if item.object_type == 'product' and item.available
                if section.settings.filter_source == 'product_type'
                  assign val = item.type | strip
                  unless options_all contains val or val == blank
                    assign options_all = options_all | append: val | append: ","
                  endunless
                else
                  for tag in item.tags
                    assign tag_strip = tag | strip
                    unless options_all contains tag_strip or tag_strip == blank
                      assign options_all = options_all | append: tag_strip | append: ","
                    endunless
                  endfor
                endif
              endif
            endfor
            assign option_list = options_all | split: "," | sort
            
            # Determine active state
            assign any_active = false
            for opt in option_list
              assign opt_down = opt | downcase
              if active_filters contains opt_down or search_terms_down contains opt_down
                assign any_active = true
                break
              endif
            endfor
          -%}

          <button class="filter-chip {% if any_active == false %}active{% endif %}" data-category="all">
            {{ 'general.search.all' | t | default: 'All Products' }}
          </button>

          {%- for opt in option_list -%}
            {%- liquid
              assign opt_down = opt | downcase
              assign is_active = false
              if active_filters contains opt_down or search_terms_down contains opt_down
                assign is_active = true
              endif
            -%}
            <button class="filter-chip {% if is_active %}active{% endif %}" data-category="{{ opt | escape }}">
              {{ opt }}
            </button>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Search Filters",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": false
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "select",
      "id": "filter_source",
      "label": "Filter source",
      "default": "product_type",
      "options": [
        { "value": "product_type", "label": "Product Type" },
        { "value": "product_tag", "label": "Product Tags" }
      ]
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Browse by Category"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "blocks_position",
      "label": "Blocks Position",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "standard",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "narrow", "label": "Narrow" },
        { "value": "full", "label": "Full Width" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Max Width",
      "default": 1350
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1",
      "options": [
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "inverse", "label": "Inverse" }
      ]
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding (Mobile)",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "category_chip",
      "name": "Filter Chip",
      "settings": [
        {
          "type": "header",
          "content": "General Settings"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Value"
        },
        {
          "type": "header",
          "content": "Visibility"
        },
        {
          "type": "checkbox",
          "id": "show_on_desktop",
          "label": "Show on Desktop",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_on_mobile",
          "label": "Show on Mobile",
          "default": true
        },
        {
          "type": "header",
          "content": "Layout & Spacing"
        },
        {
          "type": "range",
          "id": "margin_top",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "Margin Top (Desktop)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "Margin Bottom (Desktop)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_top_mobile",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "Margin Top (Mobile)",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom_mobile",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "Margin Bottom (Mobile)",
          "default": 0
        },
        {
          "type": "header",
          "content": "Typography"
        },
        {
          "type": "select",
          "id": "font_size",
          "label": "Font Size",
          "default": "medium",
          "options": [
            { "value": "small", "label": "Small" },
            { "value": "medium", "label": "Medium" },
            { "value": "large", "label": "Large" }
          ]
        },
        {
          "type": "select",
          "id": "font_weight",
          "label": "Font Weight",
          "default": "normal",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "bold", "label": "Bold" }
          ]
        },
        {
          "type": "select",
          "id": "font_style",
          "label": "Font Style",
          "default": "normal",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "italic", "label": "Italic" }
          ]
        },
        {
          "type": "select",
          "id": "text_transform",
          "label": "Text Transform",
          "default": "none",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "uppercase", "label": "Uppercase" },
            { "value": "lowercase", "label": "Lowercase" },
            { "value": "capitalize", "label": "Capitalize" }
          ]
        },
        {
          "type": "range",
          "id": "letter_spacing",
          "min": 0,
          "max": 10,
          "step": 1,
          "unit": "px",
          "label": "Letter Spacing",
          "default": 0
        },
        {
          "type": "range",
          "id": "line_height",
          "min": 100,
          "max": 200,
          "step": 5,
          "unit": "%",
          "label": "Line Height",
          "default": 120
        },
        {
          "type": "header",
          "content": "Colors (Normal)"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color"
        },
        {
          "type": "color_background",
          "id": "bg_gradient",
          "label": "Background Gradient"
        },
        {
          "type": "color",
          "id": "border_color",
          "label": "Border Color"
        },
        {
          "type": "header",
          "content": "Colors (Hover)"
        },
        {
          "type": "color",
          "id": "hover_text_color",
          "label": "Hover Text Color"
        },
        {
          "type": "color",
          "id": "hover_bg_color",
          "label": "Hover Background Color"
        },
        {
          "type": "color_background",
          "id": "hover_bg_gradient",
          "label": "Hover Background Gradient"
        },
        {
          "type": "color",
          "id": "hover_border_color",
          "label": "Hover Border Color"
        },
        {
          "type": "header",
          "content": "Colors (Active)"
        },
        {
          "type": "color",
          "id": "active_text_color",
          "label": "Active Text Color"
        },
        {
          "type": "color",
          "id": "active_bg_color",
          "label": "Active Background Color"
        },
        {
          "type": "color_background",
          "id": "active_bg_gradient",
          "label": "Active Background Gradient"
        },
        {
          "type": "color",
          "id": "active_border_color",
          "label": "Active Border Color"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Search Filters"
    }
  ]
}
{% endschema %}
