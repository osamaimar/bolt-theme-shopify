{{ 'section-search.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} {
    padding: 0 !important;
  }
  #shopify-section-{{ section.id }} .search-header-outer {
    padding-top: calc({{ section.settings.padding_top }}px + 100px) !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
    display: flow-root !important;
  }
  {%- unless section.settings.show_on_desktop -%}
    @media screen and (min-width: 769px) {
      #shopify-section-{{ section.id }} .search-header-outer {
        display: none !important;
      }
    }
  {%- endunless -%}
  {%- unless section.settings.show_on_mobile -%}
    @media screen and (max-width: 768px) {
      #shopify-section-{{ section.id }} .search-header-outer {
        display: none !important;
      }
    }
  {%- endunless -%}
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .search-header-outer {
      padding-top: calc({{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px + 80px) !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Scoped layout max width */
  #shopify-section-{{ section.id }} .search-container {
    {% if section.settings.container_width == 'narrow' %}
      max-width: 800px !important;
    {% elsif section.settings.container_width == 'standard' %}
      max-width: {{ section.settings.max_width }}px !important;
    {% elsif section.settings.container_width == 'full' %}
      max-width: 100% !important;
      padding-left: 5% !important;
      padding-right: 5% !important;
    {% endif %}
    margin: 0 auto !important;
  }

  /* Scoped layout alignment for blocks_position */
  #shopify-section-{{ section.id }} .cpd-header {
    display: flex;
    flex-direction: column;
    align-items: {% if section.settings.blocks_position == 'left' %}flex-start{% elsif section.settings.blocks_position == 'right' %}flex-end{% else %}center{% endif %} !important;
    text-align: {% if section.settings.blocks_position == 'left' %}left{% elsif section.settings.blocks_position == 'right' %}right{% else %}center{% endif %} !important;
  }

  /* Standard Block Spacing overrides */
  #shopify-section-{{ section.id }} .catalog-header-block {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 0px) !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .catalog-header-block {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 0px)) !important;
    }
  }

  /* Responsive Font Sizing for Heading */
  #shopify-section-{{ section.id }} .catalog-title.size-small { font-size: 32px; }
  #shopify-section-{{ section.id }} .catalog-title.size-medium { font-size: 48px; }
  #shopify-section-{{ section.id }} .catalog-title.size-large { font-size: 64px; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .catalog-title.size-small { font-size: 24px; }
    #shopify-section-{{ section.id }} .catalog-title.size-medium { font-size: 32px; }
    #shopify-section-{{ section.id }} .catalog-title.size-large { font-size: 40px; }
  }

  /* Heading Highlight styling */
  #shopify-section-{{ section.id }} .catalog-title span {
    background: var(--highlight-gradient, var(--color-accent)) !important;
    -webkit-background-clip: var(--highlight-clip, text) !important;
    background-clip: var(--highlight-clip, text) !important;
    -webkit-text-fill-color: var(--highlight-fill, transparent) !important;
    display: inline-block;
    color: var(--highlight-color, inherit) !important;
  }

  /* Responsive Font Sizing for Subheading */
  #shopify-section-{{ section.id }} .cpd-header-desc.size-small { font-size: 14px; }
  #shopify-section-{{ section.id }} .cpd-header-desc.size-medium { font-size: 18px; }
  #shopify-section-{{ section.id }} .cpd-header-desc.size-large { font-size: 22px; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .cpd-header-desc.size-small { font-size: 12px; }
    #shopify-section-{{ section.id }} .cpd-header-desc.size-medium { font-size: 15px; }
    #shopify-section-{{ section.id }} .cpd-header-desc.size-large { font-size: 18px; }
  }
  {%- for block in section.blocks -%}
    {%- unless block.settings.show_on_desktop -%}
      @media screen and (min-width: 769px) {
        #shopify-section-{{ section.id }} #block-{{ block.id }} {
          display: none !important;
        }
      }
    {%- endunless -%}
    {%- unless block.settings.show_on_mobile -%}
      @media screen and (max-width: 768px) {
        #shopify-section-{{ section.id }} #block-{{ block.id }} {
          display: none !important;
        }
      }
    {%- endunless -%}
  {%- endfor -%}
</style>

{%- if section.settings.show_section -%}
<div class="search-header-outer color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}">
  <div class="search-container {% if section.settings.container_width == 'full' %}search-container--full{% elsif section.settings.container_width == 'narrow' %}search-container--narrow{% endif %}">
    <div class="cpd-header">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            {%- assign heading_tag = block.settings.heading_tag | default: 'h1' -%}
            {%- assign h_color = block.settings.highlight_color -%}
            {%- assign h_gradient = block.settings.highlight_gradient -%}
            <{{ heading_tag }} class="catalog-title main-title catalog-header-block size-{{ block.settings.font_size }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                id="block-{{ block.id }}"
                {{ block.shopify_attributes }} 
                style="
                  --m-t: {{ block.settings.margin_top }}px; 
                  --m-b: {{ block.settings.margin_bottom }}px; 
                  --m-t-m: {{ block.settings.margin_top_mobile }}px; 
                  --m-b-m: {{ block.settings.margin_bottom_mobile }}px; 
                  font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; 
                  font-style: {{ block.settings.font_style }}; 
                  text-transform: {{ block.settings.text_transform }}; 
                  letter-spacing: {{ block.settings.letter_spacing }}px; 
                  line-height: {{ block.settings.line_height }}; 
                  text-align: {{ 'center' }};
                  {% if block.settings.text_color != blank %}color: {{ block.settings.text_color }} !important;{% endif %} 
                  {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background-color: {{ block.settings.bg_color }} !important;{% endif %}
                  {% if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' %}--highlight-gradient: {{ h_gradient }}; --highlight-clip: text; --highlight-fill: transparent; --highlight-color: transparent;
                  {% elsif h_color != blank and h_color != 'rgba(0,0,0,0)' %}--highlight-color: {{ h_color }}; --highlight-gradient: none; --highlight-clip: initial; --highlight-fill: {{ h_color }};
                  {% endif %}
                ">
              {{ block.settings.heading | replace: '[', '<span>' | replace: ']', '</span>' }}
            </{{ heading_tag }}>

          {%- when 'subheading' -%}
            {%- if block.settings.subheading != blank -%}
              {%- assign subheading_tag = block.settings.subheading_tag | default: 'p' -%}
              <{{ subheading_tag }} class="cpd-header-desc page-intro-text catalog-header-block size-{{ block.settings.font_size }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                 id="block-{{ block.id }}"
                 {{ block.shopify_attributes }} 
                 style="
                   --m-t: {{ block.settings.margin_top }}px; 
                   --m-b: {{ block.settings.margin_bottom }}px; 
                   --m-t-m: {{ block.settings.margin_top_mobile }}px; 
                   --m-b-m: {{ block.settings.margin_bottom_mobile }}px; 
                   width: 100% !important; max-width: {{ block.settings.max_width }}px !important;
                   margin-left: {% if section.settings.blocks_position == 'left' %}0{% elsif section.settings.blocks_position == 'right' %}auto{% else %}auto{% endif %};
                   margin-right: {% if section.settings.blocks_position == 'right' %}0{% elsif section.settings.blocks_position == 'left' %}auto{% else %}auto{% endif %};
                   text-align: {{ 'center' }};
                   font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; 
                   font-style: {{ block.settings.font_style }}; 
                   text-transform: {{ block.settings.text_transform }}; 
                   letter-spacing: {{ block.settings.letter_spacing }}px; 
                   line-height: {{ block.settings.line_height }}; 
                   {% if block.settings.text_color != blank %}color: {{ block.settings.text_color }} !important;{% endif %} 
                   {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background-color: {{ block.settings.bg_color }} !important;{% endif %}
                 ">
                {{ block.settings.subheading }}
              </{{ subheading_tag }}>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>
{%- endif -%}

