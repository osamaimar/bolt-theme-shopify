{{ 'section-search.css' | asset_url | stylesheet_tag }}
{{ 'component-product-card.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} {
    padding: 0 !important;
  }
  #shopify-section-{{ section.id }} .search-main-outer {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
    display: flow-root !important;
  }
  {%- unless section.settings.show_on_desktop -%}
    @media screen and (min-width: 769px) {
      #shopify-section-{{ section.id }} .search-main-outer {
        display: none !important;
      }
    }
  {%- endunless -%}
  {%- unless section.settings.show_on_mobile -%}
    @media screen and (max-width: 768px) {
      #shopify-section-{{ section.id }} .search-main-outer {
        display: none !important;
      }
    }
  {%- endunless -%}
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .search-main-outer {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Scoped layout max width */
  #shopify-section-{{ section.id }} .search-container {
    {% if section.settings.container_width == 'narrow' %}
      max-width: 800px !important;
    {% elsif section.settings.container_width == 'standard' %}
      max-width: {{ section.settings.max_width }}px !important;
    {% elsif section.settings.container_width == 'full' %}
      max-width: 100% !important;
      padding-left: 5% !important;
      padding-right: 5% !important;
    {% endif %}
    margin: 0 auto !important;
  }

  /* Scoped Block Spacing overrides */
  #shopify-section-{{ section.id }} .search-main-block {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 0px) !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .search-main-block {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 0px)) !important;
    }
  }

  /* Scoped Style Overrides for Block-specific items */
  {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'results_meta'
        assign b_align_alignment = 'space-between'
      when 'no_results'
        assign b_align_alignment = 'center'
  endcase
-%}
    {%- case block.type -%}
      {%- when 'results_meta' -%}
        {% if block.settings.count_text_color != blank %}
          #shopify-section-{{ section.id }} #block-{{ block.id }} .search-result-count {
            color: {{ block.settings.count_text_color }} !important;
          }
        {% endif %}
        {% if block.settings.count_highlight_color != blank %}
          #shopify-section-{{ section.id }} #block-{{ block.id }} .search-result-count strong {
            color: {{ block.settings.count_highlight_color }} !important;
          }
        {% endif %}
        {% if block.settings.sort_label_color != blank %}
          #shopify-section-{{ section.id }} #block-{{ block.id }} .search-sort label {
            color: {{ block.settings.sort_label_color }} !important;
          }
        {% endif %}
        #shopify-section-{{ section.id }} #block-{{ block.id }} {
          display: flex !important;
          align-items: center !important;
          justify-content: {{ b_align_alignment | default: 'space-between' }} !important;
          padding-top: {{ block.settings.vertical_padding | default: 12 }}px !important;
          padding-bottom: {{ block.settings.vertical_padding | default: 12 }}px !important;
          padding-left: {% if block.settings.style == 'flat' or block.settings.style == blank %}0{% else %}16{% endif %}px !important;
          padding-right: {% if block.settings.style == 'flat' or block.settings.style == blank %}0{% else %}16{% endif %}px !important;
          
          {% if block.settings.style == 'bordered' %}
            border: 1px solid var(--border-light) !important;
            border-radius: 12px !important;
            background: transparent !important;
          {% elsif block.settings.style == 'glass' %}
            background: var(--bg-glass) !important;
            backdrop-filter: blur(8px) !important;
            -webkit-backdrop-filter: blur(8px) !important;
            border: 1px solid var(--border-light) !important;
            border-radius: 12px !important;
          {% else %}
            {% if block.settings.bg_gradient != blank %}
              background: {{ block.settings.bg_gradient }} !important;
            {% elsif block.settings.bg_color != blank %}
              background-color: {{ block.settings.bg_color }} !important;
            {% endif %}
          {% endif %}
        }
        @media screen and (max-width: 768px) {
          #shopify-section-{{ section.id }} #block-{{ block.id }} {
            justify-content: {{ 'space-between' | default: b_align_alignment | default: 'space-between' }} !important;
          }
        }
        
        /* Dropdown overrides */
        #shopify-section-{{ section.id }} #block-{{ block.id }} .ccg-dropdown-list {
          {% if block.settings.dropdown_bg_gradient != blank %}
            background: {{ block.settings.dropdown_bg_gradient }} !important;
          {% elsif block.settings.dropdown_bg_color != blank %}
            background-color: {{ block.settings.dropdown_bg_color }} !important;
          {% endif %}
          {% if block.settings.dropdown_border_color != blank %}
            border-color: {{ block.settings.dropdown_border_color }} !important;
          {% endif %}
          {% if block.settings.dropdown_shadow_color != blank %}
            box-shadow: 0 10px 30px {{ block.settings.dropdown_shadow_color }} !important;
          {% endif %}
        }
        #shopify-section-{{ section.id }} #block-{{ block.id }} .ccg-dropdown-trigger {
          {% if block.settings.dropdown_text_color != blank %}
            color: {{ block.settings.dropdown_text_color }} !important;
          {% endif %}
          {% if block.settings.dropdown_border_color != blank %}
            border-color: {{ block.settings.dropdown_border_color }} !important;
          {% endif %}
          {% if block.settings.dropdown_bg_gradient != blank %}
            background: {{ block.settings.dropdown_bg_gradient }} !important;
          {% elsif block.settings.dropdown_bg_color != blank %}
            background-color: {{ block.settings.dropdown_bg_color }} !important;
          {% endif %}
        }
        #shopify-section-{{ section.id }} #block-{{ block.id }} .ccg-dropdown-option {
          {% if block.settings.dropdown_text_color != blank %}
            color: {{ block.settings.dropdown_text_color }} !important;
          {% endif %}
          transition: all 0.2s ease;
        }
        #shopify-section-{{ section.id }} #block-{{ block.id }} .ccg-dropdown-option:hover {
          {% if block.settings.dropdown_hover_text_color != blank %}
            color: {{ block.settings.dropdown_hover_text_color }} !important;
          {% endif %}
          {% if block.settings.dropdown_hover_bg_color != blank %}
            background-color: {{ block.settings.dropdown_hover_bg_color }} !important;
          {% endif %}
        }
        #shopify-section-{{ section.id }} #block-{{ block.id }} .ccg-dropdown-option.active {
          {% if block.settings.dropdown_active_text_color != blank %}
            color: {{ block.settings.dropdown_active_text_color }} !important;
          {% endif %}
          {% if block.settings.dropdown_active_bg_color != blank %}
            background-color: {{ block.settings.dropdown_active_bg_color }} !important;
          {% endif %}
        }

      {%- when 'results_grid' -%}
        /* Card Background and Colors */
        #shopify-section-{{ section.id }} #block-{{ block.id }} .cpd-product-card {
          {% if block.settings.bg_gradient != blank %}
            background: {{ block.settings.bg_gradient }} !important;
          {% elsif block.settings.bg_color != blank %}
            background-color: {{ block.settings.bg_color }} !important;
          {% endif %}
        }
        #shopify-section-{{ section.id }} #block-{{ block.id }} .cpd-product-name a {
          {% if block.settings.title_color != blank %}
            color: {{ block.settings.title_color }} !important;
          {% endif %}
        }
        #shopify-section-{{ section.id }} #block-{{ block.id }} .cpd-product-price {
          {% if block.settings.price_color != blank %}
            color: {{ block.settings.price_color }} !important;
          {% endif %}
        }
        #shopify-section-{{ section.id }} #block-{{ block.id }} .cpd-product-price s {
          {% if block.settings.compare_price_color != blank %}
            color: {{ block.settings.compare_price_color }} !important;
          {% endif %}
        }
        #shopify-section-{{ section.id }} #block-{{ block.id }} .cpd-product-footer {
          {% if block.settings.divider_color != blank %}
            border-top-color: {{ block.settings.divider_color }} !important;
          {% endif %}
        }
        #shopify-section-{{ section.id }} #block-{{ block.id }} .caption-with-letter-spacing {
          {% if block.settings.vendor_color != blank %}
            color: {{ block.settings.vendor_color }} !important;
          {% endif %}
        }
        #shopify-section-{{ section.id }} #block-{{ block.id }} .cpd-product-desc {
          {% if block.settings.desc_color != blank %}
            color: {{ block.settings.desc_color }} !important;
          {% endif %}
        }
        #shopify-section-{{ section.id }} #block-{{ block.id }} .cpd-product-grid {
          {% if block.settings.grid_gap != blank %}
            gap: {{ block.settings.grid_gap }}px !important;
          {% endif %}
        }


        
        /* CTA Button overrides */
        #shopify-section-{{ section.id }} #block-{{ block.id }} .cpd-product-cta {
          transition: all 0.3s ease;
          {% if block.settings.btn_text_color != blank %}
            color: {{ block.settings.btn_text_color }} !important;
          {% endif %}
          {% if block.settings.btn_bg_gradient != blank %}
            background: {{ block.settings.btn_bg_gradient }} !important;
          {% elsif block.settings.btn_bg_color != blank %}
            background: {{ block.settings.btn_bg_color }} !important;
            background-color: {{ block.settings.btn_bg_color }} !important;
          {% endif %}
          {% if block.settings.btn_border_color != blank %}
            border: 1px solid {{ block.settings.btn_border_color }} !important;
          {% else %}
            border: none !important;
          {% endif %}
        }
        #shopify-section-{{ section.id }} #block-{{ block.id }} .cpd-product-cta:hover {
          {% if block.settings.btn_hover_text_color != blank %}
            color: {{ block.settings.btn_hover_text_color }} !important;
          {% endif %}
          {% if block.settings.btn_hover_bg_gradient != blank %}
            background: {{ block.settings.btn_hover_bg_gradient }} !important;
          {% elsif block.settings.btn_hover_bg_color != blank %}
            background: {{ block.settings.btn_hover_bg_color }} !important;
            background-color: {{ block.settings.btn_hover_bg_color }} !important;
            background-image: none !important;
          {% endif %}
          {% if block.settings.btn_hover_border_color != blank %}
            border: 1px solid {{ block.settings.btn_hover_border_color }} !important;
          {% endif %}
        }

      {%- when 'no_results' -%}
        #shopify-section-{{ section.id }} #block-{{ block.id }} {
          {% if block.settings.text_color != blank %}
            color: {{ block.settings.text_color }} !important;
          {% endif %}
          {% if block.settings.bg_gradient != blank %}
            background: {{ block.settings.bg_gradient }} !important;
          {% elsif block.settings.bg_color != blank %}
            background-color: {{ block.settings.bg_color }} !important;
          {% endif %}
        }
        #shopify-section-{{ section.id }} #block-{{ block.id }} p {
          font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
          font-style: {{ block.settings.font_style }};
        }
        #shopify-section-{{ section.id }} #block-{{ block.id }}.size-small p { font-size: 13px; }
        #shopify-section-{{ section.id }} #block-{{ block.id }}.size-medium p { font-size: 15px; }
        #shopify-section-{{ section.id }} #block-{{ block.id }}.size-large p { font-size: 18px; }

    {%- endcase -%}
  {%- endfor -%}

  {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'results_meta'
        assign b_align_alignment = 'space-between'
      when 'no_results'
        assign b_align_alignment = 'center'
  endcase
-%}
    {%- unless block.settings.show_on_desktop -%}
      @media screen and (min-width: 769px) {
        #shopify-section-{{ section.id }} #block-{{ block.id }} {
          display: none !important;
        }
      }
    {%- endunless -%}
    {%- unless block.settings.show_on_mobile -%}
      @media screen and (max-width: 768px) {
        #shopify-section-{{ section.id }} #block-{{ block.id }} {
          display: none !important;
        }
      }
    {%- endunless -%}
  {%- endfor -%}
</style>

{%- paginate search.results by section.settings.results_per_page -%}
{%- if section.settings.show_section -%}
{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
-%}
<div class="search-main-outer color-{{ section.settings.color_scheme }} {% if section.settings.show_divider %}section--has-divider{% endif %} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}">
  <div class="search-container {% if section.settings.container_width == 'full' %}search-container--full{% endif %}">
    
    <div id="search-main-content">
      {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'results_meta'
        assign b_align_alignment = 'space-between'
      when 'no_results'
        assign b_align_alignment = 'center'
  endcase
-%}
        {%- case block.type -%}
          {%- when 'results_meta' -%}
            <div class="search-meta visible search-main-block {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                 id="block-{{ block.id }}" 
                 style="
                   --m-t: {{ block.settings.margin_top }}px; 
                   --m-b: {{ block.settings.margin_bottom }}px; 
                   --m-t-m: {{ block.settings.margin_top_mobile }}px; 
                   --m-b-m: {{ block.settings.margin_bottom_mobile }}px;
                 " 
                 {{ block.shopify_attributes }}>
              {%- if block.settings.show_count -%}
                <span class="search-result-count" id="search-result-count">
                  {%- if search.performed -%}
                    {%- if search.results_count == 0 -%}
                      {%- assign display_terms = search.terms | remove: '*' -%}
                      {{ 'general.search.no_results' | t: terms: display_terms }}
                    {%- else -%}
                      {%- if block.settings.show_search_term and search.terms != blank -%}
                        <strong>{{ search.results_count }}</strong> {{ 'general.search.results_count' | t }} for "{{ search.terms | remove: '*' | escape }}"
                      {%- else -%}
                        <strong>{{ search.results_count }}</strong> {{ 'general.search.results_count' | t }}
                      {%- endif -%}
                    {%- endif -%}
                  {%- else -%}
                    <strong>0</strong> {{ 'general.search.results_count' | t }}
                  {%- endif -%}
                </span>
              {%- endif -%}
              
              <div class="search-meta-actions" style="display: flex; align-items: center; gap: 16px;">
                {%- if block.settings.show_sort -%}
                  <div class="search-sort">
                    {%- if block.settings.show_sort_label -%}
                      <label for="sort-select">{{ 'collections.sort_by' | t }}</label>
                    {%- endif -%}
                    <div class="ccg-dropdown-box" id="search-sort-dropdown">
                      <button class="ccg-dropdown-trigger" aria-haspopup="listbox" aria-expanded="false">
                        {%- assign current_sort = search.sort_options | where: "value", search.sort_by | first -%}
                        {%- if current_sort == nil -%}
                          {%- assign current_sort = search.sort_options | where: "value", search.default_sort_by | first -%}
                        {%- endif -%}
                        <span class="ccg-dropdown-label">{{ current_sort.name | default: 'Relevance' }}</span>
                        {%- if block.settings.show_dropdown_arrow -%}
                          <svg class="ccg-dropdown-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="6 9 12 15 18 9" />
                          </svg>
                        {%- endif -%}
                      </button>
                      <div class="ccg-dropdown-list" role="listbox">
                        {%- for option in search.sort_options -%}
                          <div class="ccg-dropdown-option{% if option.value == search.sort_by %} active{% endif %}" 
                            role="option" 
                            data-value="{{ request.path }}?q={{ search.terms | escape }}&sort_by={{ option.value }}">
                            {{ option.name }}
                          </div>
                        {%- endfor -%}
                      </div>
                    </div>
                  </div>
                {%- endif -%}

                {%- if block.settings.show_filter_popup -%}
                  {{ 'component-faceted-filter-popup.css' | asset_url | stylesheet_tag }}
                  <script src="{{ 'component-faceted-filter-popup.js' | asset_url }}" defer></script>
                  <style>
                    {%- if block.settings.filter_btn_bg_color != blank -%}
                      #block-{{ block.id }} .ffp-trigger-btn {
                        background-color: {{ block.settings.filter_btn_bg_color }} !important;
                      }
                    {%- endif -%}
                    {%- if block.settings.filter_btn_text_color != blank -%}
                      #block-{{ block.id }} .ffp-trigger-btn {
                        color: {{ block.settings.filter_btn_text_color }} !important;
                      }
                      #block-{{ block.id }} .ffp-trigger-btn svg {
                        color: {{ block.settings.filter_btn_text_color }} !important;
                      }
                    {%- endif -%}
                    {%- if block.settings.filter_btn_border_color != blank -%}
                      #block-{{ block.id }} .ffp-trigger-btn {
                        border-color: {{ block.settings.filter_btn_border_color }} !important;
                      }
                    {%- endif -%}
                  </style>
                  {% render 'faceted-filter-popup', 
                    filter_context: 'search', 
                    show_filter_label: block.settings.show_filter_label,
                    show_filter_icon: block.settings.show_filter_icon
                  %}
                {%- endif -%}
              </div>
            </div>

          {%- when 'results_grid' -%}
            {%- if search.performed -%}
              <div id="block-{{ block.id }}" class="search-results-grid search-main-block {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                   style="
                     --m-t: {{ block.settings.margin_top }}px; 
                     --m-b: {{ block.settings.margin_bottom }}px; 
                     --m-t-m: {{ block.settings.margin_top_mobile }}px; 
                     --m-b-m: {{ block.settings.margin_bottom_mobile }}px;
                   "
                   {{ block.shopify_attributes }}>
                {%- if search.results_count > 0 -%}
                  <div class="cpd-product-grid" style="--columns-desktop: {{ block.settings.columns_desktop }}; --columns-tablet: {{ block.settings.columns_tablet }}; --columns-mobile: {{ block.settings.columns_mobile }};">
                    {%- for item in search.results -%}
                      {%- if item.object_type == 'product' -%}
                        {% render 'product-card', 
                          product_card_product: item, 
                          image_ratio: block.settings.image_ratio,
                          show_category: block.settings.show_category,
                          show_vendor: block.settings.show_vendor,
                          show_price: block.settings.show_price,
                          show_compare_price: block.settings.show_compare_price,
                          show_reviews: block.settings.show_rating,
                          show_rating_count: block.settings.show_rating_count,
                          rating_value: block.settings.rating_value,
                          rating_count: block.settings.rating_count,
                          show_quick_view: block.settings.show_quick_view,
                          show_add_to_cart: block.settings.show_add_to_cart,
                          show_description: block.settings.show_description,
                          show_line_divider: block.settings.show_divider,
                          show_badges: block.settings.show_badges,
                          show_cta_in_footer: block.settings.show_view_details,
                          view_details_label: block.settings.view_details_label
                        %}
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                  
                  {%- if section.settings.show_pagination and paginate.pages > 1 -%}
                    {% render 'pagination', paginate: paginate %}
                  {%- endif -%}
                {%- endif -%}
              </div>
            {%- endif -%}

          {%- when 'no_results' -%}
            {%- if search.performed and search.results_count == 0 -%}
              <div class="search-no-results search-main-block size-{{ block.settings.font_size }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                   id="block-{{ block.id }}"
                   style="
                     text-align: {{ b_align_alignment | default: section.settings.blocks_position | default: 'center' }};
                     --m-t: {{ block.settings.margin_top }}px; 
                     --m-b: {{ block.settings.margin_bottom }}px; 
                     --m-t-m: {{ block.settings.margin_top_mobile }}px; 
                     --m-b-m: {{ block.settings.margin_bottom_mobile }}px;
                   " 
                   {{ block.shopify_attributes }}>
                {%- assign default_help_text = 'general.search.no_results_help' | t -%}
                <p>{{ block.settings.help_text | default: default_help_text }}</p>
              </div>
            {%- endif -%}



        {%- endcase -%}
      {%- endfor -%}
    </div>

  </div>
</div>
{%- endif -%}
{%- endpaginate -%}

{% schema %}
{
  "name": "Search Main Content",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show separator line",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "standard",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "narrow", "label": "Narrow" },
        { "value": "full", "label": "Full Width" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Max Width",
      "default": 1350
    },
    {
      "type": "select",
      "id": "blocks_position",
      "label": "Blocks Position",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "range",
      "id": "results_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "label": "Results per page",
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show pagination",
      "default": true
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1",
      "options": [
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "inverse", "label": "Inverse" }
      ]
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
