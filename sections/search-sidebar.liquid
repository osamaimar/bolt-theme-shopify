{{ 'section-search-sidebar.css' | asset_url | stylesheet_tag }}
{{ 'component-product-card.css' | asset_url | stylesheet_tag }}

<script src="{{ 'section-search-sidebar.js' | asset_url }}" defer="defer"></script>



{%- paginate search.results by section.settings.results_per_page -%}
<div class="search-main-sidebar-outer color-{{ section.settings.color_scheme }}" id="shopify-section-{{ section.id }}">
{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile,
  padding_left: section.settings.padding_left,
  padding_right: section.settings.padding_right,
  padding_left_mobile: section.settings.padding_left_mobile,
  padding_right_mobile: section.settings.padding_right_mobile
%}
  <div class="search-container {% if section.settings.container_width == 'full' %}search-container--full{% endif %}">
    
    <div class="search-content-wrapper">
      <!-- Sidebar -->
      <aside class="search-sidebar {% unless section.settings.show_sidebar_border %}search-sidebar--no-border{% endunless %}">
        {%- if section.settings.sidebar_title != blank -%}
          <h2 class="search-sidebar-title" style="text-align: {{ 'left' }};">{{ section.settings.sidebar_title }}</h2>
        {%- endif -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            
            {%- when 'filter_category' -%}
              <div class="filter-group" {{ block.shopify_attributes }}>
                <h3 class="filter-group-title">{{ block.settings.title }}</h3>
                <div class="checkbox-list">
                  {%- liquid
                    assign source = block.settings.source
                    assign options = ""
                    
                    # 1. Try Shopify's native filters (Standard way)
                    for filter in search.filters
                      if filter.param_name contains source or filter.label contains block.settings.title
                        for value in filter.values
                          assign options = options | append: value.label | append: ","
                        endfor
                      endif
                    endfor

                    # 2. Fallback to store-wide lists to prevent disappearing options
                    if options == ""
                      if source == 'product_type'
                        for type in shop.types
                          assign options = options | append: type | append: ","
                        endfor
                      else
                        # For tags, we use a broad set from the 'all' collection
                        for tag in collections.all.all_tags
                          assign options = options | append: tag | append: ","
                        endfor
                      endif
                    endif
                    
                    assign option_array = options | split: "," | uniq | sort
                  -%}
                  {%- for opt in option_array -%}
                    {%- if opt != blank -%}
                      {%- liquid
                        assign is_checked = false
                        # Check if the exact type/tag filter is in the URL terms
                        assign search_term_check = source | append: ':"' | append: opt | append: '"'
                        assign search_term_check_no_quotes = source | append: ':' | append: opt
                        if search.terms contains search_term_check or search.terms contains search_term_check_no_quotes
                          assign is_checked = true
                        endif
                      -%}
                      <label class="checkbox-item">
                        <input type="checkbox" name="filter.p.{{ source }}" value="{{ opt | escape }}" 
                          {% if is_checked %}checked{% endif %}
                          class="sidebar-filter-input"
                          data-type="{{ source }}"
                        >
                        <span>{{ opt }}</span>
                      </label>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>

            {%- when 'filter_price' -%}
              <div class="filter-group" {{ block.shopify_attributes }}>
                <h3 class="filter-group-title">{{ block.settings.title }}</h3>
                <div class="price-inputs">
                  {%- assign price_filter = search.filters | where: 'type', 'price_range' | first -%}
                  <input type="number" id="price-min" placeholder="min" value="{{ price_filter.min_value.value | money_without_currency | replace: ',', '' }}" />
                  <span class="price-separator">-</span>
                  <input type="number" id="price-max" placeholder="max" value="{{ price_filter.max_value.value | money_without_currency | replace: ',', '' }}" />
                </div>
                <div class="price-range-label">{{ block.settings.range_text | default: '$10 - $2,500' }}</div>
              </div>

            {%- when 'filter_brand' -%}
              <div class="filter-group" {{ block.shopify_attributes }}>
                <h3 class="filter-group-title">{{ block.settings.title }}</h3>
                <div class="checkbox-list">
                  {%- liquid
                    assign brands = ""
                    # 1. Try Shopify's native filters
                    for filter in search.filters
                      if filter.param_name contains 'vendor' or filter.label contains 'Brand' or filter.label contains 'Vendor'
                        for value in filter.values
                          assign brands = brands | append: value.label | append: ","
                        endfor
                      endif
                    endfor

                    # 2. Fallback to store-wide vendors list
                    if brands == ""
                      for vendor in shop.vendors
                        assign brands = brands | append: vendor | append: ","
                      endfor
                    endif
                    
                    assign brand_array = brands | split: "," | uniq | sort
                  -%}
                  {%- for brand in brand_array -%}
                    {%- if brand != blank -%}
                      {%- liquid
                        assign is_checked = false
                        assign vendor_check = 'vendor:"' | append: brand | append: '"'
                        assign vendor_check_no_quotes = 'vendor:' | append: brand
                        if search.terms contains vendor_check or search.terms contains vendor_check_no_quotes
                          assign is_checked = true
                        endif
                      -%}
                      <label class="checkbox-item">
                        <input type="checkbox" name="filter.p.vendor" value="{{ brand | escape }}"
                          {% if is_checked %}checked{% endif %}
                          class="sidebar-filter-input"
                          data-type="vendor"
                        >
                        <span>{{ brand }}</span>
                      </label>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>

          {%- endcase -%}
        {%- endfor -%}
      </aside>

      <!-- Product Grid Area -->
      <div class="search-results-area">
        {%- for block in section.blocks -%}
          {%- if block.type == 'results_meta' -%}
            <div class="search-meta visible" style="justify-content: {{ 'space-between' }}; margin-bottom: 24px;" {{ block.shopify_attributes }}>
              {%- if block.settings.show_count -%}
                <span class="search-result-count">
                  {%- if search.performed -%}
                    <strong>{{ search.results_count }}</strong> {{ 'general.search.results_count' | t }}
                  {%- endif -%}
                </span>
              {%- endif -%}
              
              {%- if block.settings.show_sort -%}
                <div class="search-sort">
                  <label for="sort-select">{{ 'collections.sort_by' | t }}</label>
                  <div class="ccg-dropdown-box" id="search-sort-dropdown">
                    <button class="ccg-dropdown-trigger" aria-haspopup="listbox" aria-expanded="false">
                      {%- assign current_sort = search.sort_options | where: "value", search.sort_by | first -%}
                      {%- if current_sort == nil -%}
                        {%- assign current_sort = search.sort_options | where: "value", search.default_sort_by | first -%}
                      {%- endif -%}
                      <span class="ccg-dropdown-label">{{ current_sort.name | default: 'Relevance' }}</span>
                      <svg class="ccg-dropdown-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="6 9 12 15 18 9" />
                      </svg>
                    </button>
                    <div class="ccg-dropdown-list" role="listbox">
                      {%- for option in search.sort_options -%}
                        <div class="ccg-dropdown-option{% if option.value == search.sort_by %} active{% endif %}" 
                          role="option" 
                          data-value="{{ request.path }}?q={{ search.terms | escape }}&sort_by={{ option.value }}">
                          {{ option.name }}
                        </div>
                      {%- endfor -%}
                    </div>
                  </div>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- if search.performed -%}
          {%- if search.results_count > 0 -%}
            <div class="cpd-product-grid" style="--columns-desktop: {{ section.settings.columns_desktop }}; --columns-tablet: {{ section.settings.columns_tablet }}; --columns-mobile: {{ section.settings.columns_mobile }};">
              {%- for item in search.results -%}
                {%- if item.object_type == 'product' -%}
                  {% render 'product-card', 
                    product_card_product: item,
                    show_category: section.settings.show_category,
                    show_reviews: section.settings.show_rating,
                    show_rating_count: section.settings.show_rating_count,
                    rating_value: section.settings.rating_value,
                    rating_count: section.settings.rating_count,
                    show_quick_view: section.settings.show_quick_view,
                    show_add_to_cart: section.settings.show_add_to_cart,
                    show_description: section.settings.show_description,
                    show_cta_in_footer: true
                  %}
                {%- endif -%}
              {%- endfor -%}
            </div>

            {%- if section.settings.show_pagination and paginate.pages > 1 -%}
              {% render 'pagination', paginate: paginate %}
            {%- endif -%}
          {%- else -%}
            <div class="search-no-results">
              {%- assign display_terms = search.terms | remove: '*' -%}
              <p>{{ 'general.search.no_results' | t: terms: display_terms }}</p>
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>

  </div>
</div>
{%- endpaginate -%}

{% schema %}
{
  "name": "Search Main with Sidebar",
  "settings": [
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "standard",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "full", "label": "Full Width" }
      ]
    },
    {
      "type": "range",
      "id": "results_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "label": "Results per page",
      "default": 12
    },
    {
      "type": "text",
      "id": "sidebar_title",
      "label": "Sidebar Title",
      "default": "Refine Your Search"
    },
    
    {
      "type": "checkbox",
      "id": "show_sidebar_border",
      "label": "Show sidebar border",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show pagination",
      "default": true
    },
    {
      "type": "header",
      "content": "Grid Settings"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "default": "3",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ]
    },
    {
      "type": "select",
      "id": "columns_tablet",
      "label": "Columns on tablet",
      "default": "2",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "default": "1",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "header",
      "content": "Product Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_category",
      "label": "Show category",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating stars",
      "default": true
    },
    {
      "type": "range",
      "id": "rating_value",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "label": "Manual rating value",
      "default": 4.5
    },
    {
      "type": "checkbox",
      "id": "show_rating_count",
      "label": "Show rating count",
      "default": true
    },
    {
      "type": "text",
      "id": "rating_count",
      "label": "Manual rating count",
      "default": "12",
      "info": "Can be connected to a dynamic source"
    },
    {
      "type": "checkbox",
      "id": "show_quick_view",
      "label": "Show quick view button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_add_to_cart",
      "label": "Show add to cart button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show product description",
      "default": false
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1",
      "options": [
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "inverse", "label": "Inverse" }
      ]
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Left",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Right",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_left_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Left (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Right (Mobile)",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "results_meta",
      "name": "Results Meta (Sort/Count)",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_count",
          "label": "Show results count",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_sort",
          "label": "Show sort dropdown",
          "default": true
        }
      ]
    },
    {
      "type": "filter_category",
      "name": "Category Filter",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Filter Title",
          "default": "Category"
        },
        {
          "type": "select",
          "id": "source",
          "label": "Source",
          "default": "product_type",
          "options": [
            { "value": "product_type", "label": "Product Type" },
            { "value": "tag", "label": "Product Tag" }
          ]
        }
      ]
    },
    {
      "type": "filter_price",
      "name": "Price Range Filter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Filter Title",
          "default": "Price Range"
        },
        {
          "type": "text",
          "id": "range_text",
          "label": "Display Range Text",
          "default": "$10 - $2,500"
        }
      ]
    },
    {
      "type": "filter_brand",
      "name": "Brand Filter",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Filter Title",
          "default": "Brand"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Search Main with Sidebar",
      "blocks": [
        { "type": "results_meta" },
        { "type": "filter_category" },
        { "type": "filter_price" },
        { "type": "filter_brand" }
      ]
    }
  ]
}
{% endschema %}
