{{ 'section-services-page.css' | asset_url | stylesheet_tag }}

<style>
  /* Section Spacing / Visibility overrides */
  #shopify-section-{{ section.id }} .services-page-section {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .services-page-section {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px !important;
    }
  }

  /* Container Width overrides */
  #shopify-section-{{ section.id }} .container-fluid {
    max-width: 100% !important;
    padding-left: 2rem !important;
    padding-right: 2rem !important;
  }
  #shopify-section-{{ section.id }} .container-narrow {
    max-width: 800px !important;
  }
  #shopify-section-{{ section.id }} .container {
    max-width: {{ section.settings.max_width | default: 1340 }}px !important;
  }

  /* Blocks Position align overrides */
  #shopify-section-{{ section.id }} .services-page-header {
    {%- if section.settings.blocks_position == 'left' -%}
      margin-left: 0 !important;
      margin-right: auto !important;
    {%- elsif section.settings.blocks_position == 'right' -%}
      margin-left: auto !important;
      margin-right: 0 !important;
    {%- else -%}
      margin-left: auto !important;
      margin-right: auto !important;
    {%- endif -%}
  }
  #shopify-section-{{ section.id }} .services-grid-page {
    justify-content: {% if section.settings.blocks_position == 'left' %}flex-start{% elsif section.settings.blocks_position == 'right' %}flex-end{% elsif section.settings.blocks_position == 'space-between' %}stretch{% else %}center{% endif %} !important;
  }
  #shopify-section-{{ section.id }} .services-divider {
    {%- if section.settings.blocks_position == 'left' -%}
      margin-left: 0 !important;
      margin-right: auto !important;
    {%- elsif section.settings.blocks_position == 'right' -%}
      margin-left: auto !important;
      margin-right: 0 !important;
    {%- else -%}
      margin-left: auto !important;
      margin-right: auto !important;
    {%- endif -%}
  }

  /* Block Spacing overrides */
  #shopify-section-{{ section.id }} .main-title {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 20px) !important;
  }
  #shopify-section-{{ section.id }} .page-intro-text {
    margin-top: var(--sm-t, 0px) !important;
    margin-bottom: var(--sm-b, 28px) !important;
  }
  #shopify-section-{{ section.id }} .service-page-card {
    margin-top: var(--c-m-t, 0px) !important;
    margin-bottom: var(--c-m-b, 0px) !important;
  }
  #shopify-section-{{ section.id }} .services-divider {
    margin-top: var(--d-m-t, 48px) !important;
    margin-bottom: var(--d-m-b, 32px) !important;
  }
  #shopify-section-{{ section.id }} .services-button-wrapper {
    margin-top: var(--b-m-t, 20px) !important;
    margin-bottom: var(--b-m-b, 20px) !important;
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .main-title {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 20px)) !important;
    }
    #shopify-section-{{ section.id }} .page-intro-text {
      margin-top: var(--sm-t-m, var(--sm-t, 0px)) !important;
      margin-bottom: var(--sm-b-m, var(--sm-b, 28px)) !important;
    }
    #shopify-section-{{ section.id }} .service-page-card {
      margin-top: var(--c-m-t-m, var(--c-m-t, 0px)) !important;
      margin-bottom: var(--c-m-b-m, var(--c-m-b, 0px)) !important;
    }
    #shopify-section-{{ section.id }} .services-divider {
      margin-top: var(--d-m-t-m, var(--d-m-t, 32px)) !important;
      margin-bottom: var(--d-m-b-m, var(--d-m-b, 24px)) !important;
    }
    #shopify-section-{{ section.id }} .services-button-wrapper {
      margin-top: var(--b-m-t-m, var(--b-m-t, 16px)) !important;
      margin-bottom: var(--b-m-b-m, var(--b-m-b, 16px)) !important;
    }
  }

  /* Button Presets */
  #shopify-section-{{ section.id }} .services-btn.btn-style-primary {
    background-color: var(--color-primary, #000000) !important;
    color: var(--color-white, #ffffff) !important;
    border-color: var(--color-primary, #000000) !important;
  }
  #shopify-section-{{ section.id }} .services-btn.btn-style-primary:hover {
    background-color: var(--color-primary-hover, rgba(0,0,0,0.8)) !important;
  }
  #shopify-section-{{ section.id }} .services-btn.btn-style-secondary {
    background-color: var(--color-accent, #ff0000) !important;
    color: var(--color-white, #ffffff) !important;
    border-color: var(--color-accent, #ff0000) !important;
  }
  #shopify-section-{{ section.id }} .services-btn.btn-style-secondary:hover {
    background-color: var(--color-accent-hover, rgba(255,0,0,0.8)) !important;
  }
  #shopify-section-{{ section.id }} .services-btn.btn-style-outline {
    background-color: transparent !important;
    color: var(--text-primary) !important;
    border-color: var(--border-medium, rgba(255,255,255,0.3)) !important;
  }
  #shopify-section-{{ section.id }} .services-btn.btn-style-outline:hover {
    background-color: var(--color-accent-10, rgba(255,0,0,0.1)) !important;
    border-color: var(--color-accent-40, rgba(255,0,0,0.4)) !important;
  }

  /* Responsive Font Sizing */
  #shopify-section-{{ section.id }} .main-title.size-small { font-size: 24px !important; }
  #shopify-section-{{ section.id }} .main-title.size-medium { font-size: 36px !important; }
  #shopify-section-{{ section.id }} .main-title.size-large { font-size: 48px !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .main-title.size-small { font-size: 20px !important; }
    #shopify-section-{{ section.id }} .main-title.size-medium { font-size: 28px !important; }
    #shopify-section-{{ section.id }} .main-title.size-large { font-size: 36px !important; }
  }

  #shopify-section-{{ section.id }} .page-intro-text.size-small { font-size: 13px !important; }
  #shopify-section-{{ section.id }} .page-intro-text.size-medium { font-size: 15px !important; }
  #shopify-section-{{ section.id }} .page-intro-text.size-large { font-size: 18px !important; }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .page-intro-text.size-small { font-size: 11px !important; }
    #shopify-section-{{ section.id }} .page-intro-text.size-medium { font-size: 13px !important; }
    #shopify-section-{{ section.id }} .page-intro-text.size-large { font-size: 15px !important; }
  }

  /* Button size presets */
  #shopify-section-{{ section.id }} .services-btn.size-small { font-size: 13px !important; padding: 8px 16px !important; }
  #shopify-section-{{ section.id }} .services-btn.size-medium { font-size: 15px !important; padding: 12px 24px !important; }
  #shopify-section-{{ section.id }} .services-btn.size-large { font-size: 18px !important; padding: 16px 32px !important; }

  /* Button vertical alignment & flex styling fixes */
  #shopify-section-{{ section.id }} .services-btn {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    vertical-align: middle !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    border-radius: 6px !important;
    font-weight: 500 !important;
    text-decoration: none !important;
    transition: all 0.3s ease !important;
    cursor: pointer !important;
    border: 1px solid var(--border-medium) !important;
  }
  #shopify-section-{{ section.id }} .services-btn .btn-icon {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    line-height: 1 !important;
    height: 18px !important;
    margin-right: 8px !important;
  }
  #shopify-section-{{ section.id }} .services-btn .btn-icon svg {
    width: 18px !important;
    height: 18px !important;
    flex-shrink: 0 !important;
  }

  /* Button block settings dynamic overrides */
  {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subheading'
        assign b_align_alignment = ''
      when 'service_card'
        assign b_align_alignment = 'left'
      when 'button'
        assign b_align_alignment = 'center'
  endcase
-%}
    {%- if block.type == 'button' -%}
      {%- if block.settings.icon_color != blank and block.settings.icon_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .services-btn .btn-icon svg {
          color: {{ block.settings.icon_color }} !important;
        }
      {%- endif -%}
      {%- assign btn_align = b_align_alignment -%}
      {%- if btn_align == blank -%}
        {%- assign btn_align = section.settings.blocks_position -%}
      {%- endif -%}
      {%- if btn_align == 'space-between' or btn_align == blank -%}
        {%- assign btn_align = 'left' -%}
      {%- endif -%}
      #shopify-section-{{ section.id }} .services-btn {
        justify-content: {% if btn_align == 'left' %}flex-start{% elsif btn_align == 'right' %}flex-end{% else %}center{% endif %} !important;
        text-align: {{ btn_align }} !important;
      }
      {%- if btn_align == 'left' or btn_align == 'right' -%}
        #shopify-section-{{ section.id }} .services-btn {
          width: auto !important;
        }
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
}

  /* Card block settings dynamic overrides */
  {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subheading'
        assign b_align_alignment = ''
      when 'service_card'
        assign b_align_alignment = 'left'
      when 'button'
        assign b_align_alignment = 'center'
  endcase
-%}
    {%- if block.type == 'service_card' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }} {
        align-items: {% if b_align_alignment == 'center' %}center{% elsif b_align_alignment == 'right' %}flex-end{% else %}flex-start{% endif %} !important;
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} .card-title,
      #shopify-section-{{ section.id }} .block-{{ block.id }} .service-description,
      #shopify-section-{{ section.id }} .block-{{ block.id }} .service-description p,
      #shopify-section-{{ section.id }} .block-{{ block.id }} .service-description strong,
      #shopify-section-{{ section.id }} .block-{{ block.id }} .service-description li {
        font-style: {{ block.settings.font_style | default: 'normal' }} !important;
        text-transform: {{ block.settings.text_transform | default: 'none' }} !important;
        letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px !important;
      }

      #shopify-section-{{ section.id }} .block-{{ block.id }} .card-title {
        font-size: {% if block.settings.font_size == 'small' %}1.1rem{% elsif block.settings.font_size == 'large' %}1.5rem{% else %}1.25rem{% endif %} !important;
        font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}600{% endif %} !important;
        line-height: {{ block.settings.line_height | default: 170 | times: 0.76 | round }}% !important;
        width: 100% !important;
        {%- if block.settings.heading_gradient != blank and block.settings.heading_gradient != 'rgba(0,0,0,0)' -%}
          background: {{ block.settings.heading_gradient }} !important;
          -webkit-background-clip: text !important;
          background-clip: text !important;
          -webkit-text-fill-color: transparent !important;
          color: transparent !important;
          display: inline-block !important;
        {%- else -%}
          {%- assign h_color = block.settings.heading_color | default: block.settings.text_color -%}
          {%- if h_color != blank and h_color != 'rgba(0,0,0,0)' -%}
            color: {{ h_color }} !important;
          {%- endif -%}
        {%- endif -%}
      }
      #shopify-section-{{ section.id }} .block-{{ block.id }} .service-description {
        font-size: {% if block.settings.font_size == 'small' %}0.85rem{% elsif block.settings.font_size == 'large' %}1.1rem{% else %}0.95rem{% endif %} !important;
        font-weight: {% if block.settings.font_weight == 'bold' %}600{% else %}400{% endif %} !important;
        line-height: {{ block.settings.line_height | default: 170 }}% !important;
        width: 100% !important;
      }
      {%- if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' -%}

        #shopify-section-{{ section.id }} .block-{{ block.id }} .service-description,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .service-description strong,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .service-description p,
        #shopify-section-{{ section.id }} .block-{{ block.id }} .service-description li {
          color: {{ block.settings.text_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.icon_color != blank and block.settings.icon_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .service-page-icon {
          color: {{ block.settings.icon_color }} !important;
        }
        #shopify-section-{{ section.id }} .block-{{ block.id }} .service-page-icon svg {
          color: {{ block.settings.icon_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.icon_bg_gradient != blank -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .service-page-icon {
          background: {{ block.settings.icon_bg_gradient }} !important;
        }
      {%- elsif block.settings.icon_bg_color != blank and block.settings.icon_bg_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .service-page-icon {
          background-color: {{ block.settings.icon_bg_color }} !important;
          background-image: none !important;
        }
      {%- endif -%}
      {%- if block.settings.icon_size != blank -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .service-page-icon {
          width: {{ block.settings.icon_size }}px !important;
          height: {{ block.settings.icon_size }}px !important;
        }
      {%- endif -%}
      {%- if block.settings.icon_svg_size != blank -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} .service-page-icon svg {
          width: {{ block.settings.icon_svg_size }}px !important;
          height: {{ block.settings.icon_svg_size }}px !important;
        }
      {%- endif -%}
      {%- if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }} {
          border-color: {{ block.settings.border_color }} !important;
        }
      {%- endif -%}
      {%- if block.settings.hover_border_color != blank and block.settings.hover_border_color != 'rgba(0,0,0,0)' -%}
        #shopify-section-{{ section.id }} .block-{{ block.id }}:hover {
          border-color: {{ block.settings.hover_border_color }} !important;
        }
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
</style>

{%- if section.settings.show_section -%}
{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile
%}
<section 
  class="services-page-section color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}"
  id="shopify-section-{{ section.id }}"
>
  <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}">
    
    {%- comment -%}Header Section{%- endcomment -%}
    <div class="services-page-header">
      {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subheading'
        assign b_align_alignment = ''
      when 'service_card'
        assign b_align_alignment = 'left'
      when 'button'
        assign b_align_alignment = 'center'
  endcase
-%}
        {%- case block.type -%}
          {%- when 'header' -%}
            {%- if block.settings.heading != blank -%}
              {%- assign heading_tag = block.settings.heading_tag | default: 'h1' -%}
              {%- assign h_color = block.settings.highlight_color -%}
              {%- assign h_gradient = block.settings.highlight_gradient -%}
              {%- assign head_box_pos = section.settings.blocks_position -%}
              {%- if head_box_pos == 'space-between' or head_box_pos == blank -%}
                {%- assign head_box_pos = 'center' -%}
              {%- endif -%}
              {%- assign head_text_align = b_align_alignment -%}
              {%- if head_text_align == blank -%}
                {%- assign head_text_align = section.settings.blocks_position -%}
              {%- endif -%}
              {%- if head_text_align == 'space-between' or head_text_align == blank -%}
                {%- assign head_text_align = 'left' -%}
              {%- endif -%}
              <{{ heading_tag }} 
                class="main-title size-{{ block.settings.font_size | default: 'large' }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                {{ block.shopify_attributes }}
                style="
                  --m-t: {{ block.settings.margin_top | default: 0 }}px;
                  --m-b: {{ block.settings.margin_bottom | default: 20 }}px;
                  --m-t-m: {{ block.settings.margin_top_mobile | default: 0 }}px;
                  --m-b-m: {{ block.settings.margin_bottom_mobile | default: 16 }}px;
                  font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                  font-style: {{ block.settings.font_style | default: 'normal' }};
                  text-transform: {{ block.settings.text_transform | default: 'none' }};
                  letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                  line-height: {{ block.settings.line_height | default: 120 }}%;
                  text-align: {{ head_text_align }};
                  width: 100% !important;
                  max-width: {{ block.settings.max_width | default: 800 }}px !important;
                  {%- if head_box_pos == 'left' -%}
                    margin-left: 0 !important;
                    margin-right: auto !important;
                  {%- elsif head_box_pos == 'right' -%}
                    margin-left: auto !important;
                    margin-right: 0 !important;
                  {%- else -%}
                    margin-left: auto !important;
                    margin-right: auto !important;
                  {%- endif -%}
                  {% if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.text_color }} !important;{% endif %}
                  {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background: {{ block.settings.bg_color }} !important;{% endif %}
                "
              >
                {%- if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' -%}
                  {%- assign highlight_span = '<span class="highlight-text" style="background: ' | append: h_gradient | append: '; -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">' -%}
                {%- elsif h_color != blank and h_color != 'rgba(0,0,0,0)' -%}
                  {%- assign highlight_span = '<span class="highlight-text" style="color: ' | append: h_color | append: ';">' -%}
                {%- else -%}
                  {%- assign highlight_span = '<span class="highlight-text">' -%}
                {%- endif -%}
                {{ block.settings.heading | replace: '[', highlight_span | replace: ']', '</span>' }}
              </{{ heading_tag }}>
            {%- endif -%}
          {%- when 'subheading' -%}
            {%- if block.settings.subheading != blank -%}
              {%- assign subheading_tag = block.settings.subheading_tag | default: 'p' -%}
              {%- assign sub_box_pos = section.settings.blocks_position -%}
              {%- if sub_box_pos == 'space-between' or sub_box_pos == blank -%}
                {%- assign sub_box_pos = 'center' -%}
              {%- endif -%}
              {%- assign sub_text_align = b_align_alignment -%}
              {%- if sub_text_align == blank -%}
                {%- assign sub_text_align = section.settings.blocks_position -%}
              {%- endif -%}
              {%- if sub_text_align == 'space-between' or sub_text_align == blank -%}
                {%- assign sub_text_align = 'left' -%}
              {%- endif -%}
              <{{ subheading_tag }} 
                class="page-intro-text size-{{ block.settings.font_size | default: 'medium' }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                {{ block.shopify_attributes }}
                style="
                  --sm-t: {{ block.settings.margin_top | default: 0 }}px;
                  --sm-b: {{ block.settings.margin_bottom | default: 28 }}px;
                  --sm-t-m: {{ block.settings.margin_top_mobile | default: 0 }}px;
                  --sm-b-m: {{ block.settings.margin_bottom_mobile | default: 20 }}px;
                  font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                  font-style: {{ block.settings.font_style | default: 'normal' }};
                  text-transform: {{ block.settings.text_transform | default: 'none' }};
                  letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                  line-height: {{ block.settings.line_height | default: 160 }}%;
                  text-align: {{ sub_text_align }};
                  width: 100% !important;
                  max-width: {{ block.settings.max_width | default: 800 }}px !important;
                  {%- if sub_box_pos == 'left' -%}
                    margin-left: 0 !important;
                    margin-right: auto !important;
                  {%- elsif sub_box_pos == 'right' -%}
                    margin-left: auto !important;
                    margin-right: 0 !important;
                  {%- else -%}
                    margin-left: auto !important;
                    margin-right: auto !important;
                  {%- endif -%}
                  {% if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.text_color }} !important;{% endif %}
                  {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background: {{ block.settings.bg_color }} !important;{% endif %}
                "
              >
                {{ block.settings.subheading }}
              </{{ subheading_tag }}>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- comment -%}Services Grid{%- endcomment -%}
    <div class="services-grid-page">
      {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subheading'
        assign b_align_alignment = ''
      when 'service_card'
        assign b_align_alignment = 'left'
      when 'button'
        assign b_align_alignment = 'center'
  endcase
-%}
        {%- case block.type -%}
          {%- when 'service_card' -%}
            <div class="service-page-card block-{{ block.id }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                 {{ block.shopify_attributes }}
                 style="
                   --c-m-t: {{ block.settings.margin_top | default: 0 }}px;
                   --c-m-b: {{ block.settings.margin_bottom | default: 0 }}px;
                   --c-m-t-m: {{ block.settings.margin_top_mobile | default: 0 }}px;
                   --c-m-b-m: {{ block.settings.margin_bottom_mobile | default: 0 }}px;
                   text-align: {{ b_align_alignment | default: 'left' }};
