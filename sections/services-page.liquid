                  {%- else -%}
                    {%- case block.settings.icon -%}
                      {%- when 'website' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                      {%- when 'network' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                      {%- when 'chat' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                      {%- when 'target' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                      {%- when 'analytics' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                      {%- when 'team' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                      {%- when 'laptop' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                      {%- when 'message' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                      {%- when 'zap' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                      {%- when 'bar-chart' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg>
                      {%- when 'users' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                      {%- when 'share' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                      {%- when 'trending' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                      {%- when 'cpu' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>
                    {%- endcase -%}
                  {%- endif -%}
                </div>
              {%- endif -%}
              
              {%- if block.settings.show_title != false and block.settings.title != blank -%}
                <h3 class="card-title">{{ block.settings.title }}</h3>
              {%- endif -%}
              
              {%- if block.settings.show_description != false and block.settings.description != blank -%}
                <div class="service-description rte">{{ block.settings.description }}</div>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- comment -%}Button & Divider{%- endcomment -%}
    {%- for block in section.blocks -%}
{%- liquid
  assign b_align_alignment = ''
  case block.type
      when 'header'
        assign b_align_alignment = ''
      when 'subheading'
        assign b_align_alignment = ''
      when 'service_card'
        assign b_align_alignment = 'left'
      when 'button'
        assign b_align_alignment = 'center'
  endcase
-%}
      {%- case block.type -%}
        {%- when 'divider' -%}
          {%- assign thickness = block.settings.thickness | default: 1 -%}
          {%- assign d_style = block.settings.divider_style | default: 'solid' -%}
          {%- assign d_width = block.settings.width | default: 100 -%}
          {%- assign d_color = block.settings.divider_color -%}
          <hr 
            class="services-divider {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
            {{ block.shopify_attributes }}
            style="
              --d-m-t: {{ block.settings.margin_top | default: 48 }}px;
              --d-m-b: {{ block.settings.margin_bottom | default: 32 }}px;
              --d-m-t-m: {{ block.settings.margin_top_mobile | default: 32 }}px;
              --d-m-b-m: {{ block.settings.margin_bottom_mobile | default: 24 }}px;
              width: {{ d_width }}% !important;
              {%- if section.settings.blocks_position == 'left' -%}
                margin-left: 0 !important;
                margin-right: auto !important;
              {%- elsif section.settings.blocks_position == 'right' -%}
                margin-left: auto !important;
                margin-right: 0 !important;
              {%- else -%}
                margin-left: auto !important;
                margin-right: auto !important;
              {%- endif -%}
              border: none !important;
              border-top: {{ thickness }}px {{ d_style }} {% if d_color != blank and d_color != 'rgba(0,0,0,0)' %}{{ d_color }}{% else %}var(--border-light, rgba(255,255,255,0.1)){% endif %} !important;
              background: none !important;
              height: 0 !important;
            "
          >
        {%- when 'button' -%}
          {%- assign btn_align = b_align_alignment -%}
          {%- if btn_align == blank -%}
            {%- assign btn_align = section.settings.blocks_position -%}
          {%- endif -%}
          {%- if btn_align == 'space-between' or btn_align == blank -%}
            {%- assign btn_align = 'center' -%}
          {%- endif -%}
          <div class="services-button-wrapper {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
               {{ block.shopify_attributes }}
               style="
                 --b-m-t: {{ block.settings.margin_top | default: 20 }}px;
                 --b-m-b: {{ block.settings.margin_bottom | default: 20 }}px;
                 --b-m-t-m: {{ block.settings.margin_top_mobile | default: 16 }}px;
                 --b-m-b-m: {{ block.settings.margin_bottom_mobile | default: 16 }}px;
                 display: flex !important;
                 width: 100% !important;
                 justify-content: {% if btn_align == 'left' %}flex-start{% elsif btn_align == 'right' %}flex-end{% else %}center{% endif %} !important;
               "
          >
            <a 
              href="{{ block.settings.download_link | default: '#' }}" 
              class="services-btn btn-style-{{ block.settings.style | default: 'outline' }} size-{{ block.settings.font_size | default: 'medium' }}"
              download
              style="
                font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %};
                font-style: {{ block.settings.font_style | default: 'normal' }};
                text-transform: {{ block.settings.text_transform | default: 'none' }};
                letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;
                line-height: {{ block.settings.line_height | default: 115 }}%;
                {% if block.settings.text_color != blank and block.settings.text_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.text_color }} !important;{% endif %}
                {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;{% elsif block.settings.bg_color != blank %}background: {{ block.settings.bg_color }} !important;{% endif %}
                {% if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' %}border-color: {{ block.settings.border_color }} !important;{% endif %}
              "
            >
              {%- if block.settings.show_icon != false -%}
                {%- assign icon_type = block.settings.icon_type | default: 'download' -%}
                {%- if icon_type == 'download' and block.settings.download_icon != blank -%}
                  {%- assign icon_type = 'custom' -%}
                {%- endif -%}
                <span class="btn-icon" {% if block.settings.icon_color != blank %}style="color: {{ block.settings.icon_color }} !important;"{% endif %}>
                  {%- case icon_type -%}
                    {%- when 'download' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="7 10 12 15 17 10"></polyline>
                        <line x1="12" y1="15" x2="12" y2="3"></line>
                      </svg>
                    {%- when 'external' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                        <polyline points="15 3 21 3 21 9"></polyline>
                        <line x1="10" y1="14" x2="21" y2="3"></line>
                      </svg>
                    {%- when 'arrow' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                      </svg>
                    {%- when 'check' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    {%- when 'info' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="16" x2="12" y2="12"></line>
                        <line x1="12" y1="8" x2="12.01" y2="8"></line>
                      </svg>
                    {%- when 'mail' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                        <polyline points="22,6 12,13 2,6"></polyline>
                      </svg>
                    {%- when 'custom' -%}
                      {%- if block.settings.download_icon != blank -%}
                        {{ block.settings.download_icon }}
                      {%- endif -%}
                  {%- endcase -%}
                </span>
              {%- endif -%}
              {{ block.settings.download_text | default: 'Download PDF Version' }}
            </a>
          </div>
      {%- endcase -%}
    {%- endfor -%}

  </div>
</section>
{%- endif -%}

{% schema %}
