{{ 'section-showcase-stats.css' | asset_url | stylesheet_tag }}

{%- if section.settings.show_section -%}
<style>
  #shopify-section-{{ section.id }} { padding: 0 !important; }
  #shopify-section-{{ section.id }} .csh-stats-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .csh-stats-section {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
</style>

<section class="csh-stats-section color-{{ section.settings.color_scheme }}{% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}">
  <div class="csh-page {% if section.settings.container_width == 'full' %}csh-page--full{% elsif section.settings.container_width == 'narrow' %}csh-page--narrow{% endif %}"
       style="{% if section.settings.container_width == 'standard' and section.settings.max_width != blank %}max-width: {{ section.settings.max_width }}px;{% endif %} margin: 0 auto;">
    <div class="csh-stats">
      {%- for block in section.blocks -%}
        {%- if block.type == 'stat' -%}
          <div class="csh-stat-card" {{ block.shopify_attributes }}>
            <div class="csh-stat-icon">
              {%- if block.settings.custom_svg != blank -%}
                {{ block.settings.custom_svg }}
              {%- else -%}
                {%- case block.settings.icon -%}
                  {%- when 'gadgets' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2" /><line x1="8" y1="21" x2="16" y2="21" /><line x1="12" y1="17" x2="12" y2="21" /></svg>
                  {%- when 'customers' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                  {%- when 'rating' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
                  {%- when 'guarantee' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                {%- endcase -%}
              {%- endif -%}
            </div>
            <div class="csh-stat-value">{{ block.settings.value }}</div>
            <div class="csh-stat-label">{{ block.settings.label }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Showcase Stats Strip",
  "tag": "section",
  "class": "section-showcase-stats",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "standard",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "narrow", "label": "Narrow" },
        { "value": "full", "label": "Full Width" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Max Width",
      "default": 1340
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "inverse", "label": "Inverse" }
      ]
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat Card",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "gadgets",
          "options": [
            { "value": "gadgets", "label": "Gadgets" },
            { "value": "customers", "label": "Customers" },
            { "value": "rating", "label": "Rating" },
            { "value": "guarantee", "label": "Guarantee" }
          ]
        },
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Custom SVG Icon",
          "info": "Overrides the select icon above"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "500+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Smart Gadgets"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Showcase Stats Strip",
      "blocks": [
        { "type": "stat", "settings": { "icon": "gadgets", "value": "500+", "label": "Smart Gadgets" } },
        { "type": "stat", "settings": { "icon": "customers", "value": "12K+", "label": "Happy Customers" } },
        { "type": "stat", "settings": { "icon": "rating", "value": "4.9", "label": "Average Rating" } },
        { "type": "stat", "settings": { "icon": "guarantee", "value": "100%", "label": "Money-Back Guarantee" } }
      ]
    }
  ]
}
{% endschema %}
