{% stylesheet %}
  .hes-slider-wrapper {
    position: relative;
    width: 100%;
  }

  .hes-nav-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-secondary, #ffffff);
    border: 1px solid var(--border-light, rgba(255, 255, 255, 0.2));
    border-radius: 50%;
    color: var(--text-primary, #000000);
    cursor: pointer;
    z-index: 10;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
  }

  .hes-nav-arrow:hover {
    background: var(--color-accent-secondary);
    border-color: var(--color-accent-secondary);
    color: var(--bg-secondary);
    transform: translateY(-50%) scale(1.1);
    box-shadow: 0 12px 40px var(--color-accent-secondary-30);
  }

  .hes-nav-arrow.prev {
    left: -24px;
  }

  .hes-nav-arrow.next {
    right: -24px;
  }

  [dir="rtl"] .hes-nav-arrow.prev {
    left: auto;
    right: -24px;
  }

  [dir="rtl"] .hes-nav-arrow.next {
    right: auto;
    left: -24px;
  }

  .hes-nav-arrow svg {
    width: 20px;
    height: 20px;
  }

  .hes-trending-strip {
    scrollbar-width: none !important;
    -ms-overflow-style: none !important;
    scroll-behavior: smooth;
    padding-top: 20px !important;
    padding-bottom: 40px !important;
  }

  .hes-trending-strip::-webkit-scrollbar {
    display: none !important;
    width: 0 !important;
    height: 0 !important;
  }

  .hes-trend-actions {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .hes-trend-quick-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    color: var(--text-primary);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .hes-trend-quick-btn:hover {
    background: var(--color-accent-secondary);
    color: var(--bg-secondary);
    border-color: var(--color-accent-secondary);
  }

  .hes-trend-quick-btn svg {
    width: 18px;
    height: 18px;
  }

  @media (max-width: 1200px) {
    .hes-nav-arrow.prev { left: 10px; }
    .hes-nav-arrow.next { right: 10px; }
    [dir="rtl"] .hes-nav-arrow.prev { left: auto; right: 10px; }
    [dir="rtl"] .hes-nav-arrow.next { right: auto; left: 10px; }
  }

  @media (max-width: 768px) {
    .hes-nav-arrow {
      width: 40px;
      height: 40px;
    }
    .hes-nav-arrow svg {
      width: 16px;
      height: 16px;
    }
  }
{% endstylesheet %}

{% javascript %}
function initTrendingSlider(section) {
  const prevBtn = section.querySelector('.hes-nav-arrow.prev');
  const nextBtn = section.querySelector('.hes-nav-arrow.next');
  const strip = section.querySelector('.hes-trending-strip');
  if (!prevBtn || !nextBtn || !strip) return;
  
  const isRtl = document.documentElement.dir === 'rtl' || getComputedStyle(strip).direction === 'rtl';
  const scrollAmount = 344;
  
  prevBtn.addEventListener('click', () => {
    const direction = isRtl ? 1 : -1;
    strip.scrollBy({ left: scrollAmount * direction, behavior: 'smooth' });
  });
  nextBtn.addEventListener('click', () => {
    const direction = isRtl ? -1 : 1;
    strip.scrollBy({ left: scrollAmount * direction, behavior: 'smooth' });
  });
}

document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.hes-trending').forEach(initTrendingSlider);
});

document.addEventListener('shopify:section:load', (e) => {
  const section = e.target.querySelector('.hes-trending');
  if (section) initTrendingSlider(section);
});
