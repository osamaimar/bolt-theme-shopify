{{ 'section-home-ecommerce-minimal.css' | asset_url | stylesheet_tag }}

{%- if section.settings.show_section -%}
{% render 'section-padding',
  section_id: section.id,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  padding_top_mobile: section.settings.padding_top_mobile,
  padding_bottom_mobile: section.settings.padding_bottom_mobile,
  padding_left: section.settings.padding_left,
  padding_right: section.settings.padding_right,
  padding_left_mobile: section.settings.padding_left_mobile,
  padding_right_mobile: section.settings.padding_right_mobile
%}

{% style %}
  #shopify-section-{{ section.id }} .hev-trending-block {
    margin-top: var(--m-t, 0px) !important;
    margin-bottom: var(--m-b, 0px) !important;
    color: var(--block-text-color, var(--default-text-color, inherit)) !important;
    background: var(--block-bg, transparent) !important;
  }
  #shopify-section-{{ section.id }} .hev-trending-block *:not(span):not(.hev-section-link) {
    color: inherit !important;
  }
  #shopify-section-{{ section.id }} .hev-trending-heading span {
    background: var(--highlight-gradient, var(--color-accent)) !important;
    -webkit-background-clip: var(--highlight-clip, text) !important;
    background-clip: var(--highlight-clip, text) !important;
    -webkit-text-fill-color: var(--highlight-fill, transparent) !important;
    display: inline-block;
    color: var(--highlight-color, inherit) !important;
  }
  
  /* View All Link System */
  #shopify-section-{{ section.id }} .hev-section-link {
    background: var(--btn-bg, transparent) !important;
    color: var(--btn-text, var(--text-inverse)) !important;
    border: none !important;
    transition: all 0.3s ease !important;
  }
  #shopify-section-{{ section.id }} .hev-section-link:hover {
    background: var(--btn-hover-bg, var(--color-white-5)) !important;
    color: var(--btn-hover-text, var(--color-accent-secondary)) !important;
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .hev-trending-block {
      margin-top: var(--m-t-m, var(--m-t, 0px)) !important;
      margin-bottom: var(--m-b-m, var(--m-b, 0px)) !important;
    }
  }
{% endstyle %}

<section class="hes-trending color-{{ section.settings.color_scheme }} {% unless section.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless section.settings.show_on_mobile %} hidden-mobile{% endunless %}" id="shopify-section-{{ section.id }}">
    <div class="{% if section.settings.container_width == 'full' %}container-fluid{% elsif section.settings.container_width == 'narrow' %}container-narrow{% else %}container{% endif %}" style="{% if section.settings.container_width != 'full' %}max-width: {{ section.settings.max_width }}px;{% endif %} margin: 0 auto;">
        
        <div class="hev-section-header" style="justify-content: {% if 'left' == 'center' %}center{% elsif 'left' == 'right' %}flex-end{% else %}space-between{% endif %}; text-align: {{ 'left' }};">
            <div class="hev-section-header-text">
                {%- for block in section.blocks -%}
                    {%- case block.type -%}
                        {%- when 'trending_heading' -%}
                            {%- if block.settings.heading != blank -%}
                                {%- assign h_color = block.settings.highlight_color -%}
                                {%- assign h_gradient = block.settings.highlight_gradient -%}
                                <h2 class="hev-trending-heading hev-trending-block hev-trending-heading--{{ block.settings.font_size }} {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                                    style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px; font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; --default-text-color: var(--text-primary); {% if block.settings.text_color != blank %}--block-text-color: {{ block.settings.text_color }};{% endif %} {% if block.settings.bg_gradient != blank %}--block-bg: {{ block.settings.bg_gradient }};{% elsif block.settings.bg_color != blank %}--block-bg: {{ block.settings.bg_color }};{% endif %}
                                    {% if h_gradient != blank and h_gradient != 'rgba(0,0,0,0)' %}--highlight-gradient: {{ h_gradient }}; --highlight-clip: text; --highlight-fill: transparent;
                                    {% elsif h_color != blank and h_color != 'rgba(0,0,0,0)' %}--highlight-color: {{ h_color }}; --highlight-gradient: none; --highlight-clip: initial; --highlight-fill: {{ h_color }};
                                    {% endif %}"
                                    {{ block.shopify_attributes }}>
                                    {{ block.settings.heading | replace: '[', '<span>' | replace: ']', '</span>' }}
                                </h2>
                            {%- endif -%}

                        {%- when 'trending_subheading' -%}
                            {%- if block.settings.subheading != blank -%}
                                <p class="hev-trending-block {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                                   style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px; font-size: {{ block.settings.font_size }}rem; max-width: {{ block.settings.max_width }}px; margin-inline: {% if 'left' == 'center' %}auto{% elsif 'left' == 'right' %}0 0{% else %}0 auto{% endif %}; font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }}; --default-text-color: var(--text-secondary); {% if block.settings.text_color != blank %}--block-text-color: {{ block.settings.text_color }};{% endif %} {% if block.settings.bg_gradient != blank %}--block-bg: {{ block.settings.bg_gradient }};{% elsif block.settings.bg_color != blank %}--block-bg: {{ block.settings.bg_color }};{% endif %}"
                                   {{ block.shopify_attributes }}>
                                    {{ block.settings.subheading }}
                                </p>
                            {%- endif -%}
                    {%- endcase -%}
                {%- endfor -%}
            </div>
            {%- for block in section.blocks -%}
                {%- if block.type == 'view_all' -%}
                    {%- if block.settings.label != blank -%}
                        {%- liquid
                           assign btn_bg = block.settings.bg_color | default: 'transparent'
                           if block.settings.bg_gradient != blank
                              assign btn_bg = block.settings.bg_gradient
                           endif
                           assign btn_text = block.settings.text_color | default: 'var(--text-inverse)'
                        -%}
                        <div class="hev-trending-block {% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %} {% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" 
                             style="--m-t: {{ block.settings.margin_top }}px; --m-b: {{ block.settings.margin_bottom }}px; --m-t-m: {{ block.settings.margin_top_mobile }}px; --m-b-m: {{ block.settings.margin_bottom_mobile }}px;" {{ block.shopify_attributes }}>
                            <a href="{{ block.settings.link | default: '#' }}" 
                               class="hev-section-link" 
                               id="hev-view-all-link-{{ block.id }}" 
                               aria-label="{{ block.settings.label | escape }}"
                               {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener"{% endif %}
                               style="font-weight: {% if block.settings.font_weight == 'bold' %}700{% else %}400{% endif %}; font-style: {{ block.settings.font_style }}; text-transform: {{ block.settings.text_transform }}; letter-spacing: {{ block.settings.letter_spacing }}px; line-height: {{ block.settings.line_height }};
                               --btn-bg: {{ btn_bg }}; 
                               --btn-text: {{ btn_text }};
                               --btn-hover-bg: {{ block.settings.hover_bg_color | default: 'var(--color-white-5)' }};
                               --btn-hover-text: {{ block.settings.hover_text_color | default: 'var(--color-accent-secondary)' }};">
                                {{ block.settings.label }}
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true" focusable="false">
                                    <path d="M5 12h14" />
                                    <path d="M12 5l7 7-7 7" />
                                </svg>
                            </a>
                        </div>
                    {%- endif -%}
                {%- endif -%}
            {%- endfor -%}
        </div>

        {%- for block in section.blocks -%}
            {%- if block.type == 'collection_strip' -%}
                {%- assign collection = collections[block.settings.collection] | default: block.settings.collection -%}
                {%- assign products_to_show = block.settings.products_to_show | default: 4 -%}
                <div class="hes-slider-wrapper" id="Block-{{ block.id }}">
                    <style>
                      #Block-{{ block.id }} {
                        --m-t: {{ block.settings.margin_top | default: 0 }}px;
                        --m-b: {{ block.settings.margin_bottom | default: 24 }}px;
                        --m-t-m: {{ block.settings.margin_top_mobile | default: 0 }}px;
                        --m-b-m: {{ block.settings.margin_bottom_mobile | default: 24 }}px;
                      }
                      #Block-{{ block.id }} {
                        margin-top: var(--m-t) !important;
                        margin-bottom: var(--m-b) !important;
                      }
                      @media (max-width: 768px) {
                        #Block-{{ block.id }} {
                          margin-top: var(--m-t-m) !important;
                          margin-bottom: var(--m-b-m) !important;
                        }
                      }
                      {%- assign cols_d = block.settings.columns_desktop | default: 4 | plus: 0 -%}
                      {%- assign cols_t = block.settings.columns_tablet | default: 3 | plus: 0 -%}
                      {%- assign cols_m = block.settings.columns_mobile | default: 2 | plus: 0 -%}
                      {%- assign gap = block.settings.grid_gap | default: 20 | plus: 0 -%}
                      
                      {%- assign gap_d_total = cols_d | minus: 1 | times: gap -%}
                      {%- assign gap_t_total = cols_t | minus: 1 | times: gap -%}
                      {%- assign gap_m_total = cols_m | minus: 1 | times: gap -%}

                      #Block-{{ block.id }} .hes-trending-strip {
                        gap: {{ gap }}px !important;
                      }
                      {%- if cols_d > 0 -%}
                      #Block-{{ block.id }} .hes-trend-card {
                        min-width: calc((100% - {{ gap_d_total }}px) / {{ cols_d }}) !important;
                        max-width: calc((100% - {{ gap_d_total }}px) / {{ cols_d }}) !important;
                      }
                      {%- endif -%}
                      {%- if cols_t > 0 -%}
                      @media (max-width: 991px) {
                        #Block-{{ block.id }} .hes-trend-card {
                          min-width: calc((100% - {{ gap_t_total }}px) / {{ cols_t }}) !important;
                          max-width: calc((100% - {{ gap_t_total }}px) / {{ cols_t }}) !important;
                        }
                      }
                      {%- endif -%}
                      {%- if cols_m > 0 -%}
                      @media (max-width: 768px) {
                        #Block-{{ block.id }} .hes-trend-card {
                          min-width: calc((100% - {{ gap_m_total }}px) / {{ cols_m }}) !important;
                          max-width: calc((100% - {{ gap_m_total }}px) / {{ cols_m }}) !important;
                        }
                      }
                      {%- endif -%}

                      {% if block.settings.bg_color != blank or block.settings.bg_gradient != blank %}
                      #Block-{{ block.id }} .hes-trend-card { 
                         {% if block.settings.bg_gradient != blank %}background: {{ block.settings.bg_gradient }} !important;
                         {% else %}background-color: {{ block.settings.bg_color }} !important;{% endif %}
                      }
                      {% endif %}
                      {% if block.settings.title_color != blank %}
                      #Block-{{ block.id }} .hes-trend-name a { color: {{ block.settings.title_color }} !important; }
                      {% endif %}
                      {% if block.settings.vendor_color != blank %}
                      #Block-{{ block.id }} .hes-trend-category { color: {{ block.settings.vendor_color }} !important; }
                      {% endif %}
                      {% if block.settings.desc_color != blank %}
                      #Block-{{ block.id }} .hes-trend-desc { color: {{ block.settings.desc_color }} !important; }
                      {% endif %}
                      {% if block.settings.price_color != blank %}
                      #Block-{{ block.id }} .hes-trend-price { color: {{ block.settings.price_color }} !important; }
                      {% endif %}
                      {% if block.settings.compare_price_color != blank %}
                      #Block-{{ block.id }} .hes-trend-price .old { color: {{ block.settings.compare_price_color }} !important; }
                      {% endif %}
                      {% if block.settings.divider_color != blank %}
                      #Block-{{ block.id }} .hes-trend-bottom { border-top-color: {{ block.settings.divider_color }} !important; }
                      {% endif %}
                      {% unless block.settings.show_divider %}
                      #Block-{{ block.id }} .hes-trend-bottom { border-top: none !important; }
                      {% endunless %}
                      {% if block.settings.btn_bg_color != blank or block.settings.btn_bg_gradient != blank %}
                      #Block-{{ block.id }} .hes-trend-cart-btn { 
                        {% if block.settings.btn_bg_gradient != blank %}background: {{ block.settings.btn_bg_gradient }} !important;
                        {% elsif block.settings.btn_bg_color != blank %}background: {{ block.settings.btn_bg_color }} !important;{% endif %}
                        {% if block.settings.btn_border_color != blank %}border: 1px solid {{ block.settings.btn_border_color }} !important;{% endif %}
                      }
                      {% endif %}
                      {% if block.settings.btn_text_color != blank %}
                      #Block-{{ block.id }} .hes-trend-cart-btn { color: {{ block.settings.btn_text_color }} !important; }
                      {% endif %}
                      {% if block.settings.image_ratio == 'portrait' %}
                      #Block-{{ block.id }} .hes-trend-img { aspect-ratio: 3/4 !important; }
                      {% elsif block.settings.image_ratio == 'adapt' %}
                      #Block-{{ block.id }} .hes-trend-img { aspect-ratio: auto !important; }
                      {% else %}
                      #Block-{{ block.id }} .hes-trend-img { aspect-ratio: 1/1 !important; }
                      {% endif %}
                    </style>
                    <button type="button" class="hes-nav-arrow prev" aria-label="Previous">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="15 18 9 12 15 6" />
                        </svg>
                    </button>
                    <button type="button" class="hes-nav-arrow next" aria-label="Next">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="9 18 15 12 9 6" />
                        </svg>
                    </button>
                    <div class="hes-trending-strip hes-trending-strip--{{ block.settings.image_ratio }} hes-trending-strip--align-{{ 'left' }}" {{ block.shopify_attributes }}>
                        {%- if collection != blank and collection.products.size > 0 -%}
                            {%- for product in collection.products limit: products_to_show -%}
                                <article class="hes-trend-card theme-card-v2" data-category="{{ product.type | handleize }}" data-product-handle="{{ product.handle }}">
                                    <div class="hes-trend-img">
                                        <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                                        <div class="cpd-product-desc hidden" style="display: none;">{{ product.description | strip_html | truncatewords: 30 }}</div>
                                        {%- if product.featured_image != blank -%}
                                            {{ product.featured_image | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(min-width: 991px) 25vw, (min-width: 769px) 33vw, 50vw', alt: product.title | escape }}
                                        {%- else -%}
                                            {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
                                        {%- endif -%}
                                    </div>
                                    <div class="hes-trend-info">
                                        {%- if block.settings.show_category and product.type != blank -%}
                                            <div class="hes-trend-category">{{ product.type }}</div>
                                        {%- elsif block.settings.show_vendor and product.vendor != blank -%}
                                            <div class="hes-trend-category">{{ product.vendor }}</div>
                                        {%- endif -%}
                                        <div class="hes-trend-name">
                                            <a href="{{ product.url }}">{{ product.title }}</a>
                                        </div>
                                        {%- if block.settings.show_description and product.description != blank -%}
                                            <div class="hes-trend-desc" style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 10px; line-height: 1.4;">
                                                {{ product.description | strip_html | truncatewords: 15 }}
                                            </div>
                                        {%- endif -%}

                                        {%- if block.settings.show_rating -%}
                                            <div class="hes-trend-rating-group">
                                                <div class="hes-trend-stars" aria-label="5 star rating">
                                                    {%- for i in (1..5) -%}
                                                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                                                        </svg>
                                                    {%- endfor -%}
                                                </div>
                                                <span class="hes-trend-rating-count">(124)</span>
                                            </div>
                                        {%- endif -%}

                                        <div class="hes-trend-bottom">
                                            {%- if block.settings.show_price -%}
                                                <span class="hes-trend-price">
                                                    {{ product.price | money }}
                                                    {%- if block.settings.show_compare_price and product.compare_at_price > product.price -%}
                                                        <span class="old">{{ product.compare_at_price | money }}</span>
                                                    {%- endif -%}
                                                </span>
                                            {%- endif -%}
                                            
                                            <div class="hes-trend-actions">
                                                {%- if block.settings.show_quick_view -%}
                                                    <button type="button" class="cpd-quick-view-btn hes-trend-quick-btn" 
                                                        aria-label="Quick View"
                                                        title="Quick View"
                                                        data-product-handle="{{ product.handle }}"
                                                    >
                                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true" focusable="false">
                                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                                        </svg>
                                                    </button>
                                                {%- endif -%}
                                                {%- if block.settings.show_add_to_cart -%}
                                                     <button type="button" class="hes-trend-cart-btn" 
                                                         aria-label="{{ 'products.product.add_to_cart' | t }}"
                                                         title="{{ 'products.product.add_to_cart' | t }}"
                                                         onclick="document.dispatchEvent(new CustomEvent('product:add-to-cart', { detail: { productId: '{{ product.variants.first.id }}', quantity: 1, target: this }}))"
                                                     >
                                                         <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true" focusable="false">
                                                             <path stroke-linecap="round" stroke-linejoin="round"
                                                                 d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
                                                         </svg>
                                                     </button>
                                                 {%- endif -%}
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            {%- endfor -%}
                        {%- else -%}
                            {%- for i in (1..products_to_show) -%}
                                <article class="hes-trend-card theme-card-v2">
                                    <div class="hes-trend-img">
                                        {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
                                    </div>
                                    <div class="hes-trend-info">
                                        {%- if block.settings.show_category -%}
                                            <div class="hes-trend-category">{{ 'products.product.category' | t }}</div>
                                        {%- elsif block.settings.show_vendor -%}
                                            <div class="hes-trend-category">{{ 'products.product.vendor' | t }}</div>
                                        {%- endif -%}
                                        <div class="hes-trend-name">
                                            <a href="#">{{ 'products.product.sample_product' | t }} {{ i }}</a>
                                        </div>

                                        {%- if block.settings.show_rating -%}
                                            <div class="hes-trend-rating-group">
                                                <div class="hes-trend-stars">
                                                    {%- for j in (1..5) -%}
                                                        <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" /></svg>
                                                    {%- endfor -%}
                                                </div>
                                                <span class="hes-trend-rating-count">(124)</span>
                                            </div>
                                        {%- endif -%}

                                        <div class="hes-trend-bottom">
                                            {%- if block.settings.show_price -%}
                                                <span class="hes-trend-price">$99.00</span>
                                            {%- endif -%}
                                            <div class="hes-trend-actions">
                                                {%- if block.settings.show_quick_view -%}
                                                    <button type="button" class="cpd-quick-view-btn hes-trend-quick-btn" title="Quick View">
                                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true" focusable="false">
                                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                                        </svg>
                                                    </button>
                                                {%- endif -%}
                                                {%- if block.settings.show_add_to_cart -%}
                                                     <button type="button" class="hes-trend-cart-btn" title="{{ 'products.product.add_to_cart' | t }}"
                                                         onclick="const cdOverlay = document.getElementById('cd-overlay'); if(cdOverlay) { cdOverlay.classList.add('active'); document.body.classList.add('cd-open'); document.documentElement.classList.add('cd-open'); }"
                                                     >
                                                         <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                                             <path stroke-linecap="round" stroke-linejoin="round"
                                                                 d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
                                                         </svg>
                                                     </button>
                                                 {%- endif -%}
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            {%- endfor -%}
                        {%- endif -%}
                    </div>
                </div>
            {%- endif -%}
        {%- endfor -%}
    </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Trending Now - Horizontal",
  "tag": "section",
  "class": "section-trending",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "standard",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "standard", "label": "Standard" },
        { "value": "narrow", "label": "Narrow" }
      ]
    },
    {
