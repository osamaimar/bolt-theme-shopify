{% comment %}
    Renders an article card for a given blog with settings to either show the image or not.

    Accepts:
    - blog: {Object} Blog object
    - article: {Object} Article object
    - show_image: {String} The setting either show the article image or not. If it's not null it will show the image. (optional)
    - show_date: {String} The setting either show the article date or not. If it's not null it will show the date. (optional)
    - show_author: {String} The setting either show the article author or not. If it's not null it will show the author. (optional)

    Usage:
    {% render 'article-card' blog: blog, article: article, show_image: section.settings.show_image %}
{% endcomment %}

<article class="blog-card" aria-labelledby="Article-{{ article.id }}">
  {%- if show_image == true and article.image -%}
    <div class="blog-card-image-wrapper">
      <a href="{{ article.url }}" class="full-unstyled-link">
        <img
          srcset="{%- if article.image.width >= 165 -%}{{ article.image | image_url: width: 165 }} 165w,{%- endif -%}
            {%- if article.image.width >= 360 -%}{{ article.image | image_url: width: 360 }} 360w,{%- endif -%}
            {%- if article.image.width >= 533 -%}{{ article.image | image_url: width: 533 }} 533w,{%- endif -%}
            {%- if article.image.width >= 720 -%}{{ article.image | image_url: width: 720 }} 720w,{%- endif -%}
            {%- if article.image.width >= 1000 -%}{{ article.image | image_url: width: 1000 }} 1000w,{%- endif -%}
            {%- if article.image.width >= 1500 -%}{{ article.image | image_url: width: 1500 }} 1500w,{%- endif -%}
            {{ article.image | image_url }} {{ article.image.width }}w"
          src="{{ article.image | image_url: width: 533 }}"
          sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 1)"
          alt="{{ article.image.alt | default: article.title | escape }}"
          class="blog-card-image"
          loading="lazy"
          width="{{ article.image.width }}"
          height="{{ article.image.height }}"
        >
      </a>
    </div>
  {%- endif -%}

  <div class="blog-card-content">
    <div class="blog-card-meta">
      {%- if show_date -%}
        <span class="blog-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
              <line x1="16" y1="2" x2="16" y2="6" />
              <line x1="8" y1="2" x2="8" y2="6" />
              <line x1="3" y1="10" x2="21" y2="10" />
          </svg>
          {{ article.published_at | time_tag: format: 'date' }}
        </span>
      {%- endif -%}
      <span class="blog-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
          </svg>
          {%- assign read_time = article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 -%}
          {{ 'blogs.article.read_time' | t: count: read_time }}
      </span>
    </div>

    <h3 class="blog-card-title" id="Article-{{ article.id }}">
      <a href="{{ article.url }}" class="full-unstyled-link">
        {{ article.title | escape }}
      </a>
    </h3>

    {%- if article.excerpt_or_content.size > 0 -%}
      <p class="blog-card-excerpt">
        {{ article.excerpt_or_content | strip_html | truncatewords: 30 }}
      </p>
    {%- endif -%}

    <div class="blog-card-footer">
      {%- if show_author -%}
        <div class="blog-card-author">
          {%- liquid
            assign author_initials = ""
            assign author_parts = article.author | split: " "
            for part in author_parts
              assign first_char = part | slice: 0, 1 | upcase
              assign author_initials = author_initials | append: first_char
            endfor
          -%}
          <div class="blog-author-avatar">{{ author_initials | slice: 0, 2 }}</div>
          <span class="blog-author-name">{{ article.author }}</span>
        </div>
      {%- endif -%}

      <a href="{{ article.url }}" class="blog-card-read-more" aria-label="{{ 'blogs.article.read_more_title' | t: title: article.title }}">
        {{ 'blogs.article.read_more' | t }}
        {% render 'icon-arrow' %}
      </a>
    </div>
  </div>
</article>
