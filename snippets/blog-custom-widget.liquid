{%- comment -%}Custom Text/HTML Widget Block{%- endcomment -%}
<div class="blog-sidebar-widget block-{{ block.id }}{% unless block.settings.show_on_desktop %} hidden-desktop{% endunless %}{% unless block.settings.show_on_mobile %} hidden-mobile{% endunless %}" {{ block.shopify_attributes }}>
  {%- if block.settings.heading != blank -%}
    {%- assign heading_tag = block.settings.heading_tag | default: 'h3' -%}
<{{ heading_tag }} class="blog-sidebar-widget-title size-{{ block.settings.font_size | default: 'medium' }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
        <polyline points="10 9 9 9 8 9"/>
      </svg>
      {{ block.settings.heading }}
    </{{ heading_tag }}>
  {%- endif -%}
  <div class="blog-sidebar-custom-content">
    {%- if block.settings.content_type == 'html' -%}
      {{ block.settings.custom_html }}
    {%- else -%}
      <p>{{ block.settings.custom_text }}</p>
    {%- endif -%}
  </div>
</div>
