<!-- snippets/search-popup.liquid -->
{{ 'component-search-popup.css' | asset_url | stylesheet_tag }}

<div class="search-overlay" id="search-overlay" role="dialog" aria-modal="true" aria-label="{{ 'general.search.title' | t }}">
  <div class="search-popup">
    <!-- Close -->
    <button type="button" class="search-popup-close" id="search-popup-close" aria-label="{{ 'accessibility.close_menu' | t }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <!-- Title -->
    <h2 class="search-popup-title" id="search-title">
      {{ 'general.search.title' | t | replace: ' ', ' <span>' | append: '</span>' }}
    </h2>

    <!-- Search Input -->
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-input-wrapper">
      <div class="search-input-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </div>
      <input 
        type="search" 
        name="q"
        value="{{ search.terms | escape }}"
        class="search-popup-input" 
        id="search-popup-input" 
        placeholder="{{ 'general.search.placeholder' | t }}" 
        aria-label="{{ 'general.search.placeholder' | t }}"
        autocomplete="off" 
      />
      <input type="hidden" name="type" value="product">
      <div class="search-kbd" aria-hidden="true">
        <kbd>⌘</kbd><kbd>K</kbd>
      </div>
    </form>

    <!-- Quick Links (Popular Searches) -->
    {%- if settings.popular_searches != blank -%}
      <div class="search-quick-links">
        <p class="search-quick-label">{{ 'sections.header.popular_searches' | t | default: 'Popular Searches' }}</p>
        <nav class="search-quick-tags" aria-label="{{ 'sections.header.popular_searches' | t | default: 'Popular Searches' }}">
          {%- assign popular_tags = settings.popular_searches | split: ',' -%}
          {%- for tag in popular_tags -%}
            {%- assign tag_clean = tag | strip -%}
            <a class="search-quick-tag" href="{{ routes.search_url }}?q={{ tag_clean | url_encode }}&type=product">
              {{ tag_clean }}
            </a>
          {%- endfor -%}
        </nav>
      </div>
    {%- endif -%}

    <!-- Recent Searches -->
    <div class="search-recent" id="search-recent" style="display:none">
      <div class="search-recent-header">
        <span class="search-recent-label">{{ 'general.search.recent' | t }}</span>
        <button type="button" class="search-recent-clear" id="search-recent-clear">{{ 'general.search.clear_all' | t }}</button>
      </div>
      <ul class="search-recent-list" id="search-recent-list"></ul>
    </div>

    <!-- Footer Hints -->
    <div class="search-popup-footer" aria-hidden="true">
      <span class="search-hint"><kbd>↵</kbd> {{ 'general.search.to_search' | t }}</span>
      <span class="search-hint"><kbd>{{ 'general.search.esc_key' | t | default: 'ESC' }}</kbd> {{ 'general.search.to_close' | t }}</span>
      <span class="search-hint"><kbd>⌘</kbd><kbd>K</kbd> {{ 'general.search.to_toggle' | t }}</span>
    </div>
  </div>
</div>
