{%- comment -%}
  Snippet: selling-plan-badge.liquid
  Renders a subscription pill badge for a cart line item with a selling plan.
  
  Accepts:
    - selling_plan_allocation {Object} - Shopify selling_plan_allocation object
  
  Usage:
    {%- render 'selling-plan-badge', selling_plan_allocation: item.selling_plan_allocation -%}
{%- endcomment -%}

{%- if selling_plan_allocation != blank -%}
  <span class="sp-badge" aria-label="{{ 'selling_plan.badge_label' | t }}">
    {%- comment -%}Recurring/subscription icon — circular, non-directional, safe for RTL{%- endcomment -%}
    <svg class="sp-badge__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
      <path d="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46C19.54 15.03 20 13.57 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74C4.46 8.97 4 10.43 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z"/>
    </svg>
    <span class="sp-badge__label">
      {{- selling_plan_allocation.selling_plan.name | escape -}}
    </span>
  </span>
{%- endif -%}
